# bini-health 项目环境变量样例
# 复制为 .env 后按需填入真实值；切勿提交 .env 到 Git。

# ─────────── 支付配置 ───────────
# AES-256-GCM 加密密钥（用于支付通道敏感字段加密存储）
# 生成方式：openssl rand -base64 32
# 必须为 base64/hex 编码且解码后长度为 32 字节，否则后端启动时会回退到 fallback key。
PAYMENT_CONFIG_ENCRYPTION_KEY=jzsuHsRKWp/Xy01k+8d4R2lNBvb3KQTGJJkxQXRjW2A=

# 对外 API 基址（用于 notify_url / return_url 自动拼接），生产环境必须配置
PUBLIC_API_BASE_URL=https://newbb.test.bangbangvip.com/autodev/6b099ed3-7175-4a78-91f4-44570c84ed27

# [2026-05-04 H5 支付链路 BasePath 修复 v1.0]
# H5 完整基地址（域名 + basePath），用于后端拼接支付宝 H5 沙盒收银台 pay_url / 真实
# 收银台 return_url。必须与 H5 容器构建时的 NEXT_PUBLIC_BASE_PATH 保持同一前缀。
# 未来切换到根域名/独立子域名（如 https://h5.xxx.com）时只改本变量即可，业务零改动。
PROJECT_BASE_URL=https://newbb.test.bangbangvip.com/autodev/6b099ed3-7175-4a78-91f4-44570c84ed27

# ─────────── 短信 / AI / 其他 ───────────
AI_BASE_URL=
AI_MODEL_NAME=
AI_API_KEY=
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=1400920269
TENCENT_SMS_SIGN_NAME=呃唉帮帮网络
TENCENT_SMS_TEMPLATE_ID=2201340
TENCENT_SMS_APP_KEY=7e3c8242bf0799cca367fa18fa47a7ea
