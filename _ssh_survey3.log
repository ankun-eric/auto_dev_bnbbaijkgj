
==== CMD: docker exec gateway cat /etc/nginx/conf.d/6b099ed3-7175-4a78-91f4-44570c84ed27.conf
# ===== Project: 6b099ed3-7175-4a78-91f4-44570c84ed27 =====

# 鍚庣 API锛圔UG 鈶細CSV 瀵煎嚭闇€鍏抽棴缂撳啿锛岄伩鍏嶅ぇ鏂囦欢琚?nginx 缂撳瓨鍛戒腑瓒呮椂锛?
location /autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/api/ {
    resolver 127.0.0.11 valid=10s ipv6=off;
    set $target_backend 6b099ed3-7175-4a78-91f4-44570c84ed27-backend;
    rewrite ^/autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/api/(.*) /api/$1 break;
    proxy_pass http://$target_backend:8000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_buffering off;
    proxy_request_buffering off;
}

# BUG 鈶★細鏂囦欢涓婁紶/涓嬭浇锛堝姞 30 澶╃紦瀛橈紝鍑忓皯鍥炴簮锛?
location /autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/uploads/ {
    resolver 127.0.0.11 valid=10s ipv6=off;
    set $target_backend 6b099ed3-7175-4a78-91f4-44570c84ed27-backend;
    rewrite ^/autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/uploads/(.*) /uploads/$1 break;
    proxy_pass http://$target_backend:8000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    expires 30d;
    add_header Cache-Control "public" always;
}

# 绠＄悊鍚庡彴
location /autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/admin/ {
    resolver 127.0.0.11 valid=10s ipv6=off;
    set $target_admin 6b099ed3-7175-4a78-91f4-44570c84ed27-admin;
    proxy_pass http://$target_admin:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;
}

# 绠＄悊鍚庡彴 _next 闈欐€佽祫婧?
location /autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/admin/_next/ {
    resolver 127.0.0.11 valid=10s ipv6=off;
    set $target_admin 6b099ed3-7175-4a78-91f4-44570c84ed27-admin;
    proxy_pass http://$target_admin:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_cache_bypass $http_upgrade;
}


# ========= 闈欐€佷骇鐗╀笅杞斤紙PRD-03 閲嶆柊浜や粯琛ュ叏锛?=========
# 寰俊灏忕▼搴?zip 鍖呬笅杞?
location /autodev/6b099ed3-7175-4a78-91f4-44570c84ed27/miniprogram/ {
    alias /data/static/miniprogram/;
    autoindex off;
    types { application/zip zip; }
    add_header Content-Disposition 'attachment';
    add_header Cache-Control "public, max-age=86400" always;
}

# 瀹夊崜 APK 涓嬭浇
