.scan-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.scan-animation-wrapper {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.scan-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(82, 196, 26, 0.4);
  z-index: 2;
}

.scan-circle:active {
  transform: scale(0.95);
}

.scan-circle-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-emoji {
  font-size: 72rpx;
}

.scan-ripple {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(82, 196, 26, 0.3);
  animation: ripple 2s ease-out infinite;
  z-index: 1;
}

.scan-ripple.delay {
  animation-delay: 1s;
}

@keyframes ripple {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.8);
    opacity: 0;
  }
}

.scan-tip {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.scan-sub-tip {
  font-size: 26rpx;
  color: #999;
}

.order-card {
  margin-top: 20rpx;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.order-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.order-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-done {
  background: #f6ffed;
  color: #52c41a;
}

.order-detail-list {
  margin-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.price {
  color: #f5222d;
  font-size: 32rpx;
  font-weight: 700;
}

.order-actions {
  margin-bottom: 24rpx;
}

.verify-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
}

.verify-btn::after {
  border: none;
}

.verified-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #f6ffed;
  border-radius: 12rpx;
}

.verified-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.verified-text {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: 500;
}

.rescan-area {
  margin-top: 12rpx;
}

.rescan-area .btn-secondary {
  width: 100%;
}

.rescan-area .btn-secondary::after {
  border: none;
}

.refund-alert {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.refund-alert-warn {
  background: #fff7e6;
  border: 1rpx solid #ffe58f;
}

.refund-alert-err {
  background: #fff1f0;
  border: 1rpx solid #ffa39e;
}

.refund-alert-info {
  background: #e6f7ff;
  border: 1rpx solid #91d5ff;
}

.refund-alert-text {
  font-size: 26rpx;
  display: block;
  line-height: 1.5;
}

.refund-alert-warn .refund-alert-text {
  color: #fa8c16;
}

.refund-alert-err .refund-alert-text {
  color: #f5222d;
}

.refund-alert-info .refund-alert-text {
  color: #1890ff;
}
