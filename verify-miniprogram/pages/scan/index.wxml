<view class="container">
  <!-- 扫码提示区域 -->
  <view class="scan-prompt" wx:if="{{!orderInfo}}">
    <view class="scan-animation-wrapper" bindtap="startScan">
      <view class="scan-circle">
        <view class="scan-circle-inner">
          <text class="scan-emoji">📷</text>
        </view>
      </view>
      <view class="scan-ripple"></view>
      <view class="scan-ripple delay"></view>
    </view>
    <text class="scan-tip">点击上方按钮扫描核销码</text>
    <text class="scan-sub-tip">请对准用户手机上的核销二维码</text>
  </view>

  <!-- 订单信息展示 -->
  <view class="order-card card" wx:if="{{orderInfo}}">
    <view class="order-header">
      <text class="order-title">订单信息</text>
      <view class="order-status {{orderInfo.status === 'verified' ? 'status-done' : 'status-pending'}}">
        <text>{{orderInfo.status === 'verified' ? '已核销' : '待核销'}}</text>
      </view>
    </view>

    <view class="order-detail-list">
      <view class="detail-row">
        <text class="detail-label">订单号</text>
        <text class="detail-value">{{orderInfo.orderNo}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">服务名称</text>
        <text class="detail-value">{{orderInfo.serviceName}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">用户</text>
        <text class="detail-value">{{orderInfo.userName}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">金额</text>
        <text class="detail-value price">¥{{orderInfo.amount}}</text>
      </view>
      <view class="detail-row" wx:if="{{orderInfo.createTime}}">
        <text class="detail-label">下单时间</text>
        <text class="detail-value">{{orderInfo.createTime}}</text>
      </view>
    </view>

    <!-- 退款状态提示 -->
    <view class="refund-alert refund-alert-warn" wx:if="{{orderInfo.refund_status === 'applied' || orderInfo.refund_status === 'reviewing' || orderInfo.refund_status === 'approved' || orderInfo.refund_status === 'returning'}}">
      <text class="refund-alert-text">⚠️ 该订单正在退款处理中（{{orderInfo.refund_status}}），暂时无法核销</text>
    </view>
    <view class="refund-alert refund-alert-err" wx:elif="{{orderInfo.refund_status === 'refund_success'}}">
      <text class="refund-alert-text">该订单已退款，核销码已失效</text>
    </view>
    <view class="refund-alert refund-alert-info" wx:elif="{{orderInfo.refund_status === 'rejected'}}">
      <text class="refund-alert-text">退款申请已被拒绝，可正常核销</text>
    </view>

    <view class="order-actions" wx:if="{{orderInfo.status !== 'verified' && (!orderInfo.refund_status || orderInfo.refund_status === 'none' || orderInfo.refund_status === 'rejected')}}">
      <button class="btn-primary verify-btn" bindtap="handleVerify" loading="{{verifying}}">
        确认核销
      </button>
    </view>
    <view class="order-actions" wx:elif="{{orderInfo.status === 'verified'}}">
      <view class="verified-notice">
        <text class="verified-icon">✅</text>
        <text class="verified-text">该订单已核销完成</text>
      </view>
    </view>

    <view class="rescan-area">
      <button class="btn-secondary" bindtap="startScan">重新扫码</button>
    </view>
  </view>
</view>
