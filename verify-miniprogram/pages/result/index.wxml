<view class="container result-page">
  <!-- 成功状态 -->
  <view class="result-wrapper" wx:if="{{status === 'success'}}">
    <view class="result-icon success-bg">
      <text class="icon-text">✓</text>
    </view>
    <text class="result-title">核销成功</text>
    <text class="result-desc" wx:if="{{orderNo}}">订单号: {{orderNo}}</text>
    <text class="result-sub-desc">服务已确认完成</text>
  </view>

  <!-- 失败状态 -->
  <view class="result-wrapper" wx:if="{{status === 'fail'}}">
    <view class="result-icon fail-bg">
      <text class="icon-text">✕</text>
    </view>
    <text class="result-title fail-text">核销失败</text>
    <text class="result-desc">{{reason || '请稍后重试'}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area">
    <button class="btn-primary action-btn" bindtap="goScanAgain">继续扫码</button>
    <button class="btn-secondary action-btn mt-20" bindtap="goHome">返回首页</button>
  </view>
</view>
