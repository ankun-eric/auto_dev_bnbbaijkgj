.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.result-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.result-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.success-bg {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  box-shadow: 0 16rpx 48rpx rgba(82, 196, 26, 0.35);
}

.fail-bg {
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  box-shadow: 0 16rpx 48rpx rgba(255, 77, 79, 0.35);
}

.icon-text {
  font-size: 80rpx;
  color: #fff;
  font-weight: 700;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #52c41a;
  margin-bottom: 20rpx;
}

.fail-text {
  color: #ff4d4f;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.result-sub-desc {
  font-size: 26rpx;
  color: #999;
}

.action-area {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.action-btn {
  width: 100%;
}

.action-btn::after {
  border: none;
}
