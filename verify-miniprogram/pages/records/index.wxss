.records-page {
  padding-bottom: 40rpx;
}

.filter-bar {
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.date-pickers {
  display: flex;
  align-items: center;
}

.date-btn {
  font-size: 24rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid #b7eb8f;
}

.date-sep {
  font-size: 24rpx;
  color: #999;
  margin: 0 12rpx;
}

.quick-dates {
  display: flex;
  gap: 16rpx;
}

.quick-date-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 14rpx 0;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #666;
  transition: all 0.2s;
}

.quick-date-btn.active {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  color: #fff;
  font-weight: 600;
}

.summary-bar {
  padding: 16rpx 8rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #999;
}

.record-item {
  padding: 28rpx 32rpx;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-service {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.record-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.record-badge.success {
  background: #f6ffed;
  color: #52c41a;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.price {
  color: #f5222d;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #ccc;
}

.loading-more {
  text-align: center;
  padding: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.load-end {
  text-align: center;
  padding: 24rpx;
}

.load-end-text {
  font-size: 24rpx;
  color: #ddd;
}
