.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #52c41a 0%, #3da015 40%, #f5f5f5 40.1%);
  position: relative;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

.logo-wrapper {
  margin-bottom: 32rpx;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.logo-text {
  font-size: 64rpx;
  color: #fff;
  font-weight: 800;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  margin: -40rpx 40rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 36rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.input-wrapper:focus-within {
  border-color: #52c41a;
  background: #f6ffed;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.input-field {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #333;
}

.placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.toggle-pwd {
  font-size: 24rpx;
  color: #52c41a;
  padding: 8rpx 16rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.35);
}

.login-btn:active {
  opacity: 0.85;
}

.login-btn::after {
  border: none;
}

.login-footer {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #bbb;
}
