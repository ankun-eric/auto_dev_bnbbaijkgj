.container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}
.title { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.code-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.label { color: #888; font-size: 24rpx; }
.code-value { font-size: 32rpx; font-family: monospace; word-break: break-all; margin-top: 8rpx; }
.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
}
.form-label { color: #555; font-size: 26rpx; }
.form-input {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}
.redeem-btn {
  margin-top: 32rpx;
  background: #52c41a;
  color: #fff;
}
