/* ============================================================
 * bini-health · 菜单模式 PRD-442 · 晴空诊室风格
 * 小程序端 Design Tokens v1.0 (2026-05-10)
 *
 * 与 H5（design-tokens.css）和 Flutter（menu_mode_theme.dart）
 * 三端共用同一套晴空诊室色板。
 *
 * 引入方式（在 page wxss 中）：
 *   @import "/styles/menu-mode-tokens.wxss";
 * ============================================================ */

page {
  /* 11 级天蓝色阶（菜单模式命名空间） */
  --sky-50:  #f0f9ff;
  --sky-100: #e0f2fe;
  --sky-200: #bae6fd;
  --sky-300: #7dd3fc;
  --sky-400: #38bdf8;   /* 主色 · 病历卡左竖线 */
  --sky-500: #0ea5e9;
  --sky-600: #0284c7;
  --sky-700: #0369a1;
  --sky-800: #075985;   /* Hero 深蓝 */
  --sky-900: #0c4a6e;
  --sky-950: #082f49;

  /* 语义辅助色（严格控量） */
  --success: #22c55e;
  --danger:  #ef4444;
  --member:  #f59e0b;

  --text-1:  #0f172a;
  --text-2:  #475569;
  --text-3:  #94a3b8;
  --bg-base: #ffffff;
  --bg-soft: #f8fafc;

  /* 阴影（统一天蓝阴影，禁止纯黑） */
  --shadow-1: 0 2rpx 4rpx rgba(56, 189, 248, 0.08);
  --shadow-2: 0 8rpx 24rpx rgba(56, 189, 248, 0.10);   /* 病历卡阴影 */
  --shadow-3: 0 16rpx 48rpx rgba(56, 189, 248, 0.12);
  --shadow-4: 0 32rpx 80rpx rgba(56, 189, 248, 0.16);

  /* 圆角 */
  --radius-xs:  8rpx;
  --radius-sm:  16rpx;
  --radius-md:  24rpx;
  --radius-lg:  32rpx;
  --radius-xl:  48rpx;   /* 登录卡 / 主卡片 */

  /* 字号（小程序使用 rpx，1rpx = 1px*2/750） */
  --fs-12: 24rpx;
  --fs-14: 28rpx;
  --fs-16: 32rpx;
  --fs-18: 36rpx;
  --fs-20: 40rpx;
  --fs-24: 48rpx;
  --fs-30: 60rpx;
  --fs-36: 72rpx;

  /* 间距 */
  --sp-1: 8rpx;
  --sp-2: 16rpx;
  --sp-3: 24rpx;
  --sp-4: 32rpx;
  --sp-5: 40rpx;
  --sp-6: 48rpx;
  --sp-8: 64rpx;
  --sp-10: 80rpx;
}

/* ============================================================
 * Button 5 变体（高 96rpx == 48px）
 * ============================================================ */
.menu-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0 var(--sp-6);
  border-radius: var(--radius-md);
  font-size: var(--fs-16);
  font-weight: 600;
  letter-spacing: 0.5rpx;
  border: none;
  box-sizing: border-box;
}
.menu-btn--primary {
  background: linear-gradient(135deg, #38bdf8 0%, #0284c7 100%);
  color: #fff;
  box-shadow: var(--shadow-2);
}
.menu-btn--primary:active { transform: scale(0.98); }
.menu-btn--secondary {
  background: var(--bg-base);
  color: var(--sky-700);
  border: 2rpx solid var(--sky-300);
}
.menu-btn--text {
  background: transparent;
  color: var(--sky-600);
  height: 64rpx;
  padding: 0 var(--sp-3);
  font-weight: 500;
}
.menu-btn--icon {
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  background: var(--bg-base);
  color: var(--sky-600);
  border-radius: 50%;
  box-shadow: var(--shadow-1);
}
.menu-btn--disabled {
  background: #e2e8f0;
  color: var(--text-3);
  box-shadow: none;
}

/* ============================================================
 * Card · 普通 / 病历 / Hero
 * ============================================================ */
.menu-card {
  background: var(--bg-base);
  border-radius: var(--radius-lg);
  padding: var(--sp-4);
  box-shadow: var(--shadow-2);
}

/* 病历卡：白底 + 左 6rpx sky-400 竖线 + shadow-2（核心铁律） */
.menu-card--medical {
  position: relative;
  background: var(--bg-base);
  border-radius: var(--radius-lg);
  padding: var(--sp-4) var(--sp-4) var(--sp-4) var(--sp-5);
  box-shadow: var(--shadow-2);
}
.menu-card--medical::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6rpx;
  background: var(--sky-400);
  border-top-left-radius: var(--radius-lg);
  border-bottom-left-radius: var(--radius-lg);
}

.menu-card--hero {
  background: linear-gradient(135deg, #075985 0%, #0c4a6e 100%);
  color: #fff;
  border-radius: var(--radius-xl);
  padding: var(--sp-6);
  box-shadow: var(--shadow-3);
}

/* ============================================================
 * Input
 * ============================================================ */
.menu-input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--sp-4);
  background: var(--bg-soft);
  border: 2rpx solid #e2e8f0;
  border-radius: var(--radius-md);
  font-size: var(--fs-16);
  color: var(--text-1);
  box-sizing: border-box;
}
.menu-input--error { border-color: var(--danger); }

/* ============================================================
 * Topbar A1（淡天蓝渐变）
 * ============================================================ */
.menu-topbar-a1 {
  display: flex;
  align-items: center;
  height: 112rpx;
  padding: 0 var(--sp-4);
  background: linear-gradient(135deg, #f0f9ff 0%, #bae6fd 100%);
  color: var(--sky-900);
  font-size: var(--fs-18);
  font-weight: 600;
}

/* ============================================================
 * 九宫格菜单
 * ============================================================ */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--sp-4);
}
.menu-grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-4) 0;
}
.menu-grid-icon {
  width: 80rpx; height: 80rpx;
  background: var(--sky-100);
  color: var(--sky-600);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-20);
  margin-bottom: var(--sp-2);
}
.menu-grid-label { font-size: var(--fs-14); color: var(--text-1); }

/* ============================================================
 * Chip / Family chips
 * ============================================================ */
.menu-chip {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 var(--sp-3);
  background: var(--bg-base);
  border: 2rpx solid #e2e8f0;
  border-radius: 999rpx;
  font-size: var(--fs-14);
  color: var(--text-2);
  margin-right: var(--sp-2);
}
.menu-chip--active {
  background: var(--sky-400);
  border-color: var(--sky-400);
  color: #fff;
  font-weight: 600;
}

/* ============================================================
 * Avatar 4 尺寸
 * ============================================================ */
.menu-avatar {
  display: inline-block;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--sky-100);
  position: relative;
}
.menu-avatar--sm { width: 64rpx; height: 64rpx; }
.menu-avatar--lg { width: 128rpx; height: 128rpx; }
.menu-avatar--xl { width: 192rpx; height: 192rpx; }
.menu-avatar-member {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--member);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border: 4rpx solid var(--bg-base);
  font-weight: 700;
}

/* ============================================================
 * Badge
 * ============================================================ */
.menu-badge-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  background: var(--danger);
  border-radius: 50%;
}
.menu-badge-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: var(--danger);
  color: #fff;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

/* ============================================================
 * Hero（Profile / Archive）
 * ============================================================ */
.menu-hero-profile {
  background: linear-gradient(135deg, #075985 0%, #0c4a6e 100%);
  color: #fff;
  padding: var(--sp-6) var(--sp-4) var(--sp-8);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}
.menu-hero-archive-score {
  font-size: var(--fs-36);
  font-weight: 700;
  line-height: 1.2;
}
