.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  height: calc(108rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #ededed;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

.tab-item-active {
  color: #52c41a;
}

.tab-icon {
  font-size: 34rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1;
}
