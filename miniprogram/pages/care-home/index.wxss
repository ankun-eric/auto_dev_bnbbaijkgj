/* [PRD-AIHOME-CARE-V1 2026-05-27] 关怀模式样式 */
page { background: linear-gradient(180deg,#fff5e8 0%,#f0f6fb 100%); font-size: 32rpx; }
.page { padding-bottom: 240rpx; min-height: 100vh; }

.topbar { display: flex; align-items: center; justify-content: space-between; background: #fff; padding: 20rpx 32rpx; height: 112rpx; box-sizing: border-box; }
.menu-btn { font-size: 44rpx; color: #555; }
.brand { display: flex; align-items: center; gap: 12rpx; }
.brand-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: linear-gradient(135deg,#5b8fd6,#1976D2); color: #fff; font-weight: 800; font-size: 28rpx; text-align: center; line-height: 64rpx; }
.brand-text { font-size: 30rpx; font-weight: 700; }
.mode-badge { background: linear-gradient(90deg,#ff9156,#ff6b3d); color: #fff; padding: 12rpx 22rpx; border-radius: 36rpx; font-size: 24rpx; font-weight: 700; box-shadow: 0 6rpx 18rpx rgba(255,107,61,.3); }

.switch-mask { position: fixed; inset: 0; background: rgba(0,0,0,.3); z-index: 1000; display: flex; justify-content: flex-end; padding-top: 120rpx; padding-right: 32rpx; }
.switch-panel { background: #fff; border-radius: 24rpx; width: 480rpx; overflow: hidden; box-shadow: 0 16rpx 64rpx rgba(0,0,0,.15); align-self: flex-start; }
.switch-head { background: linear-gradient(90deg,#ff9156,#ff6b3d); color: #fff; padding: 24rpx 28rpx; font-weight: 700; font-size: 30rpx; }
.switch-item { padding: 24rpx 28rpx; border-bottom: 1rpx solid #eee; }
.switch-item-title { font-size: 32rpx; font-weight: 700; }
.switch-item-title.care { color: #ff6b3d; }
.switch-item-title.std { color: #3865a8; }
.switch-item-sub { font-size: 24rpx; color: #888; margin-top: 6rpx; }
.switch-foot { background: #f8f8f8; padding: 18rpx; font-size: 22rpx; color: #888; text-align: center; }

.welcome { padding: 36rpx 44rpx 20rpx; }
.welcome-main { font-size: 50rpx; font-weight: 800; color: #3d2e1f; line-height: 1.3; }
.welcome-sub { font-size: 30rpx; color: #5a4838; margin-top: 12rpx; }

.quick-row { display: flex; gap: 16rpx; padding: 0 32rpx 24rpx; }
.quick-cell { flex: 1; background: #fff; border-radius: 22rpx; padding: 18rpx 0; text-align: center; min-height: 124rpx; display: flex; flex-direction: column; justify-content: center; }
.quick-icon { width: 72rpx; height: 72rpx; border-radius: 18rpx; line-height: 72rpx; font-size: 40rpx; margin: 0 auto 8rpx; }
.bg-blue { background: #e3f2fd; }
.bg-orange { background: #fff3e0; }
.bg-green { background: #e8f5e9; }
.bg-pink { background: #fce4ec; }
.quick-cell text { font-size: 26rpx; font-weight: 600; }

.recommend-row { white-space: nowrap; padding: 0 32rpx 24rpx; }

/* [PRD-SAFETY-ROPE-V1 2026-06-03] 数字安全绳入口卡片 */
.safety-rope-card { display: flex; align-items: center; margin: 0 32rpx 24rpx;
  background: linear-gradient(135deg, #74b9a6 0%, #4a9b8e 100%); border-radius: 24rpx;
  padding: 24rpx 28rpx; color: #fff; box-shadow: 0 4rpx 16rpx rgba(74,155,142,0.25); }
.sr-icon { font-size: 56rpx; margin-right: 24rpx; }
.sr-body { flex: 1; }
.sr-title { font-size: 32rpx; font-weight: 700; }
.sr-sub { font-size: 24rpx; opacity: 0.92; margin-top: 4rpx; }
.sr-arrow { font-size: 42rpx; margin-left: 16rpx; }
.recommend-cell { display: inline-block; padding: 14rpx 28rpx; background: #fff5e8; color: #c95a1d; border-radius: 36rpx; margin-right: 16rpx; font-size: 26rpx; font-weight: 600; }

.card { background: #fff; border-radius: 28rpx; padding: 32rpx; margin: 0 32rpx 24rpx; }
.card-head { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.card-head.green { color: #43A047; }
.card-head.orange { color: #FB8C00; }
.card-head.teal { color: #00897B; }
.card-head.red { color: #E53935; }
.card.sos-card { border-left: 12rpx solid #E53935; }
.card-body { font-size: 30rpx; line-height: 1.6; margin-bottom: 24rpx; }
.row-btns { display: flex; gap: 16rpx; }
.btn-gray { flex: 1; background: #f5f5f5; border: none; border-radius: 18rpx; padding: 24rpx; font-size: 30rpx; min-height: 96rpx; }
.btn-red { flex: 1; background: #E53935; color: #fff; border: none; border-radius: 18rpx; padding: 24rpx; font-size: 30rpx; font-weight: 700; min-height: 96rpx; }

.grid-2x2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.grid-cell .label { font-size: 26rpx; color: #888; }
.grid-cell .val { font-size: 44rpx; font-weight: 800; color: #3d2e1f; margin-top: 4rpx; }
.grid-cell .val.abnormal { color: #E53935; }
.grid-cell .unit { font-size: 22rpx; color: #888; }

.med-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; font-size: 30rpx; }
.btn-green-small { background: #43A047; color: #fff; border: none; padding: 16rpx 28rpx; border-radius: 20rpx; min-height: 72rpx; font-size: 26rpx; }

.device-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.device-cell { padding: 18rpx; border-radius: 18rpx; background: #f5fafd; }
.device-cell.abnormal { background: #fff3e0; }
.device-name { font-size: 26rpx; font-weight: 600; }
.device-status { font-size: 24rpx; color: #888; margin-top: 8rpx; }

.input-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 28rpx; display: flex; gap: 16rpx; align-items: center; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.05); z-index: 100; }
.input-box { flex: 1; border: 1rpx solid #ddd; border-radius: 44rpx; padding: 20rpx 28rpx; font-size: 28rpx; min-height: 80rpx; box-sizing: border-box; }
.mic-btn { width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(135deg,#ff9156,#ff6b3d); color: #fff; text-align: center; line-height: 96rpx; font-size: 44rpx; }

.sos-ball { position: fixed; right: 28rpx; bottom: 200rpx; width: 132rpx; height: 132rpx; border-radius: 50%; background: #E53935; color: #fff; text-align: center; line-height: 132rpx; font-size: 30rpx; font-weight: 800; box-shadow: 0 0 0 16rpx rgba(229,57,53,.2), 0 8rpx 24rpx rgba(229,57,53,.4); z-index: 99; }

/* SOS 状态层 */
.sos-stage1, .sos-stage2, .sos-stage3, .sos-stage4 { position: fixed; inset: 0; z-index: 9999; padding: 80rpx 44rpx; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.sos-stage1 { background: #E53935; color: #fff; }
.s1-title { font-size: 44rpx; font-weight: 700; margin-bottom: 40rpx; }
.s1-num { font-size: 240rpx; font-weight: 900; line-height: 1; margin-bottom: 60rpx; }
.s1-cancel { background: #fff; color: #E53935; font-size: 36rpx; font-weight: 700; padding: 32rpx 100rpx; border-radius: 24rpx; border: none; min-height: 96rpx; }

.sos-stage2 { background: #fff; }
.s2-title { font-size: 38rpx; font-weight: 700; margin-bottom: 60rpx; color: #3d2e1f; }
.s2-120 { background: #E53935; color: #fff; font-size: 40rpx; font-weight: 800; padding: 40rpx; border-radius: 24rpx; border: none; width: 600rpx; min-height: 180rpx; margin-bottom: 30rpx; }
.s2-family { background: #43A047; color: #fff; font-size: 36rpx; font-weight: 700; padding: 36rpx; border-radius: 24rpx; border: none; width: 600rpx; min-height: 180rpx; margin-bottom: 40rpx; }
.s2-cancel { color: #999; font-size: 26rpx; }

.sos-stage3 { background: #fff; }
.s3-title { font-size: 38rpx; font-weight: 700; color: #3d2e1f; margin-bottom: 40rpx; }
.s3-spinner { width: 100rpx; height: 100rpx; border: 10rpx solid #E53935; border-top-color: transparent; border-radius: 50%; animation: s3spin 1s linear infinite; }
@keyframes s3spin { to { transform: rotate(360deg); } }
.s3-list { margin-top: 60rpx; font-size: 28rpx; color: #555; line-height: 1.9; }

.sos-stage4 { background: #f0f6fb; }
.s4-icon { font-size: 120rpx; }
.s4-title { font-size: 44rpx; font-weight: 800; color: #43A047; margin: 16rpx 0 40rpx; }
.s4-card { background: #fff; border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; width: 600rpx; font-size: 28rpx; line-height: 1.9; }
.s4-safe { background: #43A047; color: #fff; font-size: 32rpx; font-weight: 700; padding: 28rpx 80rpx; border-radius: 22rpx; border: none; min-height: 96rpx; margin-top: 16rpx; }
