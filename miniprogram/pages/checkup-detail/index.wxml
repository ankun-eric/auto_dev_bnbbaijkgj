<!-- 加载动画 -->
<view class="loading-page" wx:if="{{loading && analyzing && !analyzeTimeout && !analyzeError}}">
  <view class="analyze-animation">
    <view class="analyze-progress-ring-wrap">
      <view class="analyze-progress-bg"></view>
      <view class="analyze-progress-circle" style="background: conic-gradient(#52c41a {{analyzePercent * 3.6}}deg, #f0f0f0 0deg);"></view>
      <view class="analyze-progress-inner">
        <text class="analyze-percent-num">{{analyzePercent}}</text>
        <text class="analyze-percent-sign">%</text>
      </view>
    </view>
    <text class="analyze-text">{{analyzeText}}</text>
    <view class="analyze-bar-wrap">
      <view class="analyze-bar-track">
        <view class="analyze-bar-fill" style="width: {{analyzePercent}}%;"></view>
      </view>
    </view>
  </view>
</view>

<!-- 超时提示 -->
<view class="loading-page" wx:if="{{analyzeTimeout && !analyzeError}}">
  <view class="analyze-result-state">
    <text class="state-icon">⏳</text>
    <text class="state-title">分析时间较长，已转入后台处理</text>
    <text class="state-desc">您可以稍后在报告列表中查看结果</text>
    <view class="state-actions">
      <button class="btn-primary state-btn" bindtap="goBackToList">返回报告列表</button>
    </view>
  </view>
</view>

<!-- 错误提示 -->
<view class="loading-page" wx:if="{{analyzeError}}">
  <view class="analyze-result-state">
    <text class="state-icon">😔</text>
    <text class="state-title">{{analyzeError}}</text>
    <view class="state-actions">
      <button class="btn-primary state-btn" bindtap="retryAnalyze">重新分析</button>
      <button class="btn-outline state-btn" bindtap="goBackToList">返回报告列表</button>
    </view>
  </view>
</view>

<!-- 主内容 -->
<view class="detail-page" wx:if="{{!loading}}">

  <!-- 区域1：AI 综合健康评分 -->
  <view class="score-section card" wx:if="{{aiData && healthScore > 0}}">
    <view class="score-header">
      <text class="score-title">AI 综合健康评分</text>
      <view class="share-btn-small" bindtap="shareReport">
        <text class="share-icon-text">📤</text>
        <text class="share-label">分享</text>
      </view>
    </view>
    <view class="score-ring-wrap">
      <canvas id="scoreCanvas" type="2d" class="score-canvas"></canvas>
      <view class="score-center">
        <text class="score-number" style="color: {{healthScoreColor}}">{{healthScore}}</text>
        <text class="score-level" style="color: {{healthScoreColor}}">{{healthScoreLevel}}</text>
      </view>
    </view>
    <text class="score-comment" wx:if="{{healthScoreComment}}">{{healthScoreComment}}</text>
  </view>

  <!-- 区域2：异常指标汇总 -->
  <view class="summary-section" wx:if="{{aiData}}">
    <view class="summary-cards">
      <view class="summary-card summary-card-abnormal">
        <text class="summary-card-num" style="color: #F44336">{{abnormalCount}}</text>
        <text class="summary-card-label">异常指标</text>
      </view>
      <view class="summary-card summary-card-normal">
        <text class="summary-card-num" style="color: #4CAF50">{{normalCount}}</text>
        <text class="summary-card-label">正常指标</text>
      </view>
      <view class="summary-card summary-card-excellent">
        <text class="summary-card-num" style="color: #1B8C3D">{{excellentCount}}</text>
        <text class="summary-card-label">优秀指标</text>
      </view>
    </view>
  </view>

  <!-- 区域3：分类指标详细解读 -->
  <view class="categories-section" wx:if="{{categories.length > 0}}">
    <view class="cat-block card" wx:for="{{categories}}" wx:key="name" wx:for-index="catIdx">
      <view class="cat-header">
        <text class="cat-emoji">{{item.emoji}}</text>
        <text class="cat-name">{{item.name}}</text>
        <text class="cat-count">{{item.items.length}}项</text>
      </view>

      <view class="indicator-list">
        <view class="indicator-card" wx:for="{{item.items}}" wx:key="name" wx:for-item="ind">
          <!-- 指标主行 -->
          <view class="ind-main" bindtap="toggleItemDetail" data-key="{{ind.expandKey}}">
            <view class="ind-left">
              <text class="ind-name">{{ind.name}}</text>
              <view class="risk-tag" style="background: {{ind.riskBg}}; border: 1rpx solid {{ind.riskColor}}20;">
                <text class="risk-tag-emoji">{{ind.riskEmoji}}</text>
                <text class="risk-tag-text" style="color: {{ind.riskColor}}">{{ind.riskName}}</text>
              </view>
            </view>
            <view class="ind-right">
              <view class="ind-value-wrap">
                <text class="ind-value" style="color: {{ind.riskColor}}">{{ind.value}}</text>
                <text class="ind-unit">{{ind.unit}}</text>
              </view>
              <text class="ind-ref" wx:if="{{ind.referenceRange}}">参考: {{ind.referenceRange}}</text>
            </view>
            <text class="ind-arrow {{expandedItems[ind.expandKey] ? 'arrow-up' : ''}}">›</text>
          </view>

          <!-- 展开的详细建议 -->
          <view class="ind-detail" wx:if="{{expandedItems[ind.expandKey] && ind.detail}}">
            <view class="detail-module" wx:if="{{ind.detail.explanation}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">📖</text>
                <text class="detail-module-title">指标含义</text>
              </view>
              <text class="detail-module-content">{{ind.detail.explanation}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.possibleCauses}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🔍</text>
                <text class="detail-module-title">可能原因</text>
              </view>
              <text class="detail-module-content">{{ind.detail.possibleCauses}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.dietAdvice}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🥗</text>
                <text class="detail-module-title">饮食建议</text>
              </view>
              <text class="detail-module-content">{{ind.detail.dietAdvice}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.exerciseAdvice}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🏃</text>
                <text class="detail-module-title">运动建议</text>
              </view>
              <text class="detail-module-content">{{ind.detail.exerciseAdvice}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.lifestyleAdvice}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🌙</text>
                <text class="detail-module-title">生活习惯</text>
              </view>
              <text class="detail-module-content">{{ind.detail.lifestyleAdvice}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.recheckAdvice}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🔄</text>
                <text class="detail-module-title">复查建议</text>
              </view>
              <text class="detail-module-content">{{ind.detail.recheckAdvice}}</text>
            </view>
            <view class="detail-module" wx:if="{{ind.detail.medicalAdvice}}">
              <view class="detail-module-header">
                <text class="detail-module-icon">🏥</text>
                <text class="detail-module-title">就医指引</text>
              </view>
              <text class="detail-module-content">{{ind.detail.medicalAdvice}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- AI原始文本回退 -->
  <view class="card" wx:if="{{!aiData && aiRawText}}">
    <view class="section-header">
      <text class="section-title-text">AI解读结果</text>
    </view>
    <view class="raw-text-card">
      <text class="raw-text-content">{{aiRawText}}</text>
    </view>
  </view>

  <!-- 无分析结果 -->
  <view class="card" wx:if="{{!aiData && !aiRawText}}">
    <view class="empty-state">
      <text class="empty-icon">🔬</text>
      <text class="empty-text">AI正在分析中，请稍后刷新查看</text>
    </view>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer-box" wx:if="{{aiData || aiRawText}}">
    <text class="disclaimer-text">{{disclaimer}}</text>
  </view>

  <!-- 区域4：报告对比入口 -->
  <view class="compare-entry" wx:if="{{aiData}}" bindtap="goCompare">
    <view class="compare-entry-inner">
      <text class="compare-icon">📊</text>
      <view class="compare-text-wrap">
        <text class="compare-title">报告对比分析</text>
        <text class="compare-desc">与历史报告对比，追踪健康变化</text>
      </view>
      <text class="compare-arrow">›</text>
    </view>
  </view>

</view>
