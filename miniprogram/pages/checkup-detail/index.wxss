.detail-page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* 报告原图 */
.images-section {
  overflow: hidden;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.images-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.images-list {
  display: inline-flex;
  gap: 16rpx;
}

.report-image {
  width: 200rpx;
  height: 280rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* 区块通用 */
.section-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

/* 全部正常提示 */
.all-normal-tip {
  display: flex;
  align-items: center;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 24rpx;
  gap: 16rpx;
}

.all-normal-icon {
  font-size: 36rpx;
  color: #52C41A;
  font-weight: bold;
}

.all-normal-text {
  font-size: 28rpx;
  color: #52C41A;
  font-weight: 500;
}

/* 异常指标卡片 */
.abnormal-card {
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
}

.abnormal-card:last-child {
  margin-bottom: 0;
}

.abnormal-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.abnormal-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-tag {
  display: flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag-high {
  background: #FF4D4F;
}

.tag-low {
  background: #FAAD14;
}

.tag-normal {
  background: #52C41A;
}

.status-tag-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.abnormal-card-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.abnormal-card-value {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.1;
}

.value-high {
  color: #FF4D4F;
}

.value-low {
  color: #FAAD14;
}

.value-ok {
  color: #52C41A;
}

.abnormal-card-unit {
  font-size: 24rpx;
  color: #888;
}

.abnormal-card-ref {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.abnormal-card-suggestion {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  background: rgba(250, 173, 20, 0.08);
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-top: 8rpx;
}

.suggestion-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 24rpx;
  color: #7c5b00;
  line-height: 1.6;
}

/* 分类折叠块 */
.category-block {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.category-block:last-child {
  margin-bottom: 0;
}

.category-fold-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  background: #fafafa;
}

.category-fold-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-fold-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.category-abnormal-badge {
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  border-radius: 20rpx;
  padding: 2rpx 14rpx;
}

.category-abnormal-num {
  font-size: 20rpx;
  color: #FF4D4F;
}

.category-fold-arrow {
  font-size: 36rpx;
  color: #999;
  transition: transform 0.2s;
  display: inline-block;
  line-height: 1;
}

.arrow-down {
  transform: rotate(0deg);
}

.arrow-up {
  transform: rotate(90deg);
}

/* 指标行 */
.category-items {
  padding: 0 24rpx;
  background: #fff;
}

.indicator-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.indicator-row:last-child {
  border-bottom: none;
}

.indicator-row-abnormal {
  background: #fffbe6;
  margin: 0 -24rpx;
  padding: 18rpx 24rpx;
}

.indicator-row-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.indicator-dot-sm {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-high { background: #FF4D4F; }
.dot-low { background: #FAAD14; }
.dot-normal { background: #52C41A; }

.indicator-row-name {
  font-size: 26rpx;
  color: #333;
}

.indicator-row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.indicator-row-value {
  font-size: 26rpx;
  font-weight: 600;
}

.indicator-row-ref {
  font-size: 20rpx;
  color: #bbb;
}

.status-tag-sm {
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.status-tag-sm-text {
  font-size: 20rpx;
  color: #fff;
}

/* 综合建议 */
.summary-card {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.summary-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

.disclaimer-box {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 60rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 分享 */
.share-section {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 12rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-color, #52C41A), #13c2c2);
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
}

.share-btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.share-btn-text {
  color: #fff;
  font-weight: 500;
}

/* 原图卡片标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
