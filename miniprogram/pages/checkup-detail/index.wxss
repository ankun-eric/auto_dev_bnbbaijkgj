.detail-page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ========== 加载动画 ========== */
.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f7f8fa;
}

.analyze-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  padding: 0 60rpx;
}

.analyze-progress-ring-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.analyze-progress-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0f0f0;
}

.analyze-progress-circle {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  transition: background 0.15s linear;
}

.analyze-progress-inner {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.analyze-percent-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #52c41a;
  line-height: 1;
}

.analyze-percent-sign {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
  margin-top: 8rpx;
}

.analyze-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  animation: fadeInOut 2s ease-in-out infinite alternate;
}

@keyframes fadeInOut {
  0% { opacity: 0.6; }
  100% { opacity: 1; }
}

.analyze-bar-wrap {
  width: 100%;
  max-width: 500rpx;
}

.analyze-bar-track {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.analyze-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #52c41a, #13c2c2);
  transition: width 0.15s linear;
}

/* ========== 超时/错误状态 ========== */
.analyze-result-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  gap: 24rpx;
}

.state-icon {
  font-size: 100rpx;
  line-height: 1;
}

.state-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  line-height: 1.6;
}

.state-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.state-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  margin-top: 16rpx;
}

.state-btn {
  width: 100% !important;
}

.state-btn::after {
  border: none;
}

/* ========== 评分区域 ========== */
.score-section {
  text-align: center;
  position: relative;
}

.score-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.score-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.share-btn-small {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  background: #f5f5f5;
}

.share-btn-small:active {
  background: #e8e8e8;
}

.share-icon-text {
  font-size: 28rpx;
}

.share-label {
  font-size: 24rpx;
  color: #666;
}

.score-ring-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 16rpx auto 24rpx;
  width: 300rpx;
  height: 300rpx;
}

.score-canvas {
  width: 300rpx;
  height: 300rpx;
}

.score-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 80rpx;
  font-weight: 800;
  line-height: 1;
}

.score-level {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

.score-comment {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
  text-align: center;
  padding: 0 24rpx;
}

/* ========== 汇总卡片 ========== */
.summary-section {
  margin-bottom: 24rpx;
}

.summary-cards {
  display: flex;
  gap: 16rpx;
}

.summary-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.summary-card-abnormal {
  border-top: 6rpx solid #F44336;
}

.summary-card-normal {
  border-top: 6rpx solid #4CAF50;
}

.summary-card-excellent {
  border-top: 6rpx solid #1B8C3D;
}

.summary-card-num {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  line-height: 1.2;
}

.summary-card-label {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-top: 8rpx;
}

/* ========== 分类指标 ========== */
.categories-section {
  margin-bottom: 12rpx;
}

.cat-block {
  margin-bottom: 20rpx;
}

.cat-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.cat-emoji {
  font-size: 36rpx;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  flex: 1;
}

.cat-count {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.indicator-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.indicator-card {
  border: 2rpx solid #f0f0f0;
  border-radius: 14rpx;
  overflow: hidden;
}

.ind-main {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.ind-main:active {
  background: #fafafa;
}

.ind-left {
  flex: 1;
  min-width: 0;
}

.ind-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.risk-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.risk-tag-emoji {
  font-size: 22rpx;
}

.risk-tag-text {
  font-size: 22rpx;
  font-weight: 600;
}

.ind-right {
  text-align: right;
  flex-shrink: 0;
}

.ind-value-wrap {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
}

.ind-value {
  font-size: 32rpx;
  font-weight: 700;
}

.ind-unit {
  font-size: 22rpx;
  color: #999;
}

.ind-ref {
  font-size: 20rpx;
  color: #bbb;
  display: block;
  margin-top: 4rpx;
}

.ind-arrow {
  font-size: 36rpx;
  color: #ccc;
  transition: transform 0.25s;
  flex-shrink: 0;
  display: inline-block;
  transform: rotate(0deg);
}

.ind-arrow.arrow-up {
  transform: rotate(90deg);
}

/* ========== 指标详情展开 ========== */
.ind-detail {
  padding: 0 24rpx 20rpx;
  background: #fafcff;
  border-top: 2rpx solid #f0f0f0;
}

.detail-module {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-module:last-child {
  border-bottom: none;
}

.detail-module-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.detail-module-icon {
  font-size: 26rpx;
}

.detail-module-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #444;
}

.detail-module-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 36rpx;
  display: block;
}

/* ========== 原始文本回退 ========== */
.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.raw-text-card {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  border-radius: 12rpx;
  padding: 24rpx;
}

.raw-text-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

/* ========== 免责声明 ========== */
.disclaimer-box {
  padding: 20rpx 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.7;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 60rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 报告对比入口 ========== */
.compare-entry {
  margin-bottom: 24rpx;
}

.compare-entry-inner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #e8f5e9, #e0f7fa);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.compare-entry-inner:active {
  opacity: 0.85;
}

.compare-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.compare-text-wrap {
  flex: 1;
}

.compare-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.compare-desc {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

.compare-arrow {
  font-size: 40rpx;
  color: #bbb;
  flex-shrink: 0;
}
