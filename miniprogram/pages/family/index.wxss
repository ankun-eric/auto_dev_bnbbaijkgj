.family-page {
  padding: 24rpx;
  min-height: 100vh;
}

.sos-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.sos-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.4);
  margin-bottom: 12rpx;
}

.sos-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.sos-hint {
  font-size: 22rpx;
  color: #999;
}

.member-list {
  margin-top: 16rpx;
}

.member-card {
  margin-bottom: 16rpx;
}

.member-header {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-char {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.member-relation {
  font-size: 24rpx;
  color: #999;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  font-size: 32rpx;
}

.member-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 12rpx 0;
  padding-left: 96rpx;
}

.member-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  padding-left: 96rpx;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 12rpx;
}

.member-phone {
  font-size: 24rpx;
  color: #666;
}

.consult-btn {
  font-size: 24rpx;
  color: #52c41a;
  padding: 8rpx 20rpx;
  border: 1rpx solid #52c41a;
  border-radius: 24rpx;
}

.add-member-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.add-icon {
  font-size: 36rpx;
  color: #52c41a;
  margin-right: 12rpx;
}

.add-text {
  font-size: 28rpx;
  color: #52c41a;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 85%;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-actions button {
  flex: 1;
}
