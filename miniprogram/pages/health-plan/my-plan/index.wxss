.page-wrap { padding: 24rpx; min-height: 100vh; background: #f5f5f5; }
.loading-wrap { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }
.text-hint { font-size: 26rpx; color: #999; }
.empty-hint { text-align: center; padding: 40rpx 0; }

.plan-header { margin-bottom: 24rpx; }
.plan-title { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.plan-desc { font-size: 26rpx; color: #666; display: block; margin-bottom: 20rpx; line-height: 1.6; }

.progress-section { margin-top: 16rpx; }
.progress-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.progress-label { font-size: 24rpx; color: #999; }
.progress-value { font-size: 26rpx; color: #52c41a; font-weight: 600; }
.progress-bar { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #52c41a, #13c2c2); border-radius: 6rpx; transition: width 0.3s; }

.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }

.task-card { margin-bottom: 12rpx; }
.task-row { display: flex; align-items: center; }
.task-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.task-done { border-color: #52c41a; background: #52c41a; }
.check-mark { font-size: 26rpx; color: #fff; }
.task-info { flex: 1; }
.task-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.task-name-done { text-decoration: line-through; color: #999; }
.task-desc { font-size: 24rpx; color: #666; display: block; margin-top: 6rpx; }
.task-action { flex-shrink: 0; margin-left: 16rpx; }
.checkin-text { font-size: 24rpx; color: #fff; background: #52c41a; padding: 8rpx 24rpx; border-radius: 24rpx; }
