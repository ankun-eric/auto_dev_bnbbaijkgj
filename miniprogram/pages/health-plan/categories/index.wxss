.page-wrap { padding: 24rpx; min-height: 100vh; background: #f5f5f5; }
.loading-wrap { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }
.text-hint { font-size: 26rpx; color: #999; }

.section { margin-bottom: 24rpx; }
.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.empty-hint { text-align: center; padding: 40rpx 0; }

/* 我的计划 */
.plan-card { margin-bottom: 16rpx; }
.plan-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.plan-info { flex: 1; }
.plan-name { font-size: 28rpx; color: #333; font-weight: 600; display: block; }
.plan-meta { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.plan-arrow { font-size: 32rpx; color: #ccc; }
.plan-progress-bar { height: 8rpx; background: #f0f0f0; border-radius: 4rpx; overflow: hidden; }
.plan-progress-fill { height: 100%; background: linear-gradient(90deg, #52c41a, #13c2c2); border-radius: 4rpx; transition: width 0.3s; }

/* 分类卡片 */
.cat-card { margin-bottom: 16rpx; }
.cat-main { display: flex; align-items: center; }
.cat-icon { font-size: 40rpx; margin-right: 16rpx; }
.cat-text { flex: 1; }
.cat-name { font-size: 28rpx; color: #333; font-weight: 600; display: block; }
.cat-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.cat-arrow { font-size: 32rpx; color: #ccc; }
.cat-ai-btn { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; text-align: center; }
.ai-text { font-size: 24rpx; color: #52c41a; }

/* 创建按钮 */
.create-section { margin-top: 24rpx; }
.create-btn { display: flex; align-items: center; }
.create-icon { font-size: 40rpx; margin-right: 16rpx; }
.create-text { flex: 1; }
.create-title { font-size: 28rpx; color: #333; font-weight: 600; display: block; }
.create-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.create-arrow { font-size: 32rpx; color: #ccc; }
