.hp-landing { min-height: 100vh; background: #F5F5F7; padding-bottom: 120rpx; }

.hp-banner {
  padding: 48rpx 32rpx 64rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
}
.hp-banner-title { font-size: 40rpx; font-weight: bold; }
.hp-banner-desc { font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; display: block; }

.hp-overview-card {
  margin: -36rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.10);
}
.hp-stat { flex: 1; display: flex; flex-direction: column; align-items: center; }
.hp-stat-num { font-size: 40rpx; font-weight: bold; }
.hp-stat-num.purple { color: #6366F1; }
.hp-stat-num.purple-light { color: #8B5CF6; }
.hp-stat-num.pink { color: #A855F7; }
.hp-stat-label { font-size: 22rpx; color: #9CA3AF; margin-top: 8rpx; }
.hp-stat-divider { width: 1rpx; height: 64rpx; background: #f0f0f0; }

.hp-list-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 16rpx; }
.hp-list-title { font-size: 30rpx; font-weight: bold; }
.hp-list-action { font-size: 24rpx; color: #6366F1; }

.hp-loading { text-align: center; padding: 64rpx 0; color: #9CA3AF; font-size: 24rpx; }

.hp-empty {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 32rpx;
  text-align: center;
}
.hp-empty-icon { font-size: 60rpx; display: block; }
.hp-empty-text { font-size: 26rpx; color: #9CA3AF; display: block; margin-top: 16rpx; margin-bottom: 24rpx; }
.hp-empty-btn { display: inline-block; padding: 16rpx 48rpx; border-radius: 12rpx; background: #6366F1; color: #fff; font-size: 28rpx; }

.hp-plan-card {
  margin: 0 24rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
}
.hp-plan-main { flex: 1; min-width: 0; }
.hp-plan-name { font-size: 30rpx; font-weight: bold; color: #1F2937; }
.hp-plan-meta { font-size: 22rpx; color: #9CA3AF; margin-top: 8rpx; }
.hp-plan-actions { display: flex; align-items: center; gap: 16rpx; margin-left: 16rpx; }
.hp-plan-more { color: #9CA3AF; font-size: 36rpx; padding: 8rpx 12rpx; line-height: 1; }
.hp-plan-btn {
  min-width: 120rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  line-height: 56rpx;
  padding: 0 24rpx;
}
.hp-plan-btn-done {
  background: #E5E7EB;
  color: #9CA3AF;
}

.hp-fab {
  position: fixed;
  right: 36rpx;
  bottom: 80rpx;
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 56rpx;
  color: #fff;
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.35);
  z-index: 100;
}

.hp-action-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 200;
  display: flex; align-items: flex-end;
}
.hp-action-sheet { width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; }
.hp-action-item { text-align: center; padding: 32rpx; font-size: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.hp-action-danger { color: #ff4d4f; }
.hp-action-cancel { color: #9CA3AF; border-top: 8rpx solid #f5f5f5; border-bottom: none; }
