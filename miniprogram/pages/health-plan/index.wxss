.plan-page {
  padding: 24rpx;
  min-height: 100vh;
}

.progress-ring-wrap {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.progress-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid #f0f0f0;
  border-top-color: #52c41a;
  border-right-color: #52c41a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-num { font-size: 40rpx; font-weight: bold; color: #52c41a; }
.progress-label { font-size: 22rpx; color: #999; }

.task-list { margin-bottom: 24rpx; }

.task-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.task-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-done {
  border-color: #52c41a;
  background: #52c41a;
}

.check-mark { font-size: 24rpx; color: #fff; }

.task-info { flex: 1; }
.task-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.task-name-done { text-decoration: line-through; color: #999; }
.task-desc { font-size: 22rpx; color: #999; }

.task-reward {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.reward-points { font-size: 26rpx; font-weight: bold; color: #faad14; }
.reward-label { font-size: 20rpx; color: #ccc; }

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
}

.tip-icon { margin-right: 12rpx; font-size: 28rpx; }
.tip-text { font-size: 26rpx; color: #666; line-height: 1.5; flex: 1; }
