.page-wrap { padding: 24rpx; min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }
.loading-wrap { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }
.text-hint { font-size: 26rpx; color: #999; }

.plan-header { margin-bottom: 24rpx; }
.plan-title { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.plan-desc { font-size: 26rpx; color: #666; display: block; margin-bottom: 16rpx; line-height: 1.6; }
.plan-meta-row { display: flex; flex-wrap: wrap; }
.meta-item { display: flex; align-items: center; margin-right: 24rpx; margin-bottom: 8rpx; }
.meta-icon { font-size: 24rpx; margin-right: 6rpx; }
.meta-text { font-size: 24rpx; color: #999; }

.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }

.task-card { margin-bottom: 12rpx; }
.task-row { display: flex; align-items: flex-start; }
.task-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(82,196,26,0.12);
  color: #52c41a;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.task-info { flex: 1; }
.task-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.task-desc { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.join-btn {
  width: 100%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
}
.btn-disabled { opacity: 0.6; }
