.page-wrap { padding: 24rpx; min-height: 100vh; background: #f5f5f5; }
.loading-wrap, .empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.text-hint { font-size: 26rpx; color: #999; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #333; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #999; }

/* 核心数据 */
.hero-card { background: linear-gradient(135deg, #52c41a, #13c2c2) !important; color: #fff; }
.hero-row { display: flex; align-items: center; }
.hero-item { flex: 1; text-align: center; }
.hero-value { font-size: 56rpx; font-weight: bold; display: block; color: #fff !important; }
.hero-label { font-size: 24rpx; color: rgba(255,255,255,0.85); display: block; margin-top: 8rpx; }
.hero-divider { width: 1rpx; height: 80rpx; background: rgba(255,255,255,0.3); }

/* 今日概览 */
.section-card { margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 20rpx; }
.stats-grid { display: flex; justify-content: space-around; }
.stats-item { text-align: center; }
.stats-num { font-size: 40rpx; font-weight: bold; display: block; }
.stats-label { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }
.text-green { color: #52c41a; }
.text-cyan { color: #13c2c2; }
.text-blue { color: #1890ff; }
.text-orange { color: #faad14; }

/* 分类统计 */
.cat-stat-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.cat-stat-item:last-child { border-bottom: none; }
.cat-stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 28rpx;
}
.cat-stat-info { flex: 1; margin-right: 16rpx; }
.cat-stat-name { font-size: 26rpx; color: #333; display: block; margin-bottom: 8rpx; }
.cat-stat-bar { height: 8rpx; background: #f0f0f0; border-radius: 4rpx; overflow: hidden; }
.cat-stat-fill { height: 100%; border-radius: 4rpx; transition: width 0.3s; }
.cat-stat-value { font-size: 24rpx; color: #666; flex-shrink: 0; }

/* 本周打卡柱状图 */
.weekly-chart { display: flex; justify-content: space-around; align-items: flex-end; height: 200rpx; padding-top: 20rpx; }
.week-col { display: flex; flex-direction: column; align-items: center; flex: 1; }
.week-bar-wrap { width: 40rpx; height: 160rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; display: flex; align-items: flex-end; }
.week-bar { width: 100%; background: linear-gradient(180deg, #52c41a, #13c2c2); border-radius: 8rpx; transition: height 0.3s; min-height: 4rpx; }
.week-label { font-size: 20rpx; color: #999; margin-top: 8rpx; }

/* 成就 */
.achievement-list { margin-top: 12rpx; }
.achievement-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.achievement-item:last-child { border-bottom: none; }
.achievement-icon { font-size: 36rpx; margin-right: 16rpx; }
.achievement-info { flex: 1; }
.achievement-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.achievement-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
