<view class="page-wrap">
  <checkin-points-progress refreshKey="{{pointsRefreshKey}}" />

  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="text-hint">加载中...</text>
  </view>

  <view wx:elif="{{medications.length === 0}}" class="empty-wrap">
    <text class="empty-icon">💊</text>
    <text class="empty-text">暂无用药提醒</text>
    <text class="empty-desc">添加您的用药计划，按时提醒服药</text>
    <view class="empty-btn" bindtap="goAdd">添加用药提醒</view>
  </view>

  <view wx:else class="list-wrap">
    <!-- 按时段分组显示 -->
    <block wx:if="{{medGroups.length > 0}}">
      <view class="med-group" wx:for="{{medGroups}}" wx:key="period">
        <view class="med-group-header">
          <text class="med-group-title">{{item.period}}</text>
          <text class="med-group-count">{{item.items.length}}个提醒</text>
        </view>
        <view class="med-card card" wx:for="{{item.items}}" wx:for-item="med" wx:key="id">
          <view class="med-header">
            <view class="med-title-row">
              <text class="med-icon">💊</text>
              <text class="med-name">{{med.name}}</text>
              <view class="med-status {{med.is_paused ? 'status-paused' : 'status-active'}}">
                <text>{{med.is_paused ? '已暂停' : '进行中'}}</text>
              </view>
            </view>
          </view>
          <view class="med-body">
            <view class="med-info-row" wx:if="{{med.dosage}}">
              <text class="info-label">剂量</text>
              <text class="info-value">{{med.dosage}}</text>
            </view>
            <view class="med-info-row" wx:if="{{med.remind_times}}">
              <text class="info-label">提醒时间</text>
              <text class="info-value">{{med.remind_times}}</text>
            </view>
            <view class="med-info-row" wx:if="{{med.notes}}">
              <text class="info-label">备注</text>
              <text class="info-value">{{med.notes}}</text>
            </view>
          </view>
          <view class="med-actions">
            <view class="action-btn action-checkin" catchtap="onCheckin" data-id="{{med.id}}" wx:if="{{!med.is_paused && !med.today_checked}}">
              <text>打卡</text>
            </view>
            <view class="action-btn action-done" wx:if="{{med.today_checked}}">
              <text>✓ 已打卡</text>
            </view>
            <view class="action-btn action-pause" catchtap="onTogglePause" data-id="{{med.id}}">
              <text>{{med.is_paused ? '恢复' : '暂停'}}</text>
            </view>
            <view class="action-btn action-edit" catchtap="goEdit" data-id="{{med.id}}">
              <text>编辑</text>
            </view>
            <view class="action-btn action-delete" catchtap="onDelete" data-id="{{med.id}}">
              <text>删除</text>
            </view>
          </view>
        </view>
      </view>
    </block>
    <!-- 无分组时的平铺显示 -->
    <block wx:else>
      <view class="med-card card" wx:for="{{medications}}" wx:key="id">
        <view class="med-header">
          <view class="med-title-row">
            <text class="med-icon">💊</text>
            <text class="med-name">{{item.name}}</text>
            <view class="med-status {{item.is_paused ? 'status-paused' : 'status-active'}}">
              <text>{{item.is_paused ? '已暂停' : '进行中'}}</text>
            </view>
          </view>
        </view>
        <view class="med-body">
          <view class="med-info-row" wx:if="{{item.dosage}}">
            <text class="info-label">剂量</text>
            <text class="info-value">{{item.dosage}}</text>
          </view>
          <view class="med-info-row" wx:if="{{item.frequency}}">
            <text class="info-label">频率</text>
            <text class="info-value">{{item.frequency}}</text>
          </view>
          <view class="med-info-row" wx:if="{{item.remind_times}}">
            <text class="info-label">提醒时间</text>
            <text class="info-value">{{item.remind_times}}</text>
          </view>
          <view class="med-info-row" wx:if="{{item.notes}}">
            <text class="info-label">备注</text>
            <text class="info-value">{{item.notes}}</text>
          </view>
        </view>
        <view class="med-actions">
          <view class="action-btn action-checkin" catchtap="onCheckin" data-id="{{item.id}}" wx:if="{{!item.is_paused && !item.today_checked}}">
            <text>打卡</text>
          </view>
          <view class="action-btn action-done" wx:if="{{item.today_checked}}">
            <text>✓ 已打卡</text>
          </view>
          <view class="action-btn action-pause" catchtap="onTogglePause" data-id="{{item.id}}">
            <text>{{item.is_paused ? '恢复' : '暂停'}}</text>
          </view>
          <view class="action-btn action-edit" catchtap="goEdit" data-id="{{item.id}}">
            <text>编辑</text>
          </view>
          <view class="action-btn action-delete" catchtap="onDelete" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="fab-btn" bindtap="goAdd">
    <text class="fab-icon">+</text>
  </view>
</view>
