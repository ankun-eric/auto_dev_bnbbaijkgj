.form-page { padding: 24rpx; min-height: 100vh; background: #f5f5f5; }
.form-card { margin-bottom: 24rpx; }
.form-item { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-item:last-child { border-bottom: none; }
.form-label { display: block; font-size: 26rpx; color: #999; margin-bottom: 12rpx; }
.form-input { font-size: 28rpx; color: #333; padding: 8rpx 0; }
.form-textarea { font-size: 28rpx; color: #333; width: 100%; min-height: 120rpx; padding: 8rpx 0; }

.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-action { font-size: 26rpx; color: #52c41a; }

.task-form-card { margin-bottom: 16rpx; }
.task-form-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.task-form-num { font-size: 26rpx; color: #333; font-weight: 600; }
.task-form-remove { font-size: 24rpx; color: #ff4d4f; }

.form-submit { padding: 24rpx 0; }
.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
}
.btn-disabled { opacity: 0.6; }
