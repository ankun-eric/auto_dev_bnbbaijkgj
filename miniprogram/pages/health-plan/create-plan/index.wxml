<view class="form-page">
  <view class="form-card card">
    <view class="form-item">
      <text class="form-label">计划名称 *</text>
      <input class="form-input" placeholder="给计划取个名字" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-item">
      <text class="form-label">计划描述</text>
      <textarea class="form-textarea" placeholder="描述一下计划目标" value="{{description}}" bindinput="onInput" data-field="description" />
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">计划任务</text>
    <text class="section-action" bindtap="addTask">+ 添加任务</text>
  </view>

  <view class="task-form-list">
    <view class="task-form-card card" wx:for="{{tasks}}" wx:key="index">
      <view class="task-form-header">
        <text class="task-form-num">任务 {{index + 1}}</text>
        <text class="task-form-remove" catchtap="removeTask" data-idx="{{index}}" wx:if="{{tasks.length > 1}}">删除</text>
      </view>
      <view class="form-item">
        <text class="form-label">任务名称 *</text>
        <input class="form-input" placeholder="如：每天步行30分钟" value="{{item.name}}" bindinput="onTaskInput" data-idx="{{index}}" data-field="name" />
      </view>
      <view class="form-item">
        <text class="form-label">任务描述</text>
        <input class="form-input" placeholder="可选描述" value="{{item.description}}" bindinput="onTaskInput" data-idx="{{index}}" data-field="description" />
      </view>
    </view>
  </view>

  <view class="form-submit">
    <button class="submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '创建中...' : '创建计划'}}
    </button>
  </view>
</view>
