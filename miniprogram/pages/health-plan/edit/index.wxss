.edit-page { min-height: 100vh; background: #F5F5F7; padding: 32rpx 24rpx 200rpx; }
.form-card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.red { color: red; margin-right: 4rpx; }
.form-input { background: #f5f5f5; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.form-sub { font-size: 26rpx; color: #6B7280; }
.form-tip { font-size: 22rpx; color: #9CA3AF; margin-top: 16rpx; }

.freq-row { display: flex; gap: 16rpx; }
.freq-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx; background: #f5f5f5; color: #666; font-size: 28rpx; }
.freq-btn-active { background: #EEF2FF; color: #6366F1; border: 1rpx solid rgba(99,102,241,0.25); font-weight: 600; }

.weekly-count-row { display: flex; align-items: center; justify-content: space-between; margin-top: 24rpx; }
.weekly-count-input { width: 120rpx; text-align: center; background: #f5f5f5; border-radius: 12rpx; padding: 12rpx 0; font-size: 28rpx; }

.date-row { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.date-row:last-child { border-bottom: none; }
.date-right { display: flex; align-items: center; gap: 16rpx; }
.date-val { font-size: 26rpx; color: #1F2937; }
.date-clear { font-size: 24rpx; color: #6366F1; }

.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; padding: 24rpx 32rpx; background: #fff; box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.06); }
.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 16rpx;
  background: linear-gradient(135deg, #6366F1, #8B5CF6) !important;
  color: #fff !important; font-size: 30rpx; border: none;
}
