.page-wrap { padding: 24rpx; min-height: 100vh; background: #f5f5f5; }
.loading-wrap { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }
.text-hint { font-size: 26rpx; color: #999; }
.empty-hint { text-align: center; padding: 40rpx 0; }

.cat-header { text-align: center; padding: 40rpx 24rpx; margin-bottom: 24rpx; }
.cat-icon { font-size: 60rpx; display: block; margin-bottom: 16rpx; }
.cat-name { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.cat-desc { font-size: 26rpx; color: #666; display: block; }

.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }

.plan-card { margin-bottom: 16rpx; }
.plan-row { display: flex; align-items: center; }
.plan-info { flex: 1; }
.plan-name { font-size: 28rpx; color: #333; font-weight: 600; display: block; }
.plan-desc { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.plan-tags { display: flex; flex-wrap: wrap; margin-top: 12rpx; }
.plan-tag { font-size: 20rpx; color: #52c41a; background: rgba(82,196,26,0.1); padding: 4rpx 12rpx; border-radius: 8rpx; margin-right: 12rpx; }
.plan-arrow { font-size: 32rpx; color: #ccc; flex-shrink: 0; }
