<view class="hp-landing">
  <!-- 顶部蓝紫色横幅 -->
  <view class="hp-banner">
    <view class="hp-banner-title">健康计划</view>
    <view class="hp-banner-desc">每天一勾，养成更健康的自己</view>
  </view>

  <!-- 总览卡 -->
  <view class="hp-overview-card">
    <view class="hp-stat">
      <text class="hp-stat-num purple">{{overview.active_count || 0}}</text>
      <text class="hp-stat-label">进行中计划</text>
    </view>
    <view class="hp-stat-divider"></view>
    <view class="hp-stat">
      <text class="hp-stat-num purple-light">{{overview.today_done_count || 0}}</text>
      <text class="hp-stat-label">今天已打卡</text>
    </view>
    <view class="hp-stat-divider"></view>
    <view class="hp-stat">
      <text class="hp-stat-num pink">{{overview.week_completion_rate || 0}}%</text>
      <text class="hp-stat-label">本周完成率</text>
    </view>
  </view>

  <!-- 标题 + 查看成果 -->
  <view class="hp-list-header">
    <text class="hp-list-title">我的计划</text>
    <text class="hp-list-action" bindtap="onGoResult">查看成果 ›</text>
  </view>

  <!-- 计划列表 -->
  <view wx:if="{{loading}}" class="hp-loading">加载中...</view>
  <view wx:elif="{{items.length === 0}}" class="hp-empty">
    <text class="hp-empty-icon">✅</text>
    <text class="hp-empty-text">还没有计划，创建一个开始打卡吧</text>
    <view class="hp-empty-btn" bindtap="onCreate">新建计划</view>
  </view>
  <view wx:else>
    <view class="hp-plan-card" wx:for="{{items}}" wx:key="id">
      <view class="hp-plan-main">
        <view class="hp-plan-name">{{item.name}}</view>
        <view class="hp-plan-meta">{{item._freq}} · {{item._period}}</view>
      </view>
      <view class="hp-plan-actions">
        <view class="hp-plan-more" catchtap="onMoreTap" data-id="{{item.id}}">···</view>
        <view
          class="hp-plan-btn {{item.today_completed ? 'hp-plan-btn-done' : ''}}"
          catchtap="onCheckin"
          data-id="{{item.id}}"
        >
          {{item.today_completed ? '已打卡' : '打卡'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 浮动加号 -->
  <view class="hp-fab" bindtap="onCreate">+</view>

  <!-- 操作菜单 -->
  <view wx:if="{{actionMenuVisible}}" class="hp-action-mask" bindtap="onActionMenuCancel">
    <view class="hp-action-sheet" catchtap="">
      <view class="hp-action-item" bindtap="onEdit">编辑</view>
      <view class="hp-action-item hp-action-danger" bindtap="onDelete">删除</view>
      <view class="hp-action-item hp-action-cancel" bindtap="onActionMenuCancel">取消</view>
    </view>
  </view>
</view>
