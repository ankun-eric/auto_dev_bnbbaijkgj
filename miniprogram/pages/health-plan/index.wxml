<view class="plan-page">
  <!-- 统计概览 -->
  <view class="stats-overview card" bindtap="goStatistics">
    <view class="stats-header">
      <text class="stats-title-text">打卡统计</text>
      <text class="stats-arrow">详情 ></text>
    </view>
    <view class="stats-row" wx:if="{{stats}}">
      <view class="stat-col">
        <text class="stat-value text-green">{{stats.today_completed || 0}}</text>
        <text class="stat-label">今日完成</text>
      </view>
      <view class="stat-col">
        <text class="stat-value text-cyan">{{stats.streak_days || 0}}</text>
        <text class="stat-label">连续天数</text>
      </view>
      <view class="stat-col">
        <text class="stat-value text-blue">{{stats.total_checkins || 0}}</text>
        <text class="stat-label">累计打卡</text>
      </view>
    </view>
    <view class="stats-empty" wx:else>
      <text class="text-hint">暂无统计数据</text>
    </view>
  </view>

  <!-- 三大分类入口 -->
  <view class="category-grid">
    <view class="category-card card" wx:for="{{categories}}" wx:key="key" bindtap="onCategoryTap" data-url="{{item.url}}">
      <view class="category-icon-wrap" style="background: {{item.color}}20;">
        <text class="category-icon">{{item.icon}}</text>
      </view>
      <view class="category-text">
        <text class="category-name">{{item.name}}</text>
        <text class="category-desc">{{item.desc}}</text>
      </view>
      <text class="category-arrow">›</text>
    </view>
  </view>

  <!-- AI生成按钮 -->
  <view class="ai-btn card {{aiGenerating ? 'ai-btn-disabled' : ''}}" bindtap="onAiGenerate">
    <view class="ai-btn-inner">
      <text class="ai-icon">🤖</text>
      <view class="ai-text">
        <text class="ai-title">AI智能生成计划</text>
        <text class="ai-desc">根据您的健康状况，AI为您量身定制</text>
      </view>
    </view>
    <text class="ai-arrow" wx:if="{{!aiGenerating}}">›</text>
    <text class="ai-loading-text" wx:else>生成中...</text>
  </view>

  <!-- 今日待办 -->
  <view class="card today-section">
    <view class="section-header">
      <text class="section-title">今日待办</text>
      <text class="section-count" wx:if="{{todoTotalCount > 0}}">{{todoTotalCompleted}}/{{todoTotalCount}}</text>
    </view>
    <view wx:if="{{todayLoading}}" class="loading-hint">
      <text class="text-hint">加载中...</text>
    </view>
    <view wx:elif="{{todoTotalCount === 0}}" class="empty-hint">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无待办事项</text>
    </view>
    <view wx:else class="todo-groups">
      <view class="todo-group" wx:for="{{todoGroups}}" wx:key="group_type">
        <view class="todo-group-header">
          <view class="todo-group-title-row">
            <text class="todo-group-icon" wx:if="{{item.group_type === 'medication'}}">💊</text>
            <text class="todo-group-icon" wx:elif="{{item.group_type === 'checkin'}}">✅</text>
            <text class="todo-group-icon" wx:else>📋</text>
            <text class="todo-group-name">{{item.group_name}}</text>
          </view>
          <text class="todo-group-count">{{item.completed_count}}/{{item.total_count}}</text>
        </view>

        <view wx:if="{{item.is_empty}}" class="todo-group-empty">
          <text class="todo-group-empty-text">今日无待办</text>
        </view>
        <view wx:else>
          <view class="todo-item {{todoItem.is_completed ? 'todo-item-done' : ''}}" wx:for="{{item.items}}" wx:for-item="todoItem" wx:key="id">
            <view class="todo-left">
              <view class="todo-check {{todoItem.is_completed ? 'todo-checked' : ''}}">
                <text wx:if="{{todoItem.is_completed}}" class="check-mark">✓</text>
              </view>
              <view class="todo-info">
                <text class="todo-name {{todoItem.is_completed ? 'todo-done' : ''}}">{{todoItem.name}}</text>
                <text class="todo-time" wx:if="{{todoItem.remind_time}}">{{todoItem.remind_time}}</text>
                <text class="todo-time" wx:if="{{todoItem.extra.plan_name}}">{{todoItem.extra.plan_name}}</text>
              </view>
            </view>
            <view class="todo-btn" wx:if="{{!todoItem.is_completed}}" catchtap="onTodoCheckin"
              data-type="{{todoItem.type}}" data-id="{{todoItem.id}}"
              data-source-id="{{todoItem.source_id}}"
              data-target-value="{{todoItem.target_value}}"
              data-target-unit="{{todoItem.target_unit}}"
              data-name="{{todoItem.name}}">
              <text class="todo-btn-text">打卡</text>
            </view>
            <view class="todo-btn-done" wx:else>
              <text class="done-mark">✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 打卡数值输入对话框 -->
  <view class="checkin-dialog-mask" wx:if="{{checkinDialog}}" catchtap="onCheckinDialogCancel">
    <view class="checkin-dialog" catchtap="">
      <text class="checkin-dialog-title">{{checkinDialogName}}</text>
      <text class="checkin-dialog-hint">目标: {{checkinDialogTarget}} {{checkinDialogUnit}}</text>
      <input class="checkin-dialog-input" type="digit" placeholder="请输入实际值"
        value="{{checkinDialogValue}}" bindinput="onCheckinDialogInput" focus="{{checkinDialog}}" />
      <view class="checkin-dialog-actions">
        <view class="checkin-dialog-btn checkin-dialog-cancel" bindtap="onCheckinDialogCancel">取消</view>
        <view class="checkin-dialog-btn checkin-dialog-confirm" bindtap="onCheckinDialogConfirm">确认打卡</view>
      </view>
    </view>
  </view>
</view>
