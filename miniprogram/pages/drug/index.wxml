<view class="drug-page">
  <!-- 拍照操作区域 -->
  <view class="camera-section">
    <view class="camera-icon-wrap">
      <text class="camera-big-icon">📷</text>
    </view>
    <text class="camera-title">拍照识别药品</text>
    <text class="camera-desc">拍摄药品照片或从相册选择，AI 为您智能识别</text>
    <view class="camera-actions">
      <button class="btn-primary" bindtap="takePhoto" disabled="{{uploading}}">拍照识药</button>
      <button class="btn-outline" bindtap="chooseAlbum" disabled="{{uploading}}">从相册选择</button>
    </view>

    <!-- 已选图片预览 -->
    <view wx:if="{{selectedImages.length > 0}}" class="selected-images">
      <view class="selected-count">已选 {{selectedImages.length}}/{{maxImages}} 张</view>
      <view class="image-grid">
        <view wx:for="{{selectedImages}}" wx:key="index" class="image-item">
          <image src="{{item.path}}" mode="aspectFill" class="thumb" />
          <view class="delete-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
      </view>
      <view wx:if="{{uploadProgressText}}" class="progress-text">{{uploadProgressText}}</view>
      <button class="btn-start" bindtap="startRecognize" loading="{{uploading}}" disabled="{{uploading}}">
        {{uploading ? uploadProgressText || '上传中...' : '开始识别'}}
      </button>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section">
    <view class="section-header">
      <text class="section-title">识别历史</text>
    </view>

    <view wx:if="{{loading && historyList.length === 0}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{historyList.length === 0}}" class="empty-wrap">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无识别记录</text>
      <text class="empty-hint">拍照识别药品后，记录将显示在这里</text>
    </view>

    <view wx:else class="history-list">
      <view class="history-item" wx:for="{{historyList}}" wx:key="id" bindtap="goChat" data-sessionid="{{item.sessionId}}">
        <image class="history-thumb" src="{{item.thumbnail}}" mode="aspectFill" wx:if="{{item.thumbnail}}" />
        <view class="history-thumb history-thumb-placeholder" wx:else>
          <text class="thumb-icon">💊</text>
        </view>
        <view class="history-info">
          <text class="history-name">{{item.drugName}}</text>
          <text class="history-time">{{item.time}}</text>
        </view>
        <view class="history-status status-{{item.status}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
        <text class="history-arrow">›</text>
      </view>
    </view>
  </view>
</view>
