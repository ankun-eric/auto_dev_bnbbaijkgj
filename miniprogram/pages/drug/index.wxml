<wxs module="utils">
module.exports.getMemberTagColor = function(member) {
  if (!member) return '#1677ff';
  var rt = member.relationship_type || '';
  if (rt === '本人') return '#1677ff';
  if (rt === '爸爸' || rt === '父亲') return '#fa8c16';
  if (rt === '妈妈' || rt === '母亲') return '#eb2f96';
  if (rt === '配偶' || rt === '老公' || rt === '老婆') return '#722ed1';
  if (rt === '儿子' || rt === '女儿' || rt === '子女') return '#13c2c2';
  return '#8c8c8c';
}

module.exports.getMemberTagName = function(member) {
  if (!member) return '';
  if (member.nickname) return member.nickname;
  if (member.relationship_type) return member.relationship_type;
  return '本人';
}

module.exports.isPresetSelected = function(items, name) {
  if (!items || !items.length) return false;
  for (var i = 0; i < items.length; i++) {
    if (typeof items[i] === 'string' && items[i] === name) return true;
  }
  return false;
}

module.exports.isProfileComplete = function(nickname, gender, birthday, height, weight) {
  return !!(nickname && gender && birthday && height && weight);
}
</wxs>
<view class="drug-page">

  <!-- 步骤条 -->
  <view class="ck-steps-bar" wx:if="{{selectedImages.length > 0}}">
    <view class="ck-step {{uploadStep >= 1 ? 'ck-step-active' : ''}}" bindtap="onStepTap" data-step="1">
      <view class="ck-step-dot">1</view>
      <text class="ck-step-label">拍照/选图</text>
    </view>
    <view class="ck-step-line {{uploadStep >= 2 ? 'ck-line-active' : ''}}"></view>
    <view class="ck-step {{uploadStep >= 2 ? 'ck-step-active' : ''}}" bindtap="onStepTap" data-step="2">
      <view class="ck-step-dot">2</view>
      <text class="ck-step-label">选择对象</text>
    </view>
    <view class="ck-step-line {{uploadStep >= 3 ? 'ck-line-active' : ''}}"></view>
    <view class="ck-step {{uploadStep >= 3 ? 'ck-step-active' : ''}}">
      <view class="ck-step-dot">3</view>
      <text class="ck-step-label">AI 识别</text>
    </view>
  </view>

  <!-- 步骤1: 拍照/选图 -->
  <view class="camera-section" wx:if="{{uploadStep === 1}}">
    <view class="camera-icon-wrap">
      <text class="camera-big-icon">📷</text>
    </view>
    <text class="camera-title">拍照识别药品</text>
    <text class="camera-desc">拍摄药品照片或从相册选择，AI 为您智能识别</text>
    <view class="camera-actions">
      <button class="btn-primary" bindtap="takePhoto" disabled="{{uploading}}">拍照识药</button>
      <button class="btn-outline" bindtap="chooseAlbum" disabled="{{uploading}}">从相册选择</button>
    </view>

    <!-- 已选图片预览 -->
    <view wx:if="{{selectedImages.length > 0}}" class="selected-images">
      <view class="selected-count">已选 {{selectedImages.length}}/{{maxImages}} 张</view>
      <view class="image-grid">
        <view wx:for="{{selectedImages}}" wx:key="index" class="image-item">
          <image src="{{item.path}}" mode="aspectFill" class="thumb" />
          <view class="delete-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
      </view>
      <button class="btn-start" bindtap="startRecognize" disabled="{{uploading}}">
        下一步
      </button>
    </view>
  </view>

  <!-- 步骤2: 选择咨询对象 -->
  <view class="family-select-section card" wx:if="{{uploadStep === 2}}">
    <text class="section-title">选择咨询对象</text>
    <text class="upload-tip">请选择这次识药是为谁咨询</text>

    <scroll-view class="ck-member-scroll" scroll-x>
      <view class="ck-member-list">
        <view class="ck-member-item {{selectedFamilyMemberId === item.id ? 'ck-member-selected' : ''}}"
              wx:for="{{familyMembers}}" wx:key="id"
              bindtap="selectFamilyMember" data-member="{{item}}">
          <text class="ck-member-emoji">{{item.emoji}}</text>
          <text class="ck-member-relation">{{item.relationship_type}}</text>
          <text class="ck-member-name">{{item.nickname}}</text>
        </view>
        <view class="ck-member-item ck-member-add" bindtap="goAddFamilyMember">
          <text class="ck-member-emoji">➕</text>
          <text class="ck-member-relation">添加</text>
          <text class="ck-member-name">家庭成员</text>
        </view>
      </view>
    </scroll-view>

    <!-- 咨询人基本信息（始终显示） -->
    <view class="self-basic-info" wx:if="{{selectedFamilyMemberId}}">
      <view class="basic-info-title">👤 基本信息</view>
      <view class="form-item">
        <view class="form-label">姓名 <text class="required">*</text></view>
        <input class="form-input" placeholder="请输入姓名" value="{{selfNickname}}" bindinput="onSelfNicknameInput" />
      </view>
      <view class="form-item">
        <view class="form-label">出生日期 <text class="required">*</text></view>
        <picker mode="date" value="{{selfBirthday}}" start="1900-01-01" end="{{today}}" bindchange="onSelfBirthdayChange">
          <view class="form-input date-input">
            <text class="{{selfBirthday ? '' : 'placeholder'}}">{{selfBirthday || '请选择出生日期'}}</text>
            <text class="date-icon">📅</text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <view class="form-label">性别 <text class="required">*</text></view>
        <view class="gender-select">
          <view class="gender-btn {{selfGender === 'male' ? 'gender-active' : ''}}" bindtap="onSelfGenderSelect" data-gender="male">男</view>
          <view class="gender-btn {{selfGender === 'female' ? 'gender-active' : ''}}" bindtap="onSelfGenderSelect" data-gender="female">女</view>
        </view>
      </view>
    </view>

    <!-- 展开/收起按钮 -->
    <view class="expand-toggle" bindtap="toggleHealthEdit" wx:if="{{selectedFamilyMemberId}}">
      <view class="line"></view>
      <view class="text">
        <text wx:if="{{!showHealthEdit}}">更多信息（</text>
        <text wx:else>收起信息（</text>
        <text class="{{utils.isProfileComplete(selfNickname, selfGender, selfBirthday, selfHeight, selfWeight) ? 'status-complete' : 'status-incomplete'}}">{{utils.isProfileComplete(selfNickname, selfGender, selfBirthday, selfHeight, selfWeight) ? '已完善' : '待完善'}}</text>
        <text>）{{showHealthEdit ? '▲' : '▼'}}</text>
      </view>
      <view class="line"></view>
    </view>

    <!-- 展开区域 -->
    <view class="expand-content {{showHealthEdit ? 'expanded' : ''}}" wx:if="{{selectedFamilyMemberId}}">
      <view class="health-edit-panel">
        <view class="self-basic-info">
          <view class="form-item">
            <view class="form-label">身高（cm）</view>
            <input class="form-input" type="digit" placeholder="请输入身高" value="{{selfHeight}}" bindinput="onSelfHeightInput" />
          </view>
          <view class="form-item">
            <view class="form-label">体重（kg）</view>
            <input class="form-input" type="digit" placeholder="请输入体重" value="{{selfWeight}}" bindinput="onSelfWeightInput" />
          </view>
        </view>

        <view class="health-section">
          <view class="health-section-title">🏥 既往病史</view>
          <view class="tags-wrap">
            <view wx:for="{{chronicPresets}}" wx:key="id"
              class="preset-tag {{utils.isPresetSelected(chronic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleChronicPreset" data-name="{{item.name}}">{{item.name}}</view>
            <view class="preset-tag preset-tag-other {{showChronicOther ? 'preset-tag-selected' : ''}}" bindtap="toggleChronicOther">其它 ✚</view>
          </view>
          <view wx:if="{{showChronicOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它病史…" value="{{chronicOtherInput}}" bindinput="onChronicOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmChronicOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{chronicCustomItems.length > 0}}">
            <view wx:for="{{chronicCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeChronicCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <view class="health-section">
          <view class="health-section-title">⚠️ 过敏史</view>
          <view class="tags-wrap">
            <view wx:for="{{allergyPresets}}" wx:key="id"
              class="preset-tag {{utils.isPresetSelected(allergies, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleAllergyPreset" data-name="{{item.name}}">{{item.name}}</view>
            <view class="preset-tag preset-tag-other {{showAllergyOther ? 'preset-tag-selected' : ''}}" bindtap="toggleAllergyOther">其它 ✚</view>
          </view>
          <view wx:if="{{showAllergyOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它过敏源…" value="{{allergyOtherInput}}" bindinput="onAllergyOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmAllergyOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{allergyCustomItems.length > 0}}">
            <view wx:for="{{allergyCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeAllergyCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <view class="health-section">
          <view class="health-section-title">🧬 家族遗传病史</view>
          <view class="tags-wrap">
            <view wx:for="{{geneticPresets}}" wx:key="id"
              class="preset-tag {{utils.isPresetSelected(genetic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleGeneticPreset" data-name="{{item.name}}">{{item.name}}</view>
            <view class="preset-tag preset-tag-other {{showGeneticOther ? 'preset-tag-selected' : ''}}" bindtap="toggleGeneticOther">其它 ✚</view>
          </view>
          <view wx:if="{{showGeneticOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它遗传病…" value="{{geneticOtherInput}}" bindinput="onGeneticOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmGeneticOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{geneticCustomItems.length > 0}}">
            <view wx:for="{{geneticCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeGeneticCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <button class="health-save-btn" bindtap="saveHealthInfo">保存健康信息</button>
      </view>
    </view>

    <view class="family-select-actions">
      <button class="btn-outline family-action-btn" bindtap="onStepTap" data-step="1">上一步</button>
      <button class="btn-primary family-action-btn" bindtap="confirmFamilyMember">确认并识别</button>
    </view>
  </view>

  <!-- 步骤3: AI识别中 -->
  <view class="upload-progress-section card" wx:if="{{uploadStep === 3 && uploading}}">
    <text class="section-title">AI 识别中</text>
    <view wx:if="{{uploadProgressText}}" class="progress-text">{{uploadProgressText}}</view>
    <view wx:if="{{uploadPercent >= 0}}" class="upload-progress-wrap">
      <view class="upload-progress-track">
        <view class="upload-progress-fill" style="width: {{uploadPercent}}%;"></view>
      </view>
      <text class="upload-progress-pct">{{uploadPercent}}%</text>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section">
    <view class="section-header">
      <text class="section-title-hist">识别历史</text>
    </view>

    <view wx:if="{{loading && historyList.length === 0}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{historyList.length === 0}}" class="empty-wrap">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无识别记录</text>
      <text class="empty-hint">拍照识别药品后，记录将显示在这里</text>
    </view>

    <view wx:else class="history-list">
      <view class="history-item card" wx:for="{{historyList}}" wx:key="id" bindtap="goChat" data-sessionid="{{item.sessionId}}" data-item="{{item}}">
        <view class="history-item-content">
          <image
            class="history-thumb"
            src="{{item.thumbnail}}"
            mode="aspectFill"
            wx:if="{{item.thumbnail && !item.thumbnailFailed}}"
            binderror="onHistoryThumbError"
            data-id="{{item.id}}"
          />
          <view class="history-thumb history-thumb-placeholder" wx:else>
            <text class="thumb-icon">💊</text>
          </view>
          <view class="history-info">
            <view class="history-header-row">
              <text class="history-name">{{item.drugName}}</text>
            </view>
            <view class="history-meta-row">
              <text class="history-time">{{item.time}}</text>
              <view class="history-status status-{{item.status}}">
                <text class="status-text">{{item.statusText}}</text>
              </view>
              <view class="member-tag" wx:if="{{item.family_member}}" style="background: {{utils.getMemberTagColor(item.family_member)}}15; color: {{utils.getMemberTagColor(item.family_member)}}; border: 1rpx solid {{utils.getMemberTagColor(item.family_member)}}30;">
                {{utils.getMemberTagName(item.family_member)}}
              </view>
            </view>
          </view>
          <view class="history-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
