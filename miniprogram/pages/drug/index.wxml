<view class="drug-page">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索药品名称" value="{{keyword}}" bindinput="onSearch" bindconfirm="doSearch" />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
    <view class="camera-btn" bindtap="scanDrug">
      <text class="camera-icon">📷</text>
      <text class="camera-text">拍照识药</text>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="card" wx:if="{{!keyword && searchResults.length === 0}}">
    <text class="section-title">热门搜索</text>
    <view class="hot-tags">
      <view class="hot-tag" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="searchKeyword" data-keyword="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-list" wx:if="{{searchResults.length > 0}}">
    <view class="drug-card card" wx:for="{{searchResults}}" wx:key="id" bindtap="showDrugDetail" data-drug="{{item}}">
      <view class="drug-header">
        <text class="drug-name">{{item.name}}</text>
        <view class="tag tag-green" wx:if="{{item.otc}}">OTC</view>
        <view class="tag tag-blue" wx:if="{{item.prescription}}">处方药</view>
      </view>
      <text class="drug-generic">{{item.generic}}</text>
      <text class="drug-spec">规格: {{item.spec}}</text>
      <text class="drug-usage ellipsis">用法: {{item.usage}}</text>
    </view>
  </view>

  <!-- 药品详情弹窗 -->
  <view class="drug-modal" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">{{currentDrug.name}}</text>
        <text class="modal-close" bindtap="closeDetail">✕</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="detail-section">
          <text class="detail-label">通用名</text>
          <text class="detail-value">{{currentDrug.generic}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">规格</text>
          <text class="detail-value">{{currentDrug.spec}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">用法用量</text>
          <text class="detail-value">{{currentDrug.usage}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">适应症</text>
          <text class="detail-value">{{currentDrug.indication}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">不良反应</text>
          <text class="detail-value">{{currentDrug.sideEffects}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">禁忌</text>
          <text class="detail-value">{{currentDrug.contraindication}}</text>
        </view>
        <view class="detail-section">
          <text class="detail-label">注意事项</text>
          <text class="detail-value">{{currentDrug.precautions}}</text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-primary" bindtap="askAboutDrug">咨询AI医生</button>
      </view>
    </view>
  </view>
</view>
