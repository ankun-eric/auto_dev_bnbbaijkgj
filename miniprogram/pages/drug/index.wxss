.drug-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 拍照操作区域 */
.camera-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx 48rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.camera-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(82,196,26,0.12), rgba(19,194,194,0.12));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.camera-big-icon {
  font-size: 80rpx;
}

.camera-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.camera-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
}

.camera-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  width: 100%;
  height: 88rpx;
  line-height: 86rpx;
  background: #fff;
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #52c41a;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 历史记录区域 */
.history-section {
  background: #fff;
  padding: 28rpx 0;
}

.section-header {
  padding: 0 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 历史列表 */
.history-list {
  padding: 0;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.history-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-icon {
  font-size: 40rpx;
}

.history-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.history-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.history-status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.status-completed {
  background: rgba(82, 196, 26, 0.1);
}

.status-completed .status-text {
  color: #52c41a;
  font-size: 22rpx;
}

.status-pending {
  background: rgba(250, 173, 20, 0.1);
}

.status-pending .status-text {
  color: #faad14;
  font-size: 22rpx;
}

.status-failed {
  background: rgba(245, 34, 45, 0.1);
}

.status-failed .status-text {
  color: #f5222d;
  font-size: 22rpx;
}

.history-arrow {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
}
