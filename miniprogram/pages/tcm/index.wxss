.tcm-page {
  padding: 24rpx;
  min-height: 100vh;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
}

.feature-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* Quiz */
.quiz-section {
  margin-top: 24rpx;
}

.quiz-progress {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #13c2c2);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.quiz-question {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  padding: 20rpx 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.option-selected {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

/* Result */
.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.result-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.result-icon {
  font-size: 56rpx;
}

.result-type {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

.trait-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trait-item {
  display: flex;
  align-items: flex-start;
}

.trait-dot {
  color: #52c41a;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.trait-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.advice-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-block {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
}

.advice-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin-bottom: 8rpx;
}

.advice-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
