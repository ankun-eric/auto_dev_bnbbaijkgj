<view class="result-page">
  <!-- Search Bar -->
  <view class="result-header">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索症状、药品、健康知识..."
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onSearchAgain"
      />
      <view class="search-box-icons">
        <view class="mic-btn-inline" catchtap="onMicTap">
          <text class="mic-icon-inline">🎤</text>
        </view>
        <view class="clear-btn" wx:if="{{keyword}}" catchtap="onClear">
          <text class="clear-icon">✕</text>
        </view>
      </view>
    </view>
    <view class="search-btn" bindtap="onSearchAgain">
      <text class="search-btn-text">搜索</text>
    </view>
  </view>

  <!-- Voice Overlay -->
  <view class="voice-overlay" wx:if="{{showVoiceOverlay}}" catchtouchmove="preventMove">
    <view class="voice-overlay-mask"></view>
    <view class="voice-content">
      <view class="voice-recording" wx:if="{{voiceState === 'recording'}}">
        <view class="wave-container">
          <view class="wave-bar wave-bar-1"></view>
          <view class="wave-bar wave-bar-2"></view>
          <view class="wave-bar wave-bar-3"></view>
          <view class="wave-bar wave-bar-4"></view>
          <view class="wave-bar wave-bar-5"></view>
        </view>
        <text class="voice-duration">{{recordingTime}}s / 15s</text>
        <view class="stop-btn" catchtap="onStopRecording">
          <view class="stop-btn-dot"></view>
          <text class="stop-btn-text">点我结束~</text>
        </view>
      </view>
      <view class="voice-recognizing" wx:if="{{voiceState === 'recognizing'}}">
        <view class="voice-spinner"></view>
        <text class="voice-hint">正在识别...</text>
      </view>
      <view class="voice-error" wx:if="{{voiceState === 'error'}}">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{voiceErrorMsg || '识别失败，请重试'}}</text>
        <view class="retry-btn" catchtap="onRetryVoice">
          <text class="retry-text">重试</text>
        </view>
        <view class="close-btn" catchtap="onCloseVoice">
          <text class="close-text">关闭</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabTap"
      data-value="{{item.value}}"
    >
      <text class="tab-text">{{item.label}}</text>
      <view class="tab-line" wx:if="{{currentTab === item.value}}"></view>
    </view>
  </view>

  <!-- Result List -->
  <view class="result-body">
    <!-- Loading -->
    <view class="loading-wrap" wx:if="{{loading && page === 1}}">
      <view class="spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- Result Items -->
    <view class="result-list" wx:if="{{!loading || page > 1}}">
      <view class="result-item" wx:for="{{results}}" wx:key="id" bindtap="onResultTap" data-item="{{item}}">
        <view class="result-info">
          <view class="result-type-tag">
            <text class="type-tag-text">{{item.type_label || item.type || '内容'}}</text>
          </view>
          <text class="result-title">{{item.title}}</text>
          <text class="result-desc" wx:if="{{item.summary || item.description}}">{{item.summary || item.description}}</text>
          <view class="result-meta">
            <text class="meta-text" wx:if="{{item.source}}">{{item.source}}</text>
            <text class="meta-text" wx:if="{{item.time}}">{{item.time}}</text>
          </view>
        </view>
        <image class="result-cover" src="{{item.cover_image || item.cover || item.image}}" mode="aspectFill" wx:if="{{item.cover_image || item.cover || item.image}}" />
      </view>
    </view>

    <!-- Load More -->
    <view class="load-more" wx:if="{{!loading && hasMore && results.length > 0}}">
      <text class="load-more-text" bindtap="loadMore">加载更多</text>
    </view>

    <view class="load-more" wx:if="{{loadingMore}}">
      <view class="spinner-sm"></view>
      <text class="load-more-text">加载中...</text>
    </view>

    <view class="load-more" wx:if="{{!hasMore && results.length > 0}}">
      <text class="no-more-text">没有更多了</text>
    </view>

    <!-- Empty State -->
    <view class="empty-state" wx:if="{{!loading && results.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-title">未找到相关结果</text>
      <text class="empty-desc">换个关键词试试吧</text>
    </view>
  </view>
</view>
