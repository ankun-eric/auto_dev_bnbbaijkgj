.result-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Header */
.result-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.search-box-icons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.mic-btn-inline {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mic-icon-inline {
  font-size: 32rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 24rpx;
  color: #999;
  background: #ddd;
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
}

.search-btn {
  margin-left: 16rpx;
  background: #52c41a;
  border-radius: 36rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn-text {
  color: #fff;
  font-size: 28rpx;
  white-space: nowrap;
}

/* Tabs */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 16rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #52c41a;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: #52c41a;
  border-radius: 3rpx;
}

/* Result Body */
.result-body {
  padding: 0 24rpx;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #f0f0f0;
  border-top: 6rpx solid #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.spinner-sm {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* Result List */
.result-list {
  padding-top: 16rpx;
}

.result-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-type-tag {
  display: inline-block;
  margin-bottom: 8rpx;
}

.type-tag-text {
  font-size: 22rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.result-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #bbb;
}

.result-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* Load More */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #1890ff;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* Voice Overlay */
.voice-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.voice-content {
  position: relative;
  z-index: 1;
  width: 560rpx;
  min-height: 400rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.voice-recording,
.voice-recognizing,
.voice-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.wave-bar {
  width: 10rpx;
  background: #52c41a;
  border-radius: 5rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-bar-1 { height: 40rpx; animation-delay: 0s; }
.wave-bar-2 { height: 70rpx; animation-delay: 0.15s; }
.wave-bar-3 { height: 100rpx; animation-delay: 0.3s; }
.wave-bar-4 { height: 70rpx; animation-delay: 0.45s; }
.wave-bar-5 { height: 40rpx; animation-delay: 0.6s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.4); }
  50% { transform: scaleY(1); }
}

.voice-duration {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.stop-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  border: 6rpx solid #52c41a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  animation: pulse-glow 1.5s ease-in-out infinite;
}

.stop-btn-dot {
  width: 20rpx;
  height: 20rpx;
  background: #52c41a;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.stop-btn-text {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 500;
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(82, 196, 26, 0.4);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 40rpx 20rpx rgba(82, 196, 26, 0.2);
    transform: scale(1.05);
  }
}

.voice-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top: 6rpx solid #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.voice-hint {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

.retry-btn {
  background: #52c41a;
  border-radius: 36rpx;
  padding: 16rpx 64rpx;
  margin-bottom: 16rpx;
}

.retry-text {
  color: #fff;
  font-size: 28rpx;
}

.close-btn {
  padding: 16rpx 64rpx;
}

.close-text {
  color: #999;
  font-size: 26rpx;
}
