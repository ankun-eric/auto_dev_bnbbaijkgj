.bindlist-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* Empty */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* List */
.list-header {
  padding: 16rpx 8rpx 24rpx;
}

.list-header-text {
  font-size: 24rpx;
  color: #999;
}

.bind-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bind-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.bind-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.bind-avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.bind-detail {
  flex: 1;
  min-width: 0;
}

.bind-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bind-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.bind-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.revoke-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 12rpx 24rpx;
  border: 2rpx solid #ffccc7;
  border-radius: 24rpx;
  background: #fff2f0;
}
