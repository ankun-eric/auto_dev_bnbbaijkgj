<view class="invite-page">
  <view class="invite-card" wx:if="{{!loading}}">
    <view class="invite-header">
      <text class="invite-title">邀请好友</text>
      <text class="invite-desc">分享链接或二维码，邀请好友加入宾尼小康</text>
    </view>

    <view class="qr-section" wx:if="{{shareLink}}">
      <qrcode text="{{shareLink}}" size="{{400}}" />
      <text class="qr-hint">扫描二维码加入</text>
    </view>

    <view class="user-no-section" wx:if="{{userNo}}">
      <text class="user-no-label">我的邀请码</text>
      <text class="user-no-value">{{userNo}}</text>
    </view>

    <view class="action-section">
      <button class="copy-btn" bindtap="copyShareLink">复制分享链接</button>
      <button class="share-btn" open-type="share">分享给微信好友</button>
    </view>
  </view>

  <!-- 我的邀请战绩 -->
  <view class="invite-stats-card" wx:if="{{!loading}}">
    <text class="invite-stats-title">我的邀请战绩</text>
    <view class="invite-stats-row">
      <view class="invite-stats-col">
        <text class="invite-stats-label">累计邀请</text>
        <text class="invite-stats-value invite-stats-value-green">{{totalInvited}}</text>
      </view>
      <view class="invite-stats-divider"></view>
      <view class="invite-stats-col">
        <text class="invite-stats-label">累计获得积分</text>
        <text class="invite-stats-value invite-stats-value-orange">{{totalPointsEarned}}</text>
      </view>
    </view>
    <view class="invite-list" wx:if="{{inviteList.length > 0}}">
      <view class="invite-list-item" wx:for="{{inviteList}}" wx:key="user_id">
        <view class="invite-list-info">
          <text class="invite-list-name">{{item.display_name}}</text>
          <text class="invite-list-time">{{item.registered_at}}</text>
        </view>
        <text class="invite-list-points">+{{item.points_awarded}}</text>
      </view>
    </view>
    <view class="invite-list-empty" wx:else>
      还没有邀请记录，快去分享吧
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
