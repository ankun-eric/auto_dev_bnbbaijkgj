.invite-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 24rpx;
}

.invite-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.invite-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.invite-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.invite-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.qr-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.user-no-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.user-no-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.user-no-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
  letter-spacing: 4rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.copy-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #52c41a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.copy-btn::after {
  border: none;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #52c41a;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #52c41a;
}

.share-btn::after {
  border: none;
}

.invite-stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.invite-stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.invite-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.invite-stats-divider {
  width: 1rpx;
  height: 64rpx;
  background: #f0f0f0;
}

.invite-stats-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-stats-label { font-size: 24rpx; color: #999; }
.invite-stats-value { font-size: 40rpx; font-weight: bold; margin-top: 8rpx; }
.invite-stats-value-green { color: #52c41a; }
.invite-stats-value-orange { color: #fa8c16; }

.invite-list { margin-top: 16rpx; }

.invite-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.invite-list-info { flex: 1; }
.invite-list-name { font-size: 26rpx; color: #333; display: block; }
.invite-list-time { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.invite-list-points { font-size: 28rpx; color: #52c41a; font-weight: 600; }

.invite-list-empty {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 32rpx 0;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
