.invite-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 24rpx;
}

.invite-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.invite-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.invite-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.invite-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.qr-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.user-no-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.user-no-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.user-no-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
  letter-spacing: 4rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.copy-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #52c41a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.copy-btn::after {
  border: none;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #52c41a;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #52c41a;
}

.share-btn::after {
  border: none;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
