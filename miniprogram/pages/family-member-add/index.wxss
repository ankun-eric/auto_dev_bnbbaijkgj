/* [PRD-FAMILY-MEMBER-V2 2026-05-18] 添加家庭成员样式 */
page { background: #F0F9FF; }
.page { padding: 24rpx 24rpx 120rpx; }

.invite-banner {
  background: linear-gradient(135deg, #38BDF8, #0284C7);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(2,132,199,0.18);
  margin-bottom: 24rpx;
}
.banner-left { display: flex; align-items: center; gap: 16rpx; }
.banner-icon { font-size: 40rpx; }
.banner-title { color: #fff; font-size: 28rpx; font-weight: 700; }
.banner-sub { color: rgba(255,255,255,0.85); font-size: 22rpx; margin-top: 4rpx; }
.banner-btn { background: #fff; color: #0284C7; font-size: 24rpx; font-weight: 600; padding: 12rpx 24rpx; border-radius: 28rpx; }

.error-banner { background: #FEF2F2; border: 1rpx solid #FECACA; color: #DC2626; font-size: 24rpx; padding: 16rpx 24rpx; border-radius: 16rpx; margin-bottom: 24rpx; }

.card { background: #fff; border-radius: 28rpx; padding: 28rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(15,23,42,0.05); }
.card-title { font-size: 28rpx; color: #334155; font-weight: 600; margin-bottom: 20rpx; }
.required { color: #DC2626; margin-right: 6rpx; }

.grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.pill { flex: 0 0 calc((100% - 48rpx) / 4); height: 72rpx; line-height: 72rpx; text-align: center; border-radius: 20rpx; background: #F0F9FF; color: #0F172A; font-size: 26rpx; box-sizing: border-box; border: 2rpx solid transparent; }
.pill-active { background: #E0F2FE; color: #0284C7; border-color: #0EA5E9; font-weight: 600; }
.pill-disabled { background: #F1F5F9; color: #94A3B8; }
.pill-error { background: #FEE2E2; color: #DC2626; border-color: #EF4444; }

.field-row { padding: 20rpx 0; border-top: 1rpx solid #E2E8F0; }
.field-row:first-of-type { border-top: none; }
.field-label { font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 12rpx; }
.field-input { width: 100%; box-sizing: border-box; padding: 18rpx 20rpx; border-radius: 18rpx; border: 1rpx solid #E2E8F0; font-size: 28rpx; background: #fff; color: #0F172A; }
.field-input-err { border-color: #EF4444; color: #DC2626; }
.field-input-pick { display: flex; justify-content: space-between; align-items: center; }
.field-locked { padding: 18rpx 20rpx; border-radius: 18rpx; background: #F8FAFC; color: #94A3B8; border: 1rpx solid #E2E8F0; font-size: 28rpx; }
.arrow { color: #94A3B8; }
.arrow-open { transform: rotate(90deg); display: inline-block; }

.gender-group { display: flex; gap: 16rpx; }
.gender-btn { flex: 1; padding: 18rpx 0; text-align: center; border-radius: 16rpx; background: #F0F9FF; color: #0F172A; font-size: 28rpx; font-weight: 600; border: 2rpx solid transparent; }
.gender-btn-active { background: #E0F2FE; color: #0284C7; border-color: #0EA5E9; }

.more-toggle { display: flex; justify-content: space-between; align-items: center; font-size: 28rpx; color: #334155; font-weight: 600; padding: 8rpx 0; }
.more-body { padding-top: 16rpx; }
.two-col { display: flex; gap: 16rpx; }
.col { flex: 1; }
.sub-label { font-size: 24rpx; color: #64748B; margin-bottom: 8rpx; font-weight: 600; }
.sub-block { margin-top: 20rpx; }
.chip-group { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip { padding: 8rpx 20rpx; border-radius: 28rpx; background: #F0F9FF; color: #0F172A; font-size: 24rpx; border: 1rpx solid transparent; }
.chip-active { background: #E0F2FE; color: #0284C7; border-color: #0EA5E9; font-weight: 600; }
.mb6 { margin-bottom: 12rpx; }

.bottom-tip { text-align: center; color: #94A3B8; font-size: 22rpx; margin: 24rpx 0 16rpx; }
.submit-btn { width: 100%; height: 92rpx; line-height: 92rpx; border-radius: 46rpx; background: linear-gradient(135deg, #38BDF8, #0284C7); color: #fff; font-size: 30rpx; font-weight: 700; box-shadow: 0 10rpx 30rpx rgba(2,132,199,0.25); border: none; }
.submit-btn-disabled { background: #CBD5E1; color: #fff; box-shadow: none; }

.blocker-mask { position: fixed; inset: 0; background: rgba(15,23,42,0.55); display: flex; align-items: center; justify-content: center; z-index: 999; }
.blocker-card { width: 78%; max-width: 600rpx; background: #fff; border-radius: 32rpx; padding: 48rpx 36rpx 36rpx; text-align: center; box-shadow: 0 24rpx 80rpx rgba(2,132,199,0.25); }
.blocker-icon { display: inline-flex; width: 84rpx; height: 84rpx; border-radius: 50%; background: #F0F9FF; color: #0EA5E9; font-size: 48rpx; font-weight: 700; align-items: center; justify-content: center; margin-bottom: 24rpx; }
.blocker-title { font-size: 32rpx; font-weight: 700; color: #0F172A; margin-bottom: 32rpx; }
.blocker-btns { display: flex; gap: 20rpx; }
.blocker-btn { flex: 1; height: 72rpx; line-height: 72rpx; border-radius: 36rpx; font-size: 28rpx; font-weight: 600; border: none; }
.blocker-btn-ghost { background: #F1F5F9; color: #0F172A; }
.blocker-btn-primary { background: linear-gradient(135deg, #38BDF8, #0284C7); color: #fff; }

/* [PRD-FAMILY-MEMBER-OPTIM-FINAL 2026-05-31] 成员已添加成功🎉 弹框 */
.added-mask { position: fixed; inset: 0; background: rgba(15,23,42,0.55); display: flex; align-items: center; justify-content: center; z-index: 999; }
.added-card { width: 80%; max-width: 620rpx; background: #fff; border-radius: 32rpx; padding: 40rpx 36rpx 36rpx; box-shadow: 0 24rpx 80rpx rgba(2,132,199,0.25); }
.added-title { font-size: 34rpx; font-weight: 700; color: #0F172A; text-align: center; margin-bottom: 24rpx; }
.added-body { padding: 24rpx 20rpx; background: #F0F9FF; border-radius: 20rpx; font-size: 26rpx; color: #0F172A; line-height: 1.6; margin-bottom: 32rpx; }
.added-body-warn { background: #FFF7ED; }
.added-num { color: #EA580C; font-weight: 700; }
.added-btns { display: flex; gap: 20rpx; }
.added-btn { flex: 1; height: 84rpx; line-height: 84rpx; border-radius: 42rpx; font-size: 28rpx; font-weight: 600; border: none; padding: 0; }
.added-btn-ghost { background: #fff; color: #0EA5E9; border: 1rpx solid #0EA5E9; }
.added-btn-primary { background: linear-gradient(135deg, #38BDF8, #0284C7); color: #fff; box-shadow: 0 8rpx 20rpx rgba(2,132,199,0.25); }
