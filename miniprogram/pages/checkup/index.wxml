<wxs module="utils">
module.exports.isSelected = function(selectedIds, id) {
  if (!selectedIds || !selectedIds.length) return false;
  var sid = '' + id;
  for (var i = 0; i < selectedIds.length; i++) {
    if (selectedIds[i] === sid) return true;
  }
  return false;
}

module.exports.getMemberTagColor = function(member) {
  if (!member) return '#1677ff';
  var rt = member.relationship_type || '';
  if (rt === '本人') return '#1677ff';
  if (rt === '爸爸' || rt === '父亲') return '#fa8c16';
  if (rt === '妈妈' || rt === '母亲') return '#eb2f96';
  if (rt === '配偶' || rt === '老公' || rt === '老婆') return '#722ed1';
  if (rt === '儿子' || rt === '女儿' || rt === '子女') return '#13c2c2';
  return '#8c8c8c';
}

module.exports.getMemberTagName = function(member) {
  if (!member) return '本人';
  if (member.nickname) return member.nickname;
  if (member.relationship_type) return member.relationship_type;
  return '本人';
}
</wxs>
<view class="checkup-page">
  <!-- 预警横幅 -->
  <view class="alert-banner" wx:if="{{hasUnreadAlerts}}" bindtap="dismissAlert">
    <view class="alert-banner-inner">
      <text class="alert-icon">⚠️</text>
      <text class="alert-text">您有未读的健康预警，请及时查看</text>
      <text class="alert-close">✕</text>
    </view>
  </view>

  <!-- 步骤条 -->
  <view class="ck-steps-bar" wx:if="{{selectedImages.length > 0}}">
    <view class="ck-step {{uploadStep >= 1 ? 'ck-step-active' : ''}}" bindtap="onStepTap" data-step="1">
      <view class="ck-step-dot">1</view>
      <text class="ck-step-label">上传报告</text>
    </view>
    <view class="ck-step-line {{uploadStep >= 2 ? 'ck-line-active' : ''}}"></view>
    <view class="ck-step {{uploadStep >= 2 ? 'ck-step-active' : ''}}" bindtap="onStepTap" data-step="2">
      <view class="ck-step-dot">2</view>
      <text class="ck-step-label">选择对象</text>
    </view>
    <view class="ck-step-line {{uploadStep >= 3 ? 'ck-line-active' : ''}}"></view>
    <view class="ck-step {{uploadStep >= 3 ? 'ck-step-active' : ''}}">
      <view class="ck-step-dot">3</view>
      <text class="ck-step-label">AI 解读</text>
    </view>
  </view>

  <!-- 上传区域 (步骤1) -->
  <view class="upload-section card" wx:if="{{uploadStep === 1}}">
    <text class="section-title">上传体检报告</text>
    <text class="upload-tip">选择上传方式，AI为您智能解读体检报告</text>
    <view class="upload-buttons">
      <view class="upload-btn" bindtap="chooseFromAlbum">
        <view class="upload-btn-icon-wrap album">
          <text class="upload-btn-icon">🖼️</text>
        </view>
        <text class="upload-btn-label">相册选图</text>
        <text class="upload-btn-hint">选择已有图片</text>
      </view>
      <view class="upload-btn" bindtap="takePhoto">
        <view class="upload-btn-icon-wrap camera">
          <text class="upload-btn-icon">📷</text>
        </view>
        <text class="upload-btn-label">拍照上传</text>
        <text class="upload-btn-hint">直接拍摄报告</text>
      </view>
      <view class="upload-btn" bindtap="choosePDF">
        <view class="upload-btn-icon-wrap pdf">
          <text class="upload-btn-icon">📄</text>
        </view>
        <text class="upload-btn-label">PDF上传</text>
        <text class="upload-btn-hint">导入PDF文件</text>
      </view>
    </view>

    <!-- 已选图片预览 -->
    <view wx:if="{{selectedImages.length > 0}}" class="selected-images">
      <view class="selected-count">已选 {{selectedImages.length}}/{{maxImages}} 张</view>
      <view class="image-grid">
        <view wx:for="{{selectedImages}}" wx:key="index" class="image-item">
          <image src="{{item.path}}" mode="aspectFill" class="thumb" />
          <view class="delete-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
      </view>
      <button class="start-btn" bindtap="startRecognize" disabled="{{uploading}}">
        开始识别
      </button>
    </view>
  </view>

  <!-- 选择咨询对象 (步骤2) -->
  <view class="family-select-section card" wx:if="{{uploadStep === 2}}">
    <text class="section-title">选择咨询对象</text>
    <text class="upload-tip">请选择这份体检报告属于谁</text>

    <scroll-view class="ck-member-scroll" scroll-x>
      <view class="ck-member-list">
        <view class="ck-member-item {{selectedFamilyMemberId === item.id ? 'ck-member-selected' : ''}}"
              wx:for="{{familyMembers}}" wx:key="id"
              bindtap="selectFamilyMember" data-member="{{item}}">
          <text class="ck-member-emoji">{{item.emoji}}</text>
          <text class="ck-member-relation">{{item.relationship_type}}</text>
          <text class="ck-member-name">{{item.nickname}}</text>
        </view>
        <view class="ck-member-item ck-member-add" bindtap="goAddFamilyMember">
          <text class="ck-member-emoji">➕</text>
          <text class="ck-member-relation">添加</text>
          <text class="ck-member-name">家庭成员</text>
        </view>
      </view>
    </scroll-view>

    <view class="family-select-actions">
      <button class="btn-outline family-action-btn" bindtap="onStepTap" data-step="1">上一步</button>
      <button class="btn-primary family-action-btn" bindtap="confirmFamilyMember">确认并上传</button>
    </view>
  </view>

  <!-- 上传中 (步骤3) -->
  <view class="upload-progress-section card" wx:if="{{uploadStep === 3 && uploading}}">
    <text class="section-title">AI 解读中</text>
    <view wx:if="{{uploadProgressText}}" class="progress-text">{{uploadProgressText}}</view>
    <view wx:if="{{uploadPercent >= 0}}" class="upload-progress-wrap">
      <view class="upload-progress-track">
        <view class="upload-progress-fill" style="width: {{uploadPercent}}%;"></view>
      </view>
      <text class="upload-progress-pct">{{uploadPercent}}%</text>
    </view>
  </view>

  <!-- 历史报告 -->
  <view class="history-section">
    <view class="history-section-header">
      <text class="section-title" style="margin-bottom: 0;">历史报告</text>
      <view class="compare-toggle" wx:if="{{historyReports.length >= 2}}" bindtap="toggleCompareMode">
        <text class="compare-toggle-text">{{compareMode ? '取消对比' : '📊 对比分析'}}</text>
      </view>
    </view>

    <!-- 对比操作栏 -->
    <view class="compare-bar" wx:if="{{compareMode}}">
      <text class="compare-bar-hint">请勾选2份报告进行对比（已选 {{selectedIds.length}}/2）</text>
      <view class="compare-bar-btn {{selectedIds.length === 2 ? '' : 'disabled'}}" bindtap="goCompare">
        <text class="compare-bar-btn-text">开始对比</text>
      </view>
    </view>

    <view class="history-list" wx:if="{{historyReports.length > 0}}">
      <view
        class="history-item card {{compareMode && utils.isSelected(selectedIds, item.id) ? 'history-item-selected' : ''}}"
        wx:for="{{historyReports}}"
        wx:key="id"
        bindtap="onItemTap"
        data-id="{{item.id}}"
      >
        <view class="history-item-content">
          <!-- 对比模式勾选框 -->
          <view class="check-box" wx:if="{{compareMode}}">
            <view class="check-inner {{utils.isSelected(selectedIds, item.id) ? 'checked' : ''}}">
              <text wx:if="{{utils.isSelected(selectedIds, item.id)}}">✓</text>
            </view>
          </view>

          <image class="history-thumb" wx:if="{{item.thumbnail}}" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="history-thumb-placeholder" wx:else>
            <text class="placeholder-icon">📋</text>
          </view>
          <view class="history-info">
            <view class="history-header">
              <text class="history-date">{{item.dateFormatted || item.date}}</text>
              <view class="tag tag-green" wx:if="{{item.status === 'analyzed' || item.status === '已分析'}}">已分析</view>
              <view class="tag tag-blue" wx:elif="{{item.status === 'pending' || item.status === '待分析'}}">待分析</view>
              <view class="tag tag-green" wx:else>{{item.status || '已上传'}}</view>
              <view class="member-tag" style="background: {{utils.getMemberTagColor(item.family_member)}}15; color: {{utils.getMemberTagColor(item.family_member)}}; border: 1rpx solid {{utils.getMemberTagColor(item.family_member)}}30;">
                {{utils.getMemberTagName(item.family_member)}}
              </view>
            </view>
            <text class="history-name ellipsis">{{item.name || item.title || '体检报告'}}</text>
            <view class="history-meta">
              <text class="abnormal-badge" wx:if="{{item.abnormalCount > 0}}">{{item.abnormalCount}}项异常</text>
            </view>
          </view>

          <!-- 健康评分徽章 -->
          <view class="score-badge" wx:if="{{item.healthScore > 0}}" style="border-color: {{item.scoreColor}};">
            <text class="score-badge-num" style="color: {{item.scoreColor}};">{{item.healthScore}}</text>
            <text class="score-badge-label">分</text>
          </view>

          <view class="history-arrow" wx:if="{{!compareMode}}">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <text class="text-hint">加载中...</text>
    </view>

    <view class="empty-state" wx:if="{{historyReports.length === 0 && !loading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无体检报告</text>
      <text class="empty-text">上传报告获取AI智能解读</text>
    </view>
  </view>
</view>
