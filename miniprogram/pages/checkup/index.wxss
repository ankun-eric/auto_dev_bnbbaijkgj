.checkup-page {
  padding: 24rpx;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 预警横幅 */
.alert-banner {
  margin: -24rpx -24rpx 24rpx -24rpx;
  padding: 0 24rpx;
}

.alert-banner-inner {
  background: linear-gradient(135deg, #fff7e6, #ffe7ba);
  border-radius: 0 0 16rpx 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.alert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.alert-text {
  flex: 1;
  font-size: 26rpx;
  color: #d46b08;
  font-weight: 500;
}

.alert-close {
  font-size: 28rpx;
  color: #d46b08;
  padding: 0 8rpx;
}

/* 上传区域 */
.upload-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 28rpx;
}

.upload-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.upload-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  border-radius: 16rpx;
  background: #fafafa;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s;
}

.upload-btn:active {
  transform: scale(0.96);
  background: #f0f0f0;
}

.upload-btn-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.upload-btn-icon-wrap.album {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
}

.upload-btn-icon-wrap.camera {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
}

.upload-btn-icon-wrap.pdf {
  background: linear-gradient(135deg, #fff2e8, #ffd8bf);
}

.upload-btn-icon {
  font-size: 40rpx;
}

.upload-btn-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.upload-btn-hint {
  font-size: 20rpx;
  color: #bbb;
}

/* 历史报告 */
.history-section {
  margin-top: 12rpx;
}

.history-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.compare-toggle {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #e8f5e9, #e0f7fa);
  border-radius: 24rpx;
}

.compare-toggle:active {
  opacity: 0.8;
}

.compare-toggle-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 对比操作栏 */
.compare-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.compare-bar-hint {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.compare-bar-btn {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 12rpx 32rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.compare-bar-btn:active {
  opacity: 0.85;
}

.compare-bar-btn.disabled {
  opacity: 0.4;
}

.compare-bar-btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.history-list {
  margin-top: 0;
}

.history-item {
  padding: 20rpx 24rpx;
  transition: border 0.2s;
  border: 2rpx solid transparent;
}

.history-item-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.history-item-content {
  display: flex;
  align-items: center;
}

/* 勾选框 */
.check-box {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.check-inner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  transition: all 0.2s;
}

.check-inner.checked {
  background: #52c41a;
  border-color: #52c41a;
}

.history-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: nowrap;
}

.history-date {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.history-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.history-meta {
  display: flex;
  align-items: center;
}

.abnormal-badge {
  font-size: 22rpx;
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

/* 健康评分徽章 */
.score-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
  background: #fff;
}

.score-badge-num {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.score-badge-label {
  font-size: 18rpx;
  color: #999;
  line-height: 1;
  margin-top: 2rpx;
}

.history-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
}

.loading-more {
  text-align: center;
  padding: 30rpx;
}

/* 已选图片预览区域 */
.selected-images {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.selected-count {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: visible;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  display: block;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: center;
  z-index: 10;
}

.progress-text {
  font-size: 24rpx;
  color: #52c41a;
  text-align: center;
  margin-bottom: 12rpx;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  text-align: center;
  margin-top: 8rpx;
}

.start-btn::after {
  border: none;
}

.start-btn[disabled] {
  opacity: 0.7;
}

.upload-progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 0;
}

.upload-progress-track {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.upload-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  transition: width 0.3s ease;
}

.upload-progress-pct {
  font-size: 22rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

/* ========== 步骤条 ========== */
.ck-steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 48rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.ck-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ck-step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.ck-step-active .ck-step-dot {
  background: #52c41a;
  color: #fff;
}

.ck-step-label {
  font-size: 22rpx;
  color: #999;
}

.ck-step-active .ck-step-label {
  color: #52c41a;
}

.ck-step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
}

.ck-line-active {
  background: #52c41a;
}

/* ========== 家庭成员选择 ========== */
.family-select-section {
  padding-bottom: 32rpx;
}

.ck-member-scroll {
  white-space: nowrap;
  margin: 24rpx 0;
}

.ck-member-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.ck-member-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  min-width: 120rpx;
  transition: all 0.2s;
}

.ck-member-item:active {
  transform: scale(0.96);
}

.ck-member-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.ck-member-add {
  border-style: dashed;
  border-color: #d9d9d9;
  background: #fafafa;
}

.ck-member-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.ck-member-relation {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 2rpx;
}

.ck-member-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ck-member-selected .ck-member-relation,
.ck-member-selected .ck-member-name {
  color: #52c41a;
}

.family-select-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.family-action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
}

.family-action-btn::after {
  border: none;
}

/* ========== 上传进度区域 ========== */
.upload-progress-section {
  text-align: center;
  padding: 40rpx 24rpx;
}

/* ========== 咨询对象标签 ========== */
.member-tag {
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  margin-left: auto;
  flex-shrink: 0;
  line-height: 1.6;
}
