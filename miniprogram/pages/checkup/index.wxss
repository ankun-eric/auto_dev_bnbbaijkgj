.checkup-page {
  padding: 24rpx;
  min-height: 100vh;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.upload-area {
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #ccc;
}

/* 分析结果 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.result-name {
  font-size: 28rpx;
  color: #333;
}

.result-value {
  font-size: 28rpx;
  font-weight: bold;
}

.text-danger {
  color: #ff4d4f;
}

.text-normal {
  color: #52c41a;
}

.result-ref {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.result-advice {
  font-size: 24rpx;
  color: #faad14;
  margin-top: 8rpx;
  display: block;
}

.result-summary {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin-bottom: 8rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* 历史 */
.history-list {
  margin-top: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

.history-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.history-summary {
  font-size: 24rpx;
  color: #666;
}
