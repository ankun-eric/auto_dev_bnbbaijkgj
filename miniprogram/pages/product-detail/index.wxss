.detail-page {
  padding-bottom: 120rpx;
}

.media-swiper {
  width: 100%;
  height: 600rpx;
}

.media-img,
.media-video {
  width: 100%;
  height: 100%;
}

.price-section {
  margin: 24rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-sym {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.price-val {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price-orig {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.sales-text {
  font-size: 24rpx;
  color: #999;
}

.points-row {
  margin-top: 8rpx;
}

.points-text {
  font-size: 24rpx;
  color: #faad14;
  background: rgba(250, 173, 20, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.product-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-top: 16rpx;
  line-height: 1.5;
  display: block;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.detail-tag {
  font-size: 22rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.desc-section,
.faq-section,
.stores-section,
.reviews-section {
  margin: 0 24rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.faq-item {
  border-bottom: 1rpx solid #f5f5f5;
  padding: 20rpx 0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-q-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.faq-arrow {
  font-size: 18rpx;
  color: #ccc;
  transition: transform 0.2s;
  margin-left: 16rpx;
}

.faq-arrow.up {
  transform: rotate(180deg);
}

.faq-a {
  margin-top: 12rpx;
  padding-left: 24rpx;
}

.faq-a-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.store-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.store-item:last-child {
  border-bottom: none;
}

.store-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.store-addr {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.store-distance {
  font-size: 24rpx;
  color: #52c41a;
  flex-shrink: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-count {
  font-size: 24rpx;
  color: #999;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-user {
  display: flex;
  align-items: center;
}

.review-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 22rpx;
  color: #fff;
}

.review-name {
  font-size: 26rpx;
  color: #333;
}

.review-stars {
  display: flex;
}

.star {
  font-size: 24rpx;
  color: #d9d9d9;
}

.star.filled {
  color: #faad14;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

.review-images {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.review-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.review-time {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
  display: block;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bar-fav {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.fav-icon {
  font-size: 36rpx;
}

.fav-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 2rpx;
}

.bar-buy {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  margin-right: 24rpx;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.time-slots-section { margin: 20rpx; }
.time-slots-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.time-slot-btn {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid #e5e5e5;
  font-size: 24rpx;
  color: #333;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.time-slot-btn.disabled {
  background: #f5f5f5;
  color: #999;
  border-color: #e5e5e5;
}
.slot-full-tag { font-size: 20rpx; color: #ff4d4f; }

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-subtle { font-size: 22rpx; color: #bbb; }

.store-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  margin-top: 16rpx;
}
.store-main .store-info { flex: 1; min-width: 0; }
.store-switch { font-size: 24rpx; color: #1677ff; flex-shrink: 0; padding: 0 12rpx; }
/* [2026-05-01 门店地图能力 PRD v1.0] */
.store-map-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  border: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  margin: 0 16rpx;
  position: relative;
}
.store-map-img {
  width: 100%;
  height: 100%;
  display: block;
}
.store-map-pin {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
}
.store-nearest-tag {
  background: #52c41a;
  color: #fff;
  font-size: 20rpx;
  padding: 0 8rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
  line-height: 1.6;
}

.drawer-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 999;
}
.store-drawer {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  z-index: 1000;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}
.store-drawer.show { transform: translateY(0); }
.drawer-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.drawer-list { max-height: calc(70vh - 100rpx); }
.drawer-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.drawer-item-info { flex: 1; min-width: 0; }
.check-mark { color: #52c41a; font-size: 32rpx; flex-shrink: 0; }
