.articles-page {
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 14rpx 24rpx;
}

.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }

.tab-scroll {
  background: #fff;
  white-space: nowrap;
}

.tab-list { display: flex; padding: 0 12rpx; }

.tab-item {
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
}

.tab-active {
  color: #52c41a;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background: #52c41a;
  border-radius: 2rpx;
}

.article-list { padding: 24rpx; }

.article-card { margin-bottom: 16rpx; }

.article-body {
  display: flex;
  align-items: flex-start;
}

.article-info { flex: 1; }
.article-title { font-size: 28rpx; font-weight: 500; color: #333; line-height: 1.5; }

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.article-author { font-size: 22rpx; color: #999; }
.article-time { font-size: 22rpx; color: #ccc; }

.article-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.article-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.stat-item { font-size: 22rpx; color: #999; }
