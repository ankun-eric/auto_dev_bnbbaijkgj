<view class="chat-page">
  <!-- [PRD-425] 顶部操作栏：☰ + 标题(小康) + 未读徽标 + Aa（更多入口） -->
  <view class="chat-top-bar">
    <view class="drawer-toggle" bindtap="openDrawer">
      <text class="toggle-icon">☰</text>
    </view>
    <view class="top-bar-title-wrap">
      <text class="top-bar-title">{{aiSignatureDisplay}}</text>
      <!-- [PRD-425] 未读徽标：unreadCount<0 不显示；=0 小红点；>=1 数字 -->
      <view
        wx:if="{{unreadCount === 0}}"
        class="top-bar-badge top-bar-badge-dot"
        catchtap="onTopBarBadgeTap"
      ></view>
      <view
        wx:elif="{{unreadCount > 0}}"
        class="top-bar-badge top-bar-badge-num"
        catchtap="onTopBarBadgeTap"
      >{{unreadDisplay}}</view>
    </view>
    <view class="font-size-trigger" catchtap="toggleFontPopover">
      <text class="font-trigger-text">Aa</text>
    </view>
  </view>

  <!-- 字体大小选择浮层 -->
  <view class="font-popover-mask" wx:if="{{showFontPopover}}" catchtap="closeFontPopover"></view>
  <view class="font-popover" wx:if="{{showFontPopover}}">
    <view class="font-popover-arrow"></view>
    <view
      class="font-option {{fontSizeLevel === item.level ? 'font-option-active' : ''}}"
      wx:for="{{fontSizeOptions}}"
      wx:key="level"
      catchtap="onFontOptionTap"
      data-level="{{item.level}}"
    >
      <text class="font-option-label">{{item.label}}（{{item.size}}）</text>
      <text class="font-option-check" wx:if="{{fontSizeLevel === item.level}}">✓</text>
    </view>
  </view>

  <!-- 顶部摘要条 -->
  <view class="summary-bar" wx:if="{{summaryBarText}}">
    <text class="summary-bar-text">{{summaryBarText}}</text>
  </view>

  <!-- 用药识别卡片（与 H5/Flutter 对齐） -->
  <view wx:if="{{chatType === 'drug_identify'}}" class="drug-banner">
    <view class="drug-banner__head">
      <text class="drug-banner__icon">💊</text>
      <text class="drug-banner__title">用药识别</text>
      <text wx:if="{{drugIdentifyMember}}" class="drug-banner__member">咨询对象：{{drugIdentifyMember}}</text>
    </view>
    <view wx:if="{{drugIdentifyDrugNames}}" class="drug-banner__drugs">{{drugIdentifyDrugNames}}</view>
  </view>

  <!-- [2026-04-23 报告分支] 报告解读卡片（单/多报告） -->
  <block wx:if="{{chatType === 'report_interpret' && reportList && reportList.length > 0}}">
    <view class="report-card interpret" wx:for="{{reportList}}" wx:key="id">
      <view class="report-card-title">🩺 {{item.title}}</view>
      <view class="report-card-count" wx:if="{{item.total > 1}}">共 {{item.total}} 张</view>
      <view class="report-thumbs" wx:if="{{item.display_thumbs && item.display_thumbs.length > 0}}">
        <view
          class="report-thumb"
          wx:for="{{item.display_thumbs}}"
          wx:for-item="thumb"
          wx:for-index="tidx"
          wx:key="tidx"
          bindtap="onReportImageTap"
          data-urls="{{item.file_urls}}"
          data-current="{{item.file_urls[tidx]}}"
        >
          <image src="{{thumb}}" mode="aspectFill" class="report-thumb-img" />
        </view>
      </view>
    </view>
  </block>

  <!-- [2026-04-23 报告分支] 报告对比卡片（双报告） -->
  <block wx:if="{{chatType === 'report_compare' && reportList && reportList.length >= 2}}">
    <view class="report-card compare">
      <view class="report-card-title">🔄 报告对比</view>
      <view class="report-compare-item" wx:for="{{reportList}}" wx:key="id" wx:for-item="r">
        <text class="report-compare-label">{{index === 0 ? '报告 A' : '报告 B'}}：</text>
        <text class="report-compare-title">{{r.title}}</text>
      </view>
    </view>
  </block>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
    <!-- 提示信息 -->
    <view class="chat-notice">
      <text class="notice-text">AI健康咨询仅供参考，不能替代专业医疗诊断。如有紧急情况请立即就医。</text>
    </view>

    <view class="msg-item" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- [PRD-433] 时间分隔条：仅当 showTimeDivider 为 true 时渲染 -->
      <view wx:if="{{item.showTimeDivider}}" class="time-divider">
        <text class="time-divider-text">{{item.timeDividerText || item.time}}</text>
      </view>

      <!-- [PRD-432] AI 回答顶部「咨询对象档案」折叠卡片（保留在 AI 卡片外部上方） -->
      <profile-card
        wx:if="{{item.role === 'assistant'}}"
        consultant-id="{{currentConsultantId || 0}}"
      />

      <!-- [PRD-433] AI 消息：白色卡片 + 卡片外部上方头像名称行 -->
      <view class="ai-msg-wrap" wx:if="{{item.role === 'assistant'}}">
        <view class="ai-card-header">
          <view class="ai-header-avatar">
            <text class="ai-header-avatar-emoji">🤖</text>
          </view>
          <text class="ai-header-name">小康</text>
        </view>
        <view class="ai-card">
          <view class="ai-card-body">
            <text class="ai-card-text" style="font-size:{{msgFontSize}};">{{item.mainContent || item.content}}</text>
            <!-- [PRD-433 F-10] 流式输出去光标：保留打字机文本，去掉光标渲染 -->
          </view>

          <!-- [PRD-433 F-14] 参考资料容错渲染 -->
          <view wx:if="{{item.references && item.references.length > 0}}" class="ai-card-references">
            <text class="ai-card-references-title">参考资料</text>
            <view
              class="ai-card-reference-item"
              wx:for="{{item.references}}"
              wx:for-item="ref"
              wx:key="index"
            >
              <text class="ai-card-reference-text">· {{ref.title || ref.name || ref.text || ref}}</text>
            </view>
          </view>

          <block wx:if="{{item.knowledgeHits && item.knowledgeHits.length}}">
            <knowledge-card
              wx:for="{{item.knowledgeHits}}"
              wx:for-item="kh"
              wx:key="entry_id"
              hit="{{kh}}"
              hit-log-id="{{kh.hit_log_id}}"
              bind:submitted="onKnowledgeFeedback"
            />
          </block>

          <!-- [2026-04-25 PRD F5] 报告解读 OCR 详情兜底入口（卡片内） -->
          <view
            wx:if="{{(chatType === 'report_interpret' || chatType === 'report_compare') && item.id === firstAiMsgId && !item.isStreaming && !interpretFailed}}"
            class="ocr-detail-row"
          >
            <text class="ocr-detail-link" catchtap="onToggleOcrDetail">
              {{ocrDetailLoading ? '加载中…' : (ocrDetailExpanded ? '收起 OCR 识别详情 ▴' : '查看 OCR 识别详情 ▾')}}
            </text>
            <view wx:if="{{ocrDetailExpanded}}" class="ocr-detail-box">
              <text class="ocr-detail-text">{{ocrDetailText || (ocrDetailLoaded ? '（暂无 OCR 文本）' : '加载中…')}}</text>
            </view>
          </view>

          <!-- [PRD-440] AI 回答操作栏：提示文字（靠右） + 全宽虚线 + 渐变三图标（左下一排：复制 / 转发 / 语音播报） -->
          <view class="ai-action-bar-440" wx:if="{{!item.isStreaming && (item.mainContent || item.content)}}">
            <view class="ai-action-bar-440-disclaimer">
              <text class="ai-action-bar-440-disclaimer-text">AI 生成仅供参考</text>
            </view>
            <view class="ai-action-bar-440-divider"></view>
            <view class="ai-action-bar-440-icons">
              <!-- 复制：渐变描边 SVG -->
              <view class="ai-action-bar-440-btn" catchtap="copyMessage" data-msgid="{{item.id}}">
                <view class="ai-action-bar-440-icon-copy"></view>
              </view>
              <!-- 转发：三点连线分享图（渐变描边） -->
              <view class="ai-action-bar-440-btn" catchtap="shareToFriend" data-msgid="{{item.id}}">
                <view class="ai-action-bar-440-icon-share"></view>
              </view>
              <!-- 语音播报：喇叭，播报中叠加 Wi-Fi 弧线扩散动效 -->
              <view class="ai-action-bar-440-btn" catchtap="toggleTts" data-msgid="{{item.id}}">
                <view class="ai-action-bar-440-icon-speaker {{isTtsPlaying && ttsMsgId === item.id ? 'is-playing' : ''}}">
                  <block wx:if="{{isTtsPlaying && ttsMsgId === item.id}}">
                    <view class="ai-action-bar-440-wifi-ring ring1"></view>
                    <view class="ai-action-bar-440-wifi-ring ring2"></view>
                    <view class="ai-action-bar-440-wifi-ring ring3"></view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- [PRD-433 F-01] 用户消息：右侧浅蓝气泡，无头像 -->
      <view class="user-msg-wrap" wx:elif="{{item.role === 'user'}}">
        <view class="user-bubble">
          <image class="msg-image" src="{{item.image}}" mode="widthFix" wx:if="{{item.image}}" bindtap="previewImage" data-url="{{item.image}}" />
          <text class="user-bubble-text" wx:else style="font-size:{{msgFontSize}};">{{item.content}}</text>
        </view>
      </view>

      <!-- [PRD-433 F-11] Loading 卡片：白色卡片样式 + 「小康正在思考中…」+ 三点跳动 -->
      <view class="ai-msg-wrap" wx:elif="{{item.role === 'loading'}}">
        <view class="ai-card-header">
          <view class="ai-header-avatar">
            <text class="ai-header-avatar-emoji">🤖</text>
          </view>
          <text class="ai-header-name">小康</text>
        </view>
        <view class="ai-card ai-card-loading">
          <view class="ai-loading-row">
            <text class="ai-loading-text">小康正在思考中…</text>
            <view class="typing-dots">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 药品识别卡片 (Module 5) -->
    <view class="drug-card-inline" wx:if="{{showDrugCard && drugCardData}}" id="drug-card">
      <view class="drug-card-header" bindtap="toggleDrugCard">
        <text class="drug-card-title">💊 药品识别结果</text>
        <text class="drug-card-toggle">{{drugCardExpanded ? '收起 ▲' : '展开 ▼'}}</text>
      </view>
      <view class="drug-card-body" wx:if="{{drugCardExpanded}}">
        <block wx:if="{{drugCardData.name}}">
          <view class="drug-info-item">
            <text class="drug-info-key">药品名称</text>
            <text class="drug-info-val">{{drugCardData.name}}</text>
          </view>
        </block>
        <block wx:if="{{drugCardData.ingredients}}">
          <view class="drug-info-item">
            <text class="drug-info-key">成分</text>
            <text class="drug-info-val">{{drugCardData.ingredients}}</text>
          </view>
        </block>
        <block wx:if="{{drugCardData.indications}}">
          <view class="drug-info-item">
            <text class="drug-info-key">适应症</text>
            <text class="drug-info-val">{{drugCardData.indications}}</text>
          </view>
        </block>
        <block wx:if="{{drugCardData.dosage}}">
          <view class="drug-info-item">
            <text class="drug-info-key">用法用量</text>
            <text class="drug-info-val">{{drugCardData.dosage}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- [2026-04-25] 报告解读失败：重新解读按钮 -->
    <view wx:if="{{interpretFailed}}" class="interpret-failed-bar">
      <text class="interpret-failed-text">抱歉，本次解读未能完成。</text>
      <view class="interpret-failed-btn" bindtap="onRetryInterpret">重新解读</view>
    </view>

    <view id="msg-bottom" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 上传进度条 -->
  <view class="upload-progress-bar" wx:if="{{showUploadProgress && uploadPercent >= 0}}">
    <view class="upload-progress-inner">
      <view class="upload-progress-track">
        <view class="upload-progress-fill" style="width: {{uploadPercent}}%;"></view>
      </view>
      <text class="upload-progress-text">{{uploadPercent}}%</text>
    </view>
  </view>

  <!-- 功能按钮区域 -->
  <scroll-view scroll-x class="function-buttons-area" wx:if="{{functionButtons.length > 0}}">
    <view class="button-list">
      <view 
        class="func-btn" 
        wx:for="{{functionButtons}}" 
        wx:key="id"
        bindtap="onFunctionButtonTap"
        data-button="{{item}}"
      >
        <image class="func-btn-icon" src="{{item.icon_url}}" mode="aspectFit" wx:if="{{item.icon_url}}" />
        <text class="func-btn-text">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Module 5: 拍照识药快捷按钮 -->
  <view class="drug-quick-bar">
    <view class="drug-quick-btn {{drugIdentifyDisabled ? 'drug-quick-btn-disabled' : ''}}" bindtap="onDrugRecognizeTap">
      <text class="drug-quick-icon">💊</text>
      <text class="drug-quick-text">{{drugIdentifyDisabled ? '识别中...' : '拍照识药'}}</text>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area safe-bottom">
    <view class="input-bar">
      <!-- [2026-04-25] 报告解读/对比 会话：咨询人标签只读，不可切换 -->
      <view wx:if="{{chatType === 'report_interpret' || chatType === 'report_compare'}}"
            class="consult-target-btn"
            style="background: {{consultTarget.color}};"
            aria-label="当前报告所属人：{{consultTarget.name}}">
        <text class="consult-target-text">{{consultTarget.name}}</text>
      </view>
      <view wx:else class="consult-target-btn" catchtap="toggleTargetPicker" style="background: {{consultTarget.color}};">
        <text class="consult-target-text">{{consultTarget.name}}</text>
      </view>
      <view class="tool-btn" bindtap="chooseImage">
        <text class="tool-icon">📷</text>
      </view>
      <block wx:if="{{voiceMode}}">
        <view class="hold-talk-btn {{isRecording ? 'hold-talk-active' : ''}}"
              catchtouchstart="onRecordTouchStart"
              catchtouchmove="onRecordTouchMove"
              catchtouchend="onRecordTouchEnd">
          <text class="hold-talk-text">{{isRecording ? '松开结束' : '按住说话'}}</text>
        </view>
      </block>
      <block wx:else>
        <view class="input-wrapper">
          <input class="chat-input" placeholder="发信息..." value="{{inputValue}}"
                 bindinput="onInput" confirm-type="send" bindconfirm="sendMessage"
                 adjust-position="{{false}}" focus="{{inputFocus}}" />
          <view class="send-btn-inline {{inputValue ? 'send-active' : ''}}" bindtap="sendMessage" wx:if="{{inputValue}}">
            <text class="send-icon-arrow">↑</text>
          </view>
        </view>
      </block>
      <view class="voice-toggle-btn" catchtap="toggleVoiceMode">
        <text class="voice-toggle-icon">{{voiceMode ? '⌨️' : '🎤'}}</text>
      </view>
    </view>
  </view>

  <!-- 咨询对象选择浮层（PRD-420 升级：新增"+ 新建家庭成员"入口） -->
  <view class="target-picker-mask" wx:if="{{showTargetPicker}}" catchtap="toggleTargetPicker"></view>
  <view class="target-picker" wx:if="{{showTargetPicker}}">
    <view class="target-option" wx:for="{{familyMembers}}" wx:key="id" bindtap="onSelectTarget" data-member="{{item}}">
      <view class="target-avatar-small" style="background: {{item.color}};">
        <text class="target-avatar-text-small">{{item.name}}</text>
      </view>
      <text class="target-option-check" wx:if="{{consultTarget.name === item.name}}">✓</text>
    </view>
    <!-- PRD-420 F2 末行：新建家庭成员入口 -->
    <view class="target-option target-option-add" bindtap="openAddMemberPopup">
      <view class="target-avatar-small" style="background: #52c41a;">
        <text class="target-avatar-text-small">+</text>
      </view>
      <text class="target-option-add-label">新建家庭成员</text>
    </view>
  </view>

  <!-- PRD-420 F3 + F4：添加家庭成员弹层（关系九宫格 + 信息表单） -->
  <view class="add-member-mask" wx:if="{{showAddMember}}" catchtap="closeAddMemberPopup"></view>
  <view class="add-member-popup" wx:if="{{showAddMember}}">
    <view class="add-member-header">
      <text class="add-member-title">添加家庭成员</text>
      <text class="add-member-close" catchtap="closeAddMemberPopup">×</text>
    </view>

    <view class="add-member-section">
      <text class="add-member-section-title">选择关系</text>
      <view class="relation-grid">
        <view
          class="relation-card {{selectedRelation && selectedRelation.id === item.id ? 'relation-card-selected' : ''}}"
          wx:for="{{relationTypes}}"
          wx:key="id"
          bindtap="onSelectRelation"
          data-rt="{{item}}"
        >
          <text class="relation-emoji">{{item.emoji}}</text>
          <text class="relation-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="add-member-form" wx:if="{{selectedRelation}}">
      <view class="add-form-title">填写{{selectedRelation.name}}信息</view>

      <view class="form-row">
        <text class="form-label">姓名 <text class="form-required">*</text></text>
        <input class="form-input" placeholder="请输入姓名（1~20字）" value="{{addForm.nickname}}" bindinput="onAddInput" data-field="nickname" maxlength="20" />
      </view>

      <view class="form-row">
        <text class="form-label">性别 <text class="form-required">*</text></text>
        <view class="form-gender">
          <view class="gender-btn {{addForm.gender === 'male' ? 'gender-btn-active' : ''}}" bindtap="onSelectGender" data-gender="male">男</view>
          <view class="gender-btn {{addForm.gender === 'female' ? 'gender-btn-active' : ''}}" bindtap="onSelectGender" data-gender="female">女</view>
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">出生日期 <text class="form-required">*</text></text>
        <picker mode="date" value="{{addForm.birthday}}" start="1900-01-01" end="{{todayStr}}" bindchange="onPickBirthday">
          <view class="form-input form-input-picker">
            <text class="{{addForm.birthday ? '' : 'form-input-placeholder'}}">{{addForm.birthday || '请选择出生日期'}}</text>
            <text class="form-arrow">📅</text>
          </view>
        </picker>
      </view>

      <view class="form-row form-row-flex">
        <view class="form-col">
          <text class="form-label">身高 (cm)</text>
          <input class="form-input" type="number" placeholder="如：170" value="{{addForm.height}}" bindinput="onAddInput" data-field="height" />
        </view>
        <view class="form-col">
          <text class="form-label">体重 (kg)</text>
          <input class="form-input" type="digit" placeholder="如：65" value="{{addForm.weight}}" bindinput="onAddInput" data-field="weight" />
        </view>
      </view>

      <view class="form-row">
        <text class="form-label">既往病史</text>
        <view class="tag-list">
          <view
            class="form-tag {{addForm.medicalHistories.indexOf(item) >= 0 ? 'form-tag-active' : ''}}"
            wx:for="{{medicalOptions}}"
            wx:key="*this"
            bindtap="onToggleMedical"
            data-opt="{{item}}"
          >{{item}}</view>
        </view>
        <input class="form-input" placeholder="其他病史（可选）" value="{{addForm.medicalOther}}" bindinput="onAddInput" data-field="medicalOther" />
      </view>

      <view class="form-row">
        <text class="form-label">过敏史</text>
        <view class="tag-list">
          <view
            class="form-tag {{addForm.allergies.indexOf(item) >= 0 ? 'form-tag-active' : ''}}"
            wx:for="{{allergyOptions}}"
            wx:key="*this"
            bindtap="onToggleAllergy"
            data-opt="{{item}}"
          >{{item}}</view>
        </view>
        <input class="form-input" placeholder="其他过敏史（可选）" value="{{addForm.allergyOther}}" bindinput="onAddInput" data-field="allergyOther" />
      </view>

      <button class="add-save-btn {{canSaveMember ? '' : 'add-save-btn-disabled'}}" disabled="{{!canSaveMember}}" bindtap="onSaveNewMember">{{addLoading ? '保存中...' : '保存'}}</button>
    </view>
  </view>

  <!-- 录音遮罩 -->
  <view class="record-overlay" wx:if="{{showRecordOverlay}}" catchtouchmove="preventTouchMove">
    <view class="record-overlay-mask"></view>
    <view class="record-overlay-content">
      <view class="record-wave-container">
        <view class="record-wave-bar record-wave-bar-1"></view>
        <view class="record-wave-bar record-wave-bar-2"></view>
        <view class="record-wave-bar record-wave-bar-3"></view>
        <view class="record-wave-bar record-wave-bar-4"></view>
        <view class="record-wave-bar record-wave-bar-5"></view>
      </view>
      <text class="record-duration">{{recordingTime}}s / 30s</text>
      <view class="record-cancel-zone {{recordCancelling ? 'record-cancel-active' : ''}}">
        <text class="record-cancel-icon">{{recordCancelling ? '✕' : ''}}</text>
      </view>
      <text class="record-hint {{recordCancelling ? 'record-hint-cancel' : ''}}">{{recordCancelling ? '松开取消' : '松开发送，上滑取消'}}</text>
    </view>
  </view>

  <!-- 对话历史抽屉 -->
  <chat-drawer
    show="{{drawerShow}}"
    sessions="{{allSessions}}"
    bind:close="onDrawerClose"
    bind:sessiontap="onSessionTap"
    bind:newchat="onDrawerNewChat"
    bind:refresh="onDrawerRefresh"
    bind:share="onDrawerShare"
  />

  <!-- Module 9: Share canvas (hidden) -->
  <canvas type="2d" id="share-canvas" style="position: fixed; left: -9999px; top: -9999px; width: 600px; height: 800px;"></canvas>
</view>
