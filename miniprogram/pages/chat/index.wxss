.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.chat-top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.toggle-icon {
  font-size: 32rpx;
  color: #333;
}

.top-bar-spacer {
  flex: 1;
}

/* [PRD-425] 顶栏中部标题与未读徽标 */
.top-bar-title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 16rpx;
  min-width: 0;
}
.top-bar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 48rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
/* 标题右上角徽标，绝对定位防止挤压标题文字 */
.top-bar-badge {
  position: absolute;
  background: #FF3B30;
  color: #fff;
  border-radius: 18rpx;
  box-shadow: 0 0 0 3rpx #fff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.top-bar-badge-dot {
  width: 16rpx;
  height: 16rpx;
  /* 紧贴标题右上角；标题居中，按文字宽度无法精确对齐时取右上方 */
  right: 12rpx;
  top: 6rpx;
}
.top-bar-badge-num {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  right: 0;
  top: 4rpx;
}

/* 字体大小按钮 */
.font-size-trigger {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(82, 196, 26, 0.12);
}

.font-trigger-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
}

/* 字体选择浮层 */
.font-popover-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.font-popover {
  position: absolute;
  top: 88rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 8rpx 0;
  min-width: 280rpx;
}

.font-popover-arrow {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}

.font-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.font-option:active {
  background: #f5f5f5;
}

.font-option-active {
  background: rgba(82, 196, 26, 0.08);
}

.font-option-label {
  font-size: 28rpx;
  color: #333;
}

.font-option-active .font-option-label {
  color: #52c41a;
  font-weight: bold;
}

.font-option-check {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 16rpx 32rpx;
  overflow-y: auto;
}

/* ========== [PRD-433] 气泡卡片化视觉改版 ========== */

/* 时间分隔条：水平居中 12px 灰色无背景 */
.time-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}
.time-divider-text {
  font-size: 24rpx;
  color: #9CA3AF;
  background: transparent;
}

/* AI 消息整体包裹 */
.ai-msg-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 100%;
}

/* AI 卡片外部上方：头像 + 名称行 */
.ai-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}
.ai-header-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ai-header-avatar-emoji {
  font-size: 28rpx;
}
.ai-header-name {
  font-size: 28rpx;
  color: #666;
  margin-left: 16rpx;
}

/* AI 卡片：白底 + 1px #EAEBED 描边 + 12px 圆角 + 88% 占屏 */
.ai-card {
  width: 88%;
  background: #FFFFFF;
  border: 1rpx solid #EAEBED;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  box-shadow: none;
}

.ai-card-body {
  width: 100%;
}
.ai-card-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1F2937;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* 参考资料区 */
.ai-card-references {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}
.ai-card-references-title {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.ai-card-reference-item {
  margin-top: 6rpx;
}
.ai-card-reference-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* 免责声明：12px #9CA3AF，操作按钮行上方 */
.ai-card-disclaimer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #EAEBED;
}
.ai-card-disclaimer-text {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

/* 卡片底部操作按钮行：📋 复制 / 🔗 分享 / 🔁 朗读（朗读最右） */
.ai-card-action-bar {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 48rpx;
}
.ai-card-action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}
.ai-card-action-btn:active {
  opacity: 0.6;
}
.ai-card-action-btn-right {
  margin-left: auto;
}
.ai-card-action-icon {
  font-size: 32rpx;
  line-height: 1;
}
.ai-card-action-label {
  font-size: 24rpx;
  color: #6B7280;
}

/* Loading 卡片 */
.ai-card-loading {
  padding: 28rpx 32rpx;
}
.ai-loading-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ai-loading-text {
  font-size: 28rpx;
  color: #6B7280;
}

/* ===== 用户消息：右侧浅蓝气泡 ===== */
.user-msg-wrap {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}
/* 注意：覆盖下方旧 .user-bubble（兼容样式），强制使用新视觉 */
.user-msg-wrap .user-bubble {
  max-width: 75%;
  background: #E6F0FF;
  color: #1F2937;
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  word-break: break-word;
  overflow-wrap: break-word;
}
.user-bubble-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1F2937;
  word-break: break-word;
  overflow-wrap: break-word;
}
.user-msg-wrap .msg-image {
  max-width: 100%;
  border-radius: 16rpx;
}

/* ========== [PRD-433] end ========== */


/* 提示 */
.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 消息行 */
.msg-item {
  margin-bottom: 48rpx;
}

/* [PRD-429] 满屏排版：纯文本流，去气泡，左右各 24rpx 边距已由 .msg-list padding 提供 */
.msg-flow-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.msg-flow-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.msg-sender-name {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.msg-flow-body {
  width: 100%;
  padding: 0;
  background: transparent;
  border: none;
}

.msg-flow-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1A1A1A;
  word-break: break-word;
  overflow-wrap: break-word;
}

.user-flow-body .msg-flow-text {
  color: #1A1A1A;
}

.msg-flow-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 兼容旧 msg-row（暂保留以兼容页面其他可能引用，不再被消息列表使用） */
.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.user-avatar {
  background: #52c41a;
}

.avatar-emoji {
  font-size: 32rpx;
}

/* 消息内容包裹（旧版兼容） */
.msg-content-wrap {
  max-width: 100%;
}

/* 气泡（旧版兼容，新版不使用） */
.msg-bubble {
  max-width: 100%;
  padding: 0;
  border-radius: 0;
  background: transparent;
  position: relative;
}

.ai-bubble {
  background: transparent;
  box-shadow: none;
}

.user-bubble {
  max-width: 100%;
  background: transparent;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble .msg-text {
  color: #1A1A1A;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: #bbb;
  text-align: left;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

/* SSE 流式光标 */
.streaming-cursor {
  color: #52c41a;
  font-weight: bold;
  font-size: 32rpx;
  animation: cursorBlink 0.6s step-end infinite;
}

@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 打字动画 */
.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ========== Module 7: Action buttons ========== */
.msg-action-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 0 4rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.action-btn:active {
  background: #f5f5f5;
}

.action-icon {
  font-size: 24rpx;
}

.action-label {
  font-size: 22rpx;
  color: #666;
}

/* ========== Module 5: Drug quick button ========== */
.drug-quick-bar {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}

.drug-quick-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, rgba(82,196,26,0.08), rgba(19,194,194,0.08));
  border: 1rpx solid rgba(82,196,26,0.2);
  border-radius: 32rpx;
}

.drug-quick-btn:active {
  background: rgba(82,196,26,0.15);
}

.drug-quick-icon {
  font-size: 28rpx;
}

.drug-quick-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ========== Module 5: Drug card inline ========== */
.drug-card-inline {
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}

.drug-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
}

.drug-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.drug-card-toggle {
  font-size: 24rpx;
  color: #52c41a;
}

.drug-card-body {
  padding: 16rpx 24rpx;
}

.drug-info-item {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.drug-info-item:last-child {
  border-bottom: none;
}

.drug-info-key {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.drug-info-val {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 功能按钮区域 */
.function-buttons-area {
  height: 120rpx;
  white-space: nowrap;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 0;
  flex-shrink: 0;
}

.button-list {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 24rpx;
}

.func-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 32rpx;
  background: rgba(82, 196, 26, 0.08);
  border: 1rpx solid rgba(82, 196, 26, 0.25);
  border-radius: 36rpx;
  flex-shrink: 0;
}

.func-btn:active {
  background: rgba(82, 196, 26, 0.18);
}

.func-btn-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.func-btn-text {
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 40rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 44rpx;
  padding: 0 8rpx 0 24rpx;
  height: 72rpx;
  min-width: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  min-width: 0;
}

.send-btn-inline {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn-inline.send-active {
  background: #52c41a;
}

.send-icon-arrow {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}

/* Voice toggle button */
.voice-toggle-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-toggle-icon {
  font-size: 40rpx;
}

/* Hold to talk button */
.hold-talk-btn {
  flex: 1;
  height: 72rpx;
  background: #52c41a;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hold-talk-active {
  background: #389e0d;
}

.hold-talk-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* Recording overlay */
.record-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.record-overlay-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.record-wave-bar {
  width: 10rpx;
  background: #52c41a;
  border-radius: 5rpx;
  animation: recordWave 1s ease-in-out infinite;
}

.record-wave-bar-1 { height: 40rpx; animation-delay: 0s; }
.record-wave-bar-2 { height: 70rpx; animation-delay: 0.15s; }
.record-wave-bar-3 { height: 100rpx; animation-delay: 0.3s; }
.record-wave-bar-4 { height: 70rpx; animation-delay: 0.45s; }
.record-wave-bar-5 { height: 40rpx; animation-delay: 0.6s; }

@keyframes recordWave {
  0%, 100% { transform: scaleY(0.4); }
  50% { transform: scaleY(1); }
}

.record-duration {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 48rpx;
}

.record-cancel-zone {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.record-cancel-active {
  background: #ff4d4f;
  transform: scale(1.2);
}

.record-cancel-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.record-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.record-hint-cancel {
  color: #ff4d4f;
}

/* Consult target button */
.consult-target-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.consult-target-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

/* Target picker popup */
.target-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.target-picker {
  position: fixed;
  bottom: 120rpx;
  left: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-width: 400rpx;
}

.target-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
}

.target-avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-avatar-text-small {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.target-option-check {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 20rpx;
  color: #52c41a;
  font-weight: bold;
  background: #fff;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  text-align: center;
  line-height: 28rpx;
}

.upload-progress-bar {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 12rpx 24rpx;
}

.upload-progress-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.upload-progress-track {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.upload-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  transition: width 0.3s ease;
}

.upload-progress-text {
  font-size: 22rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

/* Summary bar */
.summary-bar {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid rgba(82, 196, 26, 0.15);
  flex-shrink: 0;
}

.summary-bar-text {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
}

/* Drug identify banner card (top of chat list, aligned with H5/Flutter) */
.drug-banner {
  margin: 16rpx 24rpx 0 24rpx;
  padding: 18rpx 24rpx;
  background: #fff7e6;
  border-left: 8rpx solid #fa8c16;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.drug-banner__head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.drug-banner__icon {
  font-size: 28rpx;
  color: #fa8c16;
}
.drug-banner__title {
  font-size: 26rpx;
  color: #fa8c16;
  font-weight: 600;
}
.drug-banner__member {
  margin-left: auto;
  font-size: 22rpx;
  color: #fa8c16;
}
.drug-banner__drugs {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #595959;
  line-height: 1.4;
  word-break: break-all;
}

/* Drug identify disabled */
.drug-quick-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* [2026-04-23 报告分支] 报告解读/对比顶部卡片 */
.report-card {
  background: linear-gradient(135deg, #e6f7ff, #fff);
  border: 1rpx solid #91d5ff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 16rpx;
}
.report-card.compare {
  background: linear-gradient(135deg, #fffbe6, #fff);
  border-color: #ffe58f;
}
.report-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.report-card-count {
  font-size: 24rpx;
  color: #1890ff;
  margin-top: 8rpx;
}
.report-thumbs {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.report-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.report-thumb-img {
  width: 100%;
  height: 100%;
}
.report-compare-item {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #333;
}
.report-compare-label {
  font-weight: 500;
}
.report-compare-title {
  color: #1890ff;
}
/* [2026-04-25] 报告解读失败提示条 */
.interpret-failed-bar {
  margin: 20rpx 32rpx;
  padding: 24rpx;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.interpret-failed-text {
  color: #cf1322;
  font-size: 28rpx;
}
.interpret-failed-btn {
  background: #ff4d4f;
  color: #fff;
  padding: 12rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

/* [2026-04-25 PRD F5] OCR 详情兜底入口样式（浅灰、低存在感） */
.ocr-detail-row {
  margin-top: 8rpx;
  text-align: right;
}
.ocr-detail-link {
  color: #999;
  font-size: 22rpx;
}
/* PRD-420 添加家庭成员弹层样式 */
.target-option-add {
  border-top: 1rpx dashed #e8e8e8;
  margin-top: 8rpx;
  padding-top: 16rpx !important;
}
.target-option-add-label {
  color: #52c41a;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.add-member-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
}
.add-member-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 90vh;
  overflow-y: auto;
  z-index: 999;
  padding: 0 24rpx 32rpx;
}
.add-member-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.add-member-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.add-member-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 0 12rpx;
}
.add-member-section {
  margin-top: 24rpx;
}
.add-member-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
  display: block;
}
.relation-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.relation-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}
.relation-card-selected {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  border-color: #52c41a;
}
.relation-emoji {
  font-size: 44rpx;
  line-height: 1;
}
.relation-name {
  font-size: 24rpx;
  color: #555;
  margin-top: 6rpx;
}
.relation-card-selected .relation-name {
  color: #52c41a;
}
.add-member-form {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 24rpx;
}
.add-form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 24rpx;
}
.form-row {
  margin-bottom: 20rpx;
}
.form-row-flex {
  display: flex;
  gap: 16rpx;
}
.form-col {
  flex: 1;
}
.form-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.form-required {
  color: #ff4d4f;
}
.form-input {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}
.form-input-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-input-placeholder {
  color: #bbb;
}
.form-arrow {
  margin-left: 8rpx;
}
.form-gender {
  display: flex;
  gap: 16rpx;
}
.gender-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
}
.gender-btn-active {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  border-color: #52c41a;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.form-tag {
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: #fff;
  border: 1rpx solid #d9d9d9;
  color: #666;
}
.form-tag-active {
  background: #52c41a;
  color: #fff;
  border-color: #52c41a;
}
.add-save-btn {
  width: 100%;
  margin-top: 24rpx;
  padding: 20rpx 0;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.add-save-btn-disabled {
  background: #d9d9d9 !important;
  color: #fff;
}

.ocr-detail-box {
  margin-top: 10rpx;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  text-align: left;
  max-height: 600rpx;
  overflow-y: auto;
}
.ocr-detail-text {
  color: #666;
  font-size: 24rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}
