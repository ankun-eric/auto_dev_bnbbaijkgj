  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.record-cancel-active {
  background: #ff4d4f;
  transform: scale(1.2);
}

.record-cancel-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
