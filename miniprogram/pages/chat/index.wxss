.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.chat-top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.toggle-icon {
  font-size: 32rpx;
  color: #333;
}

.top-bar-spacer {
  flex: 1;
}

/* 字体大小按钮 */
.font-size-trigger {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(82, 196, 26, 0.12);
}

.font-trigger-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
}

/* 字体选择浮层 */
.font-popover-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.font-popover {
  position: absolute;
  top: 88rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 8rpx 0;
  min-width: 280rpx;
}

.font-popover-arrow {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}

.font-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.font-option:active {
  background: #f5f5f5;
}

.font-option-active {
  background: rgba(82, 196, 26, 0.08);
}

.font-option-label {
  font-size: 28rpx;
  color: #333;
}

.font-option-active .font-option-label {
  color: #52c41a;
  font-weight: bold;
}

.font-option-check {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

/* 提示 */
.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 消息行 */
.msg-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  margin-right: 16rpx;
}

.user-avatar {
  background: #e6f7ff;
  margin-left: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

/* 气泡 */
.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.user-bubble {
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble .msg-text {
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

/* 打字动画 */
.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 40rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 8rpx 0 24rpx;
  height: 72rpx;
  min-width: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  min-width: 0;
}

.send-btn-inline {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn-inline.send-active {
  background: #52c41a;
}

.send-icon-arrow {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}

/* Voice toggle button */
.voice-toggle-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-toggle-icon {
  font-size: 40rpx;
}

/* Hold to talk button */
.hold-talk-btn {
  flex: 1;
  height: 72rpx;
  background: #52c41a;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hold-talk-active {
  background: #389e0d;
}

.hold-talk-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* Recording overlay */
.record-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.record-overlay-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.record-wave-bar {
  width: 10rpx;
  background: #52c41a;
  border-radius: 5rpx;
  animation: recordWave 1s ease-in-out infinite;
}

.record-wave-bar-1 { height: 40rpx; animation-delay: 0s; }
.record-wave-bar-2 { height: 70rpx; animation-delay: 0.15s; }
.record-wave-bar-3 { height: 100rpx; animation-delay: 0.3s; }
.record-wave-bar-4 { height: 70rpx; animation-delay: 0.45s; }
.record-wave-bar-5 { height: 40rpx; animation-delay: 0.6s; }

@keyframes recordWave {
  0%, 100% { transform: scaleY(0.4); }
  50% { transform: scaleY(1); }
}

.record-duration {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 48rpx;
}

.record-cancel-zone {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.record-cancel-active {
  background: #ff4d4f;
  transform: scale(1.2);
}

.record-cancel-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.record-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.record-hint-cancel {
  color: #ff4d4f;
}

/* Consult target button */
.consult-target-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.consult-target-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

/* Target picker popup */
.target-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.target-picker {
  position: fixed;
  bottom: 120rpx;
  left: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-width: 400rpx;
}

.target-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
}

.target-avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-avatar-text-small {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.target-option-check {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 20rpx;
  color: #52c41a;
  font-weight: bold;
  background: #fff;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  text-align: center;
  line-height: 28rpx;
}
