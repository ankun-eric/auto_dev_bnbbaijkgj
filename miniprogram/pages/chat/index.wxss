.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.chat-top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.toggle-icon {
  font-size: 32rpx;
  color: #333;
}

.top-bar-spacer {
  flex: 1;
}

/* [PRD-425] 顶栏中部标题与未读徽标 */
.top-bar-title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 16rpx;
  min-width: 0;
}
.top-bar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 48rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
/* 标题右上角徽标，绝对定位防止挤压标题文字 */
.top-bar-badge {
  position: absolute;
  background: #FF3B30;
  color: #fff;
  border-radius: 18rpx;
  box-shadow: 0 0 0 3rpx #fff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.top-bar-badge-dot {
  width: 16rpx;
  height: 16rpx;
  /* 紧贴标题右上角；标题居中，按文字宽度无法精确对齐时取右上方 */
  right: 12rpx;
  top: 6rpx;
}
.top-bar-badge-num {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  right: 0;
  top: 4rpx;
}

/* 字体大小按钮 */
.font-size-trigger {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(82, 196, 26, 0.12);
}

.font-trigger-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
}

/* 字体选择浮层 */
.font-popover-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.font-popover {
  position: absolute;
  top: 88rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 8rpx 0;
  min-width: 280rpx;
}

.font-popover-arrow {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}

.font-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.font-option:active {
  background: #f5f5f5;
}

.font-option-active {
  background: rgba(82, 196, 26, 0.08);
}

.font-option-label {
  font-size: 28rpx;
  color: #333;
}

.font-option-active .font-option-label {
  color: #52c41a;
  font-weight: bold;
}

.font-option-check {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 16rpx 32rpx;
  overflow-y: auto;
}

/* ========== [PRD-433] 气泡卡片化视觉改版 ========== */

/* 时间分隔条：水平居中 12px 灰色无背景 */
.time-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}
.time-divider-text {
  font-size: 24rpx;
  color: #9CA3AF;
  background: transparent;
}

/* AI 消息整体包裹 */
.ai-msg-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 100%;
}

/* AI 卡片外部上方：头像 + 名称行 */
.ai-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}
.ai-header-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ai-header-avatar-emoji {
  font-size: 28rpx;
}
.ai-header-name {
  font-size: 28rpx;
  color: #666;
  margin-left: 16rpx;
}

/* AI 卡片：白底 + 1px #EAEBED 描边 + 12px 圆角 + 88% 占屏 */
.ai-card {
  width: 88%;
  background: #FFFFFF;
  border: 1rpx solid #EAEBED;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  box-shadow: none;
}

.ai-card-body {
  width: 100%;
}
.ai-card-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1F2937;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* 参考资料区 */
.ai-card-references {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}
.ai-card-references-title {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.ai-card-reference-item {
  margin-top: 6rpx;
}
.ai-card-reference-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* 免责声明：12px #9CA3AF，操作按钮行上方 */
.ai-card-disclaimer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #EAEBED;
}
.ai-card-disclaimer-text {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

/* [PRD-440] AI 回答操作栏：提示文字 + 全宽虚线 + 渐变三图标 */
.ai-action-bar-440 {
  margin-top: 24rpx;
  width: 100%;
}
.ai-action-bar-440-disclaimer {
  text-align: right;
  margin-bottom: 12rpx;
}
.ai-action-bar-440-disclaimer-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}
.ai-action-bar-440-divider {
  width: 100%;
  height: 0;
  border-top: 1rpx dashed #E5E5E5;
}
.ai-action-bar-440-icons {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 16rpx;
}
.ai-action-bar-440-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.ai-action-bar-440-btn:active {
  opacity: 0.7;
}

/* 三个图标——使用 SVG 内嵌渐变（小程序通过 background-image data URI 渲染） */
/* 未触发态使用浅灰 #999；本次实现统一使用渐变（PRD：触发后渐变高亮，但移动端长按效果有限，统一用渐变更显科技感） */
.ai-action-bar-440-icon-copy,
.ai-action-bar-440-icon-share,
.ai-action-bar-440-icon-speaker {
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}
/* 复制：渐变描边图标 */
.ai-action-bar-440-icon-copy {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%25' stop-color='%236a8dff'/><stop offset='100%25' stop-color='%23b07cff'/></linearGradient></defs><rect x='9' y='9' width='11' height='11' rx='2' stroke='url(%23g)'/><path d='M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5' stroke='url(%23g)'/></svg>");
}
/* 转发：三点连线分享图（方案 3） */
.ai-action-bar-440-icon-share {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%25' stop-color='%236a8dff'/><stop offset='100%25' stop-color='%23b07cff'/></linearGradient></defs><circle cx='18' cy='5' r='2.5' stroke='url(%23g)'/><circle cx='6' cy='12' r='2.5' stroke='url(%23g)'/><circle cx='18' cy='19' r='2.5' stroke='url(%23g)'/><line x1='8.2' y1='13.3' x2='15.8' y2='17.7' stroke='url(%23g)'/><line x1='15.8' y1='6.3' x2='8.2' y2='10.7' stroke='url(%23g)'/></svg>");
}
/* 语音播报：喇叭 */
.ai-action-bar-440-icon-speaker {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%25' stop-color='%236a8dff'/><stop offset='100%25' stop-color='%23b07cff'/></linearGradient></defs><polygon points='11 5 6 9 3 9 3 15 6 15 11 19 11 5' stroke='url(%23g)'/></svg>");
  position: relative;
}

/* Wi-Fi 弧线扩散动效（1 秒一圈，3 圈错位 333ms） */
@keyframes ai-action-bar-440-wifi {
  0%   { transform: scale(1);   opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}
.ai-action-bar-440-wifi-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  border-radius: 50%;
  border: 2rpx solid #6a8dff;
  opacity: 0;
  animation: ai-action-bar-440-wifi 1000ms ease-out infinite;
  pointer-events: none;
}
.ai-action-bar-440-wifi-ring.ring1 { animation-delay: 0ms; }
.ai-action-bar-440-wifi-ring.ring2 { animation-delay: 333ms; }
.ai-action-bar-440-wifi-ring.ring3 { animation-delay: 666ms; }

/* Loading 卡片 */
.ai-card-loading {
  padding: 28rpx 32rpx;
}
.ai-loading-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ai-loading-text {
  font-size: 28rpx;
  color: #6B7280;
}

/* ===== 用户消息：右侧浅蓝气泡 ===== */
.user-msg-wrap {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}
/* 注意：覆盖下方旧 .user-bubble（兼容样式），强制使用新视觉 */
.user-msg-wrap .user-bubble {
  max-width: 75%;
  background: #E6F0FF;
  color: #1F2937;
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  word-break: break-word;
  overflow-wrap: break-word;
}
.user-bubble-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1F2937;
  word-break: break-word;
  overflow-wrap: break-word;
}
.user-msg-wrap .msg-image {
  max-width: 100%;
  border-radius: 16rpx;
}

/* ========== [PRD-433] end ========== */


/* 提示 */
.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 消息行 */
.msg-item {
  margin-bottom: 48rpx;
}

/* [PRD-429] 满屏排版：纯文本流，去气泡，左右各 24rpx 边距已由 .msg-list padding 提供 */
.msg-flow-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.msg-flow-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.msg-sender-name {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.msg-flow-body {
  width: 100%;
  padding: 0;
  background: transparent;
  border: none;
}

.msg-flow-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.6;
  color: #1A1A1A;
  word-break: break-word;
  overflow-wrap: break-word;
}

.user-flow-body .msg-flow-text {
  color: #1A1A1A;
}

.msg-flow-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 兼容旧 msg-row（暂保留以兼容页面其他可能引用，不再被消息列表使用） */
.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.user-avatar {
  background: #52c41a;
}

.avatar-emoji {
  font-size: 32rpx;
}

/* 消息内容包裹（旧版兼容） */
.msg-content-wrap {
  max-width: 100%;
}

/* 气泡（旧版兼容，新版不使用） */
.msg-bubble {
  max-width: 100%;
  padding: 0;
  border-radius: 0;
  background: transparent;
  position: relative;
}

.ai-bubble {
  background: transparent;
  box-shadow: none;
}

.user-bubble {
  max-width: 100%;
  background: transparent;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble .msg-text {
  color: #1A1A1A;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: #bbb;
  text-align: left;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

/* SSE 流式光标 */
.streaming-cursor {
  color: #52c41a;
  font-weight: bold;
  font-size: 32rpx;
  animation: cursorBlink 0.6s step-end infinite;
}

@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 打字动画 */
.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ========== Module 7: Action buttons ========== */
.msg-action-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 0 4rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.action-btn:active {
  background: #f5f5f5;
}

.action-icon {
  font-size: 24rpx;
}

.action-label {
  font-size: 22rpx;
  color: #666;
}

/* ========== Module 5: Drug quick button ========== */
.drug-quick-bar {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}

.drug-quick-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, rgba(82,196,26,0.08), rgba(19,194,194,0.08));
  border: 1rpx solid rgba(82,196,26,0.2);
  border-radius: 32rpx;
}

.drug-quick-btn:active {
  background: rgba(82,196,26,0.15);
}

.drug-quick-icon {
  font-size: 28rpx;
}

.drug-quick-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ========== Module 5: Drug card inline ========== */
.drug-card-inline {
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}

.drug-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
}

.drug-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.drug-card-toggle {
  font-size: 24rpx;
  color: #52c41a;
}

.drug-card-body {
  padding: 16rpx 24rpx;
}

.drug-info-item {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.drug-info-item:last-child {
  border-bottom: none;
}

.drug-info-key {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.drug-info-val {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 功能按钮区域 */
.function-buttons-area {
  height: 120rpx;
  white-space: nowrap;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 0;
  flex-shrink: 0;
}

.button-list {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 24rpx;
}

.func-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 32rpx;
  background: rgba(82, 196, 26, 0.08);
  border: 1rpx solid rgba(82, 196, 26, 0.25);
  border-radius: 36rpx;
  flex-shrink: 0;
}

.func-btn:active {
  background: rgba(82, 196, 26, 0.18);
}

.func-btn-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.func-btn-text {
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 40rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 44rpx;
  padding: 0 8rpx 0 24rpx;
  height: 72rpx;
  min-width: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  min-width: 0;
}

.send-btn-inline {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn-inline.send-active {
  background: #52c41a;
}

.send-icon-arrow {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}

/* Voice toggle button */
.voice-toggle-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-toggle-icon {
  font-size: 40rpx;
}

/* Hold to talk button */
.hold-talk-btn {
  flex: 1;
  height: 72rpx;
  background: #52c41a;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
