.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.chat-top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.toggle-icon {
  font-size: 32rpx;
  color: #333;
}

.top-bar-spacer {
  flex: 1;
}

/* 字体大小按钮 */
.font-size-trigger {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(82, 196, 26, 0.12);
}

.font-trigger-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
}

/* 字体选择浮层 */
.font-popover-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.font-popover {
  position: absolute;
  top: 88rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 8rpx 0;
  min-width: 280rpx;
}

.font-popover-arrow {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}

.font-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.font-option:active {
  background: #f5f5f5;
}

.font-option-active {
  background: rgba(82, 196, 26, 0.08);
}

.font-option-label {
  font-size: 28rpx;
  color: #333;
}

.font-option-active .font-option-label {
  color: #52c41a;
  font-weight: bold;
}

.font-option-check {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

/* 提示 */
.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 消息行 */
.msg-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  margin-right: 16rpx;
}

.user-avatar {
  background: #e6f7ff;
  margin-left: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

/* 消息内容包裹 */
.msg-content-wrap {
  max-width: 70%;
}

/* 气泡 */
.msg-bubble {
  max-width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.user-bubble {
  max-width: 70%;
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble .msg-text {
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

/* SSE 流式光标 */
.streaming-cursor {
  color: #52c41a;
  font-weight: bold;
  font-size: 32rpx;
  animation: cursorBlink 0.6s step-end infinite;
}

@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 打字动画 */
.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ========== Module 7: Action buttons ========== */
.msg-action-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 0 4rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.action-btn:active {
  background: #f5f5f5;
}

.action-icon {
  font-size: 24rpx;
}

.action-label {
  font-size: 22rpx;
  color: #666;
}

/* ========== Module 5: Drug quick button ========== */
.drug-quick-bar {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}

.drug-quick-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, rgba(82,196,26,0.08), rgba(19,194,194,0.08));
  border: 1rpx solid rgba(82,196,26,0.2);
  border-radius: 32rpx;
}

.drug-quick-btn:active {
  background: rgba(82,196,26,0.15);
}

.drug-quick-icon {
  font-size: 28rpx;
}

.drug-quick-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ========== Module 5: Drug card inline ========== */
.drug-card-inline {
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}

.drug-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
}

.drug-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.drug-card-toggle {
  font-size: 24rpx;
  color: #52c41a;
}

.drug-card-body {
  padding: 16rpx 24rpx;
}

.drug-info-item {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.drug-info-item:last-child {
  border-bottom: none;
}

.drug-info-key {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.drug-info-val {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 功能按钮区域 */
.function-buttons-area {
  height: 120rpx;
  white-space: nowrap;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 0;
  flex-shrink: 0;
}

.button-list {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 24rpx;
}

.func-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 32rpx;
  background: rgba(82, 196, 26, 0.08);
  border: 1rpx solid rgba(82, 196, 26, 0.25);
  border-radius: 36rpx;
  flex-shrink: 0;
}

.func-btn:active {
  background: rgba(82, 196, 26, 0.18);
}

.func-btn-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.func-btn-text {
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 40rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 8rpx 0 24rpx;
  height: 72rpx;
  min-width: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  min-width: 0;
}

.send-btn-inline {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn-inline.send-active {
  background: #52c41a;
}

.send-icon-arrow {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}

/* Voice toggle button */
.voice-toggle-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-toggle-icon {
  font-size: 40rpx;
}

/* Hold to talk button */
.hold-talk-btn {
  flex: 1;
  height: 72rpx;
  background: #52c41a;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hold-talk-active {
  background: #389e0d;
}

.hold-talk-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* Recording overlay */
.record-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.record-overlay-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.record-wave-bar {
  width: 10rpx;
  background: #52c41a;
  border-radius: 5rpx;
  animation: recordWave 1s ease-in-out infinite;
}

.record-wave-bar-1 { height: 40rpx; animation-delay: 0s; }
.record-wave-bar-2 { height: 70rpx; animation-delay: 0.15s; }
.record-wave-bar-3 { height: 100rpx; animation-delay: 0.3s; }
.record-wave-bar-4 { height: 70rpx; animation-delay: 0.45s; }
.record-wave-bar-5 { height: 40rpx; animation-delay: 0.6s; }

@keyframes recordWave {
  0%, 100% { transform: scaleY(0.4); }
  50% { transform: scaleY(1); }
}

.record-duration {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 48rpx;
}

.record-cancel-zone {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.record-cancel-active {
  background: #ff4d4f;
  transform: scale(1.2);
}

.record-cancel-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.record-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.record-hint-cancel {
  color: #ff4d4f;
}

/* Consult target button */
.consult-target-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.consult-target-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

/* Target picker popup */
.target-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.target-picker {
  position: fixed;
  bottom: 120rpx;
  left: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 999;
  padding: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-width: 400rpx;
}

.target-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
}

.target-avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-avatar-text-small {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.target-option-check {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 20rpx;
  color: #52c41a;
  font-weight: bold;
  background: #fff;
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  text-align: center;
  line-height: 28rpx;
}

.upload-progress-bar {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  padding: 12rpx 24rpx;
}

.upload-progress-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.upload-progress-track {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.upload-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  transition: width 0.3s ease;
}

.upload-progress-text {
  font-size: 22rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

/* Summary bar */
.summary-bar {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid rgba(82, 196, 26, 0.15);
  flex-shrink: 0;
}

.summary-bar-text {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
}

/* Drug identify banner card (top of chat list, aligned with H5/Flutter) */
.drug-banner {
  margin: 16rpx 24rpx 0 24rpx;
  padding: 18rpx 24rpx;
  background: #fff7e6;
  border-left: 8rpx solid #fa8c16;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.drug-banner__head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.drug-banner__icon {
  font-size: 28rpx;
  color: #fa8c16;
}
.drug-banner__title {
  font-size: 26rpx;
  color: #fa8c16;
  font-weight: 600;
}
.drug-banner__member {
  margin-left: auto;
  font-size: 22rpx;
  color: #fa8c16;
}
.drug-banner__drugs {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #595959;
  line-height: 1.4;
  word-break: break-all;
}

/* Drug identify disabled */
.drug-quick-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* [2026-04-23 报告分支] 报告解读/对比顶部卡片 */
.report-card {
  background: linear-gradient(135deg, #e6f7ff, #fff);
  border: 1rpx solid #91d5ff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 16rpx;
}
.report-card.compare {
  background: linear-gradient(135deg, #fffbe6, #fff);
  border-color: #ffe58f;
}
.report-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.report-card-count {
  font-size: 24rpx;
  color: #1890ff;
  margin-top: 8rpx;
}
.report-thumbs {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.report-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.report-thumb-img {
  width: 100%;
  height: 100%;
}
.report-compare-item {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #333;
}
.report-compare-label {
  font-weight: 500;
}
.report-compare-title {
  color: #1890ff;
}
/* [2026-04-25] 报告解读失败提示条 */
.interpret-failed-bar {
  margin: 20rpx 32rpx;
  padding: 24rpx;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.interpret-failed-text {
  color: #cf1322;
  font-size: 28rpx;
}
.interpret-failed-btn {
  background: #ff4d4f;
  color: #fff;
  padding: 12rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

/* [2026-04-25 PRD F5] OCR 详情兜底入口样式（浅灰、低存在感） */
.ocr-detail-row {
  margin-top: 8rpx;
  text-align: right;
}
.ocr-detail-link {
  color: #999;
  font-size: 22rpx;
}
.ocr-detail-box {
  margin-top: 10rpx;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  text-align: left;
  max-height: 600rpx;
  overflow-y: auto;
}
.ocr-detail-text {
  color: #666;
  font-size: 24rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}
