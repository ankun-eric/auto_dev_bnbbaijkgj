.invite-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* Error */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.retry-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 36rpx;
}

.retry-btn::after {
  border: none;
}

/* Invitation card */
.invite-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.invite-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.invite-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.invite-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
}

.qr-brand-name {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #52c41a;
  font-weight: 500;
  text-align: center;
}

.invite-info {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #f0f0f0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* Action buttons */
.action-group {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 140rpx;
  background: #fff;
  border-radius: 16rpx;
  border: none;
  font-size: 24rpx;
  color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  padding: 0;
  line-height: 1.4;
}

.action-btn::after {
  border: none;
}

.action-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-save {
  color: #52c41a;
}

.action-copy {
  color: #1890ff;
}

.action-share {
  color: #722ed1;
}

/* Benefits section */
.benefits-section {
  width: 100%;
  margin-top: 40rpx;
}

.benefit-card {
  display: flex;
  align-items: center;
  background: #f6ffed;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.benefit-card:last-child {
  margin-bottom: 0;
}

.benefit-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.1);
}

.benefit-icon {
  font-size: 36rpx;
}

.benefit-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.benefit-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.benefit-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
