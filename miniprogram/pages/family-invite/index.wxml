<view class="invite-page">
  <!-- Loading -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在生成邀请…</text>
  </view>

  <!-- Error -->
  <view class="error-wrap" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="retry">重新生成</button>
  </view>

  <!-- [PRD-FAMILY-MEMBER-OPTIM-FINAL 2026-05-31] 三端口径统一：
       标题 / 说明 / 有效期 / 三个 emoji 标签 / 按钮配色 -->
  <view class="invite-content" wx:elif="{{invitation}}">
    <view class="invite-card">
      <view class="invite-header invite-header-grad">
        <text class="invite-title">邀请 TA 加入我的健康守护</text>
        <view class="invite-tags">
          <text class="invite-tag">📋 档案管理</text>
          <text class="invite-tag">💊 用药提醒</text>
          <text class="invite-tag">🔔 异常提醒</text>
        </view>
      </view>

      <view class="qr-wrap" wx:if="{{invitation.qr_content_url || invitation.qr_url}}">
        <qrcode
          id="qrcode"
          text="{{invitation.qr_content_url || invitation.qr_url}}"
          size="{{360}}"
          bind:ready="onQRReady"
        />
        <text class="qr-brand-name">宾尼小康AI健康管家</text>
        <text class="qr-tip">让 TA 扫码或打开链接，确认后就能加入啦</text>
        <text class="qr-expire">邀请 24 小时内有效</text>
      </view>
    </view>

    <view class="action-group">
      <button class="action-btn action-save" bindtap="saveToAlbum">
        <text class="action-btn-icon">📥</text>
        <text>保存到本地</text>
      </button>
      <button class="action-btn action-copy" bindtap="copyLink">
        <text class="action-btn-icon">🔗</text>
        <text>复制链接</text>
      </button>
      <button class="action-btn action-share" open-type="share">
        <text class="action-btn-icon">💬</text>
        <text>转发微信好友</text>
      </button>
    </view>
  </view>
</view>
