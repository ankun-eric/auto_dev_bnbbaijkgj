.order-detail-page {
  padding-bottom: 140rpx;
}

.status-banner {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
}

.status-icon { font-size: 48rpx; margin-right: 16rpx; }
.status-text { font-size: 34rpx; font-weight: bold; color: #fff; }

.card { margin: 24rpx; }

.qr-card { text-align: center; }

.qr-code-wrap {
  padding: 32rpx;
  background: #f6ffed;
  border-radius: 12rpx;
  margin: 16rpx 0;
}

.qr-code-text {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 12rpx;
  color: #52c41a;
}

.qr-hint { font-size: 24rpx; color: #999; }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #999; }
.info-value { font-size: 28rpx; color: #333; }
.price { color: #ff4d4f; font-weight: bold; }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bottom-bar button { flex: 1; }
