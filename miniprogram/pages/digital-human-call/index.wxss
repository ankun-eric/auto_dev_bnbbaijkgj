.dh-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.dh-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

/* 顶部状态栏 */
.dh-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 16rpx;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), transparent);
}

.dh-call-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dh-status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999;
}

.dot-active {
  background: #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.6);
  animation: dotPulse 1.5s infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.dh-status-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.dh-duration {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* 对话气泡区域 */
.dh-dialog-area {
  position: absolute;
  bottom: 240rpx;
  left: 0;
  right: 0;
  height: 400rpx;
  z-index: 10;
  padding: 0 24rpx;
  mask-image: linear-gradient(to bottom, transparent, black 60rpx);
  -webkit-mask-image: linear-gradient(to bottom, transparent, black 60rpx);
}

.dh-dialog-scroll {
  height: 100%;
}

.dh-dialog-item {
  margin-bottom: 16rpx;
}

.dh-dialog-bubble {
  display: inline-block;
  max-width: 80%;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}

.dh-bubble-user {
  float: right;
  background: rgba(82, 196, 26, 0.85);
  border-top-right-radius: 4rpx;
  clear: both;
}

.dh-bubble-ai {
  float: left;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-top-left-radius: 4rpx;
  clear: both;
}

.dh-dialog-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
  word-break: break-all;
}

/* 底部控制栏 */
.dh-bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 20rpx 40rpx 40rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
}

.dh-record-hint {
  text-align: center;
  margin-bottom: 24rpx;
}

.dh-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.dh-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
}

/* 麦克风按钮 */
.dh-mic-btn {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.dh-mic-active {
  background: rgba(82, 196, 26, 0.6);
  border-color: #52c41a;
  animation: micPulse 1s infinite;
}

@keyframes micPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.dh-mic-icon {
  font-size: 48rpx;
}

/* 挂断按钮 */
.dh-hangup-btn {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.4);
}

.dh-hangup-btn:active {
  background: #cf1322;
}

.dh-hangup-icon {
  font-size: 48rpx;
  transform: rotate(135deg);
}

/* 权限弹窗 */
.dh-permission-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dh-permission-dialog {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
}

.dh-perm-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.dh-perm-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.dh-perm-btns {
  display: flex;
  gap: 24rpx;
}

.dh-perm-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.dh-perm-cancel-text {
  font-size: 28rpx;
  color: #666;
}

.dh-perm-confirm {
  flex: 1;
  height: 80rpx !important;
  line-height: 80rpx !important;
  background: #52c41a !important;
  color: #fff !important;
  font-size: 28rpx !important;
  border-radius: 40rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
}
