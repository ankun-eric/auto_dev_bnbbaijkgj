/* ========== 用户模式 - 左右布局 ========== */
.services-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.main-content {
  display: flex;
  flex: 1;
  min-height: 0;
}

/* OPT-1 / M3-b：携券筛选横幅 */
.coupon-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #fff7e6, #fff1d6);
  border-bottom: 1rpx solid #ffe7ba;
}
.coupon-banner-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.coupon-banner-title {
  font-size: 26rpx;
  color: #ad6800;
  font-weight: 600;
}
.coupon-banner-subtitle {
  font-size: 22rpx;
  color: #d48806;
  margin-top: 4rpx;
}
.coupon-banner-close {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #ad6800;
  margin-left: 16rpx;
}

/* --- 左侧一级分类栏 --- */
.left-categories {
  width: 176rpx;
  min-width: 176rpx;
  height: 100%;
  background: #f5f5f5;
  box-sizing: border-box;
}

.cat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  transition: background 0.25s, color 0.25s;
}

.cat-active {
  background: #fff;
  color: #52c41a;
  font-weight: bold;
}

.cat-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: #52c41a;
}

.cat-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.cat-name {
  font-size: 24rpx;
  line-height: 1.3;
  text-align: center;
  word-break: break-all;
}

/* --- 右侧内容区 --- */
.right-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background: #fff;
}

/* --- 二级子类Tab --- */
.sub-tab-scroll {
  flex-shrink: 0;
  white-space: nowrap;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.sub-tab-list {
  display: flex;
  padding: 16rpx 16rpx 16rpx 12rpx;
  gap: 12rpx;
}

.sub-tab-item {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 999rpx;
  transition: background 0.3s, color 0.3s;
}

.sub-tab-active {
  background: #52c41a;
  color: #fff;
  font-weight: bold;
}

/* --- 商品滚动区 --- */
.product-scroll {
  flex: 1;
  height: 0;
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
}

.product-group {
  padding-top: 8rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 0 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 12rpx;
}

/* --- 商品卡片 --- */
.service-card {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.service-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.service-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.service-icon {
  font-size: 44rpx;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.service-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.service-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.service-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #ff4d4f;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price-suffix {
  font-size: 20rpx;
  font-weight: normal;
  color: #52c41a;
  margin-left: 2rpx;
}

.service-sales {
  font-size: 22rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* --- 履约类型角标 --- */
.fulfillment-badge {
  display: inline-block;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  border-radius: 6rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

/* --- 空状态 / 加载 --- */
.empty-state,
.loading-more,
.load-end {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.loading-text,
.load-end-text {
  font-size: 24rpx;
  color: #999;
}

/* ========== 商家模式 — 保持不变 ========== */
.records-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.filter-bar {
  margin-bottom: 24rpx;
}

.filter-row,
.date-pickers,
.record-top,
.record-row {
  display: flex;
  align-items: center;
}

.filter-row,
.record-top,
.record-row {
  justify-content: space-between;
}

.filter-label,
.summary-text {
  font-size: 26rpx;
  color: #333;
}

.date-pickers {
  gap: 12rpx;
}

.date-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  color: #333;
}

.date-sep {
  font-size: 22rpx;
  color: #999;
}

.quick-dates {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.quick-date-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  color: #666;
}

.quick-date-btn.active {
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
}

.summary-bar {
  margin-bottom: 16rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-service {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.record-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.record-badge.success {
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
}

.record-info {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-label,
.empty-sub,
.loading-text,
.load-end-text {
  font-size: 24rpx;
  color: #999;
}

.info-value {
  font-size: 24rpx;
  color: #333;
}

.info-value.price {
  color: #ff4d4f;
  font-weight: 600;
}
