<view class="services-page" wx:if="{{pageMode === 'user'}}">
  <!-- OPT-1 / M3-b：携券进入时显示横幅 -->
  <view class="coupon-banner" wx:if="{{bannerVisible && couponBanner}}">
    <view class="coupon-banner-body">
      <text class="coupon-banner-title">{{couponBanner.title}}</text>
      <text class="coupon-banner-subtitle" wx:if="{{couponBanner.subtitle}}">{{couponBanner.subtitle}}</text>
    </view>
    <text class="coupon-banner-close" catchtap="closeCouponBanner">×</text>
  </view>
  <view class="main-content">
    <!-- 左侧一级分类栏 -->
    <scroll-view class="left-categories" scroll-y>
      <view class="cat-item {{activeTopIndex === index ? 'cat-active' : ''}}"
            wx:for="{{topCategories}}" wx:key="id"
            bindtap="switchTopCategory" data-index="{{index}}">
        <view class="cat-indicator" wx:if="{{activeTopIndex === index}}"></view>
        <text class="cat-icon" wx:if="{{item.icon}}">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧内容区 -->
    <view class="right-content">
      <!-- 二级子类Tab -->
      <scroll-view class="sub-tab-scroll" scroll-x enable-flex wx:if="{{subCategories.length > 0}}">
        <view class="sub-tab-list">
          <view class="sub-tab-item {{activeSubIndex === -1 ? 'sub-tab-active' : ''}}"
                bindtap="switchSubCategory" data-index="{{-1}}">全部</view>
          <view class="sub-tab-item {{activeSubIndex === index ? 'sub-tab-active' : ''}}"
                wx:for="{{subCategories}}" wx:key="id"
                bindtap="switchSubCategory" data-index="{{index}}">
            {{item.name}}
          </view>
        </view>
      </scroll-view>

      <!-- 商品列表 -->
      <scroll-view class="product-scroll" scroll-y
                    scroll-into-view="{{scrollToView}}"
                    bindscroll="onProductScroll"
                    scroll-with-animation>
        <block wx:for="{{groupedServices}}" wx:key="categoryId" wx:for-item="group">
          <view id="group-{{group.categoryId}}" class="product-group">
            <view class="group-title" wx:if="{{group.categoryName}}">{{group.categoryName}}</view>
            <view class="service-card card" wx:for="{{group.items}}" wx:key="id" wx:for-item="item"
                  bindtap="goServiceDetail" data-id="{{item.id}}">
              <image class="service-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}"></image>
              <view class="service-icon-wrap" style="background: {{item.bgColor}};" wx:else>
                <text class="service-icon">{{item.icon}}</text>
              </view>
              <view class="service-info">
                <text class="service-name">{{item.name}}</text>
                <text class="service-desc ellipsis-2">{{item.desc}}</text>
                <view class="service-footer">
                  <view class="service-price-row">
                    <view class="service-price">
                      <text class="price-symbol">¥</text>
                      <text class="price-value">{{item.price}}</text>
                      <text wx:if="{{item.hasMultiSpec}}" class="price-suffix">起</text>
                    </view>
                    <view class="fulfillment-badge" wx:if="{{item.fulfillmentText}}"
                          style="background: {{item.fulfillmentColor}};">
                      {{item.fulfillmentText}}
                    </view>
                  </view>
                  <text class="service-sales">已售{{item.sales}}</text>
                </view>
              </view>
            </view>
          </view>
        </block>

        <view class="empty-state" wx:if="{{!loading && groupedServices.length === 0}}">
          <text class="empty-icon">📦</text>
          <text class="empty-text">暂无相关服务</text>
        </view>

        <view class="loading-more" wx:if="{{loading}}">
          <text class="loading-text">加载中...</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<view class="container records-page" wx:else>
  <view class="filter-bar card">
    <view class="filter-row">
      <text class="filter-label">筛选日期</text>
      <view class="date-pickers">
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-btn">{{startDate || '开始日期'}}</view>
        </picker>
        <text class="date-sep">至</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="date-btn">{{endDate || '结束日期'}}</view>
        </picker>
      </view>
    </view>
    <view class="quick-dates">
      <view class="quick-date-btn {{activeQuick === 'today' ? 'active' : ''}}" bindtap="filterToday">今日</view>
      <view class="quick-date-btn {{activeQuick === 'week' ? 'active' : ''}}" bindtap="filterWeek">本周</view>
      <view class="quick-date-btn {{activeQuick === 'month' ? 'active' : ''}}" bindtap="filterMonth">本月</view>
      <view class="quick-date-btn {{activeQuick === 'all' ? 'active' : ''}}" bindtap="filterAll">全部</view>
    </view>
  </view>

  <view class="summary-bar">
    <text class="summary-text">共 <text class="text-green">{{totalCount}}</text> 条记录</text>
  </view>

  <view class="record-list" wx:if="{{records.length > 0}}">
    <view class="record-item card" wx:for="{{records}}" wx:key="id">
      <view class="record-top">
        <text class="record-service">{{item.service_name}}</text>
        <view class="record-badge success">已核销</view>
      </view>
      <view class="record-info">
        <view class="record-row">
          <text class="info-label">订单号</text>
          <text class="info-value">{{item.order_no}}</text>
        </view>
        <view class="record-row">
          <text class="info-label">用户</text>
          <text class="info-value">{{item.user_name}}</text>
        </view>
        <view class="record-row">
          <text class="info-label">金额</text>
          <text class="info-value price">¥{{item.amount}}</text>
        </view>
        <view class="record-row">
          <text class="info-label">核销时间</text>
          <text class="info-value">{{item.verify_time}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无核销记录</text>
    <text class="empty-sub">核销订单后将在此显示</text>
  </view>

  <view class="loading-more" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="load-end" wx:if="{{!loading && noMore && records.length > 0}}">
    <text class="load-end-text">— 没有更多了 —</text>
  </view>
</view>
