<view class="chat-page">

  <!-- 药物识别结构化面板（有ai_result时展示） -->
  <view class="drug-panel" wx:if="{{showDrugPanel && drugs.length > 0}}">

    <!-- 多药物：相互作用警告框 -->
    <view class="interaction-warning" wx:if="{{drugs.length > 1 && interactions.length > 0}}">
      <view class="interaction-warning-header">
        <text class="interaction-icon">⚠️</text>
        <text class="interaction-title">药物相互作用提示</text>
      </view>
      <view class="interaction-item" wx:for="{{interactions}}" wx:key="index">
        <text class="interaction-drugs">{{item.drugs.join(' + ')}}</text>
        <text class="interaction-risk">{{item.risk}}</text>
      </view>
    </view>

    <!-- 多药物：药物卡片列表（可折叠） -->
    <view wx:if="{{drugs.length > 1}}">
      <view class="drug-card-fold" wx:for="{{drugs}}" wx:key="_idx" wx:for-index="dIdx">
        <view class="drug-card-fold-header" bindtap="toggleDrug" data-idx="{{dIdx}}">
          <text class="drug-card-fold-name">{{item.name}}</text>
          <text class="drug-fold-arrow {{expandedDrugs[dIdx] ? 'arrow-up' : 'arrow-down'}}">›</text>
        </view>
        <view class="drug-card-fold-body" wx:if="{{expandedDrugs[dIdx]}}">
          <view class="drug-info-row" wx:if="{{item.ingredients}}">
            <text class="drug-info-label">成分</text>
            <text class="drug-info-value">{{item.ingredients}}</text>
          </view>
          <view class="drug-info-row" wx:if="{{item.specification}}">
            <text class="drug-info-label">规格</text>
            <text class="drug-info-value">{{item.specification}}</text>
          </view>
          <view class="drug-info-row" wx:if="{{item.indications}}">
            <text class="drug-info-label">适应症</text>
            <text class="drug-info-value">{{item.indications}}</text>
          </view>
          <view class="drug-info-row" wx:if="{{item.dosage}}">
            <text class="drug-info-label">用法用量</text>
            <text class="drug-info-value">{{item.dosage}}</text>
          </view>
          <view class="drug-info-row" wx:if="{{item.precautions}}">
            <text class="drug-info-label">注意事项</text>
            <text class="drug-info-value">{{item.precautions}}</text>
          </view>
          <view class="drug-suggestion-box" wx:if="{{item.ai_suggestion_general}}">
            <text class="drug-suggestion-label">AI建议</text>
            <text class="drug-suggestion-text">{{item.ai_suggestion_general}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 单药物：详情卡片 + Tab -->
    <view wx:if="{{drugs.length === 1}}">
      <view class="drug-single-card">
        <text class="drug-single-name">{{drugs[0].name}}</text>
        <view class="drug-info-row" wx:if="{{drugs[0].ingredients}}">
          <text class="drug-info-label">成分</text>
          <text class="drug-info-value">{{drugs[0].ingredients}}</text>
        </view>
        <view class="drug-info-row" wx:if="{{drugs[0].specification}}">
          <text class="drug-info-label">规格</text>
          <text class="drug-info-value">{{drugs[0].specification}}</text>
        </view>
        <view class="drug-info-row" wx:if="{{drugs[0].indications}}">
          <text class="drug-info-label">适应症</text>
          <text class="drug-info-value">{{drugs[0].indications}}</text>
        </view>
        <view class="drug-info-row" wx:if="{{drugs[0].dosage}}">
          <text class="drug-info-label">用法用量</text>
          <text class="drug-info-value">{{drugs[0].dosage}}</text>
        </view>
        <view class="drug-info-row" wx:if="{{drugs[0].precautions}}">
          <text class="drug-info-label">注意事项</text>
          <text class="drug-info-value">{{drugs[0].precautions}}</text>
        </view>
      </view>

      <!-- 建议 Tab -->
      <view class="suggest-tab-bar">
        <view class="suggest-tab {{activeTab === 'general' ? 'suggest-tab-active' : ''}}" bindtap="switchTab" data-tab="general">
          <text>通用建议</text>
        </view>
        <view class="suggest-tab {{activeTab === 'personal' ? 'suggest-tab-active' : ''}}" bindtap="switchTab" data-tab="personal">
          <text>个性化建议</text>
        </view>
      </view>

      <view class="suggest-tab-content">
        <!-- 通用建议 -->
        <view wx:if="{{activeTab === 'general'}}">
          <text class="suggest-content" wx:if="{{drugs[0].ai_suggestion_general}}">{{drugs[0].ai_suggestion_general}}</text>
          <text class="suggest-empty" wx:else>暂无通用建议</text>
        </view>
        <!-- 个性化建议 -->
        <view wx:if="{{activeTab === 'personal'}}">
          <view class="personal-loading" wx:if="{{loadingPersonal}}">
            <text class="personal-loading-text">加载中...</text>
          </view>
          <text class="suggest-content" wx:elif="{{personalSuggestion}}">{{personalSuggestion}}</text>
          <text class="suggest-empty" wx:elif="{{drugs[0].ai_suggestion_personal}}">{{drugs[0].ai_suggestion_personal}}</text>
          <text class="suggest-empty" wx:else>暂无个性化建议</text>
        </view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <view class="drug-share-row" wx:if="{{recordId}}">
      <view class="drug-share-btn" bindtap="shareDrug">
        <text class="drug-share-icon">📤</text>
        <text class="drug-share-text">复制分享链接</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
    <view class="chat-notice">
      <text class="notice-text">AI识别结果仅供参考，用药请遵医嘱。</text>
    </view>

    <view class="msg-item" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- AI消息 -->
      <view class="msg-row msg-left" wx:if="{{item.role === 'assistant'}}">
        <view class="msg-avatar ai-avatar">
          <text class="avatar-emoji">🤖</text>
        </view>
        <view class="msg-bubble ai-bubble">
          <text class="msg-text">{{item.mainContent || item.content}}</text>
          <view wx:if="{{item.disclaimer}}" class="disclaimer">
            <text class="disclaimer-text">{{item.disclaimer}}</text>
          </view>
          <text class="msg-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 用户消息 -->
      <view class="msg-row msg-right" wx:elif="{{item.role === 'user'}}">
        <view class="msg-bubble user-bubble">
          <image class="msg-image" src="{{item.image}}" mode="widthFix" wx:if="{{item.image}}" bindtap="previewImage" data-url="{{item.image}}" />
          <text class="msg-text" wx:else>{{item.content}}</text>
          <text class="msg-time user-time">{{item.time}}</text>
        </view>
        <view class="msg-avatar user-avatar">
          <text class="avatar-emoji">👤</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view class="msg-row msg-left" wx:elif="{{item.role === 'loading'}}">
        <view class="msg-avatar ai-avatar">
          <text class="avatar-emoji">🤖</text>
        </view>
        <view class="msg-bubble ai-bubble">
          <view class="typing-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view id="msg-bottom" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area safe-bottom">
    <view class="input-bar">
      <view class="tool-btn" bindtap="takePhoto">
        <text class="tool-icon">📷</text>
      </view>
      <view class="tool-btn" bindtap="chooseAlbum">
        <text class="tool-icon">🖼️</text>
      </view>
      <input class="chat-input" placeholder="输入您的问题..." value="{{inputValue}}"
             bindinput="onInput" confirm-type="send" bindconfirm="sendMessage"
             adjust-position="{{false}}" focus="{{inputFocus}}" />
      <view class="send-btn {{inputValue ? 'send-active' : ''}}" bindtap="sendMessage">
        <text class="send-text">发送</text>
      </view>
    </view>
  </view>
</view>
