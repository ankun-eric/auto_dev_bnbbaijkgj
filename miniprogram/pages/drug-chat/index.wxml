<view class="chat-page">

  <!-- v1.2 融合卡片（平铺，无 swiper） -->
  <view class="fused-card" wx:if="{{drugCount > 0}}">
    <view class="fused-card-body">
      <!-- 左侧 40%：药图 -->
      <view class="fused-left">
        <!-- 单药：一张 280×280rpx -->
        <view wx:if="{{drugCount === 1}}" class="drug-img-wrap drug-img-single"
              bindtap="previewDrugImage" data-idx="0">
          <image class="drug-img" src="{{drugList[0].image_url}}" mode="aspectFill" wx:if="{{drugList[0].image_url}}" />
          <view class="drug-img-fallback" wx:else>
            <text class="drug-img-fallback-emoji">💊</text>
          </view>
        </view>
        <!-- 双药：两张 136×280rpx -->
        <view wx:if="{{drugCount >= 2}}" class="drug-img-dual">
          <view class="drug-img-wrap drug-img-half" bindtap="previewDrugImage" data-idx="0">
            <image class="drug-img" src="{{drugList[0].image_url}}" mode="aspectFill" wx:if="{{drugList[0].image_url}}" />
            <view class="drug-img-fallback" wx:else><text class="drug-img-fallback-emoji">💊</text></view>
          </view>
          <view class="drug-img-wrap drug-img-half" bindtap="previewDrugImage" data-idx="1">
            <image class="drug-img" src="{{drugList[1].image_url}}" mode="aspectFill" wx:if="{{drugList[1].image_url}}" />
            <view class="drug-img-fallback" wx:else><text class="drug-img-fallback-emoji">💊</text></view>
          </view>
        </view>
      </view>

      <!-- 右侧 60%：成员信息 + 药名列表 -->
      <view class="fused-right">
        <view class="member-row" wx:if="{{memberInfo}}">
          <view class="member-avatar">
            <text class="member-avatar-emoji">👤</text>
          </view>
          <text class="member-name">{{memberDisplay}}</text>
        </view>

        <view class="drug-name-list">
          <view class="drug-name-item" wx:for="{{drugList}}" wx:key="id"
                bindtap="onDrugNameTap" data-name="{{item.name}}">
            <text class="drug-name-text">💊 {{item.name}}</text>
          </view>
        </view>

        <!-- 再加一个药 -->
        <view class="add-drug-btn {{canAddMore ? '' : 'add-drug-btn-disabled'}}"
              bindtap="addMoreDrug">
          <text class="add-drug-text" wx:if="{{canAddMore}}">➕ 再加一个药</text>
          <text class="add-drug-text" wx:else>已达上限（最多 2 个）</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
    <view class="chat-notice">
      <text class="notice-text">AI识别结果仅供参考，用药请遵医嘱。</text>
    </view>

    <view class="msg-item" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <!-- AI消息 -->
      <view class="msg-row msg-left" wx:if="{{item.role === 'assistant'}}">
        <view class="msg-avatar ai-avatar">
          <text class="avatar-emoji">🤖</text>
        </view>
        <view class="msg-bubble ai-bubble">
          <text class="msg-text" user-select="{{true}}" space="nbsp" decode="{{true}}">{{item.mainContent || item.content}}</text>
          <view wx:if="{{item.disclaimer}}" class="disclaimer">
            <text class="disclaimer-text">{{item.disclaimer}}</text>
          </view>
          <!-- 首条 AI 建议：重新生成按钮 -->
          <view wx:if="{{item.isOpening || (openingMessageId && item.id === openingMessageId)}}"
                class="regenerate-row">
            <view class="regenerate-btn {{regenerating ? 'regenerate-btn-disabled' : ''}}"
                  bindtap="regenerateOpening">
              <text class="regenerate-text">🔄 重新生成这条建议</text>
            </view>
          </view>
          <text class="msg-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 用户消息 -->
      <view class="msg-row msg-right" wx:elif="{{item.role === 'user'}}">
        <view class="msg-bubble user-bubble">
          <image class="msg-image" src="{{item.image}}" mode="widthFix" wx:if="{{item.image}}" bindtap="previewImage" data-url="{{item.image}}" />
          <text class="msg-text" wx:else>{{item.content}}</text>
          <text class="msg-time user-time">{{item.time}}</text>
        </view>
        <view class="msg-avatar user-avatar">
          <text class="avatar-emoji">👤</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view class="msg-row msg-left" wx:elif="{{item.role === 'loading'}}">
        <view class="msg-avatar ai-avatar">
          <text class="avatar-emoji">🤖</text>
        </view>
        <view class="msg-bubble ai-bubble">
          <view class="typing-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view id="msg-bottom" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area safe-bottom">
    <view class="input-bar">
      <view class="tool-btn" bindtap="takePhoto">
        <text class="tool-icon">📷</text>
      </view>
      <view class="tool-btn" bindtap="chooseAlbum">
        <text class="tool-icon">🖼️</text>
      </view>
      <input class="chat-input" placeholder="输入您的问题..." value="{{inputValue}}"
             bindinput="onInput" confirm-type="send" bindconfirm="sendMessage"
             adjust-position="{{false}}" focus="{{inputFocus}}" />
      <view class="send-btn {{inputValue ? 'send-active' : ''}}" bindtap="sendMessage">
        <text class="send-text">发送</text>
      </view>
    </view>
  </view>
</view>
