.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* ========================
   v1.2 融合卡片（平铺）
   ======================== */
.fused-card {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.fused-card-body {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  align-items: stretch;
}

/* 左侧 40% */
.fused-left {
  width: 40%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drug-img-wrap {
  background: #f5f5f5;
  border: 1rpx solid #ececec;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 单药 280×280rpx */
.drug-img-single {
  width: 280rpx;
  height: 280rpx;
}

/* 双药并排 */
.drug-img-dual {
  display: flex;
  gap: 8rpx;
  width: 100%;
  justify-content: center;
}

.drug-img-half {
  width: 136rpx;
  height: 280rpx;
}

.drug-img {
  width: 100%;
  height: 100%;
  display: block;
}

.drug-img-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.drug-img-fallback-emoji {
  font-size: 72rpx;
  opacity: 0.6;
}

/* 右侧 60% */
.fused-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 16rpx;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar-emoji {
  font-size: 28rpx;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  flex: 1;
}

.drug-name-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.drug-name-item {
  padding: 4rpx 0;
}

.drug-name-text {
  font-size: 30rpx;
  color: #000;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 再加一个药按钮 */
.add-drug-btn {
  margin-top: auto;
  padding: 14rpx 20rpx;
  border: 2rpx dashed #52c41a;
  border-radius: 16rpx;
  text-align: center;
  background: #f6ffed;
}

.add-drug-btn:active { opacity: 0.8; }

.add-drug-text {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: 500;
}

.add-drug-btn-disabled {
  border-color: #d9d9d9;
  background: #f5f5f5;
}

.add-drug-btn-disabled .add-drug-text {
  color: #999;
}

/* ========================
   消息列表
   ======================== */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.msg-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  margin-right: 16rpx;
}

.user-avatar {
  background: #e6f7ff;
  margin-left: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

.msg-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.user-bubble {
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 32rpx;
  line-height: 1.7;
  word-break: break-all;
  color: #333;
  white-space: pre-wrap;
  display: block;
}

.user-bubble .msg-text {
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}

/* 重新生成按钮 */
.regenerate-row {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
  display: flex;
  justify-content: flex-start;
}

.regenerate-btn {
  padding: 10rpx 20rpx;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 24rpx;
}

.regenerate-btn:active { opacity: 0.7; }

.regenerate-btn-disabled {
  opacity: 0.5;
}

.regenerate-text {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: 500;
}

/* ========================
   输入区域
   ======================== */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon { font-size: 40rpx; }

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: #e8e8e8;
  flex-shrink: 0;
}

.send-active {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.send-text {
  font-size: 26rpx;
  color: #fff;
}
