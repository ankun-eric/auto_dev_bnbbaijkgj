.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* ========================
   药物识别结构化面板
   ======================== */
.drug-panel {
  background: #fff;
  border-bottom: 1rpx solid #eee;
  max-height: 60vh;
  overflow-y: auto;
  padding: 24rpx;
}

/* 相互作用警告框 */
.interaction-warning {
  background: #fffbe6;
  border: 1rpx solid #FAAD14;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.interaction-warning-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.interaction-icon {
  font-size: 30rpx;
}

.interaction-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #7c5b00;
}

.interaction-item {
  padding: 10rpx 0;
  border-top: 1rpx dashed #ffe58f;
}

.interaction-drugs {
  font-size: 24rpx;
  color: #FAAD14;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.interaction-risk {
  font-size: 24rpx;
  color: #7c5b00;
  line-height: 1.6;
}

/* 多药折叠卡片 */
.drug-card-fold {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.drug-card-fold-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fafafa;
}

.drug-card-fold-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.drug-fold-arrow {
  font-size: 36rpx;
  color: #999;
  display: inline-block;
  line-height: 1;
}

.arrow-down { transform: rotate(0deg); }
.arrow-up { transform: rotate(90deg); }

.drug-card-fold-body {
  padding: 16rpx 24rpx;
  background: #fff;
}

/* 单药卡片 */
.drug-single-card {
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.drug-single-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  display: block;
  margin-bottom: 16rpx;
}

/* 药物信息行 */
.drug-info-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.drug-info-row:last-child {
  border-bottom: none;
}

.drug-info-label {
  font-size: 22rpx;
  color: #999;
  min-width: 96rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.drug-info-value {
  font-size: 24rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* 多药时的建议框 */
.drug-suggestion-box {
  margin-top: 14rpx;
  background: #f0f9eb;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
}

.drug-suggestion-label {
  font-size: 22rpx;
  color: #52C41A;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.drug-suggestion-text {
  font-size: 24rpx;
  color: #444;
  line-height: 1.6;
}

/* 建议 Tab 栏 */
.suggest-tab-bar {
  display: flex;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}

.suggest-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #888;
  border-radius: 8rpx;
}

.suggest-tab-active {
  background: #fff;
  color: #52C41A;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.suggest-tab-content {
  min-height: 80rpx;
  margin-bottom: 8rpx;
}

.suggest-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

.suggest-empty {
  font-size: 26rpx;
  color: #bbb;
}

.personal-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.personal-loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 分享行 */
.drug-share-row {
  display: flex;
  justify-content: flex-end;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.drug-share-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #52C41A, #13c2c2);
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
}

.drug-share-icon {
  font-size: 26rpx;
}

.drug-share-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* ========================
   消息列表
   ======================== */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.chat-notice {
  text-align: center;
  padding: 16rpx 40rpx;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.04);
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.msg-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
}

.msg-left { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  margin-right: 16rpx;
}

.user-avatar {
  background: #e6f7ff;
  margin-left: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.ai-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.user-bubble {
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble .msg-text {
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.user-time {
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

.msg-image {
  max-width: 100%;
  border-radius: 12rpx;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ========================
   输入区域
   ======================== */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-icon { font-size: 40rpx; }

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: #e8e8e8;
  flex-shrink: 0;
}

.send-active {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.send-text {
  font-size: 26rpx;
  color: #fff;
}

.disclaimer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
  line-height: 1.5;
}
