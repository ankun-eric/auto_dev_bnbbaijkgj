.coupon-center {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 30rpx;
}
.banner {
  padding: 30rpx 32rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
}
.banner-title { font-size: 36rpx; font-weight: 600; }
.banner-sub { font-size: 24rpx; margin-top: 6rpx; opacity: 0.9; }

.coupon-list { padding: 24rpx 24rpx 0; }

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.coupon-left {
  width: 200rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.coupon-card.disabled .coupon-left {
  background: linear-gradient(135deg, #bdbdbd, #9e9e9e);
}
.coupon-amount { font-size: 40rpx; font-weight: 700; }
.coupon-condition { font-size: 22rpx; margin-top: 8rpx; }

.coupon-divider {
  width: 0;
  border-left: 2rpx dashed #eee;
}

.coupon-right {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}
.coupon-card.disabled .coupon-name,
.coupon-card.disabled .coupon-expire,
.coupon-card.disabled .coupon-stock {
  color: #999 !important;
}

.coupon-name { font-size: 28rpx; color: #222; font-weight: 500; }
.coupon-expire { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.coupon-stock { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.coupon-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff !important;
  border-radius: 32rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}
.coupon-btn.btn-disabled {
  background: #e8e8e8 !important;
  color: #999 !important;
}

.loading-state, .empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 26rpx;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
