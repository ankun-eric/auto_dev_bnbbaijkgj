.products-page {
  padding-bottom: 24rpx;
}

.category-scroll {
  background: #fff;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 12rpx;
}

.category-list.sub {
  background: #fafafa;
}

.category-item {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
}

.category-item.active {
  color: #52c41a;
  font-weight: bold;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #52c41a;
  border-radius: 2rpx;
}

.sub-item {
  font-size: 24rpx;
  padding: 16rpx 24rpx;
}

.sub-item.active::after {
  bottom: 2rpx;
  width: 32rpx;
  height: 3rpx;
}

.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.filter-toggle-text {
  font-size: 26rpx;
  color: #666;
}

.filter-arrow {
  font-size: 18rpx;
  color: #999;
  margin-left: 8rpx;
  transition: transform 0.2s;
}

.filter-arrow.up {
  transform: rotate(180deg);
}

.filter-panel {
  background: #fff;
  padding: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.filter-section {
  margin-bottom: 24rpx;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #666;
}

.filter-tag.active {
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
}

.filter-check {
  display: flex;
  align-items: center;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #fff;
}

.check-box.checked {
  background: #52c41a;
  border-color: #52c41a;
}

.filter-check-label {
  font-size: 26rpx;
  color: #333;
}

.product-list {
  padding: 24rpx;
}

.product-card {
  display: flex;
  align-items: flex-start;
}

.product-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 200rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.product-tag {
  font-size: 20rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: auto;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-sym {
  font-size: 22rpx;
  color: #ff4d4f;
}

.price-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price-original {
  font-size: 22rpx;
  color: #ccc;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.product-sales {
  font-size: 22rpx;
  color: #ccc;
}

.product-points {
  margin-top: 8rpx;
}

.product-points text {
  font-size: 22rpx;
  color: #faad14;
}

.loading-more,
.load-end {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text,
.load-end-text {
  font-size: 24rpx;
  color: #999;
}
