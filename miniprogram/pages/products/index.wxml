<wxs src="/utils/fulfillmentLabel.wxs" module="ff" />
<view class="products-page">
  <!-- 分类横向滚动 -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view class="category-list">
      <view class="category-item {{currentCategoryId === item.id ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="id"
            bindtap="switchCategory" data-item="{{item}}">
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 二级分类 -->
  <scroll-view class="sub-category-scroll" scroll-x enable-flex wx:if="{{subCategories.length > 0}}">
    <view class="category-list sub">
      <view class="category-item sub-item {{currentSubCategoryId === item.id ? 'active' : ''}}"
            wx:for="{{subCategories}}" wx:key="id"
            bindtap="switchSubCategory" data-item="{{item}}">
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 筛选栏 -->
  <view class="filter-toggle" bindtap="toggleFilter">
    <text class="filter-toggle-text">筛选</text>
    <text class="filter-arrow {{showFilter ? 'up' : ''}}">▼</text>
  </view>

  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="filter-section">
      <text class="filter-title">履约方式</text>
      <view class="filter-options">
        <view class="filter-tag {{currentFulfillment === index ? 'active' : ''}}"
              wx:for="{{fulfillmentTypes}}" wx:key="index"
              bindtap="switchFulfillment" data-index="{{index}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>
    <view class="filter-section">
      <text class="filter-title">价格区间</text>
      <view class="filter-options">
        <view class="filter-tag {{currentPriceRange === index ? 'active' : ''}}"
              wx:for="{{priceRanges}}" wx:key="index"
              bindtap="switchPriceRange" data-index="{{index}}">
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="filter-section">
      <view class="filter-check" bindtap="togglePointsOnly">
        <view class="check-box {{pointsOnly ? 'checked' : ''}}">
          <text wx:if="{{pointsOnly}}">✓</text>
        </view>
        <text class="filter-check-label">仅看积分可兑换</text>
      </view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view class="product-card card" wx:for="{{products}}" wx:key="id"
          bindtap="goDetail" data-id="{{item.id}}">
      <image class="product-img" src="{{item.cover_image}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name ellipsis-2">{{item.name}}</text>
        <view class="product-tags" wx:if="{{item.fulfillment_type}}">
          <text class="product-tag">{{item.fulfillment_type_label || ff.fulfillmentLabel(item.fulfillment_type)}}</text>
        </view>
        <view class="product-bottom">
          <view class="product-price">
            <text class="price-sym">¥</text>
            <text class="price-num">{{item.price}}</text>
            <text class="price-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
          </view>
          <text class="product-sales" wx:if="{{item.sales}}">已售{{item.sales}}</text>
        </view>
        <view class="product-points" wx:if="{{item.points_price}}">
          <text>{{item.points_price}}积分可兑</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
  <view class="load-end" wx:if="{{!loading && noMore && products.length > 0}}">
    <text class="load-end-text">— 没有更多了 —</text>
  </view>
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <text class="empty-icon">🛍️</text>
    <text class="empty-text">暂无商品</text>
  </view>
</view>
