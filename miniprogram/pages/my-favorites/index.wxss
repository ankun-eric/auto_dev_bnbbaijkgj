.favorites-page {
  padding-bottom: 24rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #52c41a;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #52c41a;
  border-radius: 2rpx;
}

.fav-list {
  padding: 24rpx;
}

.fav-card {
  margin-bottom: 16rpx;
}

.fav-content {
  display: flex;
  align-items: flex-start;
}

.fav-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.fav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.fav-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.fav-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.fav-desc {
  font-size: 24rpx;
  color: #999;
}

.fav-remove {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.remove-text {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 24rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 999rpx;
}

.loading-more,
.load-end {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text,
.load-end-text {
  font-size: 24rpx;
  color: #999;
}
