.detail-page {
  padding: 24rpx;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.loading-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Header card */
.detail-header-card {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
}

.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.detail-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.detail-icon {
  font-size: 56rpx;
}

.detail-type {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.detail-member-tag {
  font-size: 24rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.12);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.detail-date {
  font-size: 22rpx;
  color: #999;
}

/* Section title */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* Traits */
.trait-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trait-item {
  display: flex;
  align-items: flex-start;
}

.trait-dot {
  color: #52c41a;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.trait-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* Advice */
.advice-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-block {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
}

.advice-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin-bottom: 8rpx;
}

.advice-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* Products */
.products-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.view-more {
  font-size: 24rpx;
  color: #52c41a;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-item {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.product-image {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.product-placeholder {
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-placeholder-icon {
  font-size: 48rpx;
}

.product-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4rpx;
}

.product-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* Bottom action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.consult-btn {
  width: 100%;
  margin: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
}
