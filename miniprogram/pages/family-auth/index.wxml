<view class="auth-page">
  <!-- Loading -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载邀请信息…</text>
  </view>

  <!-- Error -->
  <view class="result-wrap" wx:elif="{{error}}">
    <text class="result-icon">⚠️</text>
    <text class="result-text">{{error}}</text>
    <button class="home-btn" bindtap="goHome">返回首页</button>
  </view>

  <!-- Success result：守护关系建立成功 + 关注公众号引导 -->
  <view class="success-wrap" wx:elif="{{resultStatus === 'success'}}">
    <view class="success-card">
      <view class="success-avatar-wrap">
        <image class="success-avatar" wx:if="{{invitation.inviter_avatar}}" src="{{invitation.inviter_avatar}}" mode="aspectFill" />
        <view class="success-avatar-placeholder" wx:else>
          <text class="avatar-text">{{invitation.inviter_nickname ? invitation.inviter_nickname[0] : '家'}}</text>
        </view>
      </view>
      <text class="success-name">{{invitation.inviter_nickname || '家人'}}</text>
      <text class="success-relation">已成功守护 {{invitation.inviter_nickname || '对方'}}</text>
      <text class="success-hint">可在第一时间收到对方的体检异常等健康提醒</text>
    </view>
    <!-- 强制关注公众号引导 -->
    <view class="follow-mp-card">
      <text class="follow-mp-title">📣 还差最后一步：关注公众号</text>
      <text class="follow-mp-desc">为了让您能及时收到体检异常提醒，请长按下方二维码识别并关注"贝尼健康"公众号</text>
      <view class="follow-mp-qr">
        <text class="follow-mp-qr-placeholder">[ 公众号二维码 ]</text>
      </view>
      <text class="follow-mp-tip">关注后即可在异常发生时第一时间收到推送</text>
    </view>
    <view class="success-actions">
      <button class="home-btn" bindtap="goHome">已关注，打开首页</button>
      <text class="later-link" bindtap="goHomeLater">稍后再说</text>
    </view>
  </view>

  <!-- Rejected / Error result -->
  <view class="result-wrap" wx:elif="{{resultStatus}}">
    <text class="result-icon" wx:if="{{resultStatus === 'rejected'}}">🚫</text>
    <text class="result-icon" wx:else>❌</text>
    <text class="result-text">{{resultMessage}}</text>
    <view class="result-actions">
      <button class="home-btn" bindtap="goHome">返回首页</button>
    </view>
  </view>

  <!-- Pending confirmation -->
  <view class="auth-content" wx:elif="{{invitation}}">
    <view class="auth-card">
      <view class="auth-icon-wrap">
        <text class="auth-icon">🤝</text>
      </view>
      <text class="auth-inviter-name">{{invitation.inviter_nickname || '对方'}}</text>
      <text class="auth-desc">TA 邀请你加入家庭健康圈</text>
    </view>

    <view class="auth-actions">
      <button class="accept-btn" bindtap="onAccept" disabled="{{processing}}" loading="{{processing}}">同意</button>
      <button class="reject-btn" bindtap="onReject" disabled="{{processing}}">拒绝</button>
    </view>
  </view>
</view>
