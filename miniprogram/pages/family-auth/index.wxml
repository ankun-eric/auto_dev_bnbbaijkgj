<!-- [PRD-FAMILY-AUTH-MP-V1] 接受守护邀请页 -->
<view class="auth-page">
  <!-- 顶部品牌条 -->
  <view class="brand-bar">
    <view class="brand-logo">
      <text class="brand-logo-text">B</text>
    </view>
    <text class="brand-title">{{inviteType === 'reverse' ? '健康守护邀请' : '家庭健康守护邀请'}}</text>
    <view class="brand-cs" bindtap="onCallService">
      <text class="brand-cs-icon">💬</text>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载邀请信息…</text>
  </view>

  <!-- 致命错误（参数缺失 / 网络异常） -->
  <view class="result-wrap" wx:elif="{{error}}">
    <text class="result-icon">⚠️</text>
    <text class="result-text">{{error}}</text>
    <view class="result-actions">
      <button wx:if="{{networkError}}" class="primary-btn" bindtap="onRetry">重试</button>
      <button class="ghost-btn" bindtap="goHome">返回首页</button>
    </view>
  </view>

  <!-- 失效态（PRD §5） -->
  <view class="invalid-wrap" wx:elif="{{invalidReason}}">
    <view class="invalid-card">
      <text class="invalid-icon">🚫</text>
      <text class="invalid-title">{{invalidTitle}}</text>
      <text class="invalid-desc">{{invalidDesc}}</text>
      <view class="invalid-actions">
        <button
          wx:if="{{invalidAction === 'contact'}}"
          class="primary-btn"
          bindtap="onInvalidAction"
        >联系邀请人</button>
        <button
          wx:elif="{{invalidAction === 'bindlist'}}"
          class="primary-btn"
          bindtap="onInvalidAction"
        >前往「我的家庭」</button>
        <button class="ghost-btn" bindtap="goHome">返回首页</button>
      </view>
    </view>
  </view>

  <!-- 成功态 -->
  <view class="success-wrap" wx:elif="{{resultStatus === 'success'}}">
    <view class="success-banner">
      <text class="success-banner-icon">✅</text>
      <text class="success-banner-text">{{resultMessage}}</text>
    </view>

    <!-- 关注公众号引导弹层（PRD §4.2） -->
    <view class="mp-modal-mask" wx:if="{{showFollowMp}}">
      <view class="mp-modal">
        <text class="mp-modal-title">最后一步：让 {{invitation.inviter_nickname || '邀请人'}} 能收到您的健康提醒</text>
        <text class="mp-modal-sub">请「{{invitation.inviter_nickname || '邀请人'}}」长按下方二维码关注公众号</text>
        <view class="mp-qr-placeholder">
          <text class="mp-qr-text">[ bini-health 公众号二维码 ]</text>
        </view>
        <text class="mp-modal-tip">关注成功后，子女才能在公众号收到您的体检异常推送</text>
        <text class="mp-modal-note">※ 您可截图发给 {{invitation.inviter_nickname || '邀请人'}}，让 TA 关注</text>
        <button class="primary-btn mp-modal-btn" bindtap="onConfirmFollowMp">我已通知 {{invitation.inviter_nickname || '邀请人'}} 关注</button>
      </view>
    </view>

    <view class="success-actions">
      <button class="primary-btn" bindtap="goHome">返回首页</button>
      <text class="link-btn" bindtap="goBindList">查看家庭成员</text>
    </view>
  </view>

  <!-- 拒绝/接受出错 -->
  <view class="result-wrap" wx:elif="{{resultStatus === 'rejected' || resultStatus === 'error'}}">
    <text class="result-icon">{{resultStatus === 'rejected' ? '🚫' : '❌'}}</text>
    <text class="result-text">{{resultMessage}}</text>
    <view class="result-actions">
      <button class="primary-btn" bindtap="goHome">返回首页</button>
    </view>
  </view>

  <!-- 正常态：邀请确认 -->
  <block wx:elif="{{invitation}}">
    <!-- 邀请人卡片 -->
    <view class="card inviter-card">
      <view class="inviter-row">
        <view class="inviter-avatar">
          <image
            wx:if="{{invitation.inviter_avatar}}"
            class="inviter-avatar-img"
            src="{{invitation.inviter_avatar}}"
            mode="aspectFill"
          />
          <view wx:else class="inviter-avatar-fallback">
            <text class="inviter-avatar-text">{{invitation.inviter_nickname ? invitation.inviter_nickname[0] : '家'}}</text>
          </view>
        </view>
        <view class="inviter-info">
          <text class="inviter-name">
            {{invitation.inviter_nickname || '家人'}}
            <text class="inviter-relation" wx:if="{{relationshipLabel && inviteType !== 'reverse'}}">（您的{{relationshipLabel}}）</text>
          </text>
          <text class="inviter-desc">{{inviteType === 'reverse' ? '邀请你守护 TA 的健康' : '邀请您加入家庭健康守护'}}</text>
          <text class="inviter-expire">邀请到期：{{expiresAtText}}</text>
        </view>
      </view>
    </view>

    <!-- 关系说明卡片 -->
    <view class="card explain-card">
      <text class="card-title">接受后将发生：</text>
      <block wx:if="{{inviteType === 'reverse'}}">
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">您将可以查看 {{invitation.inviter_nickname || '对方'}} 的体检报告与健康档案</text>
        </view>
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">{{invitation.inviter_nickname || '对方'}} 的体检异常会自动推送给您</text>
        </view>
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">双方随时可以解除守护关系</text>
        </view>
      </block>
      <block wx:else>
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">{{invitation.inviter_nickname || '邀请人'}} 可查看您的体检报告与健康档案</text>
        </view>
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">您的体检异常会自动推送给 {{invitation.inviter_nickname || '邀请人'}}</text>
        </view>
        <view class="explain-item">
          <text class="explain-icon explain-icon-ok">✅</text>
          <text class="explain-text">您随时可以在「我的-家庭」中解除守护</text>
        </view>
        <view class="explain-item explain-item-warn">
          <text class="explain-icon explain-icon-warn">⚠️</text>
          <text class="explain-text">
            您当前已有 {{invitation.current_managed_by_count || 0}} 位守护者（最多 {{invitation.max_managed_by_count || 3}} 位）
          </text>
        </view>
      </block>
    </view>

    <!-- 健康档案合并预览 -->
    <view class="card merge-card" wx:if="{{mergePreview.length}}">
      <text class="card-title">健康档案合并预览</text>
      <text class="card-sub">下列字段可从「{{invitation.inviter_nickname || '邀请人'}}」处合并到您的档案：</text>
      <view class="merge-list">
        <view
          class="merge-item"
          wx:for="{{mergePreview}}"
          wx:key="key"
        >
          <view class="merge-info">
            <text class="merge-label">{{item.label}}</text>
            <text class="merge-values">
              {{item.acceptor_value || '（空）'}} → {{item.inviter_value || '—'}}
            </text>
          </view>
          <view
            class="merge-toggle {{mergeChoices[item.key] === 'merge' ? 'on' : 'off'}}"
            data-key="{{item.key}}"
            bindtap="onToggleMergeField"
          >
            <text class="merge-toggle-text">{{mergeChoices[item.key] === 'merge' ? '将合并' : '保留原值'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 授权协议 -->
    <view class="agree-row">
      <view
        class="agree-check {{agreed ? 'checked' : ''}}"
        bindtap="onToggleAgree"
      >
        <text wx:if="{{agreed}}" class="agree-check-mark">✓</text>
      </view>
      <view class="agree-text">
        <text bindtap="onToggleAgree">我已阅读</text>
        <text class="agree-link" bindtap="onOpenAgreement">《家庭健康守护授权协议》</text>
        <text bindtap="onToggleAgree">，同意 {{invitation.inviter_nickname || '邀请人'}} 在守护期间查看我的健康档案与体检报告，并接收我的体检异常通知。</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-row">
      <button
        class="accept-btn {{!agreed || processing ? 'disabled' : ''}}"
        bindtap="onAccept"
        disabled="{{!agreed || processing}}"
        loading="{{processing}}"
      >接 受</button>
      <button
        class="reject-btn"
        bindtap="onReject"
        disabled="{{processing}}"
      >拒 绝</button>
    </view>
  </block>
</view>
