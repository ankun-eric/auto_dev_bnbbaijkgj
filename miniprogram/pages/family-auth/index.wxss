.auth-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* Result */
.result-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.result-text {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
  padding: 0 40rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.home-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 40rpx;
}

.home-btn::after {
  border: none;
}

.bindlist-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  background: #fff;
  color: #52c41a;
  border: 2rpx solid #52c41a;
  border-radius: 40rpx;
}

.bindlist-btn::after {
  border: none;
}

/* Auth card */
.auth-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.auth-icon-wrap {
  margin-bottom: 24rpx;
}

.auth-icon {
  font-size: 80rpx;
}

.auth-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.auth-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.auth-detail {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.detail-row + .detail-row {
  border-top: 1rpx solid #f0f0f0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.auth-notice {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #d48806;
  line-height: 1.6;
}

/* Action buttons */
.auth-actions {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.reject-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #d9d9d9;
  border-radius: 44rpx;
}

.reject-btn::after {
  border: none;
}

.accept-btn {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-weight: 500;
}

.accept-btn::after {
  border: none;
}

.accept-btn[disabled] {
  background: #b7eb8f;
  color: #fff;
}

.reject-btn[disabled] {
  color: #ccc;
}
