.auth-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* Result (error / rejected) */
.result-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.result-text {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
  padding: 0 40rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.home-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 44rpx;
}

.home-btn::after {
  border: none;
}

/* Success page */
.success-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.success-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.success-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.success-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.success-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.success-relation {
  display: block;
  font-size: 30rpx;
  color: #52c41a;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.success-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.success-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.later-link {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #999;
}

/* Auth card (pending) */
.auth-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.auth-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.auth-icon-wrap {
  margin-bottom: 24rpx;
}

.auth-icon {
  font-size: 80rpx;
}

.auth-inviter-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.auth-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* Action buttons */
.auth-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 60rpx;
}

.accept-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-weight: 500;
}

.accept-btn::after {
  border: none;
}

.accept-btn[disabled] {
  background: #b7eb8f;
  color: #fff;
}

.reject-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #d9d9d9;
  border-radius: 44rpx;
}

.reject-btn::after {
  border: none;
}

.reject-btn[disabled] {
  color: #ccc;
}
