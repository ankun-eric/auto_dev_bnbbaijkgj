/* [PRD-FAMILY-AUTH-MP-V1] 视觉规范：主色 #1AAD19，警示色 #FA5151，
   卡片圆角 12rpx，内边距 32rpx，字号：标题 36rpx / 正文 28rpx / 辅助 24rpx */
.auth-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 64rpx;
  box-sizing: border-box;
}

/* 顶部品牌条 */
.brand-bar {
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: #1AAD19;
  color: #fff;
}
.brand-logo {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.brand-logo-text {
  color: #1AAD19;
  font-size: 32rpx;
  font-weight: bold;
}
.brand-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
}
.brand-cs {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.brand-cs-icon {
  font-size: 36rpx;
}

/* Loading */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1AAD19;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 通用卡片 */
.card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  line-height: 1.6;
}
.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.card-sub {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

/* 邀请人卡片 */
.inviter-card {
  margin-top: 32rpx;
}
.inviter-row {
  display: flex;
  align-items: flex-start;
}
.inviter-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.inviter-avatar-img {
  width: 100%;
  height: 100%;
}
.inviter-avatar-fallback {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1AAD19, #36c750);
  display: flex;
  align-items: center;
  justify-content: center;
}
.inviter-avatar-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}
.inviter-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.inviter-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}
.inviter-relation {
  font-size: 24rpx;
  font-weight: normal;
  color: #1AAD19;
  margin-left: 8rpx;
}
.inviter-desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}
.inviter-expire {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 关系说明卡片 */
.explain-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}
.explain-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1.6;
}
.explain-icon-ok { color: #1AAD19; }
.explain-icon-warn { color: #FA5151; }
.explain-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}
.explain-item-warn .explain-text { color: #FA5151; }

/* 合并字段卡片 */
.merge-list {
  display: flex;
  flex-direction: column;
}
.merge-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.merge-item:last-child { border-bottom: none; }
.merge-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.merge-label {
  font-size: 28rpx;
  color: #333;
}
.merge-values {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.merge-toggle {
  margin-left: 16rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}
.merge-toggle.on {
  background: rgba(26,173,25,0.1);
  color: #1AAD19;
  border: 1rpx solid #1AAD19;
}
.merge-toggle.off {
  background: #f0f0f0;
  color: #999;
  border: 1rpx solid transparent;
}

/* 协议行 */
.agree-row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  margin-top: 24rpx;
}
.agree-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ccc;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  margin-top: 6rpx;
}
.agree-check.checked {
  background: #1AAD19;
  border-color: #1AAD19;
}
.agree-check-mark {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}
.agree-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.agree-link {
  color: #1AAD19;
}

/* 操作按钮 */
.action-row {
  display: flex;
  padding: 24rpx 32rpx 0;
  gap: 24rpx;
}
.accept-btn {
  flex: 6;
  height: 88rpx;
  line-height: 88rpx;
  background: #1AAD19;
  color: #fff;
  font-size: 32rpx;
  border: none;
  border-radius: 44rpx;
  font-weight: 500;
}
.accept-btn::after { border: none; }
.accept-btn.disabled {
  background: #c5e7c0;
  color: #fff;
}
.reject-btn {
  flex: 4;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #999;
  font-size: 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 44rpx;
}
.reject-btn::after { border: none; }

/* 通用按钮 */
.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1AAD19;
  color: #fff;
  font-size: 30rpx;
  border: none;
  border-radius: 44rpx;
}
.primary-btn::after { border: none; }
.ghost-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 44rpx;
}
.ghost-btn::after { border: none; }
.link-btn {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #1AAD19;
  text-align: center;
}

/* 失效态 */
.invalid-wrap {
  padding: 80rpx 32rpx 0;
}
.invalid-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 80rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.invalid-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.invalid-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.invalid-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}
.invalid-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

/* 通用错误页 */
.result-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
}
.result-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}
.result-text {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}
.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 成功态 */
.success-wrap {
  padding: 32rpx;
}
.success-banner {
  background: linear-gradient(135deg, #1AAD19, #36c750);
  color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(26,173,25,0.18);
}
.success-banner-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}
.success-banner-text {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
  line-height: 1.5;
}
.success-actions {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 公众号弹层 */
.mp-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}
.mp-modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.mp-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}
.mp-modal-sub {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
.mp-qr-placeholder {
  width: 360rpx;
  height: 360rpx;
  background: #f5f5f5;
  border: 2rpx dashed #c5c5c5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.mp-qr-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
.mp-modal-tip {
  font-size: 26rpx;
  color: #FA5151;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 12rpx;
}
.mp-modal-note {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}
.mp-modal-btn {
  margin-top: 8rpx;
}
