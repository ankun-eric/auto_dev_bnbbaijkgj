/**
 * [PRD-健康档案路径统一 2026-05-16] 小程序端 v2 对齐版样式
 * [PRD-HEALTH-ARCHIVE-OPTIM-V1 2026-05-18] 健康档案页面优化：被守护角标 + 关系标签 + 今日用药 + 共管区
 * 主色蓝白渐变（对齐 H5 v2 BH_TOKENS），圆角 12/16rpx*2，病历卡左侧 3px 竖线
 * 原文件备份为 index.wxss.bak-2026-05-16
 */

/* [PRD-HEALTH-ARCHIVE-OPTIM-V1] 被守护角标（成员条头像右上角） */
.guarded-badge {
  position: absolute;
  top: -10rpx;
  right: -16rpx;
  background: #0EA5E9;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
  white-space: nowrap;
  line-height: 1.2;
}

/* [PRD-HEALTH-ARCHIVE-OPTIM-V1] Hero 大头像「被守护」角标 */
.hero-guarded-badge {
  position: absolute;
  top: -6rpx;
  right: -30rpx;
  background: #0EA5E9;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
  white-space: nowrap;
}

/* [PRD-HEALTH-ARCHIVE-OPTIM-V1] Hero 姓名+关系标签同行 */
.hero-name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}
.hero-rel-label {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.28);
  color: #fff;
}

/* [PRD-HEALTH-ARCHIVE-OPTIM-V1] Hero 今日用药入口 */
.hero-today-medication {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hero-today-medication-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
.hero-today-medication-arrow {
  font-size: 32rpx;
  color: #fff;
}

/* 守护关系卡片区 */
.guardian-cards-area {
  padding: 0 24rpx 16rpx;
}
.guardian-cards-row {
  display: flex;
  gap: 20rpx;
}
.guardian-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.guardian-card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.guardian-card-icon {
  font-size: 40rpx;
}
.guardian-card-icon-orange {
  background: #FFF7ED;
  border: 2rpx solid #FDBA74;
}
.guardian-card-icon-green {
  background: #F0FDF4;
  border: 2rpx solid #86EFAC;
}
.guardian-card-icon-purple {
  background: #FAF5FF;
  border: 2rpx solid #C4B5FD;
}
.guardian-card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 4rpx;
}
.guardian-card-count {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}
/* [PRD-MEMBER-COUNT-CONSISTENCY-V1 2026-05-31] 卡片副标题：已管理/守护者 X / 上限 Y */
.guardian-card-subtitle {
  font-size: 22rpx;
  font-weight: 500;
  color: #6B7280;
  margin-top: 6rpx;
  line-height: 1.4;
}
.guardian-card-orange {
  border-top: 6rpx solid #F97316;
}
.guardian-card-green {
  border-top: 6rpx solid #22C55E;
}

/* 我的设备入口 */
.device-entry {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #8B5CF6;
}
.device-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.device-entry-left .guardian-card-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 0;
}
.device-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}
.device-entry-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.device-entry-count {
  font-size: 26rpx;
  color: #6B7280;
}
.device-entry-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 非本人的共管区域 */
.guardian-area {
  padding: 0 24rpx 16rpx;
}
.guardian-invite-btn {
  background: #0EA5E9;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.guardian-manage-btn {
  background: #fff;
  color: #0284C7;
  border: 2rpx solid #BAE6FD;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

page {
  background: #F0F7FF;
  min-height: 100vh;
}

.hp-page {
  padding-bottom: 40rpx;
}

/* 被共管提示条 */
.managed-notice {
  display: flex; align-items: center;
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}
.managed-notice-icon { margin-right: 12rpx; }
.managed-notice-text { flex: 1; }
.managed-notice-arrow { font-size: 24rpx; opacity: .9; }

/* 1. 家庭成员条 */
.member-bar-wrap {
  background: #E8F2FF;
  padding: 20rpx 24rpx;
}
.member-bar {
  white-space: nowrap;
}
.member-item {
  display: inline-flex; flex-direction: column; align-items: center;
  min-width: 120rpx;
  margin-right: 24rpx;
  vertical-align: top;
  position: relative;
}
.avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #fff;
  border: 2rpx solid #BFDBFE;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(74,158,224,0.12);
}
.avatar-active {
  background: #4A9EE0;
  border: 4rpx solid #2563EB;
  box-shadow: 0 8rpx 24rpx rgba(34,118,235,0.30);
}
.avatar-active .avatar-emoji { color: #fff; }
.avatar-emoji {
  font-size: 44rpx;
  color: #2563EB;
}
.avatar-add {
  border: 2rpx dashed #4A9EE0;
  background: #fff;
}
.avatar-add-plus { font-size: 48rpx; color: #2563EB; }
.link-dot {
  position: absolute; top: 0; right: 6rpx;
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #22C55E;
  border: 4rpx solid #fff;
}
.member-label {
  margin-top: 8rpx; font-size: 24rpx; color: #1E3A8A;
}

/* 2. Hero 卡 */
.hero-card-wrap {
  padding: 24rpx 24rpx 16rpx;
}
.hero-card {
  position: relative;
  background: linear-gradient(135deg, #4A9EE0 0%, #2563EB 100%);
  color: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(34,118,235,0.20);
}
.hero-edit-btn {
  position: absolute; top: 20rpx; right: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
}
.hero-top { display: flex; align-items: center; }
.hero-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx;
}
.hero-avatar-emoji { font-size: 60rpx; color: #fff; }
.hero-info { flex: 1; min-width: 0; }
.hero-name {
  font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx;
}
.hero-sub {
  font-size: 24rpx; opacity: 0.95;
}
.link-badge {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.3);
  font-size: 20rpx; font-weight: 600;
}
.hero-baseline {
  margin-top: 8rpx;
  font-size: 22rpx; opacity: 0.8;
}
.hero-metrics {
  display: flex; margin-top: 28rpx;
  gap: 16rpx;
}
.hero-metric {
  flex: 1; text-align: center;
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 20rpx 8rpx;
}
.hero-metric-count {
  font-size: 36rpx; font-weight: 700;
}
.hero-metric-label {
  font-size: 22rpx; opacity: 0.9; margin-top: 4rpx;
}

/* 3. 粘性 5 Tab */
.sticky-tabs {
  position: sticky; top: 0; z-index: 50;
  background: #fff;
  display: flex;
  border-bottom: 1rpx solid #BFDBFE;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  height: 96rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.tab-item {
  flex: 0 0 auto;
  padding: 0 28rpx;
  line-height: 96rpx;
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
  border-bottom: 4rpx solid transparent;
}
.tab-item-active {
  color: #2563EB; font-weight: 700;
  border-bottom: 4rpx solid #2563EB;
}

/* 通用块 */
.block {
  padding: 24rpx;
}
.block-title {
  font-size: 32rpx; font-weight: 600; color: #1E40AF;
  margin: 8rpx 0 20rpx;
}
.block-title-row {
  display: flex; align-items: center; justify-content: space-between;
  margin: 8rpx 0 20rpx;
}
.add-btn {
  color: #2563EB; font-size: 28rpx;
}

/* 今日数据 6 宫格 */
.metric-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx;
}
.metric-card {
  background: #fff;
  border-left: 6rpx solid #22C55E;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,158,224,0.08);
  position: relative;
}
.metric-card-abnormal {
  border-left-color: #F59E0B;
}
.metric-top {
  display: flex; justify-content: space-between; align-items: flex-start;
}
.metric-label { font-size: 24rpx; color: #6B7280; }
.metric-tag {
  font-size: 20rpx; font-weight: 600; color: #fff;
  background: #F59E0B;
  padding: 4rpx 12rpx; border-radius: 10rpx;
}
.metric-value-row {
  margin-top: 12rpx;
}
.metric-value {
  font-size: 40rpx; font-weight: 700; color: #1F2937;
}
.metric-unit {
  font-size: 24rpx; color: #6B7280; margin-left: 8rpx;
}
.med-progress {
  height: 10rpx; background: #DBEAFE; border-radius: 6rpx; margin-top: 12rpx;
  overflow: hidden;
}
.med-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #4A9EE0, #2563EB);
  border-radius: 6rpx;
}

/* 健康信息 / 共管与提醒卡片 */
.info-card {
  background: #fff;
  border-left: 6rpx solid #22C55E;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,158,224,0.08);
}
.info-card-title {
  font-size: 28rpx; font-weight: 600; color: #1F2937;
  margin-bottom: 16rpx;
}
.tags-wrap {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.preset-tag {
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  background: #F3F4F6;
  color: #4B5563;
  font-size: 26rpx;
}
.preset-tag-selected {
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff;
}
.preset-tag-other {
  background: #fff; color: #2563EB; border: 2rpx dashed #BFDBFE;
}
.custom-input-wrap {
  display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx;
}
.custom-input {
  flex: 1; padding: 12rpx 20rpx;
  background: #F3F4F6; border-radius: 16rpx;
  font-size: 26rpx;
}
.confirm-btn {
  background: #2563EB; color: #fff;
  font-size: 24rpx; border-radius: 16rpx;
}
.custom-tags {
  display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx;
}
.custom-tag {
  padding: 12rpx 24rpx; border-radius: 28rpx;
  background: #EFF6FF; color: #1E40AF;
  font-size: 24rpx;
}
.tag-remove { margin-left: 8rpx; color: #9CA3AF; }

/* 习惯行 */
.habit-row {
  display: flex; align-items: center;
  padding: 16rpx 0;
}
.habit-label { width: 120rpx; color: #4B5563; font-size: 26rpx; }
.habit-options { display: flex; gap: 16rpx; flex: 1; }
.habit-opt {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #F3F4F6;
  color: #4B5563;
  font-size: 24rpx;
}
.habit-opt-active {
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff;
}

/* 保存按钮 */
.save-bar {
  padding: 24rpx 8rpx;
}
.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx; font-weight: 600;
  height: 88rpx; line-height: 88rpx;
}

/* 用药计划卡片 */
.med-plan-card {
  background: #fff;
  border-left: 6rpx solid #22C55E;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,158,224,0.08);
}
.med-plan-head { display: flex; justify-content: space-between; }
.med-plan-name { font-size: 30rpx; font-weight: 600; color: #1F2937; }
.med-plan-dose { font-size: 24rpx; color: #6B7280; }
.med-plan-rate { font-size: 24rpx; color: #4B5563; margin-top: 8rpx; }
.time-chips { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.time-chip {
  padding: 8rpx 20rpx; border-radius: 20rpx;
  background: #F3F4F6; color: #4B5563; font-size: 24rpx;
}
.time-chip-checked {
  background: #22C55E; color: #fff;
}

.empty-hint {
  text-align: center; color: #9CA3AF; font-size: 26rpx;
  padding: 60rpx 0;
}

/* 共管/提醒 */
.link-hint { display: block; color: #6B7280; font-size: 26rpx; margin-bottom: 16rpx; }
.invite-btn {
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff; border-radius: 24rpx; font-size: 28rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #4A9EE0, #2563EB);
  color: #fff; border-radius: 24rpx; font-size: 28rpx;
}
.linked-status-row { display: flex; align-items: center; justify-content: space-between; }
.linked-badge { display: flex; align-items: center; }
.linked-badge-dot {
  display: inline-block; width: 16rpx; height: 16rpx;
  border-radius: 50%; background: #22C55E; margin-right: 8rpx;
}
.linked-badge-text { color: #16A34A; font-size: 26rpx; }
.unlink-btn { color: #DC2626; font-size: 26rpx; }
.reminder-summary { color: #4B5563; font-size: 26rpx; }
.overdue-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx; border-radius: 16rpx;
  background: #FEF3C7; color: #B45309; font-size: 22rpx;
}

/* 健康事件 */
.event-card {
  background: #fff;
  border-left: 6rpx solid #4A9EE0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,158,224,0.08);
}
.event-time { font-size: 22rpx; color: #6B7280; }
.event-title { font-size: 28rpx; font-weight: 600; color: #1F2937; margin: 8rpx 0; }
.event-desc { font-size: 24rpx; color: #4B5563; }

/* Hero 编辑弹层 */
.modal-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex; align-items: flex-end;
}
.modal-sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 32rpx; border-top-right-radius: 32rpx;
  max-height: 80vh;
  display: flex; flex-direction: column;
}
.modal-head {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #DBEAFE;
  display: flex; justify-content: space-between; align-items: center;
}
.modal-title { font-size: 32rpx; font-weight: 700; }
.modal-close { font-size: 44rpx; color: #9CA3AF; }
.modal-body { padding: 24rpx 32rpx; overflow-y: auto; flex: 1; }
.modal-foot {
  display: flex; gap: 16rpx; padding: 24rpx 32rpx;
  border-top: 1rpx solid #DBEAFE;
}
.modal-foot .btn-ghost {
  flex: 1; background: #fff; color: #2563EB;
  border: 2rpx solid #BFDBFE; border-radius: 48rpx;
  font-size: 30rpx;
}
.modal-foot .btn-primary {
  flex: 1; height: 88rpx; line-height: 88rpx;
  border-radius: 48rpx;
}

.form-item {
  display: flex; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.form-label { width: 180rpx; color: #4B5563; font-size: 28rpx; }
.form-input {
  flex: 1; font-size: 28rpx; color: #1F2937; text-align: right;
}
.form-value {
  flex: 1; font-size: 28rpx; color: #1F2937; text-align: right;
}
.form-value.placeholder { color: #9CA3AF; }
.gender-group { flex: 1; display: flex; justify-content: flex-end; gap: 16rpx; }
.gender-btn {
  padding: 8rpx 24rpx; border-radius: 20rpx;
  background: #F3F4F6; color: #4B5563; font-size: 26rpx;
}
.gender-active {
  background: linear-gradient(135deg, #4A9EE0, #2563EB); color: #fff;
}

.safe-bottom-fix { height: env(safe-area-inset-bottom); }

/* [PRD-HEALTH-PROFILE-SELF-COMPLETE 2026-05-29] 本人资料完善弹窗 + 抽屉样式 */
.self-complete-mask {
  position: fixed; inset: 0; z-index: 3000;
  background: rgba(15,23,42,0.55);
  display: flex; align-items: center; justify-content: center;
  padding: 48rpx;
}
.self-complete-dialog {
  width: 100%; max-width: 640rpx; background: #fff;
  border-radius: 24rpx; padding: 44rpx 40rpx 36rpx;
  box-shadow: 0 24rpx 80rpx rgba(2,132,199,0.25);
  position: relative;
}
.self-complete-close {
  position: absolute; top: 16rpx; right: 24rpx;
  font-size: 48rpx; color: #94A3B8; line-height: 1;
}
.self-complete-title {
  font-size: 34rpx; font-weight: 700; color: #0F172A;
  margin-bottom: 20rpx; text-align: center;
}
.self-complete-body {
  font-size: 26rpx; color: #475569; line-height: 1.6;
  margin-bottom: 36rpx; text-align: center;
}
.self-complete-btns {
  display: flex; gap: 24rpx;
}
.self-complete-btn-later {
  flex: 1; height: 84rpx; border-radius: 42rpx;
  background: #F1F5F9; color: #0F172A;
  font-size: 28rpx; font-weight: 600; border: none;
}
.self-complete-btn-go {
  flex: 1; height: 84rpx; border-radius: 42rpx;
  background: linear-gradient(135deg, #38BDF8, #0284C7);
  color: #fff; font-size: 28rpx; font-weight: 700; border: none;
}

.self-drawer-mask {
  position: fixed; inset: 0; z-index: 3000;
  background: rgba(15,23,42,0.55);
  display: flex; align-items: flex-end;
}
.self-drawer-sheet {
  width: 100%; background: #F8FAFC;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 92vh; display: flex; flex-direction: column;
}
.self-drawer-head {
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1rpx solid #E2E8F0;
}
.self-drawer-close { font-size: 44rpx; color: #64748B; width: 40rpx; }
.self-drawer-title { font-size: 32rpx; font-weight: 700; color: #0F172A; }
.self-drawer-spacer { width: 40rpx; }
.self-drawer-tip {
  margin: 24rpx 32rpx 16rpx;
  padding: 20rpx 24rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
  border-radius: 16rpx;
  font-size: 24rpx; color: #1E40AF; line-height: 1.6;
}
.self-drawer-body {
  flex: 1; padding: 0 32rpx 24rpx;
}
.self-field {
  background: #fff; border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx 28rpx;
}
.self-field-row {
  display: flex; align-items: center;
}
.self-field-label {
  width: 180rpx; font-size: 26rpx; color: #475569; font-weight: 600;
  flex-shrink: 0;
}
.self-field-required { color: #EF4444; margin-right: 4rpx; }
.self-field-input {
  flex: 1; padding: 14rpx 20rpx; border: 1rpx solid #E2E8F0;
  border-radius: 16rpx; font-size: 26rpx; background: #fff;
}
.self-field-input-err { border-color: #EF4444; }
.self-field-value { flex: 1; padding: 14rpx 20rpx; border: 1rpx solid #E2E8F0;
  border-radius: 16rpx; font-size: 26rpx; background: #fff; display: block; }
.self-field-value.placeholder { color: #94A3B8; }
.self-field-err {
  font-size: 22rpx; color: #EF4444; margin-top: 8rpx;
  padding-left: 180rpx;
}
.self-gender-group { flex: 1; display: flex; gap: 16rpx; }
.self-gender-btn {
  flex: 1; height: 64rpx; line-height: 64rpx; text-align: center;
  background: #F1F5F9; color: #0F172A;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
}
.self-gender-btn-active {
  background: #DBEAFE; color: #0284C7;
  border: 2rpx solid #38BDF8;
}
.self-collapsed-head {
  background: #fff; border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 26rpx; color: #475569; font-weight: 600;
}
.self-collapsed-arrow {
  color: #94A3B8; transition: transform 0.2s;
  display: inline-block;
}
.self-collapsed-arrow-open {
  transform: rotate(90deg);
}
.self-collapsed-body {
  background: #fff; border-radius: 16rpx;
  margin-bottom: 16rpx; padding: 12rpx 0;
}
.self-field-inline { background: transparent; margin-bottom: 0; padding: 12rpx 28rpx; }
.self-drawer-foot {
  padding: 20rpx 32rpx 32rpx;
  background: #fff; border-top: 1rpx solid #E2E8F0;
}
.self-drawer-save {
  width: 100%; height: 92rpx; border-radius: 46rpx;
  background: linear-gradient(135deg, #38BDF8, #0284C7);
  color: #fff; font-size: 30rpx; font-weight: 700; border: none;
}
.self-drawer-save-disabled {
  background: #CBD5E1 !important;
}
