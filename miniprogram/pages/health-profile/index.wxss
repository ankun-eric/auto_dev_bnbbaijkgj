.health-profile-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* Family Tabs */
.family-tabs-wrapper {
  margin-bottom: 24rpx;
}

.family-tabs {
  white-space: nowrap;
  padding: 8rpx 0;
}

.family-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
  vertical-align: middle;
}

.family-tab-active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.family-tab-text {
  font-size: 22rpx;
  font-weight: bold;
}

.family-tab-add {
  background: #f0f0f0;
  border: 2rpx dashed #ccc;
}

.family-tab-add .family-tab-text {
  font-size: 36rpx;
  font-weight: normal;
  color: #999;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child { border-bottom: none; }

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #ccc;
}

.gender-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.gender-btn {
  padding: 10rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.gender-active {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #52c41a;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.removable-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f6ffed;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #52c41a;
}

.tag-remove {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.med-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.med-info { flex: 1; }

.med-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.med-dosage {
  font-size: 22rpx;
  color: #999;
}

.save-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.save-btn {
  width: 100%;
}
