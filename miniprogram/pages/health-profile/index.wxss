.health-profile-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* Family Tabs */
.family-tabs-wrapper {
  margin-bottom: 24rpx;
}

.family-tabs {
  white-space: nowrap;
  padding: 8rpx 0;
}

.family-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
  vertical-align: middle;
}

.family-tab-active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.family-tab-text {
  font-size: 22rpx;
  font-weight: bold;
}

.family-tab-add {
  background: #f0f0f0;
  border: 2rpx dashed #ccc;
}

.family-tab-add .family-tab-text {
  font-size: 36rpx;
  font-weight: normal;
  color: #999;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child { border-bottom: none; }

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #ccc;
}

.gender-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.gender-btn {
  padding: 10rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.gender-active {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #52c41a;
}

/* Preset tags */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.preset-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.preset-tag-selected {
  background: #f6ffed;
  border-color: #52c41a;
  color: #52c41a;
  font-weight: 500;
}

.preset-tag-other {
  border-style: dashed;
}

/* Custom input */
.custom-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 8rpx 0;
}

.custom-input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.confirm-btn {
  width: 120rpx !important;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  font-size: 26rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

.confirm-btn::after {
  border: none;
}

/* Custom tags */
.custom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.custom-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #d48806;
}

.delete-btn {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #d48806;
}

/* Medications */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.removable-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f6ffed;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #52c41a;
}

.tag-remove {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.med-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.med-info { flex: 1; }

.med-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.med-dosage {
  font-size: 22rpx;
  color: #999;
}

/* Managed notice bar */
.managed-notice {
  display: flex;
  align-items: center;
  background: #e6f7ff;
  border: 1rpx solid #91d5ff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.managed-notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.managed-notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #1890ff;
}

.managed-notice-arrow {
  font-size: 24rpx;
  color: #1890ff;
}

/* Tab link status */
.family-tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  vertical-align: top;
}

.family-tab {
  position: relative;
  margin-right: 0;
}

.link-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.link-dot-green {
  background: #52c41a;
}

.tab-link-label {
  font-size: 18rpx;
  margin-top: 6rpx;
  line-height: 1;
}

.tab-link-linked {
  color: #52c41a;
}

.tab-link-pending {
  color: #faad14;
}

/* Family link card */
.family-link-card {
  margin-top: 8rpx;
}

.link-action-wrap {
  margin-top: 16rpx;
}

.link-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.invite-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

.invite-btn::after {
  border: none;
}

.linked-status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.linked-badge {
  display: flex;
  align-items: center;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
}

.linked-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #52c41a;
  margin-right: 8rpx;
}

.linked-badge-text {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
}

.unlink-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 20rpx;
}

.save-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.save-btn {
  width: 100%;
}
