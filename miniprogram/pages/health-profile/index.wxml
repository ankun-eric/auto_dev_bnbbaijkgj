<wxs src="./helpers.wxs" module="h" />

<view class="health-profile-page">
  <!-- 家庭成员 Tab -->
  <view class="family-tabs-wrapper">
    <scroll-view class="family-tabs" scroll-x>
      <view class="family-tab {{activeTabIndex === index ? 'family-tab-active' : ''}}"
            wx:for="{{familyTabs}}" wx:key="id"
            bindtap="onTabSelect" data-index="{{index}}"
            style="background: {{activeTabIndex === index ? item.color : '#f0f0f0'}};">
        <text class="family-tab-text" style="color: {{activeTabIndex === index ? '#fff' : '#666'}};">{{item.name}}</text>
      </view>
      <view class="family-tab family-tab-add" bindtap="onAddMemberTap">
        <text class="family-tab-text" style="color: #999;">+</text>
      </view>
    </scroll-view>
  </view>

  <!-- 基础信息 -->
  <view class="card">
    <text class="section-title">基础信息</text>
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{profile.name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="gender-group">
        <view class="gender-btn {{profile.gender === '男' ? 'gender-active' : ''}}" bindtap="setGender" data-gender="男">男</view>
        <view class="gender-btn {{profile.gender === '女' ? 'gender-active' : ''}}" bindtap="setGender" data-gender="女">女</view>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">出生日期</text>
      <picker mode="date" value="{{profile.birthday}}" bindchange="onDateChange">
        <text class="form-value {{profile.birthday ? '' : 'placeholder'}}">{{profile.birthday || '请选择'}}</text>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">身高(cm)</text>
      <input class="form-input" type="digit" placeholder="请输入" value="{{profile.height}}" bindinput="onInput" data-field="height" />
    </view>
    <view class="form-item">
      <text class="form-label">体重(kg)</text>
      <input class="form-input" type="digit" placeholder="请输入" value="{{profile.weight}}" bindinput="onInput" data-field="weight" />
    </view>
    <view class="form-item">
      <text class="form-label">血型</text>
      <picker range="{{bloodTypes}}" value="{{bloodTypeIndex}}" bindchange="onBloodTypeChange">
        <text class="form-value {{profile.bloodType ? '' : 'placeholder'}}">{{profile.bloodType || '请选择'}}</text>
      </picker>
    </view>
  </view>

  <!-- 慢性病史 -->
  <view class="card">
    <view class="section-title">🏥 慢性病史</view>
    <view class="tags-wrap">
      <view wx:for="{{chronicPresets}}" wx:key="id"
        class="preset-tag {{h.isPresetSelected(profile.chronic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
        bindtap="toggleChronicPreset" data-name="{{item.name}}">
        {{item.name}}
      </view>
      <view class="preset-tag preset-tag-other {{showChronicOther ? 'preset-tag-selected' : ''}}"
        bindtap="toggleChronicOther">
        其它 ✚
      </view>
    </view>
    <view wx:if="{{showChronicOther}}" class="custom-input-wrap">
      <input class="custom-input" placeholder="请输入其它慢性病…"
        value="{{chronicOtherInput}}" bindinput="onChronicOtherInput" maxlength="100"/>
      <button class="confirm-btn" bindtap="confirmChronicOther">确认</button>
    </view>
    <view class="custom-tags" wx:if="{{chronicCustomItems.length > 0}}">
      <view wx:for="{{chronicCustomItems}}" wx:key="value" class="custom-tag">
        {{item.value}} <text class="delete-btn" bindtap="removeChronicCustom" data-value="{{item.value}}">✕</text>
      </view>
    </view>
  </view>

  <!-- 过敏史 -->
  <view class="card">
    <view class="section-title">⚠️ 过敏史</view>
    <view class="tags-wrap">
      <view wx:for="{{allergyPresets}}" wx:key="id"
        class="preset-tag {{h.isPresetSelected(profile.allergies, item.name) ? 'preset-tag-selected' : ''}}"
        bindtap="toggleAllergyPreset" data-name="{{item.name}}">
        {{item.name}}
      </view>
      <view class="preset-tag preset-tag-other {{showAllergyOther ? 'preset-tag-selected' : ''}}"
        bindtap="toggleAllergyOther">
        其它 ✚
      </view>
    </view>
    <view wx:if="{{showAllergyOther}}" class="custom-input-wrap">
      <input class="custom-input" placeholder="请输入其它过敏源…"
        value="{{allergyOtherInput}}" bindinput="onAllergyOtherInput" maxlength="100"/>
      <button class="confirm-btn" bindtap="confirmAllergyOther">确认</button>
    </view>
    <view class="custom-tags" wx:if="{{allergyCustomItems.length > 0}}">
      <view wx:for="{{allergyCustomItems}}" wx:key="value" class="custom-tag">
        {{item.value}} <text class="delete-btn" bindtap="removeAllergyCustom" data-value="{{item.value}}">✕</text>
      </view>
    </view>
  </view>

  <!-- 家族遗传病史 -->
  <view class="card">
    <view class="section-title">🧬 家族遗传病史</view>
    <view class="tags-wrap">
      <view wx:for="{{geneticPresets}}" wx:key="id"
        class="preset-tag {{h.isPresetSelected(profile.genetic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
        bindtap="toggleGeneticPreset" data-name="{{item.name}}">
        {{item.name}}
      </view>
      <view class="preset-tag preset-tag-other {{showGeneticOther ? 'preset-tag-selected' : ''}}"
        bindtap="toggleGeneticOther">
        其它 ✚
      </view>
    </view>
    <view wx:if="{{showGeneticOther}}" class="custom-input-wrap">
      <input class="custom-input" placeholder="请输入其它遗传病…"
        value="{{geneticOtherInput}}" bindinput="onGeneticOtherInput" maxlength="100"/>
      <button class="confirm-btn" bindtap="confirmGeneticOther">确认</button>
    </view>
    <view class="custom-tags" wx:if="{{geneticCustomItems.length > 0}}">
      <view wx:for="{{geneticCustomItems}}" wx:key="value" class="custom-tag">
        {{item.value}} <text class="delete-btn" bindtap="removeGeneticCustom" data-value="{{item.value}}">✕</text>
      </view>
    </view>
  </view>

  <!-- 用药记录 -->
  <view class="card">
    <view class="section-header-row">
      <text class="section-title">💊 当前用药</text>
      <text class="add-btn" bindtap="addMedication">+ 添加</text>
    </view>
    <view class="med-list" wx:if="{{profile.medications.length > 0}}">
      <view class="med-item" wx:for="{{profile.medications}}" wx:key="name">
        <view class="med-info">
          <text class="med-name">{{item.name}}</text>
          <text class="med-dosage">{{item.dosage}}</text>
        </view>
        <text class="tag-remove" bindtap="removeMedication" data-index="{{index}}">×</text>
      </view>
    </view>
    <text class="empty-hint" wx:else>暂无用药信息</text>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section safe-bottom">
    <button class="btn-primary save-btn" bindtap="saveProfile">保存档案</button>
  </view>
</view>
