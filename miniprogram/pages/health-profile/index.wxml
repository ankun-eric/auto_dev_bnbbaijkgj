<!--
  [PRD-健康档案路径统一 2026-05-16] 小程序端按 H5 v2 信息架构完整重写
  原文件备份为 *.bak-2026-05-16，1 个月后清理
  信息架构：成员条 → Hero卡 → 粘性5 Tab → 今日数据/健康信息/用药计划/共管与提醒/健康事件
-->
<wxs src="./helpers.wxs" module="h" />

<view class="hp-page">
  <!-- 被共管提示条 -->
  <view class="managed-notice" wx:if="{{isManagedByOthers}}" bindtap="goBindList">
    <text class="managed-notice-icon">🔗</text>
    <text class="managed-notice-text">您的健康档案正在被{{managedByList.length}}位家人守护</text>
    <text class="managed-notice-arrow">查看 ›</text>
  </view>

  <!-- 1. 家庭成员条 [PRD-HEALTH-ARCHIVE-OPTIM-V1 F1 F3] -->
  <view class="member-bar-wrap">
    <scroll-view class="member-bar" scroll-x>
      <view
        wx:for="{{members}}" wx:key="id"
        class="member-item"
        bindtap="onSelectMember" data-id="{{item.id}}"
      >
        <view class="avatar {{selectedMemberId === item.id ? 'avatar-active' : ''}}">
          <text class="avatar-emoji">{{h.relationEmoji(item)}}</text>
          <!-- [PRD-HEALTH-ARCHIVE-OPTIM-V1 F3] 被守护角标 -->
          <view class="guarded-badge" wx:if="{{guardedFlags[item.id]}}">被守护</view>
        </view>
        <text class="member-label">{{item.is_self ? '本人' : (item.relation_type_name || item.nickname)}}</text>
      </view>
      <view class="member-item" bindtap="onAddMemberTap">
        <view class="avatar avatar-add">
          <text class="avatar-add-plus">+</text>
        </view>
        <text class="member-label">添加</text>
      </view>
    </scroll-view>
  </view>

  <!-- 2. Hero 卡 [PRD-HEALTH-ARCHIVE-OPTIM-V1 F4] -->
  <view class="hero-card-wrap" wx:if="{{profile}}">
    <view class="hero-card">
      <view class="hero-edit-btn" bindtap="onEditHero">✏️ 编辑</view>
      <view class="hero-top">
        <view class="hero-avatar">
          <text class="hero-avatar-emoji">{{h.relationEmoji(selectedMember)}}</text>
          <view class="hero-guarded-badge" wx:if="{{!selectedMember.is_self && guardedFlags[selectedMember.id]}}">被守护</view>
        </view>
        <view class="hero-info">
          <!-- [PRD-HEALTH-ARCHIVE-OPTIM-V1 F4-1] 姓名 + 关系标签同行 -->
          <view class="hero-name-row">
            <text class="hero-name">{{profile.name || '未填'}}</text>
            <text class="hero-rel-label">{{selectedMember.is_self ? '本人' : (selectedMember.relation_type_name || '家庭成员')}}</text>
          </view>
          <view class="hero-baseline">{{baseLine || '未填基础信息'}}</view>
        </view>
      </view>

      <!-- [PRD-HEALTH-ARCHIVE-OPTIM-V1 F4-3] 今日用药入口 -->
      <view class="hero-today-medication" bindtap="onTapTodayMedication">
        <text class="hero-today-medication-text">💊 {{medHeroText || '今日用药 · 0'}}</text>
        <text class="hero-today-medication-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 守护关系卡片区 -->
  <view class="guardian-cards-area" wx:if="{{profile && selectedMember.is_self}}">
    <view class="guardian-cards-row">
      <view class="guardian-card guardian-card-orange" bindtap="onTapGuardianList">
        <view class="guardian-card-icon-wrap guardian-card-icon-orange">
          <text class="guardian-card-icon">🛡️</text>
        </view>
        <!-- [PRD-HEALTH-ARCHIVE-FAMILY-MEMBER-V1 2026-06-01 改动点1] 入口卡叫法由「健康档案列表」统一为「家庭成员」 -->
        <text class="guardian-card-title">家庭成员</text>
        <!-- [PRD-MEMBER-COUNT-CONSISTENCY-V1 2026-05-31 / PRD-HEALTH-ARCHIVE-FAMILY-MEMBER-V1 2026-06-01 改动点2]
             人数以列表口径为准：managedCount = /api/family/member/quota 的 quota_used（含本人），
             与「家庭成员」列表 state/list.quota_used 完全一致 -->
        <text class="guardian-card-count">{{managedCount || 0}}</text>
        <text class="guardian-card-subtitle">已管理 {{managedCount || 0}} / 上限 {{managedMaxLabel}}</text>
      </view>
      <view class="guardian-card guardian-card-green" bindtap="onTapMyGuardians">
        <view class="guardian-card-icon-wrap guardian-card-icon-green">
          <text class="guardian-card-icon">💚</text>
        </view>
        <text class="guardian-card-title">守护我的人</text>
        <!-- [PRD-MEMBER-COUNT-CONSISTENCY-V1 2026-05-31] 文案统一为「守护者 X / 上限 Y」
             X 不含本人（别人来守护我的人数） -->
        <text class="guardian-card-count">{{myGuardianCount || 0}}</text>
        <text class="guardian-card-subtitle">守护者 {{myGuardianCount || 0}} / 上限 {{myGuardianMaxLabel}}</text>
      </view>
    </view>
  </view>

  <!-- 非本人成员的共管操作 -->
  <view class="guardian-area" wx:if="{{profile && selectedMember && !selectedMember.is_self}}">
    <view
      wx:if="{{!guardedFlags[selectedMember.id]}}"
      class="guardian-invite-btn"
      bindtap="onTapInviteCoManage"
    >+ 邀请守护</view>
    <view
      wx:else
      class="guardian-manage-btn"
      bindtap="onTapManageGuardian"
    >🔧 管理</view>
  </view>

  <!-- 3. 粘性 5 Tab -->
  <view class="sticky-tabs">
    <view
      wx:for="{{tabList}}" wx:key="id"
      class="tab-item {{activeTab === item.id ? 'tab-item-active' : ''}}"
      bindtap="onTabClick" data-id="{{item.id}}"
    >{{item.label}}</view>
  </view>

  <!-- Tab 1：今日数据 6 宫格 -->
  <view wx:if="{{activeTab === 'today-data'}}" class="block">
    <view class="block-title">今日数据</view>
    <view class="metric-grid">
      <view
        wx:for="{{todayCells}}" wx:key="id"
        class="metric-card {{item.abnormal ? 'metric-card-abnormal' : ''}}"
        bindtap="onMetricCardTap" data-id="{{item.id}}"
      >
        <view class="metric-top">
          <text class="metric-label">{{item.icon}} {{item.label}}</text>
          <!-- [PRD-HR-ALIGN-BP-V1 2026-06-01] 三档胶囊（正常蓝 / 偏慢偏快橙）；无胶囊时回退「异常」标签 -->
          <text class="metric-capsule" wx:if="{{item.capLabel}}" style="background: {{item.capBg}}; color: {{item.capColor}};">{{item.capLabel}}</text>
          <text class="metric-tag" wx:elif="{{item.abnormal}}">异常</text>
        </view>
        <view class="metric-value-row">
          <text class="metric-value">{{item.value}}</text>
          <text class="metric-unit">{{item.unit}}</text>
        </view>
        <!-- 底部「时间 · 来源」行（无数据时隐藏，与血压一致） -->
        <view class="metric-time-source" wx:if="{{item.timeSource}}">{{item.timeSource}}</view>
      </view>
      <view
        class="metric-card {{medCell.has_overdue ? 'metric-card-abnormal' : ''}}"
        bindtap="onTabClick" data-id="medication-plan"
      >
        <view class="metric-top">
          <text class="metric-label">💊 用药提醒</text>
          <text class="metric-tag" wx:if="{{medCell.has_overdue}}">待服</text>
        </view>
        <view class="metric-value-row">
          <text class="metric-value">{{medCell.checked}}/{{medCell.total}}</text>
          <text class="metric-unit">已服</text>
        </view>
        <view class="med-progress">
          <view class="med-progress-bar" style="width: {{medCell.percent}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 2：健康信息 -->
  <view wx:if="{{activeTab === 'health-info'}}" class="block">
    <view class="block-title">健康信息</view>

    <view class="info-card">
      <view class="info-card-title">🏥 既往病史</view>
      <view class="tags-wrap">
        <view wx:for="{{chronicPresets}}" wx:key="*this"
          class="preset-tag {{h.inList(profile.chronic_diseases, item) ? 'preset-tag-selected' : ''}}"
          bindtap="togglePreset" data-field="chronic_diseases" data-name="{{item}}">{{item}}</view>
        <view class="preset-tag preset-tag-other" bindtap="toggleOther" data-key="chronic">其它 ✚</view>
      </view>
      <view wx:if="{{showChronicOther}}" class="custom-input-wrap">
        <input class="custom-input" placeholder="请输入其它病史" value="{{chronicOtherInput}}"
          bindinput="onOtherInput" data-key="chronic" maxlength="100" />
        <button class="confirm-btn" size="mini" bindtap="confirmOther" data-key="chronic">确认</button>
      </view>
      <view class="custom-tags" wx:if="{{chronicCustomItems.length > 0}}">
        <view wx:for="{{chronicCustomItems}}" wx:key="value" class="custom-tag">
          {{item.value}} <text class="tag-remove" bindtap="removeCustom" data-key="chronic" data-value="{{item.value}}">×</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">⚠️ 过敏史</view>
      <view class="tags-wrap">
        <view wx:for="{{allergyPresets}}" wx:key="*this"
          class="preset-tag {{h.inList(profile.allergies, item) ? 'preset-tag-selected' : ''}}"
          bindtap="togglePreset" data-field="allergies" data-name="{{item}}">{{item}}</view>
        <view class="preset-tag preset-tag-other" bindtap="toggleOther" data-key="allergy">其它 ✚</view>
      </view>
      <view wx:if="{{showAllergyOther}}" class="custom-input-wrap">
        <input class="custom-input" placeholder="请输入其它过敏源" value="{{allergyOtherInput}}"
          bindinput="onOtherInput" data-key="allergy" maxlength="100" />
        <button class="confirm-btn" size="mini" bindtap="confirmOther" data-key="allergy">确认</button>
      </view>
      <view class="custom-tags" wx:if="{{allergyCustomItems.length > 0}}">
        <view wx:for="{{allergyCustomItems}}" wx:key="value" class="custom-tag">
          {{item.value}} <text class="tag-remove" bindtap="removeCustom" data-key="allergy" data-value="{{item.value}}">×</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">🧬 家族病史</view>
      <view class="tags-wrap">
        <view wx:for="{{geneticPresets}}" wx:key="*this"
          class="preset-tag {{h.inList(profile.genetic_diseases, item) ? 'preset-tag-selected' : ''}}"
          bindtap="togglePreset" data-field="genetic_diseases" data-name="{{item}}">{{item}}</view>
        <view class="preset-tag preset-tag-other" bindtap="toggleOther" data-key="genetic">其它 ✚</view>
      </view>
      <view wx:if="{{showGeneticOther}}" class="custom-input-wrap">
        <input class="custom-input" placeholder="请输入其它遗传病" value="{{geneticOtherInput}}"
          bindinput="onOtherInput" data-key="genetic" maxlength="100" />
        <button class="confirm-btn" size="mini" bindtap="confirmOther" data-key="genetic">确认</button>
      </view>
      <view class="custom-tags" wx:if="{{geneticCustomItems.length > 0}}">
        <view wx:for="{{geneticCustomItems}}" wx:key="value" class="custom-tag">
          {{item.value}} <text class="tag-remove" bindtap="removeCustom" data-key="genetic" data-value="{{item.value}}">×</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">🧘 个人习惯</view>
      <view class="habit-row">
        <text class="habit-label">吸烟</text>
        <view class="habit-options">
          <view wx:for="{{smokingOptions}}" wx:key="*this"
            class="habit-opt {{profile.smoking === item ? 'habit-opt-active' : ''}}"
            bindtap="setHabit" data-field="smoking" data-value="{{item}}">{{item}}</view>
        </view>
      </view>
      <view class="habit-row">
        <text class="habit-label">饮酒</text>
        <view class="habit-options">
          <view wx:for="{{drinkingOptions}}" wx:key="*this"
            class="habit-opt {{profile.drinking === item ? 'habit-opt-active' : ''}}"
            bindtap="setHabit" data-field="drinking" data-value="{{item}}">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="save-bar">
      <button class="save-btn" bindtap="saveProfile" loading="{{saving}}">保存档案</button>
    </view>
  </view>

  <!-- Tab 3：用药计划 -->
  <view wx:if="{{activeTab === 'medication-plan'}}" class="block">
    <view class="block-title-row">
      <text class="block-title">用药计划</text>
      <text class="add-btn" bindtap="addMedication">+ 添加</text>
    </view>
    <view class="med-list" wx:if="{{medications.length > 0}}">
      <view class="med-plan-card" wx:for="{{medications}}" wx:key="plan_id">
        <view class="med-plan-head">
          <text class="med-plan-name">{{item.drug_name}}</text>
          <text class="med-plan-dose">{{item.dosage}}</text>
        </view>
        <view class="med-plan-rate">
          本周完成率 {{item.weekly_completed}}/{{item.weekly_total}}（{{item.weekly_rate}}%）
        </view>
        <view class="time-chips">
          <text wx:for="{{item.time_chips}}" wx:for-item="chip" wx:key="scheduled_time"
            class="time-chip {{chip.checked ? 'time-chip-checked' : ''}}">{{chip.scheduled_time}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-hint">暂无用药计划，点击右上角「+ 添加」</view>
  </view>

  <!-- Tab 4：守护与提醒 -->
  <view wx:if="{{activeTab === 'care-reminder'}}" class="block">
      <view class="block-title">守护与提醒</view>
    <view class="info-card">
      <view class="info-card-title">🔗 家庭守护</view>
      <view wx:if="{{!isLinked && selectedMember && !selectedMember.is_self}}">
        <text class="link-hint">邀请本人关联后，对方可同步查看和管理此健康档案</text>
        <button class="btn-primary invite-btn" bindtap="onInviteLink">邀请本人关联</button>
      </view>
      <view wx:elif="{{isLinked && selectedMember && !selectedMember.is_self}}" class="linked-status-row">
        <view class="linked-badge">
          <text class="linked-badge-dot"></text>
          <text class="linked-badge-text">已关联</text>
        </view>
        <text class="unlink-btn" bindtap="onUnlink">解除关联</text>
      </view>
      <view wx:else class="empty-hint">本人档案默认不需要守护</view>
    </view>
    <view class="info-card">
      <view class="info-card-title">⏰ 用药提醒</view>
      <view class="reminder-summary">
        今日已完成 {{medCell.checked}} / {{medCell.total}}
        <text wx:if="{{medCell.has_overdue}}" class="overdue-tag">有待服</text>
      </view>
    </view>
    <!-- 我的设备入口 -->
    <view class="device-entry" bindtap="onTapDevices" wx:if="{{selectedMember.is_self}}">
      <view class="device-entry-left">
        <view class="guardian-card-icon-wrap guardian-card-icon-purple">
          <text class="guardian-card-icon">📱</text>
        </view>
        <text class="device-entry-title">我的设备</text>
      </view>
      <view class="device-entry-right">
        <text class="device-entry-count">{{deviceCount || 0}} 台</text>
        <text class="device-entry-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Tab 5：健康事件 -->
  <view wx:if="{{activeTab === 'health-events'}}" class="block">
    <view class="block-title">健康事件</view>
    <view class="event-list" wx:if="{{events.length > 0}}">
      <view class="event-card" wx:for="{{events}}" wx:key="id">
        <view class="event-time">{{item.occurred_at}}</view>
        <view class="event-title">{{item.title}}</view>
        <view class="event-desc" wx:if="{{item.description}}">{{item.description}}</view>
      </view>
    </view>
    <view wx:else class="empty-hint">暂无健康事件记录</view>
  </view>

  <!-- Hero 编辑弹层 -->
  <view class="modal-mask" wx:if="{{showHeroEdit}}" bindtap="closeHeroEdit">
    <view class="modal-sheet" catchtap="">
      <view class="modal-head">
        <text class="modal-title">编辑基本信息</text>
        <text class="modal-close" bindtap="closeHeroEdit">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">姓名</text>
          <input class="form-input" placeholder="请输入姓名" value="{{heroEditDraft.name}}"
            bindinput="onHeroInput" data-field="name" />
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <view class="gender-group">
            <view wx:for="{{['男','女','其他']}}" wx:key="*this"
              class="gender-btn {{heroEditDraft.gender === item ? 'gender-active' : ''}}"
              bindtap="onHeroPick" data-field="gender" data-value="{{item}}">{{item}}</view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">出生日期</text>
          <picker mode="date" value="{{heroEditDraft.birthday}}" bindchange="onHeroDate">
            <text class="form-value {{heroEditDraft.birthday ? '' : 'placeholder'}}">{{heroEditDraft.birthday || '请选择'}}</text>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">身高(cm)</text>
          <input class="form-input" type="digit" placeholder="请输入"
            value="{{heroEditDraft.height}}" bindinput="onHeroInput" data-field="height" />
        </view>
        <view class="form-item">
          <text class="form-label">体重(kg)</text>
          <input class="form-input" type="digit" placeholder="请输入"
            value="{{heroEditDraft.weight}}" bindinput="onHeroInput" data-field="weight" />
        </view>
        <view class="form-item">
          <text class="form-label">血型</text>
          <picker range="{{bloodTypes}}" value="{{bloodTypeIndex}}" bindchange="onHeroBloodType">
            <text class="form-value {{heroEditDraft.blood_type ? '' : 'placeholder'}}">{{heroEditDraft.blood_type || '请选择'}}</text>
          </picker>
        </view>
      </view>
      <view class="modal-foot">
        <button class="btn-ghost" bindtap="closeHeroEdit">取消</button>
        <button class="btn-primary" bindtap="saveHero" loading="{{heroSaving}}">保存</button>
      </view>
    </view>
  </view>

  <!-- [PRD-HEALTH-PROFILE-SELF-COMPLETE 2026-05-29] 本人资料完善弹窗 -->
  <view class="self-complete-mask" wx:if="{{showSelfCompleteDialog}}" bindtap="onSelfCompleteLater">
    <view class="self-complete-dialog" catchtap="">
      <text class="self-complete-close" bindtap="onSelfCompleteLater">×</text>
      <view class="self-complete-title">完善健康档案</view>
      <view class="self-complete-body">为了给您提供更精准的健康服务，请先完善您的基本资料（姓名、性别、出生日期）。</view>
      <view class="self-complete-btns">
        <button class="self-complete-btn-later" bindtap="onSelfCompleteLater">稍后</button>
        <button class="self-complete-btn-go" bindtap="onSelfCompleteGo">去完善</button>
      </view>
    </view>
  </view>

  <!-- [PRD-HEALTH-PROFILE-SELF-COMPLETE 2026-05-29] 完善健康档案抽屉 -->
  <view class="self-drawer-mask" wx:if="{{showSelfCompleteDrawer}}" bindtap="closeSelfCompleteDrawer">
    <view class="self-drawer-sheet" catchtap="">
      <view class="self-drawer-head">
        <text class="self-drawer-close" bindtap="closeSelfCompleteDrawer">×</text>
        <text class="self-drawer-title">完善健康档案</text>
        <text class="self-drawer-spacer"></text>
      </view>
      <view class="self-drawer-tip">为了给您提供更精准的健康服务，请先完善您的基本资料（姓名、性别、出生日期）。</view>

      <scroll-view scroll-y class="self-drawer-body">
        <!-- 姓名（必填） -->
        <view class="self-field">
          <view class="self-field-row">
            <text class="self-field-label"><text class="self-field-required">*</text>姓名</text>
            <input class="self-field-input {{selfFormErrs.name ? 'self-field-input-err' : ''}}"
              placeholder="请输入姓名" maxlength="20"
              value="{{selfFormDraft.name}}"
              bindinput="onSelfFormInput" data-field="name" />
          </view>
          <view class="self-field-err" wx:if="{{selfFormErrs.name}}">请填写姓名</view>
        </view>

        <!-- 性别（必填） -->
        <view class="self-field">
          <view class="self-field-row">
            <text class="self-field-label"><text class="self-field-required">*</text>性别</text>
            <view class="self-gender-group">
              <view wx:for="{{['男','女']}}" wx:key="*this"
                class="self-gender-btn {{selfFormDraft.gender === item ? 'self-gender-btn-active' : ''}}"
                bindtap="onSelfGenderPick" data-value="{{item}}">{{item}}</view>
            </view>
          </view>
          <view class="self-field-err" wx:if="{{selfFormErrs.gender}}">请选择性别</view>
        </view>

        <!-- 出生日期（必填） -->
        <view class="self-field">
          <view class="self-field-row">
            <text class="self-field-label"><text class="self-field-required">*</text>出生日期</text>
            <picker mode="date" value="{{selfFormDraft.birthday}}"
              start="1900-01-01" end="{{todayDateStr}}"
              bindchange="onSelfBirthdayPick">
              <text class="self-field-value {{selfFormDraft.birthday ? '' : 'placeholder'}}">{{selfFormDraft.birthday || '请选择'}}</text>
            </picker>
          </view>
          <view class="self-field-err" wx:if="{{selfFormErrs.birthday}}">请选择出生日期</view>
        </view>

        <!-- 折叠区 -->
        <view class="self-collapsed-head" bindtap="toggleSelfDrawerMore">
          <text>其他（选填）</text>
          <text class="self-collapsed-arrow {{selfDrawerMoreOpen ? 'self-collapsed-arrow-open' : ''}}">›</text>
        </view>
        <view class="self-collapsed-body" wx:if="{{selfDrawerMoreOpen}}">
          <view class="self-field self-field-inline">
            <view class="self-field-row">
              <text class="self-field-label">身高(cm)</text>
              <input class="self-field-input" type="digit" placeholder="0-300"
                value="{{selfFormDraft.height}}"
                bindinput="onSelfFormInput" data-field="height" />
            </view>
          </view>
          <view class="self-field self-field-inline">
            <view class="self-field-row">
              <text class="self-field-label">体重(kg)</text>
              <input class="self-field-input" type="digit" placeholder="0-300"
                value="{{selfFormDraft.weight}}"
                bindinput="onSelfFormInput" data-field="weight" />
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="self-drawer-foot">
        <button class="self-drawer-save {{selfFormCanSubmit ? '' : 'self-drawer-save-disabled'}}"
          disabled="{{!selfFormCanSubmit}}"
          loading="{{selfFormSubmitting}}"
          bindtap="onSelfFormSubmit">保存</button>
      </view>
    </view>
  </view>

  <view class="safe-bottom-fix"></view>
</view>
