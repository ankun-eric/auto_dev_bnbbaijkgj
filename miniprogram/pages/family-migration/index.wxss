.mig-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}
.loading {
  padding: 200rpx 0;
  text-align: center;
  color: #999;
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon { font-size: 96rpx; }
.empty-text {
  margin: 24rpx 0;
  color: #666;
}
.header { margin-bottom: 24rpx; }
.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.header-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}
.mig-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.mig-row {
  display: flex;
  margin-bottom: 16rpx;
}
.mig-label { width: 180rpx; color: #999; font-size: 26rpx; }
.mig-value { flex: 1; color: #333; font-size: 28rpx; }
.mig-tip {
  background: #fffbe6;
  border-left: 6rpx solid #ffd666;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #663b0c;
  margin: 16rpx 0 24rpx;
  border-radius: 0 12rpx 12rpx 0;
}
.mig-actions {
  display: flex;
  gap: 24rpx;
}
.btn-confirm {
  flex: 1;
  background: #52c41a;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
}
.btn-reject {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
  font-size: 30rpx;
}
.home-btn {
  margin-top: 32rpx;
  width: 60%;
  background: #52c41a;
  color: #fff;
  border-radius: 16rpx;
}
