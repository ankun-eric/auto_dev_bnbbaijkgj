page { background: #F0F7FF; min-height: 100vh; }
.page { padding: 24rpx; padding-bottom: 80rpx; }
.header { font-size: 24rpx; color: #6b7280; margin-bottom: 16rpx; }
.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
}
.avatar-self { background: #A7F3D0; }
.avatar-other { background: #BAE6FD; }
.info { flex: 1; min-width: 0; }
.name { font-size: 30rpx; font-weight: 600; color: #1f2937; }
.self-tag { font-size: 22rpx; color: #0EA5E9; margin-left: 12rpx; }
.sub { font-size: 24rpx; color: #6b7280; margin-top: 8rpx; }
.arrow { font-size: 40rpx; color: #9ca3af; margin-left: 16rpx; }
.empty {
  text-align: center;
  color: #9ca3af;
  padding: 100rpx 32rpx;
  font-size: 26rpx;
}
