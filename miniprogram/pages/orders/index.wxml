<view class="orders-page">
  <!-- Tab -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}" 
          wx:for="{{tabs}}" wx:key="index" 
          bindtap="switchTab" data-index="{{index}}">
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="id" bindtap="goOrderDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="order-body">
        <text class="order-icon">{{item.icon}}</text>
        <view class="order-info">
          <text class="order-name">{{item.name}}</text>
          <text class="order-time">{{item.time}}</text>
        </view>
        <text class="order-price">¥{{item.price}}</text>
      </view>
      <view class="order-footer">
        <button class="order-btn" wx:if="{{item.status === 'pending'}}" catchtap="payOrder" data-id="{{item.id}}">去支付</button>
        <button class="order-btn" wx:if="{{item.status === 'paid'}}" catchtap="useOrder" data-id="{{item.id}}">去使用</button>
        <button class="order-btn btn-gray" wx:if="{{item.status === 'pending'}}" catchtap="cancelOrder" data-id="{{item.id}}">取消</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
