.messages-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.msg-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.msg-header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.msg-read-all {
  font-size: 26rpx;
  color: #52c41a;
}

.msg-list {
  padding: 16rpx 24rpx;
}

.msg-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.msg-unread {
  background: #fafffe;
  border-left: 6rpx solid #52c41a;
}

.msg-dot {
  position: absolute;
  top: 28rpx;
  left: 12rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.msg-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(82, 196, 26, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.msg-type-icon {
  font-size: 32rpx;
}

.msg-body {
  flex: 1;
  overflow: hidden;
}

.msg-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.msg-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.msg-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.msg-action-row {
  margin-top: 16rpx;
  display: flex;
}

.msg-action-btn {
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
}

.msg-accept-btn {
  background: #52c41a;
  color: #fff;
}

.msg-reinvite-btn {
  background: #fff;
  color: #52c41a;
  border: 1rpx solid #52c41a;
}

.msg-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.msg-empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.msg-empty-text {
  font-size: 28rpx;
  color: #999;
}

.msg-loading {
  text-align: center;
  padding: 32rpx 0;
}

.msg-loading-text {
  font-size: 26rpx;
  color: #999;
}

.msg-bottom {
  text-align: center;
  padding: 24rpx 0;
}

.msg-bottom-text {
  font-size: 24rpx;
  color: #ccc;
}
