.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.empty { text-align: center; padding: 80rpx 0; color: #999; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-name { font-size: 30rpx; font-weight: 600; }
.card-meta { color: #888; font-size: 24rpx; margin-top: 8rpx; }
.card-actions { margin-top: 16rpx; display: flex; gap: 16rpx; }
