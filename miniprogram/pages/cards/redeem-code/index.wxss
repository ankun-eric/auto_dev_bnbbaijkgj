.page { padding: 32rpx; background: #f5f5f5; min-height: 100vh; }
.empty { text-align: center; padding: 100rpx 0; color: #999; }
.panel { background: #fff; padding: 32rpx; border-radius: 24rpx; text-align: center; }
.qr-placeholder { border: 4rpx solid #52c41a; padding: 32rpx; word-break: break-all; font-size: 22rpx; min-height: 300rpx; display: flex; align-items: center; justify-content: center; }
.digits { font-size: 56rpx; letter-spacing: 8rpx; color: #237804; margin: 24rpx 0; font-family: monospace; }
.meta { color: #888; font-size: 24rpx; margin-bottom: 24rpx; }
.refresh { background: #52c41a; }
