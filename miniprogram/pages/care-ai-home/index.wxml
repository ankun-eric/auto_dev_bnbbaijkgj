<!-- [PRD-CARE-MODE-OPTIM-V4 2026-05-31] 关怀模式首页优化 -->
<view class="care-home">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <!-- [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求1] 第一行（顶栏）两版统一，照标准版样式：
       ☰三横杠(带红点) → 档案/咨询/服务 三 Tab(当前停咨询·蓝下划线) → 🔔铃铛(带橙点) → ⊕加号圈。
       原顶栏旧胶囊与 🎁邀请图标已全部移除。 -->
  <view class="topbar unified-topbar">
    <!-- 1. 左：← 返回箭头（[BUGFIX-AI-HOME-CARE-BACK-V1 2026-06-01 §问题2]）
         旧版为「☰ 三横杠」，点击跳标准 AI 首页并顺带把模式带回标准模式（"一点就跳回标准模式" BUG）。
         关怀模式用不上"历史对话"，现去掉 ☰，换成向左箭头「←」返回图标：
         点击退出关怀模式，统一退回标准 AI 主页（复用 switchToStandard：存 standard 偏好 → 跳 /pages/ai/index）。 -->
    <view class="uni-back" catchtap="goBackStandard" data-testid="care-home-back-btn">
      <text class="uni-back-icon" data-testid="care-home-back-icon">‹</text>
    </view>

    <!-- 2~4. 中：档案 / 咨询 / 服务 三 Tab（当前停「咨询」，选中蓝色下划线） -->
    <view class="uni-tabs" data-testid="care-home-top-tabs">
      <view class="uni-tab" catchtap="onTopTab" data-key="profile" data-testid="care-home-top-tab-profile">
        <text class="uni-tab-label">档案</text>
        <view class="uni-tab-underline"></view>
      </view>
      <view class="uni-tab uni-tab-active" catchtap="onTopTab" data-key="consult" data-testid="care-home-top-tab-consult">
        <text class="uni-tab-label uni-tab-label-active">咨询</text>
        <view class="uni-tab-underline uni-tab-underline-active"></view>
      </view>
      <view class="uni-tab" catchtap="onTopTab" data-key="service" data-testid="care-home-top-tab-service">
        <text class="uni-tab-label">服务</text>
        <view class="uni-tab-underline"></view>
      </view>
    </view>

    <!-- 5+6. 右：🔔 铃铛（带橙点） + ⊕ 加号圈 -->
    <view class="uni-right">
      <view class="uni-bell" catchtap="openBell" data-testid="care-home-topbar-bell">
        <text class="uni-bell-icon">🔔</text>
        <view class="uni-bell-reddot" data-testid="care-home-topbar-bell-reddot"></view>
      </view>
      <view class="uni-plus" catchtap="openMoreMenu" data-testid="care-home-more-btn">
        <view class="uni-plus-circle" data-testid="care-home-more-icon-plus-circle">
          <text class="uni-plus-sign">+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- [PRD-AIHOME-OPTIM-SHARE-V1 2026-06-02 §需求1/2] 关怀模式「⊕ 加号圈」菜单（5 项）：
       1.🔀切换模式 2.👑会员中心 3.📷扫一扫 4.🎁分享好友 5.❓帮助与反馈
       关怀模式无 AI 对话，已删除「💬发起新对话」「🔤字体大小」；并删除「📤立即分享」「🎁邀请好友」。
       「🎁 分享好友」点击弹出分享面板，与标准模式完全一致。 -->
  <view class="more-menu-mask" wx:if="{{moreMenuShow}}" catchtap="closeMoreMenu"></view>
  <view class="more-menu-card" wx:if="{{moreMenuShow}}" data-testid="care-home-more-menu-card">
    <view class="more-menu-item" catchtap="onTapSwitchMode" data-testid="care-home-more-menu-item-切换模式">
      <text class="more-menu-icon">🔀</text>
      <text class="more-menu-label">切换模式</text>
      <text class="more-menu-mode-tag" data-testid="care-home-more-menu-mode-tag">关怀版</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item more-menu-item-gold" catchtap="onTapMemberCenter" data-testid="care-home-more-menu-item-会员中心">
      <text class="more-menu-icon">👑</text>
      <text class="more-menu-label more-menu-label-gold">会员中心</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" catchtap="onTapScan" data-testid="care-home-more-menu-item-扫一扫">
      <text class="more-menu-icon">📷</text>
      <text class="more-menu-label">扫一扫</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" catchtap="onTapShareFriend" data-testid="care-home-more-menu-item-分享好友">
      <text class="more-menu-icon">🎁</text>
      <text class="more-menu-label">分享好友</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" catchtap="onTapHelpFeedback" data-testid="care-home-more-menu-item-帮助与反馈">
      <text class="more-menu-icon">❓</text>
      <text class="more-menu-label">帮助与反馈</text>
    </view>
  </view>

  <!-- 2. 欢迎区（主体排版保持原样，仅在右上角新增「模式切换」胶囊） -->
  <view class="welcome">
    <!-- [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求3] 欢迎区右上角「模式切换」胶囊（方案1：胶囊带文字）
         显示「关怀版 ▾」，点击弹下拉：标准版(可切换) / 关怀版(当前打勾)。与 ⊕菜单里的「切换模式」并存。 -->
    <view class="welcome-mode-switch" data-testid="care-home-mode-switcher">
      <view class="mode-capsule" catchtap="toggleModeDropdown" data-testid="care-home-mode-capsule">
        <text class="mode-capsule-label">关怀版</text>
        <text class="mode-capsule-arrow {{modeDropdownOpen ? 'mode-capsule-arrow-up' : ''}}">▾</text>
      </view>
      <view class="mode-dropdown-mask" wx:if="{{modeDropdownOpen}}" catchtap="closeModeDropdown"></view>
      <view class="mode-dropdown-panel mode-dropdown-panel-welcome" wx:if="{{modeDropdownOpen}}" data-testid="care-home-mode-dropdown-panel">
        <view class="mode-dropdown-item" catchtap="switchToStandard" data-testid="care-home-mode-option-standard">
          <text class="mode-dropdown-text">标准版</text>
        </view>
        <view class="mode-dropdown-item mode-dropdown-item-active" catchtap="closeModeDropdown" data-testid="care-home-mode-option-care">
          <text class="mode-dropdown-text">关怀版</text>
          <text class="mode-dropdown-check">✓</text>
        </view>
      </view>
    </view>
    <view class="welcome-text">
      <view class="greeting">{{greetingText}} {{greetingIcon}}</view>
      <view class="sub">我是宾尼小康，聊聊健康问题吧~</view>
      <!-- [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化4] 今日提醒智能轮转 + 点击直达打卡页 -->
      <view class="med-reminder" catchtap="onTapMedReminder" data-testid="care-home-med-reminder">🔔 今日提醒：{{medText}} ›</view>
    </view>
    <view class="robot-logo">
      <image class="robot-img" src="{{logoUrl}}" mode="aspectFill"></image>
    </view>
  </view>

  <!-- 3. 5 张大字整行卡片（主体排版保持原样） -->
  <view class="cards">
    <view class="card" wx:for="{{cards}}" wx:key="key" data-key="{{item.key}}" catchtap="onCardTap">
      <view class="card-icon" style="background: {{item.bg}}"><text>{{item.icon}}</text></view>
      <view class="card-body">
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.desc}}</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>

  <!-- [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化3] 「分享给好友」按钮（合并原 邀请好友/立即分享）
       只负责纯拉新分享，点击弹出分享面板（卡片预览 + 微信好友/生成海报/复制链接） -->
  <view class="share-section" data-testid="care-home-share-section">
    <view class="share-friend-btn" catchtap="openSharePanel" data-testid="care-home-share-friend-btn">
      <text class="share-friend-icon">🎁</text>
      <text class="share-friend-label">分享好友</text>
    </view>
    <view class="share-friend-sub">把宾尼小康推荐给亲友</view>
  </view>

  <!-- 9. 右下角悬浮 SOS（红色圆 + SOS 白字 + 扩散光圈动画），点击 = 进紧急呼叫流程 -->
  <view class="sos-fab" catchtap="onSosFabTap">
    <view class="sos-fab-ripple sos-fab-ripple-1"></view>
    <view class="sos-fab-ripple sos-fab-ripple-2"></view>
    <view class="sos-fab-ripple sos-fab-ripple-3"></view>
    <view class="sos-fab-core"><text class="sos-fab-text">SOS</text></view>
  </view>

  <!-- [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化2] 底部居中向下小箭头（轻轻上下跳动），下滑后自动隐藏 -->
  <view class="scroll-hint" wx:if="{{showScrollHint}}" data-testid="care-home-scroll-hint">
    <text class="scroll-hint-arrow">⌄</text>
  </view>

  <!-- [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化3] 分享面板（卡片预览 + 微信好友/生成海报/复制链接） -->
  <view class="share-mask" wx:if="{{sharePanelShow}}" catchtap="closeSharePanel"></view>
  <view class="share-panel" wx:if="{{sharePanelShow}}" data-testid="care-share-panel">
    <!-- 分享卡片预览（统一文案） -->
    <view class="share-card-preview" data-testid="care-share-card-preview">
      <image class="share-card-logo" src="{{logoUrl}}" mode="aspectFill"></image>
      <text class="share-card-slogan" data-testid="care-share-slogan">我在用 宾尼小康 守护家人健康，推荐您也来试试~</text>
    </view>
    <!-- 3 个渠道 -->
    <view class="share-channels">
      <button class="share-channel" open-type="share" catchtap="onShareWechat" data-testid="care-share-channel-wechat">
        <view class="share-channel-icon">💬</view>
        <text class="share-channel-label">微信好友</text>
      </button>
      <view class="share-channel" catchtap="onSharePoster" data-testid="care-share-channel-poster">
        <view class="share-channel-icon">🖼️</view>
        <text class="share-channel-label">生成海报</text>
      </view>
      <view class="share-channel" catchtap="onShareCopy" data-testid="care-share-channel-copy">
        <view class="share-channel-icon">🔗</view>
        <text class="share-channel-label">复制链接</text>
      </view>
    </view>
    <view class="share-cancel" catchtap="closeSharePanel">取消</view>
  </view>

  <!-- [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §三] 方案 A 温情暖色海报 -->
  <view class="share-mask" wx:if="{{posterShow}}" catchtap="closePoster"></view>
  <view class="poster-panel" wx:if="{{posterShow}}" data-testid="care-share-poster-wrap">
    <view class="poster-card" data-testid="care-share-poster">
      <view class="poster-top">
        <view class="poster-logo-wrap">
          <image class="poster-logo" src="{{logoUrl}}" mode="aspectFill"></image>
        </view>
        <text class="poster-brand">宾尼小康</text>
      </view>
      <view class="poster-title">我在用 <text class="poster-title-em">宾尼小康</text> 守护家人健康，推荐您也来试试~</view>
      <view class="poster-illu">👵 💗 👨‍👩‍👧</view>
      <view class="poster-feats">
        <view class="poster-feat"><view class="poster-feat-icon">💊</view><text class="poster-feat-label">用药提醒</text></view>
        <view class="poster-feat"><view class="poster-feat-icon">📈</view><text class="poster-feat-label">健康记录</text></view>
        <view class="poster-feat"><view class="poster-feat-icon">🛡️</view><text class="poster-feat-label">家人守护</text></view>
      </view>
      <view class="poster-qr-row">
        <view class="poster-qr" data-testid="care-share-poster-qr">▦</view>
        <view class="poster-qr-text">
          <text class="poster-qr-title">微信扫一扫</text>
          <text class="poster-qr-sub">立即体验宾尼小康</text>
        </view>
      </view>
    </view>
    <view class="poster-tip">截图保存上方海报即可分享给亲友</view>
    <view class="poster-done" catchtap="closePoster">完成</view>
  </view>
</view>
