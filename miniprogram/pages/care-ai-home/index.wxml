<!-- [PRD-CARE-MODE-OPTIM-V1 2026-05-31] 关怀模式首页优化 -->
<view class="care-home" catchtap="closeModeDropdown">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <!-- 1. 顶部固定栏 -->
  <view class="topbar">
    <view class="topbar-left" catchtap="goMenu">
      <view class="hamburger">
        <view class="hb-line hb-1"></view>
        <view class="hb-line hb-2"></view>
        <view class="hb-line hb-3"></view>
      </view>
    </view>
    <view class="topbar-title">小康</view>
    <view class="topbar-right">
      <!-- 模式切换胶囊 -->
      <view class="mode-wrap" catchtap="toggleModeDropdown">
        <view class="mode-capsule">
          <text>关怀模式</text>
          <text class="mode-arrow {{modeDropdownOpen ? 'mode-arrow-up' : ''}}">▾</text>
        </view>
        <view class="mode-dropdown" wx:if="{{modeDropdownOpen}}" catchtap="closeModeDropdown">
          <view class="mode-item" catchtap="switchToStandard">
            <text>标准模式</text>
          </view>
          <view class="mode-item mode-item-active">
            <text>关怀模式</text>
            <text>✓</text>
          </view>
        </view>
      </view>
      <!-- 🎁 -->
      <view class="topbar-icon" catchtap="goInvite"><text>🎁</text></view>
      <!-- ⊕ -->
      <view class="topbar-icon" catchtap="goInvite"><text class="plus-circle">⊕</text></view>
    </view>
  </view>

  <!-- 2. 欢迎区 -->
  <view class="welcome">
    <view class="welcome-text">
      <view class="greeting">{{greetingText}} {{greetingIcon}}</view>
      <view class="sub">我是小康，有健康问题随时问我~</view>
      <view class="med-reminder">🔔 今日提醒：{{medText}}</view>
    </view>
    <view class="robot-logo">
      <image class="robot-img" src="{{logoUrl}}" mode="aspectFill"></image>
    </view>
  </view>

  <!-- 3. 5 张大字整行卡片 -->
  <view class="cards">
    <view class="card" wx:for="{{cards}}" wx:key="key" data-key="{{item.key}}" catchtap="onCardTap">
      <view class="card-icon" style="background: {{item.bg}}"><text>{{item.icon}}</text></view>
      <view class="card-body">
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.desc}}</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>
</view>
