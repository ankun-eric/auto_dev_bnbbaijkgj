/* [PRD-CARE-MODE-OPTIM-V1 2026-05-31] 关怀模式首页优化 */
.care-home {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

.status-bar { background: #F0F9FF; }
/* 顶栏 */
.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: linear-gradient(180deg, #F0F9FF 0%, #DBEAFE 100%);
}
.topbar-left { width: 64rpx; display: flex; align-items: center; }
.hamburger { width: 42rpx; }
.hb-line { height: 5rpx; border-radius: 3rpx; background: #0C4A6E; margin-bottom: 9rpx; }
.hb-1 { width: 32rpx; }
.hb-2 { width: 32rpx; }
.hb-3 { width: 22rpx; }
.topbar-title { font-size: 36rpx; font-weight: 600; color: #0C4A6E; }
.topbar-right { display: flex; align-items: center; gap: 14rpx; }
.topbar-icon { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 38rpx; }
.plus-circle { color: #0C4A6E; font-size: 42rpx; }

.mode-wrap { position: relative; }
.mode-capsule {
  display: flex; align-items: center; gap: 6rpx;
  background: #E8F5E9; color: #2E7D32;
  padding: 8rpx 18rpx; border-radius: 28rpx;
  font-size: 24rpx; font-weight: 600;
}
.mode-arrow { font-size: 18rpx; transition: transform 0.15s; }
.mode-arrow-up { transform: rotate(180deg); }
.mode-dropdown {
  position: absolute; top: 56rpx; right: 0;
  min-width: 220rpx; background: #fff; border-radius: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.15); overflow: hidden; z-index: 50;
}
.mode-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 26rpx; font-size: 28rpx; color: #374151;
}
.mode-item-active { background: #E8F5E9; color: #2E7D32; font-weight: 600; }

/* 欢迎区 */
.welcome {
  background: linear-gradient(135deg, #1976D2 0%, #43A047 100%);
  color: #fff;
  padding: 40rpx 36rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex; align-items: center; justify-content: space-between; gap: 20rpx;
}
.welcome-text { flex: 1; min-width: 0; }
.greeting { font-size: 52rpx; font-weight: 700; margin-bottom: 10rpx; }
.sub { font-size: 28rpx; opacity: 0.95; margin-bottom: 22rpx; }
.med-reminder {
  display: inline-block;
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  max-width: 100%;
}
.robot-logo {
  flex-shrink: 0;
  width: 150rpx; height: 150rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.12);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.robot-img { width: 132rpx; height: 132rpx; border-radius: 50%; }

/* 卡片 */
.cards { padding: 28rpx; display: flex; flex-direction: column; gap: 24rpx; }
.card {
  display: flex; align-items: center; gap: 28rpx;
  background: #fff; border: 1rpx solid #EEF1F4; border-radius: 32rpx;
  padding: 32rpx 28rpx; box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.04);
}
.card-icon {
  flex-shrink: 0; width: 100rpx; height: 100rpx;
  border-radius: 28rpx; display: flex; align-items: center; justify-content: center;
  font-size: 50rpx;
}
.card-body { flex: 1; min-width: 0; }
.card-title { font-size: 38rpx; font-weight: 700; color: #1F2937; margin-bottom: 6rpx; }
.card-desc { font-size: 26rpx; color: #9CA3AF; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-arrow { flex-shrink: 0; font-size: 44rpx; color: #C4CDD5; }
