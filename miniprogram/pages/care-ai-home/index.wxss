/* [PRD-CARE-MODE-OPTIM-V1 2026-05-31] 关怀模式首页优化 */
.care-home {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

.status-bar { background: #EAF6FF; }
/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求1] 顶栏两版统一：☰红点 → 档案/咨询/服务 → 🔔橙点 → ⊕ */
.topbar.unified-topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  background: linear-gradient(180deg, #EAF6FF 0%, #DCEFFF 100%);
}
.uni-hamburger {
  position: relative;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.uni-hamburger-icon { font-size: 40rpx; color: #1F2D3D; line-height: 1; }
.uni-hamburger-reddot {
  position: absolute; top: 8rpx; right: 10rpx;
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #FF3B30;
}
.uni-tabs {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  gap: 44rpx; min-width: 0;
}
.uni-tab {
  position: relative;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 64rpx; padding: 0 4rpx;
}
.uni-tab-label { font-size: 32rpx; font-weight: 500; color: #6B7B8C; line-height: 1; }
.uni-tab-label-active { font-weight: 700; color: #3FA9F5; }
.uni-tab-underline { margin-top: 10rpx; width: 0; height: 6rpx; border-radius: 3rpx; background: transparent; }
.uni-tab-underline-active { width: 40rpx; background: #3FA9F5; }
.uni-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.uni-bell { position: relative; width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.uni-bell-icon { font-size: 38rpx; line-height: 1; }
.uni-bell-reddot {
  position: absolute; top: 6rpx; right: 8rpx;
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #FF7A45; box-shadow: 0 0 0 3rpx #fff;
}
.uni-plus { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.uni-plus-circle {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #1F2D3D;
  display: flex; align-items: center; justify-content: center;
}
.uni-plus-sign { font-size: 36rpx; color: #1F2D3D; line-height: 1; font-weight: 300; }

/* 模式切换胶囊（欢迎区右上角） */
.mode-capsule {
  display: flex; align-items: center; gap: 6rpx;
  background: rgba(255,255,255,0.22); border: 1rpx solid rgba(255,255,255,0.45);
  padding: 8rpx 18rpx; border-radius: 28rpx;
}
.mode-capsule-label { font-size: 24rpx; font-weight: 600; color: #FFFFFF; line-height: 1; }
.mode-capsule-arrow { font-size: 20rpx; color: #FFFFFF; line-height: 1; transition: transform 0.15s ease; }
.mode-capsule-arrow-up { transform: rotate(180deg); }

/* 模式切换下拉面板 */
.mode-dropdown-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: transparent; z-index: 998; }
.mode-dropdown-panel {
  position: absolute; top: 92rpx; left: 50%; transform: translateX(-30%);
  min-width: 240rpx; background: #fff; border: 1rpx solid #E5E7EB; border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15); overflow: hidden; z-index: 999;
}
.mode-dropdown-panel-welcome { top: calc(100% + 12rpx); right: 0; left: auto; transform: none; }
.mode-dropdown-item { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 28rpx; background: #fff; }
.mode-dropdown-item-active { background: #E8F5E9; }
.mode-dropdown-text { font-size: 28rpx; font-weight: 500; color: #374151; }
.mode-dropdown-item-active .mode-dropdown-text { color: #2E7D32; font-weight: 600; }
.mode-dropdown-check { font-size: 28rpx; color: #2E7D32; font-weight: 600; }

/* 更多菜单弹层（统一 8 项） */
.more-menu-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.35); z-index: 999; }
.more-menu-card {
  position: fixed; top: 100rpx; right: 24rpx; min-width: 360rpx;
  background: #F0F9FF; border: 1rpx solid #BAE6FD; border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18); z-index: 1000; overflow: hidden;
}
.more-menu-item { display: flex; align-items: center; padding: 24rpx 28rpx; gap: 18rpx; background: transparent; }
.more-menu-item:active { background: #E0F2FE; }
.more-menu-divider { height: 1rpx; background: #BAE6FD; margin: 0 28rpx; }
.more-menu-icon { font-size: 32rpx; line-height: 1; }
.more-menu-label { flex: 1; font-size: 28rpx; color: #1F2937; }
.more-menu-label-gold { color: #E5A23B; font-weight: 700; }
/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求2] 「切换模式」右侧当前模式小标签 */
.more-menu-mode-tag {
  font-size: 22rpx; font-weight: 600; color: #3FA9F5;
  background: #EAF6FF; border-radius: 16rpx; padding: 4rpx 14rpx; line-height: 1.2;
}
.more-menu-badge {
  font-size: 20rpx; font-weight: 700; color: #5C3B00;
  background: linear-gradient(90deg, #E5A23B 0%, #F4D793 100%);
  padding: 2rpx 12rpx; border-radius: 16rpx; line-height: 1.2;
}

/* 欢迎区 */
.welcome {
  position: relative;
  background: linear-gradient(135deg, #1976D2 0%, #43A047 100%);
  color: #fff;
  padding: 40rpx 36rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex; align-items: center; justify-content: space-between; gap: 20rpx;
}
/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求3] 欢迎区右上角模式切换胶囊容器 */
.welcome-mode-switch { position: absolute; right: 28rpx; top: 24rpx; z-index: 5; }
.welcome-text { flex: 1; min-width: 0; }
.greeting { font-size: 52rpx; font-weight: 700; margin-bottom: 10rpx; }
.sub { font-size: 28rpx; opacity: 0.95; margin-bottom: 22rpx; }
.med-reminder {
  display: inline-block;
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  max-width: 100%;
}
.robot-logo {
  flex-shrink: 0;
  width: 150rpx; height: 150rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.12);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.robot-img { width: 132rpx; height: 132rpx; border-radius: 50%; }

/* 卡片 */
.cards { padding: 28rpx; display: flex; flex-direction: column; gap: 24rpx; }
.card {
  display: flex; align-items: center; gap: 28rpx;
  background: #fff; border: 1rpx solid #EEF1F4; border-radius: 32rpx;
  padding: 32rpx 28rpx; box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.04);
}
.card-icon {
  flex-shrink: 0; width: 100rpx; height: 100rpx;
  border-radius: 28rpx; display: flex; align-items: center; justify-content: center;
  font-size: 50rpx;
}
.card-body { flex: 1; min-width: 0; }
.card-title { font-size: 38rpx; font-weight: 700; color: #1F2937; margin-bottom: 6rpx; }
.card-desc { font-size: 26rpx; color: #9CA3AF; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-arrow { flex-shrink: 0; font-size: 44rpx; color: #C4CDD5; }

/* 9. 右下角悬浮 SOS（红色圆 + SOS 白字 + 扩散光圈动画） */
.sos-fab {
  position: fixed;
  right: 36rpx;
  bottom: 80rpx;
  width: 132rpx;
  height: 132rpx;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sos-fab-core {
  position: relative;
  z-index: 2;
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 40%, #EF5350 0%, #E53935 70%, #C62828 100%);
  box-shadow: 0 8rpx 22rpx rgba(229,57,53,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sos-fab-text { color: #fff; font-size: 36rpx; font-weight: 800; letter-spacing: 2rpx; }
.sos-fab-ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 116rpx;
  height: 116rpx;
  margin-left: -58rpx;
  margin-top: -58rpx;
  border-radius: 50%;
  background: rgba(229,57,53,0.35);
  z-index: 1;
  animation: sos-fab-spread 2s ease-out infinite;
}
.sos-fab-ripple-2 { animation-delay: 0.66s; }
.sos-fab-ripple-3 { animation-delay: 1.32s; }
@keyframes sos-fab-spread {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2.1); opacity: 0; }
}

/* [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化4] 今日提醒可点击态 */
.med-reminder { cursor: pointer; }

/* [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化3] 分享给好友按钮 */
.share-section { padding: 8rpx 28rpx 16rpx; }
.share-friend-btn {
  width: 100%;
  box-sizing: border-box;
  display: flex; align-items: center; justify-content: center; gap: 14rpx;
  background: linear-gradient(135deg, #FFB877 0%, #FB8C00 100%);
  color: #fff; border-radius: 28rpx; padding: 30rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(251,140,0,0.28);
}
.share-friend-icon { font-size: 38rpx; }
.share-friend-label { font-size: 34rpx; font-weight: 700; }
.share-friend-sub { text-align: center; font-size: 24rpx; color: #9CA3AF; margin-top: 14rpx; }

/* [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化2] 底部向下箭头（轻轻上下跳动） */
.scroll-hint {
  position: fixed; left: 50%; bottom: 28rpx; transform: translateX(-50%);
  z-index: 120; width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.92); box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.15);
  display: flex; align-items: center; justify-content: center; pointer-events: none;
}
.scroll-hint-arrow {
  font-size: 44rpx; color: #1976D2; line-height: 1;
  animation: care-arrow-bounce 1.2s ease-in-out infinite;
}
@keyframes care-arrow-bounce {
  0%, 100% { transform: translateY(-6rpx); }
  50% { transform: translateY(6rpx); }
}

/* [PRD-CARE-OPTIM-FINAL-V1 2026-06-01 §优化3] 分享面板 / 海报 */
.share-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 900; }
.share-panel {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 901;
  background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 36rpx 36rpx 56rpx;
}
.share-card-preview {
  display: flex; align-items: center; gap: 24rpx;
  background: #FFF6EC; border: 1rpx solid #FFE0BD; border-radius: 24rpx;
  padding: 28rpx; margin-bottom: 32rpx;
}
.share-card-logo { width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0; background: #fff; }
.share-card-slogan { font-size: 28rpx; font-weight: 700; color: #5B3A1E; line-height: 1.5; flex: 1; }
.share-channels { display: flex; justify-content: space-around; }
.share-channel {
  display: flex; flex-direction: column; align-items: center; gap: 14rpx;
  background: transparent; border: none; line-height: 1.4; padding: 0; margin: 0;
}
.share-channel::after { border: none; }
.share-channel-icon {
  width: 104rpx; height: 104rpx; border-radius: 50%;
  background: rgba(251,140,0,0.12); display: flex; align-items: center; justify-content: center;
  font-size: 46rpx;
}
.share-channel-label { font-size: 26rpx; color: #8A5A2E; }
.share-cancel {
  margin-top: 36rpx; text-align: center; background: #F5F5F5; color: #888;
  border-radius: 24rpx; padding: 24rpx; font-size: 28rpx;
}

.poster-panel {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 901;
  background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 36rpx 56rpx;
  text-align: center;
}
.poster-card {
  width: 560rpx; margin: 0 auto; border-radius: 32rpx; overflow: hidden;
  background: linear-gradient(180deg, #FFF6EC 0%, #FFE9D2 100%);
  box-shadow: 0 16rpx 50rpx rgba(244,115,31,0.22);
}
.poster-top { padding: 40rpx 36rpx 16rpx; }
.poster-logo-wrap {
  width: 140rpx; height: 140rpx; border-radius: 50%; background: #fff;
  border: 6rpx solid #fff; box-shadow: 0 8rpx 22rpx rgba(244,115,31,0.22);
  margin: 0 auto 14rpx; display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.poster-logo { width: 128rpx; height: 128rpx; border-radius: 50%; }
.poster-brand { font-size: 34rpx; font-weight: 800; color: #F4731F; letter-spacing: 2rpx; }
.poster-title { padding: 8rpx 40rpx 24rpx; font-size: 30rpx; font-weight: 700; color: #5B3A1E; line-height: 1.6; }
.poster-title-em { color: #F4731F; }
.poster-illu {
  margin: 0 32rpx 22rpx; height: 130rpx; border-radius: 24rpx;
  background: linear-gradient(135deg, #FFD9A8 0%, #FFB877 100%);
  display: flex; align-items: center; justify-content: center; font-size: 56rpx; letter-spacing: 8rpx;
}
.poster-feats { display: flex; justify-content: space-around; padding: 0 28rpx 28rpx; }
.poster-feat { text-align: center; }
.poster-feat-icon {
  width: 76rpx; height: 76rpx; border-radius: 22rpx; background: #fff;
  display: flex; align-items: center; justify-content: center; font-size: 38rpx; margin: 0 auto 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(244,115,31,0.12);
}
.poster-feat-label { font-size: 24rpx; color: #8A5A2E; font-weight: 600; }
.poster-qr-row { background: #fff; padding: 26rpx 36rpx; display: flex; align-items: center; gap: 24rpx; }
.poster-qr {
  width: 120rpx; height: 120rpx; border-radius: 18rpx; background: #F2F2F2;
  border: 2rpx dashed #C9A06A; display: flex; align-items: center; justify-content: center; font-size: 44rpx; flex-shrink: 0;
}
.poster-qr-text { text-align: left; display: flex; flex-direction: column; }
.poster-qr-title { font-size: 26rpx; font-weight: 700; color: #F4731F; }
.poster-qr-sub { font-size: 24rpx; color: #9A7B5C; }
.poster-tip { font-size: 24rpx; color: #9CA3AF; margin-top: 24rpx; }
.poster-done {
  margin-top: 28rpx; background: #FB8C00; color: #fff; border-radius: 24rpx;
  padding: 26rpx; font-size: 30rpx; font-weight: 600;
}
