/* [PRD-CARE-AI-HOME 2026-05-27] 关怀模式 AI 主页 v1 样式 */
.care-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 200rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #212121;
}

/* 顶栏 */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E0E0E0;
}
.topbar-menu {
  font-size: 44rpx;
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.topbar-center {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.topbar-name {
  font-size: 34rpx;
  font-weight: 600;
}
.online-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #43A047;
}
.online-text {
  font-size: 26rpx;
  color: #666;
}
.topbar-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.mode-badge {
  background: #E8F5E9;
  color: #1976D2;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.switch-btn {
  background: #1976D2;
  color: #FFF;
  padding: 10rpx 22rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
}

/* 欢迎区 */
.welcome {
  background: linear-gradient(135deg, #1976D2 0%, #43A047 100%);
  color: #FFFFFF;
  padding: 48rpx 36rpx;
  border-radius: 0 0 36rpx 36rpx;
}
.welcome-title {
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.welcome-sub {
  font-size: 30rpx;
}

/* 快捷胶囊 */
.quick-grid {
  display: flex;
  padding: 28rpx 24rpx;
  gap: 16rpx;
}
.quick-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 8rpx;
  min-height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  border: 2rpx solid #E0E0E0;
}
.quick-icon {
  font-size: 46rpx;
}
.quick-label {
  font-weight: 500;
}

/* 卡片 */
.cards {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.card-icon {
  font-size: 40rpx;
}
.card-title {
  font-size: 34rpx;
  font-weight: 600;
}
.card-text {
  font-size: 30rpx;
  color: #424242;
  margin-bottom: 20rpx;
}
.card-text-sm {
  font-size: 26rpx;
  color: #666;
}

.metric-grid {
  display: flex;
  gap: 14rpx;
}
.metric-item {
  flex: 1;
  background: #F5F7FA;
  border-radius: 18rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}
.metric-label {
  font-size: 24rpx;
  color: #666;
}
.metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #212121;
  margin: 8rpx 0;
}
.metric-unit {
  font-size: 20rpx;
  color: #999;
  margin-left: 4rpx;
}
.metric-status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 14rpx;
}

.sos-card {
  background: #FFF5F5;
  border: 2rpx solid #FFCDD2;
}
.sos-title {
  color: #C62828;
}

.row-buttons {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}
.btn-primary {
  flex: 1;
  background: #43A047;
  color: #FFF;
  border-radius: 20rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-outline {
  flex: 1;
  background: #FFF;
  color: #1976D2;
  border: 2rpx solid #1976D2;
  border-radius: 20rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-danger {
  flex: 1;
  background: #E53935;
  color: #FFF;
  border-radius: 20rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 悬浮球 */
.fab-consult {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 48rpx;
  background: #1976D2;
  color: #FFF;
  border-radius: 64rpx;
  padding: 24rpx 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(25,118,210,0.4);
  z-index: 20;
}
.fab-icon {
  font-size: 40rpx;
}
.fab-sos {
  position: fixed;
  right: 36rpx;
  bottom: 48rpx;
  background: #E53935;
  color: #FFF;
  border-radius: 50%;
  width: 112rpx;
  height: 112rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(229,57,53,0.5);
  z-index: 20;
}
