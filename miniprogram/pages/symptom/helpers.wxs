function isPresetSelected(items, name) {
  if (!items || !items.length) return false;
  var i;
  for (i = 0; i < items.length; i++) {
    if (typeof items[i] === 'string' && items[i] === name) return true;
  }
  return false;
}

function isProfileComplete(nickname, gender, birthday, height, weight) {
  return !!(nickname && gender && birthday && height && weight);
}

module.exports = {
  isPresetSelected: isPresetSelected,
  isProfileComplete: isProfileComplete
};
