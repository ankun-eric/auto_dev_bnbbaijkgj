.symptom-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #f5f5f5;
}

/* 家庭成员选择 */
.member-section {
  background: #fff;
  padding: 24rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-section-title {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.member-scroll {
  white-space: nowrap;
}

.member-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.member-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  min-width: 100rpx;
}

.member-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.member-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.member-relation {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 2rpx;
}

.member-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-selected .member-relation,
.member-selected .member-name {
  color: #52c41a;
}

/* 步骤指示器 */
.steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 48rpx;
  background: #fff;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.step-active .step-dot {
  background: #52c41a;
  color: #fff;
}

.step-label {
  font-size: 22rpx;
  color: #999;
}

.step-active .step-label {
  color: #52c41a;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
}

.line-active {
  background: #52c41a;
}

/* 内容 */
.step-content {
  padding: 24rpx;
}

.content-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.content-subtitle {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* 身体部位 */
.body-parts {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.part-item {
  width: calc(33.33% - 14rpx);
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.part-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.part-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.part-name {
  font-size: 24rpx;
  color: #333;
}

/* 症状选择 */
.symptom-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.symptom-tag {
  padding: 14rpx 28rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.symptom-selected {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.extra-section {
  margin-top: 32rpx;
}

.duration-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.duration-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.duration-selected {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.desc-input {
  width: 100%;
  height: 160rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 分析结果 */
.analysis-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.possible-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.possible-item:last-child {
  border-bottom: none;
}

.possible-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.possible-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.possible-prob {
  font-size: 24rpx;
  color: #52c41a;
}

.prob-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.prob-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #13c2c2);
  border-radius: 4rpx;
}

.possible-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.advice-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #52c41a;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-btns {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  background: #fff;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bottom-bar .btn-primary,
.bottom-bar .btn-outline {
  flex: 1;
}
