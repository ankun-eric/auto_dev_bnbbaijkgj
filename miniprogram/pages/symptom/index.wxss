.symptom-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #f5f5f5;
}

/* 步骤指示器 */
.steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 48rpx;
  background: #fff;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.step-active .step-dot {
  background: #52c41a;
  color: #fff;
}

.step-label {
  font-size: 22rpx;
  color: #999;
}

.step-active .step-label {
  color: #52c41a;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
}

.line-active {
  background: #52c41a;
}

/* 内容 */
.step-content {
  padding: 24rpx;
}

.content-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.symptom-section-title {
  margin-top: 32rpx;
}

.content-subtitle {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.content-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}

/* 身体部位 */
.body-parts {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.part-item {
  width: calc(33.33% - 14rpx);
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.part-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.part-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.part-name {
  font-size: 24rpx;
  color: #333;
}

/* 症状选择 */
.symptom-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.symptom-tag {
  padding: 14rpx 28rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.symptom-selected {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.extra-section {
  margin-top: 32rpx;
}

.duration-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.duration-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.duration-selected {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

.desc-input {
  width: 100%;
  height: 160rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* ========== 咨询人选择 (与checkup一致) ========== */
.ck-member-scroll {
  white-space: nowrap;
  margin: 24rpx 0;
}

.ck-member-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.ck-member-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  min-width: 120rpx;
  transition: all 0.2s;
}

.ck-member-item:active {
  transform: scale(0.96);
}

.ck-member-selected {
  border-color: #52c41a;
  background: #f6ffed;
}

.ck-member-add {
  border-style: dashed;
  border-color: #d9d9d9;
  background: #fafafa;
}

.ck-member-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.ck-member-relation {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 2rpx;
}

.ck-member-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ck-member-selected .ck-member-relation,
.ck-member-selected .ck-member-name {
  color: #52c41a;
}

/* 健康信息编辑入口 */
.health-edit-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.health-edit-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.health-edit-arrow {
  font-size: 24rpx;
  color: #52c41a;
}

/* 健康信息编辑面板 */
.health-edit-panel {
  padding: 16rpx 0 8rpx;
}

.health-section {
  margin-bottom: 24rpx;
}

.health-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

/* 预设标签 */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
}

.preset-tag-selected {
  background: #f6ffed;
  border-color: #52c41a;
  color: #52c41a;
  font-weight: 500;
}

.preset-tag-other {
  border-style: dashed;
}

/* 自定义输入 */
.custom-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.custom-input {
  flex: 1;
  height: 60rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  background: #fafafa;
}

.confirm-btn {
  width: 100rpx !important;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  font-size: 24rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

.confirm-btn::after {
  border: none;
}

/* 自定义标签 */
.custom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.custom-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #d48806;
}

.health-delete-btn {
  margin-left: 6rpx;
  font-size: 26rpx;
  color: #d48806;
}

.health-save-btn {
  width: 100% !important;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.health-save-btn::after {
  border: none;
}

/* 本人基本信息 */
.self-basic-info {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.basic-info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.required {
  color: #ff4d4f;
}

.form-input {
  background: #f9f9f9;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

.date-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.placeholder {
  color: #bbb;
}

.date-icon {
  font-size: 28rpx;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f9f9f9;
  border: 1rpx solid #e8e8e8;
  color: #666;
}

.gender-active {
  background: #52c41a;
  color: #fff;
  border-color: #52c41a;
}

.form-error {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 4rpx;
}

/* 分析结果 */
.analysis-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.possible-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.possible-item:last-child {
  border-bottom: none;
}

.possible-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.possible-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.possible-prob {
  font-size: 24rpx;
  color: #52c41a;
}

.prob-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
}

.prob-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #13c2c2);
  border-radius: 4rpx;
}

.possible-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.advice-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #52c41a;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-btns {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 通用按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #52c41a, #3dbb08);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  width: 100%;
  height: 88rpx;
  line-height: 86rpx;
  background: #fff;
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #52c41a;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  background: #fff;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bottom-bar .btn-primary,
.bottom-bar .btn-outline {
  flex: 1;
}
