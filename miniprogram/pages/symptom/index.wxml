<wxs src="./helpers.wxs" module="h" />

<view class="symptom-page">

  <!-- 步骤指示器 -->
  <view class="steps-bar">
    <view class="step {{currentStep >= 0 ? 'step-active' : ''}}">
      <view class="step-dot">1</view>
      <text class="step-label">描述症状</text>
    </view>
    <view class="step-line {{currentStep >= 1 ? 'line-active' : ''}}"></view>
    <view class="step {{currentStep >= 1 ? 'step-active' : ''}}">
      <view class="step-dot">2</view>
      <text class="step-label">选择对象</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'line-active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'step-active' : ''}}">
      <view class="step-dot">3</view>
      <text class="step-label">AI分析</text>
    </view>
  </view>

  <!-- 步骤1: 选择部位 + 描述症状 + 持续时间 (合并为一页) -->
  <view class="step-content" wx:if="{{currentStep === 0}}">
    <!-- 选择身体部位 -->
    <text class="content-title">请选择不适的身体部位</text>
    <view class="body-parts">
      <view class="part-item {{selectedPart === item.id ? 'part-selected' : ''}}"
            wx:for="{{bodyParts}}" wx:key="id"
            bindtap="selectPart" data-part="{{item}}">
        <text class="part-icon">{{item.icon}}</text>
        <text class="part-name">{{item.name}}</text>
      </view>
    </view>

    <!-- 选择症状 (部位选中后展示) -->
    <block wx:if="{{selectedPart && symptoms.length > 0}}">
      <text class="content-title symptom-section-title">请选择您的症状（可多选）</text>
      <view class="symptom-list">
        <view class="symptom-tag {{item.selected ? 'symptom-selected' : ''}}"
              wx:for="{{symptoms}}" wx:key="id"
              bindtap="toggleSymptom" data-index="{{index}}">
          <text>{{item.name}}</text>
        </view>
      </view>

      <!-- 持续时间 -->
      <view class="extra-section">
        <text class="content-subtitle">持续时间</text>
        <view class="duration-list">
          <view class="duration-item {{selectedDuration === item ? 'duration-selected' : ''}}"
                wx:for="{{durations}}" wx:key="*this"
                bindtap="selectDuration" data-duration="{{item}}">
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 补充描述 -->
      <view class="extra-section">
        <text class="content-subtitle">补充描述</text>
        <textarea class="desc-input" placeholder="请描述其他症状或情况..." value="{{extraDesc}}" bindinput="onDescInput" maxlength="500" />
      </view>
    </block>
  </view>

  <!-- 步骤2: 选择咨询人 (横向滚动，与checkup一致) -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <text class="content-title">选择咨询对象</text>
    <text class="content-hint">请选择此次症状自查是为谁进行</text>

    <scroll-view class="ck-member-scroll" scroll-x>
      <view class="ck-member-list">
        <view class="ck-member-item {{selectedMemberId === item.id ? 'ck-member-selected' : ''}}"
              wx:for="{{members}}" wx:key="id"
              bindtap="selectMember" data-member="{{item}}">
          <text class="ck-member-emoji">{{item.emoji}}</text>
          <text class="ck-member-relation">{{item.relationship_type}}</text>
          <text class="ck-member-name">{{item.nickname}}</text>
        </view>
        <view class="ck-member-item ck-member-add" bindtap="goAddFamilyMember">
          <text class="ck-member-emoji">➕</text>
          <text class="ck-member-relation">添加</text>
          <text class="ck-member-name">家庭成员</text>
        </view>
      </view>
    </scroll-view>

    <!-- 咨询人基本信息（始终显示） -->
    <view class="self-basic-info" wx:if="{{selectedMemberId}}">
      <view class="basic-info-title">👤 基本信息</view>

      <view class="form-item">
        <view class="form-label">姓名 <text class="required">*</text></view>
        <input class="form-input" placeholder="请输入姓名" value="{{selfNickname}}" bindinput="onSelfNicknameInput" />
        <view class="form-error" wx:if="{{selfErrors.nickname}}">{{selfErrors.nickname}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">出生日期 <text class="required">*</text></view>
        <picker mode="date" value="{{selfBirthday}}" start="1900-01-01" end="{{today}}" bindchange="onSelfBirthdayChange">
          <view class="form-input date-input">
            <text class="{{selfBirthday ? '' : 'placeholder'}}">{{selfBirthday || '请选择出生日期'}}</text>
            <text class="date-icon">📅</text>
          </view>
        </picker>
        <view class="form-error" wx:if="{{selfErrors.birthday}}">{{selfErrors.birthday}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">性别 <text class="required">*</text></view>
        <view class="gender-select">
          <view class="gender-btn {{selfGender === 'male' ? 'gender-active' : ''}}" bindtap="onSelfGenderSelect" data-gender="male">男</view>
          <view class="gender-btn {{selfGender === 'female' ? 'gender-active' : ''}}" bindtap="onSelfGenderSelect" data-gender="female">女</view>
        </view>
        <view class="form-error" wx:if="{{selfErrors.gender}}">{{selfErrors.gender}}</view>
      </view>
    </view>

    <!-- 展开/收起按钮 -->
    <view class="expand-toggle" bindtap="toggleHealthEdit" wx:if="{{selectedMemberId}}">
      <view class="line"></view>
      <view class="text">
        <text wx:if="{{!showHealthEdit}}">更多信息（</text>
        <text wx:else>收起信息（</text>
        <text class="{{h.isProfileComplete(selfNickname, selfGender, selfBirthday, selfHeight, selfWeight) ? 'status-complete' : 'status-incomplete'}}">{{h.isProfileComplete(selfNickname, selfGender, selfBirthday, selfHeight, selfWeight) ? '已完善' : '待完善'}}</text>
        <text>）{{showHealthEdit ? '▲' : '▼'}}</text>
      </view>
      <view class="line"></view>
    </view>

    <!-- 展开区域（身高、体重、病史类） -->
    <view class="expand-content {{showHealthEdit ? 'expanded' : ''}}" wx:if="{{selectedMemberId}}">
      <view class="health-edit-panel">
        <!-- 身高体重 -->
        <view class="self-basic-info">
          <view class="form-item">
            <view class="form-label">身高（cm）</view>
            <input class="form-input" type="digit" placeholder="请输入身高" value="{{selfHeight}}" bindinput="onSelfHeightInput" />
          </view>
          <view class="form-item">
            <view class="form-label">体重（kg）</view>
            <input class="form-input" type="digit" placeholder="请输入体重" value="{{selfWeight}}" bindinput="onSelfWeightInput" />
          </view>
        </view>

        <!-- 既往病史 -->
        <view class="health-section">
          <view class="health-section-title">🏥 既往病史</view>
          <view class="tags-wrap">
            <view wx:for="{{chronicPresets}}" wx:key="id"
              class="preset-tag {{h.isPresetSelected(chronic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleChronicPreset" data-name="{{item.name}}">
              {{item.name}}
            </view>
            <view class="preset-tag preset-tag-other {{showChronicOther ? 'preset-tag-selected' : ''}}"
              bindtap="toggleChronicOther">
              其它 ✚
            </view>
          </view>
          <view wx:if="{{showChronicOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它病史…"
              value="{{chronicOtherInput}}" bindinput="onChronicOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmChronicOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{chronicCustomItems.length > 0}}">
            <view wx:for="{{chronicCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeChronicCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <!-- 过敏史 -->
        <view class="health-section">
          <view class="health-section-title">⚠️ 过敏史</view>
          <view class="tags-wrap">
            <view wx:for="{{allergyPresets}}" wx:key="id"
              class="preset-tag {{h.isPresetSelected(allergies, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleAllergyPreset" data-name="{{item.name}}">
              {{item.name}}
            </view>
            <view class="preset-tag preset-tag-other {{showAllergyOther ? 'preset-tag-selected' : ''}}"
              bindtap="toggleAllergyOther">
              其它 ✚
            </view>
          </view>
          <view wx:if="{{showAllergyOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它过敏源…"
              value="{{allergyOtherInput}}" bindinput="onAllergyOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmAllergyOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{allergyCustomItems.length > 0}}">
            <view wx:for="{{allergyCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeAllergyCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <!-- 家族遗传病史 -->
        <view class="health-section">
          <view class="health-section-title">🧬 家族遗传病史</view>
          <view class="tags-wrap">
            <view wx:for="{{geneticPresets}}" wx:key="id"
              class="preset-tag {{h.isPresetSelected(genetic_diseases, item.name) ? 'preset-tag-selected' : ''}}"
              bindtap="toggleGeneticPreset" data-name="{{item.name}}">
              {{item.name}}
            </view>
            <view class="preset-tag preset-tag-other {{showGeneticOther ? 'preset-tag-selected' : ''}}"
              bindtap="toggleGeneticOther">
              其它 ✚
            </view>
          </view>
          <view wx:if="{{showGeneticOther}}" class="custom-input-wrap">
            <input class="custom-input" placeholder="请输入其它遗传病…"
              value="{{geneticOtherInput}}" bindinput="onGeneticOtherInput" maxlength="100"/>
            <button class="confirm-btn" bindtap="confirmGeneticOther">确认</button>
          </view>
          <view class="custom-tags" wx:if="{{geneticCustomItems.length > 0}}">
            <view wx:for="{{geneticCustomItems}}" wx:key="value" class="custom-tag">
              {{item.value}} <text class="health-delete-btn" bindtap="removeGeneticCustom" data-value="{{item.value}}">✕</text>
            </view>
          </view>
        </view>

        <button class="health-save-btn" bindtap="saveHealthInfo">保存健康信息</button>
      </view>
    </view>
  </view>

  <!-- 步骤3: AI分析结果 -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="analysis-loading" wx:if="{{analyzing}}">
      <view class="loading-animation">
        <text class="loading-icon">🔍</text>
      </view>
      <text class="loading-text">AI正在分析您的症状...</text>
    </view>

    <view class="analysis-result" wx:if="{{!analyzing && analysisResult}}">
      <view class="result-card card">
        <text class="result-title">分析结果</text>
        <view class="possible-list">
          <view class="possible-item" wx:for="{{analysisResult.possibilities}}" wx:key="name">
            <view class="possible-header">
              <text class="possible-name">{{item.name}}</text>
              <text class="possible-prob">可能性 {{item.probability}}%</text>
            </view>
            <view class="prob-bar">
              <view class="prob-fill" style="width: {{item.probability}}%;"></view>
            </view>
            <text class="possible-desc">{{item.description}}</text>
          </view>
        </view>
      </view>

      <view class="advice-card card">
        <text class="result-title">建议</text>
        <view class="advice-item" wx:for="{{analysisResult.advices}}" wx:key="index">
          <text class="advice-num">{{index + 1}}</text>
          <text class="advice-text">{{item}}</text>
        </view>
      </view>

      <view class="action-btns">
        <button class="btn-primary" bindtap="goChat">咨询AI健康顾问</button>
        <button class="btn-outline" bindtap="restart">重新自查</button>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar safe-bottom" wx:if="{{currentStep < 2}}">
    <button class="btn-outline" bindtap="prevStep" wx:if="{{currentStep > 0}}">上一步</button>
    <button class="btn-primary" bindtap="nextStep">{{currentStep === 1 ? '开始分析' : '下一步'}}</button>
  </view>
</view>
