.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }

.loading {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8e8e8;
  border-top: 4rpx solid #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty {
  padding: 200rpx 0;
  text-align: center;
  color: #999;
}

.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 26rpx; margin-bottom: 30rpx; }

.empty-btn {
  display: inline-block;
  padding: 14rpx 40rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 26rpx;
}

.list { padding: 20rpx; }

.count-tip { font-size: 22rpx; color: #999; padding: 8rpx 8rpx 16rpx; }

.item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.main { flex: 1; margin-left: 20rpx; min-width: 0; }

.row1 {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.type-name { font-size: 30rpx; font-weight: bold; }

.member { font-size: 22rpx; color: #999; }

.desc {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.time { font-size: 20rpx; color: #bbb; margin-top: 6rpx; }

.arrow { color: #ccc; font-size: 40rpx; }
