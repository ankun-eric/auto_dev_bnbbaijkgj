<view class="orders-page">
  <!-- 顶部Tab -->
  <scroll-view class="tab-scroll" scroll-x enable-flex>
    <view class="tab-list">
      <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
            wx:for="{{tabs}}" wx:key="index"
            bindtap="switchTab" data-index="{{index}}">
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-card card" wx:for="{{orders}}" wx:key="id"
          bindtap="goDetail" data-id="{{item.id}}">
      <view class="order-top">
        <text class="order-no">订单号：{{item.order_no}}</text>
        <text class="order-status status-{{item.status}}">{{item.status_label || item.status}}</text>
      </view>

      <view class="order-product">
        <image class="order-img" src="{{item.product_cover || item.cover_image}}" mode="aspectFill" />
        <view class="order-info">
          <text class="order-name ellipsis-2">{{item.product_name || item.name}}</text>
          <view class="order-meta">
            <text class="order-price">¥{{item.total_amount || item.price}}</text>
            <text class="order-qty">×{{item.quantity || 1}}</text>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-time">{{item.created_at}}</text>
        <view class="order-actions">
          <view class="action-btn outline" wx:if="{{item.status === 'pending_payment'}}"
                catchtap="cancelOrder" data-id="{{item.id}}">取消</view>
          <view class="action-btn primary" wx:if="{{item.status === 'pending_payment'}}"
                catchtap="payOrder" data-id="{{item.id}}">付款</view>
          <view class="action-btn primary" wx:if="{{item.status === 'paid' || item.status === 'in_progress'}}"
                catchtap="confirmOrder" data-id="{{item.id}}">确认收货</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
  <view class="load-end" wx:if="{{!loading && noMore && orders.length > 0}}">
    <text class="load-end-text">— 没有更多了 —</text>
  </view>
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
