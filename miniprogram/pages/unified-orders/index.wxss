.orders-page {
  padding-bottom: 24rpx;
}

.tab-scroll {
  background: #fff;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-list {
  display: flex;
  padding: 0 12rpx;
}

.tab-item {
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  position: relative;
}

.tab-active {
  color: #52c41a;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #52c41a;
  border-radius: 2rpx;
}

.order-list {
  padding: 24rpx;
}

.order-card {
  margin-bottom: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending_payment {
  color: #faad14;
}

.status-paid {
  color: #52c41a;
}

.status-in_progress {
  color: #1890ff;
}

.status-completed {
  color: #999;
}

.status-cancelled {
  color: #ccc;
}

.status-refunded {
  color: #ff4d4f;
}

.order-product {
  display: flex;
  align-items: flex-start;
}

.order-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 160rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.order-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.order-qty {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-time {
  font-size: 22rpx;
  color: #ccc;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.action-btn.outline {
  border: 1rpx solid #d9d9d9;
  color: #666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
}

.loading-more,
.load-end {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text,
.load-end-text {
  font-size: 24rpx;
  color: #999;
}
