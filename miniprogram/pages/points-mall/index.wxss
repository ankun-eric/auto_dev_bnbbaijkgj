.mall-page {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

.points-bar {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFE7A8 100%);
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-bar-left {
  display: flex;
  flex-direction: column;
}

.my-points { font-size: 26rpx; color: #8C6D1F; }
.points-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #B8860B;
  margin-top: 4rpx;
}
.points-badge {
  font-size: 44rpx;
  line-height: 1;
  text-shadow: 0 2rpx 2rpx rgba(184, 134, 11, 0.35);
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx;
}

.goods-card {
  width: calc(50% - 8rpx);
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
}

.goods-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.goods-icon { font-size: 48rpx; }
.goods-name { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.goods-desc { font-size: 22rpx; color: #999; text-align: center; margin-bottom: 12rpx; }

.goods-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goods-points { font-size: 26rpx; font-weight: bold; color: #ff4d4f; }
.goods-stock { font-size: 20rpx; color: #ccc; }
