.mall-page {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

/* PRD-POINTS-SKIN-V1: 商城顶部 banner 换肤为天蓝渐变（高度 240rpx，圆角底部） */
.points-bar {
  background: linear-gradient(135deg, #F0F9FF, #DBEAFE);
  padding: 32rpx 32rpx;
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

.points-bar-left {
  display: flex;
  flex-direction: column;
}
.points-bar-right {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.my-points { font-size: 26rpx; color: #666666; }
.points-num {
  font-size: 56rpx;
  font-weight: bold;
  color: #0EA5E9;
  margin-top: 4rpx;
  line-height: 1.2;
}
.points-unit-text { font-size: 24rpx; font-weight: normal; color: #0EA5E9; margin-left: 4rpx; }
.points-tip { font-size: 22rpx; color: #0284C7; margin-top: 4rpx; }

/* 去赚积分按钮（次级胶囊：白底蓝字蓝边） */
.earn-points-btn {
  padding: 8rpx 24rpx;
  border: 1rpx solid #0EA5E9;
  background: #FFFFFF;
  color: #0EA5E9;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 36rpx;
  text-align: center;
}

.exchange-record-btn {
  padding: 8rpx 24rpx;
  border: 1rpx solid #7DD3FC;
  background: rgba(14, 165, 233, 0.1);
  color: #0EA5E9;
  font-size: 22rpx;
  border-radius: 30rpx;
  text-align: center;
}

/* v1.1 M5 Tab */
.tab-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-item {
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  margin-right: 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}
/* PRD-POINTS-SKIN-V1: tab 激活态改为天蓝 */
.tab-item.tab-active {
  background: #0EA5E9;
  color: #fff;
  font-weight: 600;
}
.tab-wrap {
  position: relative;
}
.tab-dot {
  position: absolute;
  top: 2rpx;
  right: 20rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx;
}

.goods-card {
  width: calc(50% - 8rpx);
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  position: relative;
}

.type-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 2rpx 10rpx;
  font-size: 18rpx;
  border-radius: 16rpx;
  line-height: 1.4;
}

.goods-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.goods-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.goods-icon { font-size: 48rpx; }
.goods-img { width: 80rpx; height: 80rpx; }
.goods-name { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.goods-desc { font-size: 22rpx; color: #999; text-align: center; margin-bottom: 12rpx; min-height: 28rpx; }

.goods-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  min-height: 32rpx;
}

/* PRD-POINTS-SKIN-V1: 积分数字和按钮换为天蓝色系 */
.goods-points { font-size: 26rpx; font-weight: bold; color: #0EA5E9; }
.goods-lowstock { font-size: 20rpx; color: #999999; }

.quick-btn {
  width: 100%;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  border-radius: 16rpx;
  line-height: 1;
}
.quick-btn.primary {
  background: #0EA5E9;
  color: #fff;
}
.quick-btn.outline {
  background: #fff;
  color: #0EA5E9;
  border: 1rpx solid #0EA5E9;
}
.quick-btn.disabled,
.quick-btn.btn-disabled {
  background: #BAE6FD;
  color: rgba(255,255,255,0.7);
}
.quick-btn.warn {
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
}

.empty {
  text-align: center;
  color: #bbb;
  padding: 40rpx 0;
  font-size: 26rpx;
}
