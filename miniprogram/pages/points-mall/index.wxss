.mall-page {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

.points-bar {
  background: #C8E6C9;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-bar-left {
  display: flex;
  flex-direction: column;
}

.my-points { font-size: 24rpx; color: #1B5E20; }
.points-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-top: 4rpx;
  line-height: 1.2;
}
.points-tip { font-size: 22rpx; color: #2E7D32; margin-top: 4rpx; }

.exchange-record-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(27, 94, 32, 0.35);
  background: rgba(27, 94, 32, 0.12);
  color: #1B5E20;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* v1.1 M5 Tab */
.tab-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-item {
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  margin-right: 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}
.tab-item.tab-active {
  background: #2E7D32;
  color: #fff;
  font-weight: 600;
}
.tab-wrap {
  position: relative;
}
.tab-dot {
  position: absolute;
  top: 2rpx;
  right: 20rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx;
}

.goods-card {
  width: calc(50% - 8rpx);
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  position: relative;
}

.type-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 2rpx 10rpx;
  font-size: 18rpx;
  border-radius: 16rpx;
  line-height: 1.4;
}

.goods-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.goods-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.goods-icon { font-size: 48rpx; }
.goods-img { width: 80rpx; height: 80rpx; }
.goods-name { font-size: 26rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.goods-desc { font-size: 22rpx; color: #999; text-align: center; margin-bottom: 12rpx; min-height: 28rpx; }

.goods-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  min-height: 32rpx;
}

.goods-points { font-size: 26rpx; font-weight: bold; color: #B8860B; }
.goods-lowstock { font-size: 20rpx; color: #ff4d4f; }

.quick-btn {
  width: 100%;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  border-radius: 28rpx;
  line-height: 1;
}
.quick-btn.primary {
  background: linear-gradient(135deg, #2E7D32, #43A047);
  color: #fff;
}
.quick-btn.outline {
  background: #fff;
  color: #2E7D32;
  border: 1rpx solid #2E7D32;
}
.quick-btn.disabled,
.quick-btn.btn-disabled {
  background: #f0f0f0;
  color: #bfbfbf;
}
.quick-btn.warn {
  background: linear-gradient(135deg, #fa8c16, #faad14);
  color: #fff;
}

.empty {
  text-align: center;
  color: #bbb;
  padding: 40rpx 0;
  font-size: 26rpx;
}
