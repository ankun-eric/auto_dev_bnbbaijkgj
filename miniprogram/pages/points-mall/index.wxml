<view class="mall-page">
  <view class="points-bar">
    <view class="points-bar-left">
      <text class="my-points">可用积分</text>
      <text class="points-num">{{totalPoints}}</text>
      <text class="points-tip">用积分兑换好礼</text>
    </view>
    <view class="exchange-record-btn" bindtap="goExchangeRecords">
      <text>兑换记录</text>
    </view>
  </view>

  <!-- v1.1 M5：全部/可兑换 Tab -->
  <view class="tab-bar">
    <view class="tab-item {{tab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab-wrap">
      <view class="tab-item {{tab === 'exchangeable' ? 'tab-active' : ''}}" data-tab="exchangeable" bindtap="switchTab">可兑换</view>
      <view class="tab-dot" wx:if="{{hasExchangeable}}"></view>
    </view>
  </view>

  <view class="goods-grid">
    <view class="goods-card card" wx:for="{{goods}}" wx:key="id">
      <view class="type-badge" style="background: {{item.badgeBg}}; color: {{item.badgeColor}};">
        {{item.badgeText}}
      </view>
      <view class="goods-top" bindtap="goDetail" data-id="{{item.id}}">
        <view class="goods-icon-wrap" style="background: {{item.bgColor}};">
          <image wx:if="{{item.image}}" src="{{item.image}}" class="goods-img" mode="aspectFit"></image>
          <text wx:else class="goods-icon">{{item.icon}}</text>
        </view>
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-desc">{{item.desc}}</text>
      </view>
      <view class="goods-footer">
        <text class="goods-points">{{item.points}}积分</text>
        <text class="goods-lowstock" wx:if="{{item.isSoldOut}}">已兑完</text>
        <text class="goods-lowstock" wx:elif="{{item.isLowStock}}">仅剩{{item.stock}}件</text>
      </view>
      <!-- BUG-2：按 can_redeem / redeem_block_reason 渲染按钮，不可兑换时置灰但仍可点击 -->
      <view class="quick-btn {{item.btnClass}}" catchtap="quickExchange" data-item="{{item}}">
        {{item.btnText}}
      </view>
    </view>
  </view>
  <view wx:if="{{goods.length === 0}}" class="empty">暂无商品</view>
</view>
