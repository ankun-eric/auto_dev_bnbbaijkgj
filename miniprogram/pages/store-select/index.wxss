.store-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.intro-card,
.store-card,
.empty-state {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.intro-card {
  margin-bottom: 24rpx;
}

.intro-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.intro-desc,
.store-code,
.store-address,
.empty-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.7;
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.store-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.store-role {
  font-size: 22rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.12);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}

.module-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.module-tag {
  font-size: 22rpx;
  color: #333333;
  background: #f5f5f5;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.empty-state {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}
