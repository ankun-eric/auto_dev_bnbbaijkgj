.guide-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: #f5f5f5;
}

/* Progress bar */
.progress-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.step-active .step-circle {
  background: #52c41a;
  color: #fff;
}

.step-text {
  font-size: 20rpx;
  color: #999;
}

.step-active .step-text {
  color: #52c41a;
  font-weight: 500;
}

.progress-track {
  height: 6rpx;
  background: #e8e8e8;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #13c2c2);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* Step content */
.step-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.step-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.step-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* Form */
.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child { border-bottom: none; }

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #ccc;
}

.gender-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.gender-btn {
  padding: 10rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.gender-active {
  border-color: #52c41a;
  background: #f6ffed;
  color: #52c41a;
}

/* Tags */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preset-tag {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.preset-tag-selected {
  background: #f6ffed;
  border-color: #52c41a;
  color: #52c41a;
  font-weight: 500;
}

.preset-tag-other {
  border-style: dashed;
}

/* Custom input */
.custom-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-input {
  flex: 1;
  height: 68rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #fafafa;
}

.confirm-btn {
  width: 120rpx !important;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  font-size: 26rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

.confirm-btn::after {
  border: none;
}

/* Custom tags */
.custom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.custom-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #d48806;
}

.delete-btn {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #d48806;
}

.hint-text {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
}

/* Bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bar-left {
  flex-shrink: 0;
}

.bar-right {
  display: flex;
  gap: 16rpx;
}

.btn-link {
  background: none;
  border: none;
  color: #999;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
}

.btn-link::after {
  border: none;
}
