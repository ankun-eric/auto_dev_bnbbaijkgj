.ai-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.history-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.history-icon {
  font-size: 30rpx;
  color: #333;
}

.history-text {
  font-size: 24rpx;
  color: #666;
}

.page-title-wrap {
  display: flex;
  align-items: center;
}

.brand-logo-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  vertical-align: middle;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.top-bar-placeholder {
  width: 120rpx;
}

.type-section {
  margin-bottom: 24rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.type-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.type-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #999;
}

.quick-list {
  margin-top: 16rpx;
}

.quick-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.quick-item:last-child {
  border-bottom: none;
}

.quick-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.quick-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.chat-list {
  margin-bottom: 24rpx;
}

.chat-item {
  padding: 24rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chat-time {
  font-size: 22rpx;
  color: #999;
}

.chat-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.new-chat-btn {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  z-index: 10;
}

.new-chat-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.merchant-scan-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.scan-prompt {
  padding-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-animation-wrapper {
  position: relative;
  width: 260rpx;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.scan-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.scan-circle-inner {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-emoji {
  font-size: 54rpx;
}

.scan-ripple {
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(82, 196, 26, 0.2);
}

.scan-ripple.delay {
  width: 250rpx;
  height: 250rpx;
}

.scan-tip {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.scan-sub-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.order-card {
  margin-top: 24rpx;
}

.order-header,
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-header {
  margin-bottom: 24rpx;
}

.order-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.order-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-done {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.12);
}

.status-pending {
  color: #faad14;
  background: rgba(250, 173, 20, 0.12);
}

.order-detail-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333;
}

.detail-value.price {
  color: #ff4d4f;
  font-weight: 600;
}

.order-actions,
.rescan-area {
  margin-top: 28rpx;
}

.verified-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #52c41a;
  font-size: 26rpx;
}

.verified-icon {
  margin-right: 10rpx;
}
