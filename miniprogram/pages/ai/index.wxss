.ai-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.type-section {
  margin-bottom: 24rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.type-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.type-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #999;
}

.quick-list {
  margin-top: 16rpx;
}

.quick-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.quick-item:last-child {
  border-bottom: none;
}

.quick-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.quick-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.chat-list {
  margin-bottom: 24rpx;
}

.chat-item {
  padding: 24rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chat-time {
  font-size: 22rpx;
  color: #999;
}

.chat-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.new-chat-btn {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  z-index: 10;
}

.new-chat-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}
