.ai-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  position: relative;
}

/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求1] 顶栏两版统一：☰红点 → 档案/咨询/服务 → 🔔橙点 → ⊕ */
.unified-topbar {
  min-height: 88rpx;
  margin: -24rpx -24rpx 12rpx -24rpx;
  padding: 0 16rpx;
  background: linear-gradient(180deg, #EAF6FF 0%, #DCEFFF 100%);
}
.uni-hamburger {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.uni-hamburger-icon { font-size: 40rpx; color: #1F2D3D; line-height: 1; }
.uni-hamburger-reddot {
  position: absolute; top: 8rpx; right: 10rpx;
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #FF3B30;
}
.uni-tabs {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 44rpx;
  min-width: 0;
}
.uni-tab {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 4rpx;
}
.uni-tab-label { font-size: 32rpx; font-weight: 500; color: #6B7B8C; line-height: 1; }
.uni-tab-label-active { font-weight: 700; color: #3FA9F5; }
.uni-tab-underline { margin-top: 10rpx; width: 0; height: 6rpx; border-radius: 3rpx; background: transparent; }
.uni-tab-underline-active { width: 40rpx; background: #3FA9F5; }
.uni-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.uni-bell {
  position: relative;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}
.uni-bell-icon { font-size: 38rpx; line-height: 1; }
.uni-bell-reddot {
  position: absolute; top: 6rpx; right: 8rpx;
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #FF7A45; box-shadow: 0 0 0 3rpx #fff;
}
.uni-plus {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}
.uni-plus-circle {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #1F2D3D;
  display: flex; align-items: center; justify-content: center;
}
.uni-plus-sign { font-size: 36rpx; color: #1F2D3D; line-height: 1; font-weight: 300; }

/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求3] 欢迎条：问候语 + 右上角模式切换胶囊 */
/* [PRD-AIHOME-WELCOME-UNIFY-V1 2026-06-02] 标准模式欢迎区照搬关怀风格 + 蓝绿渐变背景 + 瘦身（无用药卡） */
.welcome-strip {
  position: relative;
  background: linear-gradient(135deg, #1976D2 0%, #43A047 100%);
  color: #fff;
  padding: 40rpx 36rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 0 -16rpx 16rpx;
}
.welcome-strip .welcome-text { flex: 1; min-width: 0; }
.welcome-strip .greeting { font-size: 52rpx; font-weight: 700; margin-bottom: 10rpx; color: #fff; }
.welcome-strip .sub { font-size: 28rpx; opacity: 0.95; color: #fff; }
.welcome-right-col {
  flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; gap: 18rpx;
}
.welcome-strip .robot-logo {
  flex-shrink: 0;
  width: 150rpx; height: 150rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.12);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.welcome-strip .robot-img { width: 132rpx; height: 132rpx; border-radius: 50%; }
.welcome-hello { font-size: 30rpx; font-weight: 600; color: #1F2D3D; }
.mode-dropdown-panel-welcome { top: 120rpx; right: 16rpx; }

.history-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.history-icon {
  font-size: 30rpx;
  color: #333;
}

.history-text {
  font-size: 24rpx;
  color: #666;
}

/* PRD v1.0 2026-04-23：标题容器水平居中 */
.page-title-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-logo-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  vertical-align: middle;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.top-bar-placeholder {
  width: 120rpx;
}

/* [Bug 修复 v1.0 §3.1.3] 顶部「更多」按钮 + 弹出菜单样式 */
.more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 60rpx;
  padding: 0;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.more-icon {
  font-size: 40rpx;
  color: #333;
  line-height: 1;
}

/* [PRD-MODE-CAPSULE-V1 2026-05-31] 右上角控件容器：模式胶囊 + 🎁 + ⋯ */
.topbar-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 模式切换下拉胶囊（收起态） */
.mode-capsule-wrap {
  position: relative;
}

.mode-capsule {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: #E3F2FD;
  border-radius: 28rpx;
}

.mode-capsule-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1976D2;
  line-height: 1;
}

.mode-capsule-arrow {
  font-size: 20rpx;
  color: #1976D2;
  line-height: 1;
  transition: transform 0.15s ease;
}

.mode-capsule-arrow-up {
  transform: rotate(180deg);
}

/* [PRD-AIHOME-WELCOME-UNIFY-V1 2026-06-02] 彩底欢迎区内的胶囊改半透明白（与关怀模式一致） */
.welcome-strip .mode-capsule {
  background: rgba(255,255,255,0.22);
  border: 1rpx solid rgba(255,255,255,0.45);
}
.welcome-strip .mode-capsule-label,
.welcome-strip .mode-capsule-arrow { color: #fff; }
.welcome-strip .mode-dropdown-panel-welcome { top: 120rpx; right: 16rpx; }

/* 🎁 邀请好友按钮 */
.invite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 60rpx;
}

.invite-icon {
  font-size: 36rpx;
  line-height: 1;
}

/* 模式切换下拉面板（展开态） */
.mode-dropdown-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 998;
}

.mode-dropdown-panel {
  position: absolute;
  top: 80rpx;
  right: 152rpx;
  min-width: 220rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  z-index: 999;
}

.mode-dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx;
  background: #FFFFFF;
}

.mode-dropdown-item-active {
  background: #E3F2FD;
}

.mode-dropdown-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
}

.mode-dropdown-item-active .mode-dropdown-text {
  color: #1976D2;
  font-weight: 600;
}

.mode-dropdown-check {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: 600;
}

.more-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 999;
}

.more-menu-card {
  position: fixed;
  top: 110rpx;
  right: 24rpx;
  min-width: 320rpx;
  background: #F0F9FF;
  border: 1rpx solid #BAE6FD;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
  z-index: 1000;
  overflow: hidden;
}

.more-menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 18rpx;
  background: transparent;
}

.more-menu-item:active {
  background: #E0F2FE;
}

.more-menu-divider {
  height: 1rpx;
  background: #BAE6FD;
  margin: 0 28rpx;
}

.more-menu-icon {
  font-size: 32rpx;
  line-height: 1;
}

.more-menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.more-menu-label-gold {
  color: #E5A23B;
  font-weight: 700;
}

/* [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求2] 「切换模式」右侧当前模式小标签 */
.more-menu-mode-tag {
  font-size: 22rpx;
  font-weight: 600;
  color: #3FA9F5;
  background: #EAF6FF;
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
  line-height: 1.2;
}

.more-menu-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #5C3B00;
  background: linear-gradient(90deg, #E5A23B 0%, #F4D793 100%);
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  line-height: 1.2;
}

.type-section {
  margin-bottom: 24rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.type-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.type-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #999;
}

.quick-list {
  margin-top: 16rpx;
}

.quick-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.quick-item:last-child {
  border-bottom: none;
}

.quick-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.quick-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.chat-list {
  margin-bottom: 24rpx;
}

.chat-item {
  padding: 24rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chat-time {
  font-size: 22rpx;
  color: #999;
}

.chat-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.new-chat-btn {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  z-index: 10;
  /* PRD v1.0 2026-04-23：按钮内文字水平+垂直居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.new-chat-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  line-height: 1;
}

.merchant-scan-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.scan-prompt {
  padding-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-animation-wrapper {
  position: relative;
  width: 260rpx;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.scan-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.scan-circle-inner {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-emoji {
  font-size: 54rpx;
}

.scan-ripple {
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(82, 196, 26, 0.2);
}

.scan-ripple.delay {
  width: 250rpx;
  height: 250rpx;
}

.scan-tip {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.scan-sub-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.order-card {
  margin-top: 24rpx;
}

.order-header,
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-header {
  margin-bottom: 24rpx;
}

.order-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.order-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-done {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.12);
}

.status-pending {
  color: #faad14;
  background: rgba(250, 173, 20, 0.12);
}

.order-detail-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333;
}

.detail-value.price {
  color: #ff4d4f;
  font-weight: 600;
}

.order-actions,
.rescan-area {
  margin-top: 28rpx;
}

.verified-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #52c41a;
  font-size: 26rpx;
}

.verified-icon {
  margin-right: 10rpx;
}
