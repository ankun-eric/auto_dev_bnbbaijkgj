<view class="ai-page">
  <!-- 顶部问诊类型 -->
  <view class="type-section">
    <text class="section-title">选择问诊类型</text>
    <view class="type-grid">
      <view class="type-card" wx:for="{{consultTypes}}" wx:key="id" bindtap="startConsult" data-type="{{item}}">
        <view class="type-icon-wrap" style="background: {{item.bgColor}};">
          <text class="type-icon">{{item.icon}}</text>
        </view>
        <text class="type-name">{{item.name}}</text>
        <text class="type-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 快速问题 -->
  <view class="card">
    <text class="section-title">快速提问</text>
    <view class="quick-list">
      <view class="quick-item" wx:for="{{quickQuestions}}" wx:key="index" bindtap="quickAsk" data-question="{{item}}">
        <text class="quick-text">{{item}}</text>
        <text class="quick-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 最近对话 -->
  <view class="section-header">
    <text class="section-title">最近对话</text>
    <text class="section-more" bindtap="viewAllChats" wx:if="{{chatHistory.length > 0}}">查看全部 ></text>
  </view>

  <view class="chat-list" wx:if="{{chatHistory.length > 0}}">
    <view class="chat-item card" wx:for="{{chatHistory}}" wx:key="id" bindtap="continueChat" data-id="{{item.id}}">
      <view class="chat-header">
        <text class="chat-type-tag tag tag-green">{{item.type}}</text>
        <text class="chat-time">{{item.time}}</text>
      </view>
      <text class="chat-summary ellipsis-2">{{item.summary}}</text>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">💬</text>
    <text class="empty-text">暂无对话记录</text>
    <text class="empty-text">开始一次AI问诊吧</text>
  </view>

  <!-- 新建对话按钮 -->
  <view class="new-chat-btn" bindtap="newChat">
    <text class="new-chat-text">+ 新建对话</text>
  </view>
</view>
