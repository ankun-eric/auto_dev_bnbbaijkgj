<view class="ai-page" wx:if="{{pageMode === 'user'}}">
  <!-- [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求1] 第一行（顶栏）两版统一，照标准版样式：
       ☰三横杠(带红点) → 档案/咨询/服务 三 Tab(当前停咨询·蓝下划线) → 🔔铃铛(带橙点) → ⊕加号圈 -->
  <view class="top-bar unified-topbar">
    <!-- 1. 左：☰ 三横杠（带小红点 → 历史/侧边栏入口） -->
    <view class="uni-hamburger" bindtap="openDrawer" data-testid="ai-home-hamburger-btn">
      <text class="uni-hamburger-icon" data-testid="ai-home-hamburger-icon">☰</text>
      <view class="uni-hamburger-reddot" data-testid="ai-home-hamburger-reddot"></view>
    </view>

    <!-- 2~4. 中：档案 / 咨询 / 服务 三 Tab（当前停「咨询」，选中蓝色下划线） -->
    <view class="uni-tabs" data-testid="ai-home-top-tabs">
      <view class="uni-tab" bindtap="onTopTab" data-key="profile" data-testid="ai-home-top-tab-profile">
        <text class="uni-tab-label">档案</text>
        <view class="uni-tab-underline"></view>
      </view>
      <view class="uni-tab uni-tab-active" bindtap="onTopTab" data-key="consult" data-testid="ai-home-top-tab-consult">
        <text class="uni-tab-label uni-tab-label-active">咨询</text>
        <view class="uni-tab-underline uni-tab-underline-active"></view>
      </view>
      <view class="uni-tab" bindtap="onTopTab" data-key="service" data-testid="ai-home-top-tab-service">
        <text class="uni-tab-label">服务</text>
        <view class="uni-tab-underline"></view>
      </view>
    </view>

    <!-- 5+6. 右：🔔 铃铛（带橙点） + ⊕ 加号圈 -->
    <view class="uni-right">
      <view class="uni-bell" bindtap="openBell" data-testid="ai-home-topbar-bell">
        <text class="uni-bell-icon">🔔</text>
        <view class="uni-bell-reddot" data-testid="ai-home-topbar-bell-reddot"></view>
      </view>
      <view class="uni-plus" bindtap="openMoreMenu" data-testid="ai-home-more-btn">
        <view class="uni-plus-circle" data-testid="ai-home-more-icon-plus-circle">
          <text class="uni-plus-sign">+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- [PRD-AIHOME-UNIFY-V1 2026-06-01 §需求3] 欢迎区右上角「模式切换」胶囊（方案1：胶囊带文字）
       显示当前模式名「标准版 ▾」，点击弹下拉：标准版(当前打勾) / 关怀版(可切换)。
       与 ⊕菜单里的「切换模式」并存。 -->
  <!-- [PRD-AIHOME-WELCOME-UNIFY-V1 2026-06-02] 标准模式欢迎区统一为关怀模式风格（同结构/版式/字号/问候语/头像/切换胶囊），
       做瘦身：不含「今日用药提醒」卡片。两模式仅靠背景底色区分——标准模式照搬现关怀模式的蓝绿渐变。 -->
  <view class="welcome welcome-strip">
    <view class="welcome-text">
      <view class="greeting" data-testid="ai-home-welcome-greeting">{{greetingText}} {{greetingIcon}}</view>
      <view class="sub" data-testid="ai-home-welcome-text">我是宾尼小康，聊聊健康问题吧~</view>
    </view>
    <view class="welcome-right-col">
      <view class="mode-capsule-wrap" data-testid="ai-home-mode-switcher">
        <view class="mode-capsule" bindtap="toggleModeDropdown" data-testid="ai-home-mode-capsule">
          <text class="mode-capsule-label" data-testid="ai-home-mode-capsule-label">标准版</text>
          <text class="mode-capsule-arrow {{modeDropdownShow ? 'mode-capsule-arrow-up' : ''}}" data-testid="ai-home-mode-capsule-arrow">▾</text>
        </view>
      </view>
      <view class="robot-logo" data-testid="ai-home-welcome-avatar">
        <image class="robot-img" src="{{logoUrl}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- [PRD-MODE-CAPSULE-V1 2026-05-31] 模式切换下拉面板（展开态） -->
  <view class="mode-dropdown-mask" wx:if="{{modeDropdownShow}}" bindtap="closeModeDropdown"></view>
  <view class="mode-dropdown-panel mode-dropdown-panel-welcome" wx:if="{{modeDropdownShow}}" data-testid="ai-home-mode-dropdown-panel">
    <!-- 当前模式：标准版（高亮 + 打勾，点击仅收起不切换） -->
    <view class="mode-dropdown-item mode-dropdown-item-active" bindtap="closeModeDropdown" data-testid="ai-home-mode-option-standard">
      <text class="mode-dropdown-text">标准版</text>
      <text class="mode-dropdown-check">✓</text>
    </view>
    <!-- 关怀版（点击触发切换流程） -->
    <view class="mode-dropdown-item" bindtap="switchToCareMode" data-testid="ai-home-mode-option-care">
      <text class="mode-dropdown-text">关怀版</text>
    </view>
  </view>

  <!-- [PRD-AIHOME-OPTIM-SHARE-V1 2026-06-02 §需求1/2] 标准模式「⊕ 加号圈」菜单（7 项）：
       1.💬发起新对话 2.🔤字体大小 3.🔀切换模式 4.👑会员中心 5.📷扫一扫 6.🎁分享好友 7.❓帮助与反馈
       已删除「📤立即分享」（合并进🎁分享好友）与「🎁邀请好友」（拉守护人入口不放这里）。
       「🎁 分享好友」点击弹出分享面板，与关怀模式完全一致。 -->
  <view class="more-menu-mask" wx:if="{{moreMenuShow}}" bindtap="closeMoreMenu"></view>
  <view class="more-menu-card" wx:if="{{moreMenuShow}}" data-testid="ai-home-more-menu-card">
    <view class="more-menu-item" bindtap="onTapNewChat" data-testid="ai-home-more-menu-item-发起新对话">
      <text class="more-menu-icon">💬</text>
      <text class="more-menu-label">发起新对话</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" bindtap="onTapFontSize" data-testid="ai-home-more-menu-item-字体大小">
      <text class="more-menu-icon">🔤</text>
      <text class="more-menu-label">字体大小</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" bindtap="onTapSwitchMode" data-testid="ai-home-more-menu-item-切换模式">
      <text class="more-menu-icon">🔀</text>
      <text class="more-menu-label">切换模式</text>
      <text class="more-menu-mode-tag" data-testid="ai-home-more-menu-mode-tag">标准版</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item more-menu-item-gold" bindtap="onTapMemberCenter" data-testid="ai-home-more-menu-item-会员中心">
      <text class="more-menu-icon">👑</text>
      <text class="more-menu-label more-menu-label-gold">会员中心</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" bindtap="onTapScan" data-testid="ai-home-more-menu-item-扫一扫">
      <text class="more-menu-icon">📷</text>
      <text class="more-menu-label">扫一扫</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" bindtap="onTapShareFriend" data-testid="ai-home-more-menu-item-分享好友">
      <text class="more-menu-icon">🎁</text>
      <text class="more-menu-label">分享好友</text>
    </view>
    <view class="more-menu-divider"></view>
    <view class="more-menu-item" bindtap="onTapHelpFeedback" data-testid="ai-home-more-menu-item-帮助与反馈">
      <text class="more-menu-icon">❓</text>
      <text class="more-menu-label">帮助与反馈</text>
    </view>
  </view>

  <view class="type-section">
    <text class="section-title">选择咨询类型</text>
    <view class="type-grid">
      <view class="type-card" wx:for="{{consultTypes}}" wx:key="id" bindtap="startConsult" data-type="{{item}}">
        <view class="type-icon-wrap" style="background: {{item.bgColor}};">
          <text class="type-icon">{{item.icon}}</text>
        </view>
        <text class="type-name">{{item.name}}</text>
        <text class="type-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">快速提问</text>
    <view class="quick-list">
      <view class="quick-item" wx:for="{{quickQuestions}}" wx:key="index" bindtap="quickAsk" data-question="{{item}}">
        <text class="quick-text">{{item}}</text>
        <text class="quick-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">最近对话</text>
    <text class="section-more" bindtap="viewAllChats" wx:if="{{chatHistory.length > 0}}">查看全部 ></text>
  </view>

  <view class="chat-list" wx:if="{{chatHistory.length > 0}}">
    <view class="chat-item card" wx:for="{{chatHistory}}" wx:key="id" bindtap="continueChat" data-id="{{item.id}}">
      <view class="chat-header">
        <text class="chat-type-tag tag tag-green">{{item.type}}</text>
        <text class="chat-time">{{item.time}}</text>
      </view>
      <text class="chat-summary ellipsis-2">{{item.summary}}</text>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">💬</text>
    <text class="empty-text">暂无对话记录</text>
    <text class="empty-text">开始AI健康咨询吧</text>
  </view>

  <!-- PRD v1.0 2026-04-23：+新建对话（加号与文字无空格，按钮内水平+垂直居中） -->
  <view class="new-chat-btn" bindtap="newChat">
    <text class="new-chat-text">+新建对话</text>
  </view>

  <!-- 对话历史抽屉 -->
  <chat-drawer
    show="{{drawerShow}}"
    sessions="{{allSessions}}"
    bind:close="onDrawerClose"
    bind:sessiontap="onSessionTap"
    bind:newchat="onDrawerNewChat"
    bind:refresh="onDrawerRefresh"
    bind:share="onDrawerShare"
  />
</view>

<view class="container merchant-scan-page" wx:else>
  <view class="scan-prompt" wx:if="{{!orderInfo}}">
    <view class="scan-animation-wrapper" bindtap="startScan">
      <view class="scan-circle">
        <view class="scan-circle-inner">
          <text class="scan-emoji">📷</text>
        </view>
      </view>
      <view class="scan-ripple"></view>
      <view class="scan-ripple delay"></view>
    </view>
    <text class="scan-tip">点击上方按钮扫描核销码</text>
    <text class="scan-sub-tip">请对准用户手机上的核销二维码</text>
  </view>

  <view class="order-card card" wx:if="{{orderInfo}}">
    <view class="order-header">
      <text class="order-title">订单信息</text>
      <view class="order-status {{orderInfo.status === 'verified' ? 'status-done' : 'status-pending'}}">
        <text>{{orderInfo.status === 'verified' ? '已核销' : '待核销'}}</text>
      </view>
    </view>

    <view class="order-detail-list">
      <view class="detail-row">
        <text class="detail-label">订单号</text>
        <text class="detail-value">{{orderInfo.order_no}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">服务名称</text>
        <text class="detail-value">{{orderInfo.service_name}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">用户</text>
        <text class="detail-value">{{orderInfo.user_name}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">金额</text>
        <text class="detail-value price">¥{{orderInfo.amount}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">下单时间</text>
        <text class="detail-value">{{orderInfo.create_time}}</text>
      </view>
    </view>

    <view class="order-actions" wx:if="{{orderInfo.status !== 'verified'}}">
      <button class="btn-primary verify-btn" bindtap="handleVerify" loading="{{verifying}}">
        确认核销
      </button>
    </view>
    <view class="order-actions" wx:else>
      <view class="verified-notice">
        <text class="verified-icon">✅</text>
        <text class="verified-text">该订单已核销完成</text>
      </view>
    </view>

    <view class="rescan-area">
      <button class="btn-secondary" bindtap="startScan">重新扫码</button>
    </view>
  </view>
</view>
