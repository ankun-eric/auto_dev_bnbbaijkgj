.profile-page {
  padding-bottom: 24rpx;
}

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  align-items: center;
}

.merchant-header {
  justify-content: space-between;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.login-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.user-name {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.member-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 16rpx;
  padding: 4rpx 16rpx;
  margin-top: 8rpx;
}

.member-text {
  font-size: 22rpx;
  color: #fff;
}

.arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.switch-role-inline {
  font-size: 22rpx;
  color: #ffffff;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

/* 统计 */
.stats-bar {
  display: flex;
  align-items: center;
  margin: -30rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

/* 卡片 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-more {
  font-size: 24rpx;
  color: #999;
}

.card {
  margin: 0 24rpx 24rpx;
}

/* 订单快捷 */
.order-quick {
  display: flex;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

/* 菜单 */
.menu-card {
  padding: 0 24rpx;
}

.role-switch-item .menu-label {
  color: #52c41a;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  font-size: 28rpx;
  color: #333;
}

.menu-item .arrow {
  color: #ccc;
}
