<view class="profile-page" wx:if="{{pageMode === 'user'}}">
  <view class="user-header" bindtap="goLogin" wx:if="{{!isLoggedIn}}">
    <view class="avatar-wrap">
      <text class="avatar-text">?</text>
    </view>
    <view class="user-info">
      <text class="login-text">点击登录</text>
      <text class="login-desc">登录后享受更多健康服务</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <view class="user-header" wx:else>
    <view class="avatar-wrap">
      <image class="avatar-img" src="{{userInfo.avatar}}" wx:if="{{userInfo.avatar}}" />
      <text class="avatar-text" wx:else>{{userInfo.nickname ? userInfo.nickname[0] : '用'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '用户'}}</text>
      <view class="member-tag" wx:if="{{userInfo.memberLevel}}">
        <text class="member-text">{{userInfo.memberLevel}}</text>
      </view>
    </view>
    <view class="header-actions">
      <text class="switch-role-inline" wx:if="{{canSwitchRole}}" bindtap="switchRole">切换角色</text>
      <text class="arrow" bindtap="goHealthProfile">›</text>
    </view>
  </view>

  <view class="stats-bar card">
    <view class="stat-item" bindtap="goPoints">
      <text class="stat-value">{{points}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goOrders">
      <text class="stat-value">{{orderCount}}</text>
      <text class="stat-label">订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goFamily">
      <text class="stat-value">{{familyCount}}</text>
      <text class="stat-label">家人</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{checkDays}}</text>
      <text class="stat-label">签到天数</text>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">我的订单</text>
      <text class="card-more" bindtap="goOrders">全部订单 ></text>
    </view>
    <view class="order-quick">
      <view class="quick-btn" bindtap="goOrders" data-status="pending">
        <text class="quick-icon">💰</text>
        <text class="quick-label">待付款</text>
      </view>
      <view class="quick-btn" bindtap="goOrders" data-status="paid">
        <text class="quick-icon">📦</text>
        <text class="quick-label">待使用</text>
      </view>
      <view class="quick-btn" bindtap="goOrders" data-status="used">
        <text class="quick-icon">✅</text>
        <text class="quick-label">已完成</text>
      </view>
      <view class="quick-btn" bindtap="goOrders" data-status="refund">
        <text class="quick-icon">🔄</text>
        <text class="quick-label">退款</text>
      </view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item role-switch-item" wx:if="{{canSwitchRole}}" bindtap="switchRole">
      <view class="menu-left">
        <text class="menu-icon">🔁</text>
        <text class="menu-label">切换到商家端</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <block wx:for="{{menuList}}" wx:key="id">
      <view class="menu-item" bindtap="onMenuTap" data-item="{{item}}">
        <view class="menu-left">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-label">{{item.label}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </block>
  </view>

</view>

<view class="profile-page" wx:else>
  <view class="user-header merchant-header">
    <view class="avatar-wrap">
      <image class="avatar-img" src="{{merchantProfile.avatar}}" wx:if="{{merchantProfile.avatar}}" />
      <text class="avatar-text" wx:else>{{merchantProfile.nickname ? merchantProfile.nickname[0] : '店'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{merchantProfile.nickname || userInfo.nickname || '商家账号'}}</text>
      <view class="member-tag">
        <text class="member-text">{{currentStore.store_name}}</text>
      </view>
    </view>
    <text class="switch-role-inline" wx:if="{{canSwitchRole}}" bindtap="switchRole">切换角色</text>
  </view>

  <view class="stats-bar card">
    <view class="stat-item">
      <text class="stat-value">{{currentStore.store_code}}</text>
      <text class="stat-label">当前门店编码</text>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item role-switch-item" wx:if="{{canSwitchRole}}" bindtap="switchRole">
      <view class="menu-left">
        <text class="menu-icon">🔁</text>
        <text class="menu-label">切换到用户端</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:for="{{merchantMenuList}}" wx:key="id" bindtap="onMenuTap" data-item="{{item}}">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-label">{{item.label}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="logout">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-label">退出登录</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
