.invite-page {
  min-height: 100vh;
  background: #F0FDF4;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #22C55E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.error-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 40rpx;
}
.retry-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background: #22C55E;
  color: #fff;
  border: none;
  border-radius: 36rpx;
}
.retry-btn::after { border: none; }

.invite-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.invite-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.invite-header {
  text-align: center;
  margin-bottom: 40rpx;
}
.invite-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 12rpx;
}
.invite-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
}

.qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.qr-brand-name {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #22C55E;
  font-weight: 500;
  text-align: center;
}

.invite-info {
  background: #F0FDF4;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}
.info-row + .info-row {
  border-top: 1rpx solid #DCFCE7;
}
.info-label {
  font-size: 26rpx;
  color: #6B7280;
}
.info-value {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
}

.action-group {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 140rpx;
  background: #fff;
  border-radius: 16rpx;
  border: none;
  font-size: 24rpx;
  color: #374151;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  padding: 0;
  line-height: 1.4;
}
.action-btn::after { border: none; }
.action-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.action-save { color: #22C55E; }
.action-copy { color: #1890ff; }
.action-share { color: #722ed1; }

.tips-section {
  width: 100%;
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}
.tip-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.tip-text {
  font-size: 26rpx;
  color: #374151;
}
.tip-note {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
}
