<view class="home-page" wx:if="{{pageMode === 'user'}}">
  <view class="custom-nav" style="padding-top:{{statusBarHeight}}px;">
    <view class="custom-nav-content">
      <view class="custom-nav-title-wrap">
        <!-- Bug 1：LOGO 放大到顶栏高度 75%，去掉文字品牌名 -->
        <image wx:if="{{brandLogoUrl}}" class="brand-logo-large" src="{{brandLogoUrl}}" mode="aspectFit" />
        <text wx:else class="custom-nav-title">宾尼小康</text>
      </view>
      <view class="custom-nav-actions">
        <view class="nav-action-btn" catchtap="onScanTap">
          <text class="nav-action-icon">📷</text>
        </view>
        <view class="nav-action-btn nav-msg-btn" catchtap="goMessages">
          <text class="nav-action-icon">💬</text>
          <view class="nav-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="search-bar" style="margin-top:{{navBarHeight}}px;" wx:if="{{homeConfig.search_visible !== false}}">
    <view class="city-selector" bindtap="onCityTap">
      <text class="city-name">{{cityName}}</text>
      <text class="city-arrow">▼</text>
    </view>
    <view class="search-divider"></view>
    <view class="search-input" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">{{homeConfig.search_placeholder || '搜索您想要的健康服务'}}</text>
    </view>
    <view class="switch-role-chip" wx:if="{{canSwitchRole}}" catchtap="switchRole">切换角色</view>
    <view class="notification-btn" catchtap="goNotifications">
      <text class="bell-icon">🔔</text>
      <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
    </view>
  </view>

  <view class="search-bar" style="margin-top:{{navBarHeight}}px;" wx:elif="{{homeConfig.search_visible === false}}">
    <view class="search-bar-right">
      <view class="switch-role-chip" wx:if="{{canSwitchRole}}" catchtap="switchRole">切换角色</view>
      <view class="notification-btn" catchtap="goNotifications">
        <text class="bell-icon">🔔</text>
        <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
      </view>
    </view>
  </view>

  <swiper class="banner-swiper" wx:if="{{banners.length > 0}}" indicator-dots autoplay circular interval="{{4000}}">
    <block wx:for="{{banners}}" wx:key="id">
      <swiper-item wx:if="{{item.image_url}}">
        <view class="banner-item" bindtap="onBannerTap" data-item="{{item}}">
          <image class="banner-image" src="{{item.image_url}}" mode="aspectFill" />
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="card">
    <view class="grid-menu">
      <view class="grid-item" style="width:{{gridColumnWidth}}" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-item="{{item}}">
        <view class="grid-icon" style="background: {{item.bgColor || 'rgba(82,196,26,0.12)'}};">
          <image class="icon-img" wx:if="{{item.icon_type === 'image' && item.icon_content}}" src="{{item.icon_content}}" mode="aspectFit" />
          <text class="icon-text" wx:else>{{item.icon_content || item.icon || '📌'}}</text>
        </view>
        <text class="grid-label">{{item.name || item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{healthTips.length > 0}}">
    <view class="section-header">
      <text class="section-title">健康提醒</text>
    </view>
    <view class="tip-item" wx:for="{{healthTips}}" wx:key="id">
      <text class="tip-icon">💡</text>
      <text class="tip-text">{{item.content}}</text>
    </view>
  </view>

  <!-- 今日待办 -->
  <view class="card today-todos-card">
    <view class="section-header">
      <text class="section-title">今日待办</text>
      <text class="section-more" wx:if="{{todoTotalCount > 0}}" style="font-size:22rpx;color:#999;">{{todoTotalCompleted}}/{{todoTotalCount}}</text>
    </view>
    <view wx:if="{{todayTodosLoading}}" class="todo-loading">
      <text class="text-hint">加载中...</text>
    </view>
    <view wx:elif="{{todoTotalCount === 0}}" class="todo-empty">
      <text class="todo-empty-icon">📋</text>
      <text class="todo-empty-text">暂无今日待办，去创建健康计划吧</text>
      <view class="todo-empty-btn" bindtap="goHealthPlan">去创建</view>
    </view>
    <view wx:else class="todo-groups">
      <view class="todo-group" wx:for="{{todoGroups}}" wx:key="group_type">
        <view class="todo-group-header">
          <view class="todo-group-title-row">
            <text class="todo-group-icon" wx:if="{{item.group_type === 'medication'}}">💊</text>
            <text class="todo-group-icon" wx:elif="{{item.group_type === 'checkin'}}">✅</text>
            <text class="todo-group-icon" wx:else>📋</text>
            <text class="todo-group-name">{{item.group_name}}</text>
          </view>
          <text class="todo-group-count">{{item.completed_count}}/{{item.total_count}}</text>
        </view>

        <view wx:if="{{item.is_empty}}" class="todo-group-empty">
          <text class="todo-group-empty-text">今日无待办</text>
        </view>
        <view wx:else>
          <view class="todo-item {{todoItem.is_completed ? 'todo-item-done' : ''}}" wx:for="{{item.items}}" wx:for-item="todoItem" wx:key="id">
            <view class="todo-left">
              <view class="todo-check-circle {{todoItem.is_completed ? 'todo-checked' : ''}}">
                <text wx:if="{{todoItem.is_completed}}" class="todo-check-mark">✓</text>
              </view>
              <view class="todo-info">
                <text class="todo-name {{todoItem.is_completed ? 'todo-done' : ''}}">{{todoItem.name}}</text>
                <text class="todo-time" wx:if="{{todoItem.remind_time}}">{{todoItem.remind_time}}</text>
                <text class="todo-time" wx:if="{{todoItem.extra.plan_name}}">{{todoItem.extra.plan_name}}</text>
              </view>
            </view>
            <view class="todo-action" wx:if="{{!todoItem.is_completed}}" catchtap="onTodoCheckin"
              data-type="{{todoItem.type}}" data-id="{{todoItem.id}}"
              data-source-id="{{todoItem.source_id}}"
              data-target-value="{{todoItem.target_value}}"
              data-target-unit="{{todoItem.target_unit}}"
              data-name="{{todoItem.name}}">
              <text class="todo-checkin-btn">打卡</text>
            </view>
            <view class="todo-action-done" wx:else>
              <text class="todo-done-icon">✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="todo-footer" bindtap="goHealthPlan">
      <text class="todo-footer-text">查看全部计划 ></text>
    </view>
  </view>

  <!-- 打卡数值输入对话框 -->
  <view class="checkin-dialog-mask" wx:if="{{checkinDialog}}" catchtap="onCheckinDialogCancel">
    <view class="checkin-dialog" catchtap="">
      <text class="checkin-dialog-title">{{checkinDialogName}}</text>
      <text class="checkin-dialog-hint">目标: {{checkinDialogTarget}} {{checkinDialogUnit}}</text>
      <input class="checkin-dialog-input" type="digit" placeholder="请输入实际值"
        value="{{checkinDialogValue}}" bindinput="onCheckinDialogInput" focus="{{checkinDialog}}" />
      <view class="checkin-dialog-actions">
        <view class="checkin-dialog-btn checkin-dialog-cancel" bindtap="onCheckinDialogCancel">取消</view>
        <view class="checkin-dialog-btn checkin-dialog-confirm" bindtap="onCheckinDialogConfirm">确认打卡</view>
      </view>
    </view>
  </view>

  <block wx:if="{{articles.length > 0}}">
    <view class="section-header">
      <text class="section-title">健康知识</text>
      <text class="section-more" bindtap="goArticles">更多 ></text>
    </view>

    <view class="article-list">
      <view class="article-card card" wx:for="{{articles}}" wx:key="id" bindtap="goArticleDetail" data-id="{{item.id}}">
        <view class="article-info">
          <text class="article-title ellipsis-2">{{item.title}}</text>
          <view class="article-meta">
            <text class="tag tag-green" wx:if="{{item.tag}}">{{item.tag}}</text>
            <text class="article-time">{{item.time}}</text>
          </view>
        </view>
        <image class="article-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}" />
      </view>
    </view>
  </block>

</view>

<view class="container merchant-home-page" wx:else>
  <view class="header-card card">
    <view class="user-row">
      <view class="avatar">
        <text class="avatar-text">{{merchantUserName ? merchantUserName[0] : '店'}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{merchantUserName || '门店工作人员'}}</text>
        <text class="user-role">{{currentStore.store_name}}</text>
      </view>
      <view class="switch-link" wx:if="{{canSwitchRole}}" bindtap="switchRole">
        <text class="switch-link-text">切换角色</text>
      </view>
    </view>
  </view>

  <view class="stats-card card">
    <text class="stats-title">今日门店核销统计</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num text-green">{{todayCount}}</text>
        <text class="stat-label">核销笔数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num text-cyan">¥{{todayAmount}}</text>
        <text class="stat-label">核销金额</text>
      </view>
    </view>
  </view>

  <view class="scan-area" bindtap="goScan">
    <view class="scan-btn-big">
      <view class="scan-icon-wrapper">
        <text class="scan-icon-text">📷</text>
      </view>
      <text class="scan-btn-label">扫码核销</text>
      <text class="scan-btn-desc">扫描用户订单核销码</text>
    </view>
  </view>

  <view class="quick-entry card" bindtap="goRecords">
    <view class="entry-left">
      <text class="entry-icon">📋</text>
      <view class="entry-text">
        <text class="entry-title">核销记录</text>
        <text class="entry-desc">查看当前门店历史核销订单</text>
      </view>
    </view>
    <text class="entry-arrow">›</text>
  </view>

  <view class="quick-entry card" bindtap="goNotifications">
    <view class="entry-left">
      <text class="entry-icon">🔔</text>
      <view class="entry-text">
        <text class="entry-title">商家消息</text>
        <text class="entry-desc">查看与商家端相关的独立消息</text>
      </view>
    </view>
    <text class="entry-arrow">›</text>
  </view>
</view>

<view class="invite-fab" wx:if="{{pageMode === 'user'}}" bindtap="goInvite">
  <text class="invite-fab-icon">🎁</text>
  <text class="invite-fab-text">邀请好友</text>
</view>

<view class="loading-wrap" wx:if="{{loading}}">
  <text class="text-hint">加载中...</text>
</view>
