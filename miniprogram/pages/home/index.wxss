.home-page {
  padding-bottom: 20rpx;
}

/* Custom navigation bar */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.custom-nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 24rpx;
}

.custom-nav-title-wrap {
  display: flex;
  align-items: center;
}

.brand-logo-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  vertical-align: middle;
}

/* Bug 1：首页 LOGO 放大到顶栏高度 75%（顶栏 44px ≈ 88rpx，75% ≈ 66rpx，向上取 72rpx） */
.brand-logo-large {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  margin-left: 4rpx;
  vertical-align: middle;
  display: block;
}

.custom-nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.custom-nav-actions {
  display: flex;
  align-items: center;
}

.nav-action-btn {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.nav-action-icon {
  font-size: 40rpx;
}

.nav-msg-btn {
  position: relative;
}

.nav-badge {
  position: absolute;
  top: 4rpx;
  right: 2rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: #ff4d4f;
  border-radius: 16rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.merchant-home-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-bar-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.city-selector {
  display: flex;
  align-items: center;
  max-width: 160rpx;
  flex-shrink: 0;
}

.city-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.city-arrow {
  font-size: 18rpx;
  color: #999;
  margin-left: 4rpx;
}

.search-divider {
  width: 2rpx;
  height: 32rpx;
  background: #e0e0e0;
  margin: 0 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #E8F7EE;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #52c41a;
}

.search-placeholder {
  color: #86909C;
  font-size: 26rpx;
}

.notification-btn {
  position: relative;
  margin-left: 20rpx;
  padding: 10rpx;
}

.switch-role-chip {
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
  font-size: 22rpx;
}

.bell-icon {
  font-size: 40rpx;
}

/* Banner */
.banner-swiper {
  height: 280rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.banner-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.banner-content {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 网格菜单 */
.grid-menu {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 40rpx;
}

.icon-img {
  width: 48rpx;
  height: 48rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #333;
}

/* 健康提醒 */
.tip-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* 今日待办 */
.today-todos-card { margin: 0 24rpx 24rpx; }
.todo-loading, .todo-empty { padding: 40rpx 0; text-align: center; }
.todo-empty { display: flex; flex-direction: column; align-items: center; }
.todo-empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.todo-empty-text { font-size: 26rpx; color: #999; margin-bottom: 20rpx; }
.todo-empty-btn { padding: 12rpx 40rpx; background: #52c41a; color: #fff; border-radius: 32rpx; font-size: 26rpx; }

.todo-groups { margin-top: 8rpx; }
.todo-group { margin-bottom: 20rpx; }
.todo-group:last-child { margin-bottom: 0; }
.todo-group-header { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; }
.todo-group-title-row { display: flex; align-items: center; }
.todo-group-icon { font-size: 28rpx; margin-right: 8rpx; }
.todo-group-name { font-size: 26rpx; font-weight: 600; color: #333; }
.todo-group-count { font-size: 22rpx; color: #999; }
.todo-group-empty { padding: 16rpx 0; padding-left: 36rpx; }
.todo-group-empty-text { font-size: 24rpx; color: #ccc; }

.todo-subgroup { margin-bottom: 12rpx; }
.todo-subgroup:last-child { margin-bottom: 0; }
.todo-subgroup-header { display: flex; align-items: center; justify-content: space-between; padding: 8rpx 0 8rpx 36rpx; }
.todo-subgroup-name { font-size: 24rpx; color: #666; font-weight: 500; }
.todo-subgroup-count { font-size: 20rpx; color: #999; }
.todo-subgroup-empty-header { opacity: 0.5; }
.todo-subgroup-empty-tag { font-size: 20rpx; color: #ccc; }

.todo-item { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0 14rpx 36rpx; border-bottom: 1rpx solid #f9f9f9; }
.todo-item:last-child { border-bottom: none; }
.todo-item-done { opacity: 0.6; }
.todo-left { display: flex; align-items: center; flex: 1; overflow: hidden; }
.todo-check-circle { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #d9d9d9; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.todo-checked { background: #52c41a; border-color: #52c41a; }
.todo-check-mark { font-size: 22rpx; color: #fff; font-weight: bold; }
.todo-info { flex: 1; overflow: hidden; }
.todo-name { font-size: 28rpx; color: #333; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.todo-done { text-decoration: line-through; color: #999; }
.todo-time { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.todo-action { flex-shrink: 0; margin-left: 16rpx; }
.todo-checkin-btn { font-size: 24rpx; color: #fff; background: #52c41a; padding: 8rpx 24rpx; border-radius: 24rpx; }
.todo-action-done { flex-shrink: 0; margin-left: 16rpx; }
.todo-done-icon { font-size: 28rpx; color: #52c41a; font-weight: bold; }

.todo-footer { padding: 16rpx 0 4rpx; text-align: center; border-top: 1rpx solid #f5f5f5; }
.todo-footer-text { font-size: 24rpx; color: #52c41a; }

/* 打卡数值输入对话框 */
.checkin-dialog-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: center; justify-content: center; }
.checkin-dialog { width: 560rpx; background: #fff; border-radius: 24rpx; padding: 40rpx; }
.checkin-dialog-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; text-align: center; margin-bottom: 12rpx; }
.checkin-dialog-hint { font-size: 24rpx; color: #999; display: block; text-align: center; margin-bottom: 32rpx; }
.checkin-dialog-input { border: 2rpx solid #e8e8e8; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 32rpx; text-align: center; margin-bottom: 32rpx; }
.checkin-dialog-actions { display: flex; justify-content: space-between; }
.checkin-dialog-btn { flex: 1; text-align: center; padding: 18rpx 0; border-radius: 36rpx; font-size: 28rpx; }
.checkin-dialog-cancel { background: #f5f5f5; color: #666; margin-right: 16rpx; }
.checkin-dialog-confirm { background: #52c41a; color: #fff; }

/* Section header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  padding: 0 24rpx;
}

.article-card {
  display: flex;
  align-items: center;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx;
}

.article-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.article-time {
  font-size: 22rpx;
  color: #999;
}

.article-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* Merchant page styles */
.container {
  box-sizing: border-box;
}

.header-card,
.stats-card,
.quick-entry {
  margin-bottom: 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.user-role {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.switch-link {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
}

.switch-link-text {
  font-size: 22rpx;
  color: #52c41a;
}

.stats-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 600;
}

.scan-area {
  margin-bottom: 24rpx;
}

.scan-btn-big {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.scan-icon-text {
  font-size: 42rpx;
}

.scan-btn-label {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.scan-btn-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.entry-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.entry-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.entry-text {
  display: flex;
  flex-direction: column;
}

.entry-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.entry-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.entry-arrow {
  font-size: 34rpx;
  color: #ccc;
}

.invite-fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  border-radius: 50rpx;
  padding: 20rpx 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
  z-index: 50;
}

.invite-fab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.invite-fab-text {
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
}
