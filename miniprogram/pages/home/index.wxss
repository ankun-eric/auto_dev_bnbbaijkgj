.home-page {
  padding-bottom: 20rpx;
}

.merchant-home-page {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-bar-right {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.font-btn {
  margin-left: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(82, 196, 26, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.font-btn-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #52c41a;
}

.notification-btn {
  position: relative;
  margin-left: 20rpx;
  padding: 10rpx;
}

.switch-role-chip {
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
  font-size: 22rpx;
}

.bell-icon {
  font-size: 40rpx;
}

/* Banner */
.banner-swiper {
  height: 280rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.banner-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.banner-content {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 网格菜单 */
.grid-menu {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 40rpx;
}

.icon-img {
  width: 48rpx;
  height: 48rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #333;
}

/* 健康提醒 */
.tip-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* Section header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  padding: 0 24rpx;
}

.article-card {
  display: flex;
  align-items: center;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx;
}

.article-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.article-time {
  font-size: 22rpx;
  color: #999;
}

.article-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* Font modal */
.font-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.font-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.font-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.font-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.font-modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.font-modal-preview {
  text-align: center;
  padding: 40rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
  color: #333;
}

.font-slider-wrap {
  padding: 0 12rpx;
  margin-bottom: 40rpx;
}

.font-slider-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.font-slider-label {
  font-size: 26rpx;
  color: #999;
}

.font-slider-label.active {
  color: #52c41a;
  font-weight: bold;
}

.font-modal-footer {
  display: flex;
  justify-content: center;
}

.font-confirm-btn {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 120rpx;
  font-size: 30rpx;
  text-align: center;
}

/* Merchant page styles */
.container {
  box-sizing: border-box;
}

.header-card,
.stats-card,
.quick-entry {
  margin-bottom: 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.user-role {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.switch-link {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
}

.switch-link-text {
  font-size: 22rpx;
  color: #52c41a;
}

.stats-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 600;
}

.scan-area {
  margin-bottom: 24rpx;
}

.scan-btn-big {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.scan-icon-text {
  font-size: 42rpx;
}

.scan-btn-label {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.scan-btn-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.entry-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.entry-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.entry-text {
  display: flex;
  flex-direction: column;
}

.entry-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.entry-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.entry-arrow {
  font-size: 34rpx;
  color: #ccc;
}
