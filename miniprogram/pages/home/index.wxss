.home-page {
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.notification-btn {
  position: relative;
  margin-left: 20rpx;
  padding: 10rpx;
}

.bell-icon {
  font-size: 40rpx;
}

/* Banner */
.banner-swiper {
  height: 280rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 网格菜单 */
.grid-menu {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 40rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #333;
}

/* 健康提醒 */
.tip-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* Section header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  padding: 0 24rpx;
}

.article-card {
  display: flex;
  align-items: center;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx;
}

.article-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.article-time {
  font-size: 22rpx;
  color: #999;
}

.article-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}
