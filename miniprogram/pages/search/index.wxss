.search-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* Search Header */
.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 24rpx;
  color: #999;
  background: #ddd;
  border-radius: 50%;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
}

.mic-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  background: #f0faf0;
  border-radius: 50%;
}

.mic-icon {
  font-size: 36rpx;
}

.search-btn {
  margin-left: 16rpx;
  background: #52c41a;
  border-radius: 36rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn-text {
  color: #fff;
  font-size: 28rpx;
  white-space: nowrap;
}

/* Auto Search Bar */
.auto-search-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #fffbe6;
  border-bottom: 1rpx solid #ffe58f;
}

.auto-search-text {
  font-size: 26rpx;
  color: #d48806;
}

.auto-search-cancel {
  font-size: 26rpx;
  color: #1890ff;
  margin-left: 24rpx;
}

/* Suggest List */
.suggest-list {
  background: #fff;
}

.suggest-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.suggest-icon {
  font-size: 28rpx;
  color: #bbb;
  margin-right: 16rpx;
}

.suggest-text {
  font-size: 28rpx;
  color: #333;
}

/* Body Sections */
.search-body {
  padding: 0 24rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 24rpx;
  color: #999;
}

/* Tag List (Hot Search) */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  background: #f5f5f5;
  border-radius: 28rpx;
  padding: 12rpx 28rpx;
}

.tag-text {
  font-size: 26rpx;
  color: #555;
}

/* History List */
.history-list {
  /* vertical list */
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #bbb;
}

.history-text {
  font-size: 28rpx;
  color: #333;
}

/* Voice Overlay */
.voice-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-overlay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.voice-content {
  position: relative;
  z-index: 1;
  width: 560rpx;
  min-height: 400rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.voice-recording,
.voice-recognizing,
.voice-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* Wave Animation */
.wave-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.wave-bar {
  width: 10rpx;
  background: #52c41a;
  border-radius: 5rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-bar-1 { height: 40rpx; animation-delay: 0s; }
.wave-bar-2 { height: 70rpx; animation-delay: 0.15s; }
.wave-bar-3 { height: 100rpx; animation-delay: 0.3s; }
.wave-bar-4 { height: 70rpx; animation-delay: 0.45s; }
.wave-bar-5 { height: 40rpx; animation-delay: 0.6s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.4); }
  50% { transform: scaleY(1); }
}

.voice-duration {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.voice-hint {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

/* Spinner */
.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top: 6rpx solid #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Error State */
.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

.retry-btn {
  background: #52c41a;
  border-radius: 36rpx;
  padding: 16rpx 64rpx;
  margin-bottom: 16rpx;
}

.retry-text {
  color: #fff;
  font-size: 28rpx;
}

.close-btn {
  padding: 16rpx 64rpx;
}

.close-text {
  color: #999;
  font-size: 26rpx;
}
