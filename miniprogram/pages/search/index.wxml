<view class="search-page">
  <!-- Search Bar -->
  <view class="search-header">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索症状、药品、健康知识..."
        value="{{keyword}}"
        focus="{{inputFocus}}"
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onSearch"
      />
      <view class="clear-btn" wx:if="{{keyword}}" catchtap="onClear">
        <text class="clear-icon">✕</text>
      </view>
    </view>
    <view class="mic-btn" bindlongpress="onMicLongPress" bindtouchend="onMicTouchEnd" catchtap="onMicTap">
      <text class="mic-icon">🎤</text>
    </view>
    <view class="search-btn" bindtap="onSearch">
      <text class="search-btn-text">搜索</text>
    </view>
  </view>

  <!-- Auto-search countdown -->
  <view class="auto-search-bar" wx:if="{{autoSearchCountdown > 0}}">
    <text class="auto-search-text">{{autoSearchCountdown}}秒后自动搜索</text>
    <text class="auto-search-cancel" catchtap="cancelAutoSearch">取消</text>
  </view>

  <!-- Suggest List -->
  <view class="suggest-list" wx:if="{{keyword && suggestions.length > 0 && !showVoiceOverlay}}">
    <view class="suggest-item" wx:for="{{suggestions}}" wx:key="index" bindtap="onSuggestTap" data-text="{{item}}">
      <text class="suggest-icon">🔍</text>
      <text class="suggest-text">{{item}}</text>
    </view>
  </view>

  <!-- Main Content (shown when no suggestions) -->
  <view class="search-body" wx:if="{{!keyword || suggestions.length === 0}}">
    <!-- Hot Search -->
    <view class="section" wx:if="{{hotList.length > 0}}">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="tag-list">
        <view class="tag-item" wx:for="{{hotList}}" wx:key="index" bindtap="onTagTap" data-text="{{item}}">
          <text class="tag-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- Search History -->
    <view class="section" wx:if="{{historyList.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="section-action" catchtap="onClearHistory">清空</text>
      </view>
      <view class="history-list">
        <view class="history-item" wx:for="{{historyList}}" wx:key="index" bindtap="onTagTap" data-text="{{item}}">
          <text class="history-icon">🕐</text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Voice Overlay -->
  <view class="voice-overlay" wx:if="{{showVoiceOverlay}}" catchtouchmove="preventMove">
    <view class="voice-overlay-mask"></view>
    <view class="voice-content">
      <!-- Recording State -->
      <view class="voice-recording" wx:if="{{voiceState === 'recording'}}">
        <view class="wave-container">
          <view class="wave-bar wave-bar-1"></view>
          <view class="wave-bar wave-bar-2"></view>
          <view class="wave-bar wave-bar-3"></view>
          <view class="wave-bar wave-bar-4"></view>
          <view class="wave-bar wave-bar-5"></view>
        </view>
        <text class="voice-duration">{{recordingTime}}s / 15s</text>
        <text class="voice-hint">松开结束</text>
      </view>

      <!-- Recognizing State -->
      <view class="voice-recognizing" wx:if="{{voiceState === 'recognizing'}}">
        <view class="spinner"></view>
        <text class="voice-hint">正在识别...</text>
      </view>

      <!-- Error State -->
      <view class="voice-error" wx:if="{{voiceState === 'error'}}">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{voiceErrorMsg || '识别失败，请重试'}}</text>
        <view class="retry-btn" catchtap="onRetryVoice">
          <text class="retry-text">重试</text>
        </view>
        <view class="close-btn" catchtap="onCloseVoice">
          <text class="close-text">关闭</text>
        </view>
      </view>
    </view>
  </view>
</view>
