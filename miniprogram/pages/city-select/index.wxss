.city-select-page {
  background: #fff;
  min-height: 100vh;
  position: relative;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

/* 搜索结果 */
.search-results {
  padding: 0 24rpx;
}

.search-empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 主内容区 */
.city-content {
  height: calc(100vh - 100rpx);
  padding-right: 48rpx;
}

/* 分区 */
.section {
  padding: 16rpx 24rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.section-letter {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* GPS 行 */
.gps-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.gps-city {
  font-size: 28rpx;
  color: #333;
}

.gps-reload {
  font-size: 24rpx;
  color: #52c41a;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-tag {
  padding: 14rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

/* 热门城市网格 */
.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  width: calc(25% - 12rpx);
  text-align: center;
  padding: 18rpx 0;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

/* 城市列表项 */
.city-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.city-item:last-child {
  border-bottom: none;
}

.city-item-name {
  font-size: 28rpx;
  color: #333;
}

/* 右侧字母索引 */
.letter-index {
  position: fixed;
  right: 4rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 20;
}

.letter-item {
  font-size: 20rpx;
  color: #52c41a;
  padding: 4rpx 8rpx;
  line-height: 1.4;
}
