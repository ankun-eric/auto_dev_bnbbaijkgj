<view class="settings-page">
  <!-- 账号信息 -->
  <view class="card">
    <view class="setting-item" bindtap="editNickname">
      <text class="setting-label">昵称</text>
      <view class="setting-right">
        <text class="setting-value">{{userInfo.nickname || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="editAvatar">
      <text class="setting-label">头像</text>
      <view class="setting-right">
        <view class="mini-avatar">
          <text class="mini-avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : '?'}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="setting-item">
      <text class="setting-label">手机号</text>
      <text class="setting-value">{{userInfo.phone || '未绑定'}}</text>
    </view>
  </view>

  <!-- 通知设置 -->
  <view class="card">
    <text class="card-label">通知设置</text>
    <view class="setting-item">
      <text class="setting-label">健康提醒</text>
      <switch class="setting-switch" checked="{{healthReminder}}" bindchange="toggleHealthReminder" color="#52c41a" />
    </view>
    <view class="setting-item">
      <text class="setting-label">订单通知</text>
      <switch class="setting-switch" checked="{{orderNotify}}" bindchange="toggleOrderNotify" color="#52c41a" />
    </view>
    <view class="setting-item">
      <text class="setting-label">活动推送</text>
      <switch class="setting-switch" checked="{{activityPush}}" bindchange="toggleActivityPush" color="#52c41a" />
    </view>
  </view>

  <!-- 其他 -->
  <view class="card">
    <view class="setting-item" bindtap="clearCache">
      <text class="setting-label">清除缓存</text>
      <view class="setting-right">
        <text class="setting-value">{{cacheSize}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="showAbout">
      <text class="setting-label">关于我们</text>
      <view class="setting-right">
        <text class="setting-value">v1.0.0</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="showAgreement">
      <text class="setting-label">用户协议</text>
      <view class="setting-right">
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="showPrivacy">
      <text class="setting-label">隐私政策</text>
      <view class="setting-right">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">
    <text class="logout-text">退出登录</text>
  </view>
</view>
