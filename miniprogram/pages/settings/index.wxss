.settings-page {
  padding: 24rpx;
  min-height: 100vh;
}

.card {
  margin-bottom: 24rpx;
}

.card-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.setting-value {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

.mini-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-avatar-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.setting-switch {
  transform: scale(0.85);
}

.logout-btn {
  margin-top: 48rpx;
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #ff4d4f;
}
