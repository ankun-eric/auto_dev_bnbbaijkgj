.experts-page {
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
}

.filter-item {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-active {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #52c41a;
}

.expert-list { padding: 24rpx; }

.expert-card { margin-bottom: 16rpx; }

.expert-top {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.expert-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-char {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.expert-info { flex: 1; }

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.expert-name { font-size: 30rpx; font-weight: bold; color: #333; }
.expert-title { font-size: 22rpx; color: #52c41a; }
.expert-dept { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }

.expert-tags { display: flex; gap: 8rpx; }

.expert-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.expert-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.consult-count, .rating { font-size: 22rpx; color: #999; margin-right: 16rpx; }
.price-label { font-size: 22rpx; color: #999; margin-right: 8rpx; }
.price-value { font-size: 28rpx; font-weight: bold; color: #ff4d4f; }
