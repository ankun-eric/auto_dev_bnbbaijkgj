.notifications-page {
  min-height: 100vh;
}

.notify-list {
  padding: 24rpx;
}

.notify-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  margin-bottom: 16rpx;
}

.unread {
  background: #fffbe6;
}

.notify-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(82, 196, 26, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notify-icon {
  font-size: 32rpx;
}

.notify-content {
  flex: 1;
}

.notify-header {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.notify-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.notify-time {
  font-size: 22rpx;
  color: #999999;
}

.notify-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.7;
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.clear-btn {
  text-align: center;
  padding-bottom: 32rpx;
}

.clear-text {
  color: #52c41a;
  font-size: 26rpx;
}
