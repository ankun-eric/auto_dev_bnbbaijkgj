.cs-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.cs-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.cs-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.cs-emoji { font-size: 56rpx; }
.cs-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.cs-subtitle { font-size: 24rpx; color: #999; }

.card { margin: 0 24rpx 24rpx; }

.faq-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child { border-bottom: none; }
.faq-text { font-size: 28rpx; color: #333; flex: 1; }
.faq-arrow { font-size: 32rpx; color: #ccc; }

.start-btn { margin: 0 48rpx; }

/* 对话 */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
}

.msg-item { margin-bottom: 20rpx; }
.msg-row { display: flex; align-items: flex-start; }
.msg-left { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

.cs-avatar-sm {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  font-size: 28rpx;
}

.msg-bubble {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 18rpx;
}

.service-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
}

.user-bubble {
  background: #52c41a;
}

.msg-text { font-size: 28rpx; line-height: 1.6; }
.user-bubble .msg-text { color: #fff; }

.input-area {
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: #e8e8e8;
  font-size: 26rpx;
  color: #999;
}

.send-active {
  background: #52c41a;
  color: #fff;
}
