.detail-page {
  padding-bottom: 120rpx;
}

.status-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.status-bg-pending_payment {
  background: linear-gradient(135deg, #faad14, #ffc53d);
}

.status-bg-cancelled,
.status-bg-refunded {
  background: linear-gradient(135deg, #999, #bbb);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.verify-section,
.product-section,
.address-section,
.appt-section,
.logistics-section,
.order-info-section,
.price-section {
  margin: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.qr-area {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.qr-img {
  width: 360rpx;
  height: 360rpx;
}

.verify-code-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.verify-code {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 8rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #52c41a;
  border: 1rpx solid #52c41a;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.verify-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

.od-product {
  display: flex;
  align-items: flex-start;
}

.od-product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.od-product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 160rpx;
}

.od-product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.od-product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.od-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.od-qty {
  font-size: 24rpx;
  color: #999;
}

.addr-line {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.addr-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.addr-top-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.addr-name-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.addr-phone-text {
  font-size: 26rpx;
  color: #666;
}

.store-phone {
  margin-top: 12rpx;
}

.phone-text {
  font-size: 26rpx;
  color: #52c41a;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.discount {
  color: #52c41a;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.copy-link {
  font-size: 22rpx;
  color: #52c41a;
}

.price-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 0;
}

.total-label {
  font-weight: bold;
  color: #333;
}

.total-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.logistics-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  position: relative;
}

.log-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-right: 16rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.log-dot.active {
  background: #52c41a;
}

.log-content {
  flex: 1;
}

.log-desc {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.log-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bar-actions {
  display: flex;
  gap: 16rpx;
}

.bar-btn {
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.bar-btn.outline {
  border: 1rpx solid #d9d9d9;
  color: #666;
}

.bar-btn.primary {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
