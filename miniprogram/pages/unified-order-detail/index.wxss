.detail-page {
  padding-bottom: 120rpx;
}

.status-header {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
}

.status-bg-pending_payment {
  background: linear-gradient(135deg, #faad14, #ffc53d);
}

.status-bg-cancelled,
.status-bg-refunded {
  background: linear-gradient(135deg, #999, #bbb);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.verify-section,
.product-section,
.address-section,
.appt-section,
.logistics-section,
.order-info-section,
.price-section {
  margin: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* [2026-05-05 订单页地址导航按钮 PRD v1.0] 地址行版式 */
.addr-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
/* [2026-05-05 预约门店点击行为统一为联系商家 v1.0] 整行可点击的视觉提示 */
.addr-row-clickable {
  position: relative;
  padding: 4rpx 0;
}
.addr-row-hover {
  background: rgba(82, 196, 26, 0.06);
  border-radius: 12rpx;
}
.addr-arrow {
  align-self: center;
  font-size: 36rpx;
  color: #cccccc;
  margin-left: 4rpx;
  line-height: 1;
}
.addr-row-main {
  flex: 1;
  min-width: 0;
}
.nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(82, 196, 26, 0.12);
  color: #52c41a;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.nav-btn-icon {
  font-size: 24rpx;
}

.qr-area {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.qr-img {
  width: 360rpx;
  height: 360rpx;
}

.verify-code-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.verify-code {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 8rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #52c41a;
  border: 1rpx solid #52c41a;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.verify-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

.od-product {
  display: flex;
  align-items: flex-start;
}

.od-product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.od-product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 160rpx;
}

.od-product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.od-fulfillment-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.od-product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.od-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.od-qty {
  font-size: 24rpx;
  color: #999;
}

.addr-line {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.addr-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.addr-top-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.addr-name-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.addr-phone-text {
  font-size: 26rpx;
  color: #666;
}

.store-phone {
  margin-top: 12rpx;
}

.phone-text {
  font-size: 26rpx;
  color: #52c41a;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.discount {
  color: #52c41a;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.copy-link {
  font-size: 22rpx;
  color: #52c41a;
}

.price-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 0;
}

.total-label {
  font-weight: bold;
  color: #333;
}

.total-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.logistics-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  position: relative;
}

.log-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-right: 16rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.log-dot.active {
  background: #52c41a;
}

.log-content {
  flex: 1;
}

.log-desc {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.log-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bar-actions {
  display: flex;
  gap: 16rpx;
}

.bar-btn {
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.bar-btn.outline {
  border: 1rpx solid #d9d9d9;
  color: #666;
}

.bar-btn.primary {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
}

/* [核销订单过期+改期规则优化 v1.0] 改约按钮置灰样式 */
.bar-btn.is-disabled {
  color: #bfbfbf !important;
  border-color: #d9d9d9 !important;
  background: #f5f5f5 !important;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.refund-status-bar {
  margin: 0 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-top: -8rpx;
}

.refund-bar-applied,
.refund-bar-reviewing,
.refund-bar-approved,
.refund-bar-returning {
  background: #fff7e6;
}

.refund-bar-rejected {
  background: #fff1f0;
}

.refund-bar-refund_success {
  background: #f0f0f0;
}

.refund-bar-text {
  font-size: 26rpx;
  color: #fa8c16;
  display: block;
}

.refund-bar-rejected .refund-bar-text {
  color: #f5222d;
}

.refund-bar-refund_success .refund-bar-text {
  color: #999;
}

.qr-img-disabled {
  opacity: 0.3;
  filter: grayscale(100%);
}

.verify-code-disabled {
  color: #ccc;
}

.verify-hint-warn {
  color: #fa8c16;
}

.verify-hint-err {
  color: #f5222d;
}

.refund-tag-row {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.refund-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
  padding: 6rpx 24rpx;
  border-radius: 8rpx;
}

/* [先下单后预约 Bug 修复 v1.0] 待预约横幅 + 立即预约弹窗 */
.appt-banner {
  margin: 16rpx 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(90deg, #fffbe6 0%, #fff7e6 100%);
  border: 1rpx solid #ffd591;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.appt-banner-text {
  font-size: 26rpx;
  color: #d48806;
  flex: 1;
}
.appt-banner-btn {
  background: #52c41a;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.appt-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}
.appt-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 32rpx 32rpx 48rpx;
  z-index: 1001;
}
.appt-modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.appt-row, .appt-slots-row {
  margin-bottom: 24rpx;
}
.appt-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.appt-value {
  font-size: 28rpx;
  color: #333;
  padding: 18rpx 24rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  display: inline-block;
}
/* [修改预约 Bug 修复 v1.0] 改为每行固定 3 个时段（grid 3 列） */
.appt-slots {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.appt-slot {
  padding: 14rpx 0;
  text-align: center;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
}
.appt-slot.active {
  background: #52c41a;
  color: #fff;
  border-color: #52c41a;
}
.appt-modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.appt-modal-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
}
.appt-modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.appt-modal-btn.confirm {
  background: #52c41a;
  color: #fff;
}
