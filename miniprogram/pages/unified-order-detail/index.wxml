<wxs src="/utils/fulfillmentLabel.wxs" module="ff" />
<view class="detail-page" wx:if="{{order}}">
  <!-- 订单状态 -->
  <view class="status-header status-bg-{{order.status}}">
    <text class="status-text">{{order.display_status || order.status_label || order.status}}</text>
    <text class="status-desc" wx:if="{{order.status_desc}}">{{order.status_desc}}</text>
  </view>

  <!-- [先下单后预约 Bug 修复 v1.0] 待预约横幅 -->
  <view class="appt-banner" wx:if="{{order.status === 'pending_appointment' && (!order.refund_status || order.refund_status === 'none')}}">
    <text class="appt-banner-text">🗓️ 您还未预约服务时间，请尽快选择您方便的时间</text>
    <view class="appt-banner-btn" bindtap="openApptModal">立即预约</view>
  </view>

  <!-- 退款状态提示栏 -->
  <view class="refund-status-bar refund-bar-{{order.refund_status}}" wx:if="{{order.refund_status && order.refund_status !== 'none'}}">
    <text class="refund-bar-text" wx:if="{{order.refund_status === 'applied'}}">退款已申请，等待商家审核</text>
    <text class="refund-bar-text" wx:elif="{{order.refund_status === 'reviewing'}}">退款审核中</text>
    <text class="refund-bar-text" wx:elif="{{order.refund_status === 'approved'}}">退款已批准，处理中</text>
    <text class="refund-bar-text" wx:elif="{{order.refund_status === 'returning'}}">退款退货处理中</text>
    <text class="refund-bar-text" wx:elif="{{order.refund_status === 'rejected'}}">退款申请已被拒绝</text>
    <text class="refund-bar-text" wx:elif="{{order.refund_status === 'refund_success'}}">退款成功</text>
  </view>

  <!-- 核销码 -->
  <view class="verify-section card" wx:if="{{(order.status === 'pending_use' || order.status === 'appointed' || order.status === 'partial_used') && (order.verify_code || order.qr_code_url)}}">
    <!-- 正常状态：refund_status 为 none/rejected 或不存在 -->
    <block wx:if="{{!order.refund_status || order.refund_status === 'none' || order.refund_status === 'rejected'}}">
      <text class="section-title">核销码</text>
      <view class="qr-area" wx:if="{{order.qr_code_url}}">
        <image class="qr-img" src="{{order.qr_code_url}}" mode="aspectFit"
               bindtap="previewQrCode" />
      </view>
      <view class="verify-code-row" wx:if="{{order.verify_code}}">
        <text class="verify-code">{{order.verify_code}}</text>
        <text class="copy-btn" bindtap="copyVerifyCode">复制</text>
      </view>
      <text class="verify-hint">请向门店工作人员出示此码进行核销</text>
    </block>
    <!-- 退款处理中：applied/reviewing/approved/returning -->
    <block wx:elif="{{order.refund_status === 'applied' || order.refund_status === 'reviewing' || order.refund_status === 'approved' || order.refund_status === 'returning'}}">
      <text class="section-title">核销码</text>
      <view class="qr-area" wx:if="{{order.qr_code_url}}">
        <image class="qr-img qr-img-disabled" src="{{order.qr_code_url}}" mode="aspectFit" />
      </view>
      <view class="verify-code-row" wx:if="{{order.verify_code}}">
        <text class="verify-code verify-code-disabled">{{order.verify_code}}</text>
      </view>
      <text class="verify-hint verify-hint-warn">退款处理中，核销码暂时不可用</text>
    </block>
    <!-- 已退款：refund_success -->
    <block wx:elif="{{order.refund_status === 'refund_success'}}">
      <text class="section-title">核销码</text>
      <view class="refund-tag-row">
        <text class="refund-tag">已退款</text>
      </view>
      <view class="qr-area" wx:if="{{order.qr_code_url}}">
        <image class="qr-img qr-img-disabled" src="{{order.qr_code_url}}" mode="aspectFit" />
      </view>
      <text class="verify-hint verify-hint-err">该订单已退款，核销码已失效</text>
    </block>
  </view>

  <!-- 商品信息 -->
  <view class="product-section card">
    <view class="od-product">
      <image class="od-product-img" src="{{order.product_cover || order.cover_image}}" mode="aspectFill" />
      <view class="od-product-info">
        <text class="od-product-name ellipsis-2">{{order.product_name || order.name}}</text>
        <text class="od-fulfillment-label">{{ff.fulfillmentLabel(order.fulfillment_type)}}</text>
        <view class="od-product-meta">
          <text class="od-price">¥{{order.unit_price || order.price}}</text>
          <text class="od-qty">×{{order.quantity || 1}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 收货/门店信息 -->
  <view class="address-section card" wx:if="{{order.address || order.store_name}}">
    <text class="section-title">{{order.store_name ? '服务门店' : '收货信息'}}</text>
    <view wx:if="{{order.store_name}}">
      <text class="addr-line">{{order.store_name}}</text>
      <text class="addr-sub">{{order.store_address}}</text>
      <view class="store-phone" wx:if="{{order.store_phone}}" bindtap="callStore">
        <text class="phone-text">📞 {{order.store_phone}}</text>
      </view>
    </view>
    <view wx:elif="{{order.address}}">
      <view class="addr-top-row">
        <text class="addr-name-text">{{order.address.name}}</text>
        <text class="addr-phone-text">{{order.address.phone}}</text>
      </view>
      <text class="addr-sub">{{order.address.full_address || (order.address.province + order.address.city + order.address.district + order.address.detail)}}</text>
    </view>
  </view>

  <!-- 预约信息 -->
  <view class="appt-section card" wx:if="{{order.appointment_date}}">
    <text class="section-title">预约信息</text>
    <view class="info-row">
      <text class="info-label">预约日期</text>
      <text class="info-value">{{order.appointment_date}}</text>
    </view>
    <view class="info-row" wx:if="{{order.appointment_time}}">
      <text class="info-label">预约时间</text>
      <text class="info-value">{{order.appointment_time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.note}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.note}}</text>
    </view>
  </view>

  <!-- 物流信息 -->
  <view class="logistics-section card" wx:if="{{order.logistics && order.logistics.length > 0}}">
    <text class="section-title">物流信息</text>
    <view class="logistics-item" wx:for="{{order.logistics}}" wx:key="index">
      <view class="log-dot {{index === 0 ? 'active' : ''}}"></view>
      <view class="log-content">
        <text class="log-desc">{{item.description}}</text>
        <text class="log-time">{{item.time}}</text>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info-section card">
    <text class="section-title">订单信息</text>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <view class="info-right">
        <text class="info-value">{{order.order_no}}</text>
        <text class="copy-link" bindtap="copyOrderNo">复制</text>
      </view>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.created_at}}</text>
    </view>
    <view class="info-row" wx:if="{{order.paid_at}}">
      <text class="info-label">支付时间</text>
      <text class="info-value">{{order.paid_at}}</text>
    </view>
    <!-- [支付配置 PRD v1.0] 优先展示具体通道文案 payment_method_text -->
    <view class="info-row">
      <text class="info-label">支付方式</text>
      <text class="info-value">{{order.payment_method_text || order.payment_method_label || '微信支付'}}</text>
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="price-section card">
    <view class="info-row">
      <text class="info-label">商品金额</text>
      <text class="info-value">¥{{order.total_amount}}</text>
    </view>
    <view class="info-row" wx:if="{{order.coupon_discount}}">
      <text class="info-label">优惠券</text>
      <text class="info-value discount">-¥{{order.coupon_discount}}</text>
    </view>
    <view class="info-row" wx:if="{{order.points_discount}}">
      <text class="info-label">积分抵扣</text>
      <text class="info-value discount">-¥{{order.points_discount}}</text>
    </view>
    <view class="price-divider"></view>
    <view class="info-row">
      <text class="info-label total-label">实付金额</text>
      <text class="info-value total-val">¥{{order.final_amount || order.total_amount}}</text>
    </view>
  </view>

  <view class="bottom-space"></view>

  <!-- 底部操作 -->
  <view class="bottom-bar safe-bottom">
    <view class="bar-actions">
      <view class="bar-btn outline" wx:if="{{order.status === 'pending_payment'}}" bindtap="cancelOrder">取消订单</view>
      <view class="bar-btn outline" wx:if="{{(order.status === 'pending_use' || order.status === 'appointed') && (!order.refund_status || order.refund_status === 'none' || order.refund_status === 'rejected')}}" bindtap="goRefund">申请退款</view>
      <!-- [核销订单过期+改期规则优化 v1.0] 改约：达上限置灰 -->
      <view
        class="bar-btn outline {{(order.reschedule_count >= order.reschedule_limit) ? 'is-disabled' : ''}}"
        wx:if="{{(order.status === 'pending_use' || order.status === 'appointed' || order.status === 'partial_used') && (!order.refund_status || order.refund_status === 'none')}}"
        catchtap="onRescheduleClick">
        {{(order.reschedule_count >= order.reschedule_limit) ? '改约（已无法改期）' : '改约'}}
      </view>
      <view class="bar-btn outline" wx:if="{{(order.status === 'pending_use' || order.status === 'appointed') && order.refund_status === 'applied'}}" bindtap="withdrawRefund">撤回退款</view>
      <view class="bar-btn primary" wx:if="{{order.status === 'pending_payment'}}" bindtap="payOrder">立即付款</view>
      <view class="bar-btn primary" wx:if="{{order.status === 'pending_receipt'}}" bindtap="confirmOrder">确认收货</view>
      <view class="bar-btn primary" wx:if="{{order.status === 'completed' && !order.is_reviewed}}" bindtap="goReview">评价</view>
      <!-- [先下单后预约 Bug 修复 v1.0] 待预约状态：底部立即预约按钮 -->
      <view class="bar-btn primary" wx:if="{{order.status === 'pending_appointment' && (!order.refund_status || order.refund_status === 'none')}}" bindtap="openApptModal">立即预约</view>
      <!-- [核销订单过期+改期规则优化 v1.0] 联系商家：所有状态均展示 -->
      <view class="bar-btn outline" bindtap="onContactStore">联系商家</view>
    </view>
  </view>

  <!-- [先下单后预约 Bug 修复 v1.0] 立即预约弹窗 -->
  <view class="appt-modal-mask" wx:if="{{showApptModal}}" bindtap="closeApptModal"></view>
  <view class="appt-modal" wx:if="{{showApptModal}}">
    <text class="appt-modal-title">选择预约时间</text>
    <view class="appt-row">
      <text class="appt-label">预约日期</text>
      <picker mode="date" value="{{apptDate}}" start="{{apptMinDate}}" end="{{apptMaxDate}}" bindchange="onApptDateChange">
        <text class="appt-value">{{apptDate || '请选择日期'}}</text>
      </picker>
    </view>
    <!-- [修改预约 Bug 修复 v1.0] date 模式下整块时段选择隐藏（仅日期） -->
    <view class="appt-slots-row" wx:if="{{apptCurrentMode !== 'date'}}">
      <text class="appt-label">预约时段</text>
      <view class="appt-slots">
        <view
          class="appt-slot {{apptSlot === item ? 'active' : ''}}"
          wx:for="{{apptSlotOptions}}"
          wx:key="*this"
          data-slot="{{item}}"
          catchtap="onApptSlotTap"
        >{{item}}</view>
      </view>
    </view>
    <view class="appt-modal-btns">
      <view class="appt-modal-btn cancel" bindtap="closeApptModal">取消</view>
      <view class="appt-modal-btn confirm" bindtap="submitAppt">确认预约</view>
    </view>
  </view>
</view>

<view class="loading-wrap" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
