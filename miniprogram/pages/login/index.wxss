.login-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
}

.login-page.layout-horizontal .logo-section {
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.login-page.layout-horizontal .logo-circle {
  margin-bottom: 0;
  margin-right: 28rpx;
}

.login-page.layout-horizontal .logo-text-block {
  align-items: flex-start;
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo-text-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #999;
}

/* Form */
.form-section {
  flex: 1;
  padding-top: 40rpx;
}

.register-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.settings-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.settings-loading-text {
  font-size: 28rpx;
  color: #999;
}

.input-group {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.input-prefix {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-right: 20rpx;
  padding-right: 20rpx;
  border-right: 2rpx solid #eee;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  height: 72rpx;
}

.code-btn {
  padding: 12rpx 24rpx;
  border: 2rpx solid #52c41a;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.code-btn-disabled {
  border-color: #d9d9d9;
}

.code-text {
  font-size: 24rpx;
  color: #52c41a;
}

.code-btn-disabled .code-text {
  color: #999;
}

.login-btn {
  margin-top: 48rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* Divider */
.divider-line {
  display: flex;
  align-items: center;
  margin: 60rpx 0 40rpx;
}

.divider-line .line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* WeChat login */
.wx-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 44rpx;
  padding: 20rpx;
  width: 100%;
}

.wx-login-btn::after {
  border: none;
}

.wx-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.wx-text {
  font-size: 30rpx;
  color: #333;
}

/* Agreement */
.agreement {
  display: flex;
  align-items: flex-start;
  padding: 40rpx 0 60rpx;
}

.check-wrap {
  padding: 4rpx 16rpx 4rpx 0;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #52c41a;
  border-color: #52c41a;
}

.check-mark {
  font-size: 20rpx;
  color: #fff;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.link {
  color: #52c41a;
}
