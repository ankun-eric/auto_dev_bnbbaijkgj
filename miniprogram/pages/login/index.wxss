/* PRD｜登录页布局优化 v1.0（2026-05-06）
 * 顶部 42% 屏高绿色渐变品牌区 + 92×92 白色圆形 LOGO 托盘
 * 表单卡片上浮 -28rpx*2，覆盖在渐变下沿
 */

.login-page-v3 {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* === 顶部绿色渐变沉浸式品牌区 === */
.top-brand {
  height: 42vh;
  min-height: 560rpx;
  background: linear-gradient(180deg, #2fb56a 0%, #5cd692 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx 112rpx;
  position: relative;
  box-sizing: border-box;
}

/* 92×92 白色圆形 LOGO 托盘 */
.logo-circle {
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 40rpx;
  overflow: hidden;
}

.brand-logo {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
}

.logo-fallback {
  font-size: 80rpx;
}

.brand-title {
  display: block;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.08);
}

.brand-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

/* === 表单卡片 上浮 -56rpx 覆盖渐变下沿 === */
.form-card {
  margin: -56rpx 40rpx 0;
  background: #ffffff;
  border-radius: 48rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow:
    0 -8rpx 48rpx rgba(0, 0, 0, 0.06),
    0 16rpx 48rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 2;
  box-sizing: border-box;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.input-prefix {
  font-size: 30rpx;
  color: #555;
  font-weight: 500;
  margin-right: 16rpx;
}

.input-divider {
  width: 2rpx;
  height: 36rpx;
  background: #e0e3e8;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  height: 64rpx;
  background: transparent;
}

/* 「获取验证码」按钮：white-space:nowrap，不换行 */
.code-btn {
  flex: 0 0 auto;
  padding: 12rpx 24rpx;
  margin-left: 16rpx;
  white-space: nowrap;
  word-break: keep-all;
}

.code-btn-disabled .code-text {
  color: #999;
}

.code-text {
  font-size: 26rpx;
  color: #2fb56a;
  font-weight: 500;
  white-space: nowrap;
  word-break: keep-all;
}

.referrer-hint {
  display: block;
  font-size: 24rpx;
  color: #2fb56a;
  line-height: 1.5;
  margin: 8rpx 0 0;
}

.register-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin: 8rpx 0;
}

/* 登录按钮：始终高亮可点 */
.login-btn-primary {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #2fb56a 0%, #5cd692 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(47, 181, 106, 0.32);
  border: none;
}

.login-btn-primary::after {
  border: none;
}

/* === 协议勾选行 === */
.agreement {
  display: flex;
  align-items: flex-start;
  margin-top: 28rpx;
}

.check-wrap {
  padding: 4rpx 16rpx 4rpx 0;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #2fb56a;
  border-color: #2fb56a;
}

.check-mark {
  font-size: 20rpx;
  color: #fff;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.link {
  color: #2fb56a;
}

/* === 分隔线 + 微信一键登录 === */
.divider-line {
  display: flex;
  align-items: center;
  margin: 48rpx 0 32rpx;
}

.divider-line .line {
  flex: 1;
  height: 1rpx;
  background: #eee;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

.wx-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 48rpx;
  padding: 20rpx;
  width: 100%;
  font-size: 30rpx;
  color: #333;
}

.wx-login-btn::after {
  border: none;
}

.wx-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.wx-text {
  font-size: 30rpx;
  color: #333;
}

/* === 加载中 === */
.settings-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #2fb56a 0%, #5cd692 100%);
}

.settings-loading-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* === 角色选择弹窗（保留） === */
.role-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  z-index: 999;
}

.role-picker-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 24rpx;
  box-sizing: border-box;
}

.role-picker-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.role-picker-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.role-picker-btn {
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.user-btn {
  background: #2fb56a;
  color: #fff;
}

.merchant-btn {
  background: #f5f5f5;
  color: #333;
}
