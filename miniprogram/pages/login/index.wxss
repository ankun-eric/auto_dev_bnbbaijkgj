/* PRD-370 BUG-FIX-LOGIN-DESIGN-ALIGN-V1
 * 设计 token：
 *   主色 #34C759（iOS 标准绿）
 *   三段渐变按钮：#4AD97A → #34C759 → #2BD4C4
 *   背景渐变：#4AD97A → #34C759
 *   白色卡片圆角：24rpx → 48rpx（小程序 rpx）
 *   输入框：F3F4F6 灰底胶囊 14rpx → 28rpx
 *   输入框聚焦：白底 + 4rpx → 8rpx 绿色描边 + 浅绿光晕
 */

.login-page-v370 {
  min-height: 100vh;
  background: linear-gradient(180deg, #4AD97A 0%, #34C759 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow-x: hidden;
}

/* === 顶部品牌区 === */
.top-brand {
  flex: 0 0 auto;
  min-height: 38vh;
  padding: 96rpx 64rpx 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(180deg, #4AD97A 0%, #34C759 100%);
  box-sizing: border-box;
}

.logo-circle {
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 40rpx;
  overflow: hidden;
}

.brand-logo {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
}

.logo-fallback {
  font-size: 80rpx;
}

.brand-title {
  display: block;
  color: #ffffff;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.brand-subtitle {
  display: block;
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

/* === 白色卡片：上浮 -56rpx，顶部圆角 24px*2 === */
.form-card {
  margin: -56rpx 0 0;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 64rpx 48rpx 48rpx;
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  flex: 1 1 auto;
}

.input-group {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  border-radius: 28rpx;
  height: 104rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  border: 4rpx solid transparent;
  transition: background 0.2s, border 0.2s, box-shadow 0.2s;
}

.input-group-focused {
  background: #ffffff;
  border-color: #34C759;
  box-shadow: 0 0 0 8rpx rgba(52, 199, 89, 0.12);
}

.input-prefix {
  font-size: 32rpx;
  color: #1F2937;
  font-weight: 500;
  margin-right: 16rpx;
}

.input-divider {
  width: 2rpx;
  height: 36rpx;
  background: #E5E7EB;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  height: 64rpx;
  background: transparent;
  color: #1F2937;
}

.code-btn {
  flex: 0 0 auto;
  padding: 12rpx 0 12rpx 24rpx;
  white-space: nowrap;
  word-break: keep-all;
}

.code-btn-disabled .code-text {
  color: #9CA3AF;
}

.code-text {
  font-size: 28rpx;
  color: #34C759;
  font-weight: 600;
  white-space: nowrap;
  word-break: keep-all;
}

.referrer-hint {
  display: block;
  font-size: 24rpx;
  color: #34C759;
  line-height: 1.5;
  margin: 8rpx 0 0;
  padding: 0 8rpx;
}

/* === 三段渐变登录按钮 === */
.login-btn-primary {
  margin-top: 32rpx;
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #4AD97A 0%, #34C759 50%, #2BD4C4 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 16rpx 48rpx rgba(52, 199, 89, 0.32);
  border: none;
}

.login-btn-disabled {
  opacity: 0.5;
}

.login-btn-primary::after {
  border: none;
}

/* === 协议勾选行 === */
.agreement {
  display: flex;
  align-items: flex-start;
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.check-wrap {
  padding: 4rpx 16rpx 4rpx 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #D1D5DB;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.checkbox.checked {
  background: #34C759;
  border-color: #34C759;
}

.check-mark {
  font-size: 24rpx;
  color: #fff;
}

.agreement-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  flex: 1;
}

.link {
  color: #34C759;
}

/* === 协议二次确认弹窗（居中） === */
.agreement-dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 48rpx;
}

.agreement-dialog {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.agreement-dialog-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  padding: 48rpx 48rpx 24rpx;
}

.agreement-dialog-body {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6B7280;
  padding: 0 48rpx 48rpx;
  text-align: center;
}

.agreement-dialog-actions {
  display: flex;
  border-top: 2rpx solid #F3F4F6;
}

.agreement-dialog-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.reject-btn {
  color: #6B7280;
  border-right: 2rpx solid #F3F4F6;
}

.agree-btn {
  color: #34C759;
  font-weight: 600;
}

/* === 协议详情半屏抽屉 === */
.agreement-drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.agreement-drawer {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-handle {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 8rpx;
}

.drawer-handle-bar {
  width: 72rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #E5E7EB;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 24rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.drawer-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #9CA3AF;
}

.drawer-body {
  flex: 1;
  background: #fafafa;
}

.drawer-content {
  padding: 32rpx;
}

.drawer-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #1F2937;
  white-space: pre-wrap;
}

/* === 加载中 === */
.settings-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #4AD97A 0%, #34C759 100%);
}

.settings-loading-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* === 角色选择弹窗（保留） === */
.role-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  z-index: 999;
}

.role-picker-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 24rpx;
  box-sizing: border-box;
}

.role-picker-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.role-picker-desc {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.role-picker-btn {
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.user-btn {
  background: #34C759;
  color: #fff;
}

.merchant-btn {
  background: #f5f5f5;
  color: #1F2937;
}
