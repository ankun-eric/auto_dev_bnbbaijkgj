<!-- PRD-370 BUG-FIX-LOGIN-DESIGN-ALIGN-V1：上绿下白分屏卡片式布局 -->
<view class="login-page-v370" wx:if="{{!settingsLoading}}">
  <!-- 上半绿色品牌区（设计稿对齐：#34C759 iOS 标准绿） -->
  <view class="top-brand">
    <view class="logo-circle">
      <image wx:if="{{brandLogoUrl}}" class="brand-logo" src="{{brandLogoUrl}}" mode="aspectFit" />
      <text wx:else class="logo-fallback">🌿</text>
    </view>
    <text class="brand-title">宾尼小康</text>
    <text class="brand-subtitle">AI 健康管家 · 您的私人健康助手</text>
  </view>

  <!-- 白色卡片：顶部圆角 24，padding-top 32，无问候语 -->
  <view class="form-card">
    <!-- 手机号 -->
    <view class="input-group {{phoneFocused ? 'input-group-focused' : ''}}">
      <text class="input-prefix">+86</text>
      <view class="input-divider"></view>
      <input class="input-field" type="number" maxlength="11"
             placeholder="请输入手机号" value="{{phone}}"
             bindinput="onPhoneInput"
             bindfocus="onPhoneFocus"
             bindblur="onPhoneBlur" />
    </view>

    <!-- 验证码 + 获取验证码 -->
    <view class="input-group {{codeFocused ? 'input-group-focused' : ''}}">
      <input class="input-field" type="number" maxlength="6"
             placeholder="请输入验证码" value="{{code}}"
             bindinput="onCodeInput"
             bindfocus="onCodeFocus"
             bindblur="onCodeBlur" />
      <view class="code-btn {{codeCooldown > 0 ? 'code-btn-disabled' : ''}}" bindtap="sendCode">
        <text class="code-text">{{codeCooldown > 0 ? codeCooldown + ' s' : '获取验证码'}}</text>
      </view>
    </view>

    <text class="referrer-hint" wx:if="{{referrerNo}}">🎉 已识别邀请码：{{referrerNo}}</text>

    <!-- 三段渐变登录按钮 -->
    <button class="login-btn-primary {{(!phone || phone.length !== 11 || !code || code.length < 4) ? 'login-btn-disabled' : ''}}" bindtap="loginByPhone">
      {{submitButtonText}}
    </button>

    <!-- 协议勾选行 -->
    <view class="agreement">
      <view class="check-wrap" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text class="check-mark" wx:if="{{agreed}}">✓</text>
        </view>
      </view>
      <text class="agreement-text">
        我已阅读并同意
        <text class="link" bindtap="showAgreement" data-type="user">《用户服务协议》</text>
        和
        <text class="link" bindtap="showAgreement" data-type="privacy">《隐私政策》</text>
      </text>
    </view>
  </view>

  <!-- 协议二次确认弹窗（居中） -->
  <view class="agreement-dialog-mask" wx:if="{{agreementDialogVisible}}">
    <view class="agreement-dialog">
      <text class="agreement-dialog-title">服务协议及隐私保护</text>
      <view class="agreement-dialog-body">
        <text>请您阅读并同意</text>
        <text class="link" bindtap="openAgreementDrawer" data-type="user">《用户服务协议》</text>
        <text>和</text>
        <text class="link" bindtap="openAgreementDrawer" data-type="privacy">《隐私政策》</text>
        <text>后才能继续登录。</text>
      </view>
      <view class="agreement-dialog-actions">
        <view class="agreement-dialog-btn reject-btn" bindtap="rejectAgreement">不同意</view>
        <view class="agreement-dialog-btn agree-btn" bindtap="agreeAndLogin">同意</view>
      </view>
    </view>
  </view>

  <!-- 协议详情半屏抽屉 -->
  <view class="agreement-drawer-mask" wx:if="{{drawerVisible}}" bindtap="closeDrawer">
    <view class="agreement-drawer" catchtap="noop">
      <view class="drawer-handle">
        <view class="drawer-handle-bar"></view>
      </view>
      <view class="drawer-header">
        <text class="drawer-title">{{drawerType === 'user' ? '用户服务协议' : '隐私政策'}}</text>
        <view class="drawer-close" bindtap="closeDrawer">×</view>
      </view>
      <scroll-view class="drawer-body" scroll-y="true">
        <view class="drawer-content">
          <text wx:if="{{drawerType === 'user'}}" class="drawer-text">{{serviceAgreementContent}}</text>
          <text wx:else class="drawer-text">{{privacyPolicyContent}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 角色选择弹窗（保留原有逻辑） -->
  <view class="role-picker-mask" wx:if="{{showRolePicker}}">
    <view class="role-picker-card">
      <text class="role-picker-title">请选择本次进入身份</text>
      <text class="role-picker-desc">同一账号已同时开通用户端与商家端，请选择本次要进入的角色。</text>
      <button class="role-picker-btn user-btn" data-role="user" bindtap="chooseLoginRole">进入用户端</button>
      <button class="role-picker-btn merchant-btn" data-role="merchant" bindtap="chooseLoginRole">进入商家端</button>
    </view>
  </view>
</view>

<view class="settings-loading" wx:if="{{settingsLoading}}">
  <text class="settings-loading-text">正在加载...</text>
</view>
