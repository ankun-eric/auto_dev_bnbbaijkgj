<view class="login-page {{layoutClass}}" wx:if="{{!settingsLoading}}">
  <!-- Logo -->
  <view class="logo-section">
    <view class="logo-circle">
      <text class="logo-text">宾尼小康</text>
    </view>
    <view class="logo-text-block">
      <text class="app-name">宾尼小康</text>
      <text class="app-desc">AI健康管家 · 守护您的健康</text>
    </view>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 手机号 -->
    <view class="input-group">
      <text class="input-prefix">+86</text>
      <input class="input-field" type="number" maxlength="11"
             placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <!-- 验证码 -->
    <view class="input-group">
      <text class="input-icon">🔒</text>
      <input class="input-field" type="number" maxlength="6"
             placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
      <view class="code-btn {{codeCooldown > 0 ? 'code-btn-disabled' : ''}}" bindtap="sendCode">
        <text class="code-text">{{codeCooldown > 0 ? codeCooldown + 's后重发' : '获取验证码'}}</text>
      </view>
    </view>

    <text class="register-hint" wx:if="{{registerHelperText}}">{{registerHelperText}}</text>

    <!-- 登录按钮 -->
    <button class="login-btn btn-primary" bindtap="loginByPhone" disabled="{{!phone || !code}}">
      {{submitButtonText}}
    </button>

    <!-- 分隔线 -->
    <view class="divider-line">
      <view class="line"></view>
      <text class="divider-text">其他登录方式</text>
      <view class="line"></view>
    </view>

    <!-- 微信登录 -->
    <button class="wx-login-btn" bindtap="loginByWechat">
      <text class="wx-icon">💚</text>
      <text class="wx-text">微信一键登录</text>
    </button>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <view class="check-wrap" bindtap="toggleAgreement">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text class="check-mark" wx:if="{{agreed}}">✓</text>
      </view>
    </view>
    <text class="agreement-text">
      我已阅读并同意
      <text class="link" bindtap="showAgreement" data-type="user">《用户服务协议》</text>
      和
      <text class="link" bindtap="showAgreement" data-type="privacy">《隐私政策》</text>
    </text>
  </view>

  <view class="role-picker-mask" wx:if="{{showRolePicker}}">
    <view class="role-picker-card">
      <text class="role-picker-title">请选择本次进入身份</text>
      <text class="role-picker-desc">同一账号已同时开通用户端与商家端，请选择本次要进入的角色。</text>
      <button class="role-picker-btn user-btn" data-role="user" bindtap="chooseLoginRole">进入用户端</button>
      <button class="role-picker-btn merchant-btn" data-role="merchant" bindtap="chooseLoginRole">进入商家端</button>
    </view>
  </view>
</view>

<view class="settings-loading" wx:if="{{settingsLoading}}">
  <text class="settings-loading-text">正在加载注册设置...</text>
</view>
