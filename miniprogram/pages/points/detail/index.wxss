.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 24rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item.active {
  color: #4CAF50;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 4rpx;
  background: #4CAF50;
  border-radius: 2rpx;
}

.content { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }

.list { background: #fff; border-radius: 12rpx; }
.record-item {
  padding: 28rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}
.record-left { flex: 1; }
.record-title { font-size: 28rpx; color: #333; display: block; }
.record-time { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block; }
.record-points { font-size: 30rpx; font-weight: 600; }
.record-points.positive { color: #4CAF50; }
.record-points.negative { color: #F44336; }

.ex-list { display: flex; flex-direction: column; gap: 16rpx; }
.ex-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
}
.ex-img-wrap {
  width: 112rpx; height: 112rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ex-img { width: 100%; height: 100%; border-radius: 12rpx; }
.ex-icon { font-size: 56rpx; }
.ex-body { flex: 1; min-width: 0; }
.ex-tags { display: flex; gap: 10rpx; align-items: center; }
.ex-tag { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 4rpx; color: #fff; }
.ex-status { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 4rpx; border: 1rpx solid #ccc; background: #fff; }
.ex-name { font-size: 28rpx; color: #333; display: block; margin-top: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ex-time { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.ex-expire { font-size: 22rpx; color: #fa8c16; display: block; margin-top: 4rpx; }
.ex-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.ex-cost { color: #F44336; font-weight: 600; font-size: 26rpx; }
.ex-btn { padding: 6rpx 20rpx; border-radius: 24rpx; font-size: 22rpx; }
.ex-btn-primary { background: #4CAF50; color: #fff; }
.ex-btn-orange { background: rgba(250,140,22,0.1); color: #fa8c16; border: 1rpx solid #fa8c16; }
.ex-btn-purple { background: rgba(114,46,209,0.1); color: #722ed1; border: 1rpx solid #722ed1; }
