.points-page {
  min-height: 100vh;
}

.points-header {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-label { font-size: 26rpx; color: rgba(255, 255, 255, 0.8); }
.points-value { font-size: 72rpx; font-weight: bold; color: #fff; margin: 8rpx 0 24rpx; }

.points-actions {
  display: flex;
  gap: 48rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.action-text { font-size: 24rpx; color: rgba(255, 255, 255, 0.9); }

.card { margin: 24rpx; }

/* 签到 */
.sign-week {
  display: flex;
  margin-top: 16rpx;
}

.sign-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.day-label { font-size: 22rpx; color: #999; margin-bottom: 8rpx; }

.day-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.signed .day-icon {
  background: #52c41a;
  color: #fff;
}

.today .day-icon {
  border: 2rpx solid #52c41a;
}

.day-points { font-size: 20rpx; color: #ccc; }
.signed .day-points { color: #52c41a; }

/* 记录 */
.record-list { padding: 0 24rpx; margin-top: 16rpx; }

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title { font-size: 28rpx; color: #333; display: block; }
.record-time { font-size: 22rpx; color: #999; }
.record-points { font-size: 30rpx; font-weight: bold; }
.points-add { color: #52c41a; }
.points-sub { color: #ff4d4f; }
