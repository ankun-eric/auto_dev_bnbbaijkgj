.points-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

.points-header {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  padding: 32rpx 32rpx 48rpx;
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-label { font-size: 26rpx; color: rgba(255, 255, 255, 0.85); }
.records-link {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.points-value { font-size: 80rpx; font-weight: bold; color: #fff; margin: 16rpx 0 8rpx; text-align: center; }
.today-tip { font-size: 26rpx; color: rgba(255, 255, 255, 0.9); text-align: center; }

.card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  margin-top: -20rpx;
}
.quick-icon { font-size: 48rpx; margin-right: 20rpx; }
.quick-info { flex: 1; }
.quick-title { font-size: 30rpx; color: #333; display: block; }
.quick-desc { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.quick-arrow { color: #ccc; font-size: 32rpx; }

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 24rpx 32rpx 8rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-desc { font-size: 22rpx; color: #999; }

.loading-tip {
  text-align: center;
  color: #999;
  padding: 48rpx 0;
  font-size: 26rpx;
}

.task-list {}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-info { flex: 1; margin-right: 16rpx; }

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.task-title { font-size: 28rpx; color: #333; font-weight: 500; }
.task-tag {
  font-size: 20rpx;
  border: 1rpx solid;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}
.task-points { font-size: 22rpx; color: #fa8c16; }
.task-subtitle { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }

.task-btn {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  min-width: 100rpx;
  text-align: center;
}
.task-btn-disabled {
  background: #e8e8e8;
  color: #999;
}
