.points-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

/* Bug 3：我的积分卡片背景统一为 #C8E6C9（浅绿），与上方深绿标题区形成层次 */
.points-header {
  background: #C8E6C9;
  padding: 32rpx 32rpx 48rpx;
  color: #1B5E20;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-label { font-size: 26rpx; color: #1B5E20; }
.records-link-group {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.records-link {
  font-size: 24rpx;
  color: #1B5E20;
  background: rgba(27, 94, 32, 0.12);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.points-value { font-size: 80rpx; font-weight: bold; color: #1B5E20; margin: 16rpx 0 8rpx; text-align: center; }
.today-tip { font-size: 26rpx; color: #2E7D32; text-align: center; }

/* Bug 6：一次性任务完成后置灰 */
.task-card-done {
  opacity: 0.55;
  background: #f5f5f5;
}
.task-title-done {
  color: #999;
  text-decoration: line-through;
}
.task-points-done { color: #bfbfbf; }
.task-subtitle-done { color: #bfbfbf; }
.task-tag-done {
  border-color: #d9d9d9 !important;
  color: #bfbfbf !important;
  background: #eeeeee !important;
}
.task-done-mark {
  font-size: 22rpx;
  color: #52c41a;
  margin-left: 8rpx;
}

.card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  margin-top: -20rpx;
}
.quick-icon { font-size: 48rpx; margin-right: 20rpx; }
.quick-info { flex: 1; }
.quick-title { font-size: 30rpx; color: #333; display: block; }
.quick-desc { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.quick-arrow { color: #ccc; font-size: 32rpx; }

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 24rpx 32rpx 8rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-desc { font-size: 22rpx; color: #999; }

.loading-tip {
  text-align: center;
  color: #999;
  padding: 48rpx 0;
  font-size: 26rpx;
}

.task-list {}

.task-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-info { flex: 1; margin-right: 16rpx; }

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.task-title { font-size: 28rpx; color: #333; font-weight: 500; }
.task-tag {
  font-size: 20rpx;
  border: 1rpx solid;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}
.task-points { font-size: 22rpx; color: #fa8c16; }
.task-subtitle { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }

.task-btn {
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  min-width: 100rpx;
  text-align: center;
}
.task-btn-disabled {
  background: #e8e8e8;
  color: #999;
}
