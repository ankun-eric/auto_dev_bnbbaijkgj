<view class="points-page">
  <!-- 顶部 -->
  <view class="points-header">
    <view class="header-top">
      <text class="points-label">我的可用积分</text>
      <view class="records-link-group">
        <view class="records-link" bindtap="goDetail">积分明细 ›</view>
      </view>
    </view>
    <text class="points-value">{{availablePoints}}</text>
    <view class="today-tip">
      <block wx:if="{{todayEarned > 0}}">今天获得积分 +{{todayEarned}}</block>
      <block wx:else>今天还未获得积分，快去赚取吧</block>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="card quick-card" bindtap="goMall">
    <view class="quick-icon">🎁</view>
    <view class="quick-info">
      <text class="quick-title">积分商城</text>
      <text class="quick-desc">用积分兑换好礼</text>
    </view>
    <text class="quick-arrow">›</text>
  </view>

  <!-- 日常任务 -->
  <view class="section-header">
    <text class="section-title">日常任务</text>
    <text class="section-desc">完成任务赚积分</text>
  </view>

  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view wx:else class="task-list">
    <view class="task-card card {{item.onceDone ? 'task-card-done' : ''}}" wx:for="{{tasks}}" wx:key="key" data-key="{{item.key}}" bindtap="handleTask">
      <view class="task-info">
        <view class="task-title-row">
          <text class="task-title {{item.onceDone ? 'task-title-done' : ''}}">{{item.title}}</text>
          <text wx:if="{{item.onceDone}}" class="task-done-mark">✓ 已完成</text>
          <text class="task-tag {{item.onceDone ? 'task-tag-done' : ''}}" style="color:{{item.categoryColor}};border-color:{{item.categoryColor}};">{{item.categoryLabel}}</text>
          <text class="task-points {{item.onceDone ? 'task-points-done' : ''}}">+{{item.points}}积分</text>
        </view>
        <text class="task-subtitle {{item.onceDone ? 'task-subtitle-done' : ''}}" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
      </view>
      <view class="task-btn {{item.btnDisabled ? 'task-btn-disabled' : ''}}" catchtap="handleTask" data-key="{{item.key}}">
        {{item.btnText}}
      </view>
    </view>
  </view>
</view>
