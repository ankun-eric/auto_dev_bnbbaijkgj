<view class="exchange-records">
  <view class="header">
    <text class="title">我的兑换记录</text>
    <text class="tip">优惠券、体验服务、实物兑换均在此查看</text>
  </view>

  <view wx:if="{{loading && items.length === 0}}" class="loading-tip">加载中...</view>
  <view wx:elif="{{items.length === 0}}" class="empty-tip">暂无兑换记录</view>

  <view wx:else class="record-list">
    <view class="record-card card" wx:for="{{items}}" wx:key="id">
      <view class="record-left">
        <image wx:if="{{item.goods_image}}" src="{{item.goods_image}}" class="record-img" mode="aspectFit"></image>
        <text wx:else class="record-icon">{{item.typeIcon}}</text>
      </view>
      <view class="record-body">
        <view class="tag-row">
          <text class="tag" style="background: {{item.typeColor}}1A; color: {{item.typeColor}};">{{item.typeText}}</text>
          <text class="tag outline" style="border-color: {{item.statusColor}}; color: {{item.statusColor}};">{{item.statusText}}</text>
        </view>
        <text class="goods-name">{{item.goods_name}}</text>
        <text class="time-row">兑换时间：{{item.exchangeTimeStr}}</text>
        <text wx:if="{{item.expireAtStr}}" class="expire-row">有效期至：{{item.expireAtStr}}</text>
        <view class="bottom-row">
          <text class="points">-{{item.points_cost}} 积分</text>
          <view wx:if="{{item.canAppointment}}" class="btn btn-primary" data-item="{{item}}" bindtap="goAppointment">去预约</view>
          <view wx:elif="{{item.canViewCoupon}}" class="btn btn-outline" bindtap="goMyCoupons">查看我的券</view>
          <view wx:elif="{{item.canViewOrder}}" class="btn btn-outline purple" bindtap="goOrder">查看订单</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!hasMore && items.length > 0}}" class="no-more">没有更多了</view>
</view>
