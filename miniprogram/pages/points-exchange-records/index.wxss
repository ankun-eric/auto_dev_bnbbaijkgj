.exchange-records {
  min-height: 100vh;
  background: #f5f7f5;
  padding-bottom: 40rpx;
}

/* PRD-POINTS-SKIN-V1: 顶部装饰条换肤为天蓝渐变 */
.header {
  background: linear-gradient(135deg, #F0F9FF, #DBEAFE);
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
}
.header .title { color: #0EA5E9; font-size: 28rpx; font-weight: bold; }
.header .tip { color: #0284C7; font-size: 22rpx; margin-top: 6rpx; }

.loading-tip, .empty-tip, .no-more {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 60rpx 0;
}

.record-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}

.record-left {
  width: 96rpx;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.record-img { width: 80rpx; height: 80rpx; }
.record-icon { font-size: 48rpx; }

.record-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }

.tag-row { display: flex; gap: 10rpx; }
.tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  line-height: 1.6;
}
.tag.outline {
  background: #fff;
  border: 1rpx solid;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* PRD-POINTS-SKIN-V1: 所有按钮统一天蓝色系；负向积分由橙金/红改灰 */
.time-row, .expire-row { font-size: 22rpx; color: #999; }
.expire-row { color: #0284C7; }

.bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}
.points { color: #999999; font-weight: 600; font-size: 26rpx; }

.btn {
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  line-height: 1.4;
}
.btn-primary {
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
}
.btn-outline {
  border: 1rpx solid #0EA5E9;
  color: #0EA5E9;
  background: rgba(14,165,233,0.08);
}
.btn-outline.purple {
  border-color: #0284C7;
  color: #0284C7;
  background: rgba(2,132,199,0.08);
}

/* OPT-4：优惠券双按钮组 */
.btn-group {
  display: flex;
  gap: 12rpx;
}
