.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 998;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

.drawer-panel {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 70vw;
  max-width: 560rpx;
  background: #fff;
  z-index: 999;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 4rpx 0 24rpx rgba(0, 0, 0, 0.08);
}

.drawer-panel.show {
  transform: translateX(0);
}

.drawer-header {
  padding: 24rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.new-chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  background: linear-gradient(135deg, #52c41a, #13c2c2);
  border-radius: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.session-list {
  flex: 1;
  overflow-y: auto;
}

.session-group {
  padding: 0 24rpx;
}

.group-label {
  font-size: 22rpx;
  color: #999;
  padding: 20rpx 0 12rpx;
  font-weight: 500;
}

.session-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
  transition: background 0.15s ease;
}

.session-item:active {
  background: #f5f5f5;
}

.session-item.pinned {
  background: rgba(82, 196, 26, 0.04);
}

.session-info {
  flex: 1;
  min-width: 0;
}

.session-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.pin-icon {
  font-size: 22rpx;
  flex-shrink: 0;
}

.session-title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.session-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.session-type-tag {
  font-size: 20rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.session-count {
  font-size: 20rpx;
  color: #bbb;
}

.session-arrow {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.empty-sessions {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
