.med-drawer-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}
.med-drawer {
  width: 100%;
  max-height: 50vh;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  display: flex;
  flex-direction: column;
  padding: 16rpx 0 24rpx;
}
.med-drawer-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin: 8rpx auto 16rpx;
}
.med-drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 20rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.med-drawer-title {
  font-size: 32rpx;
  font-weight: 600;
}
.med-drawer-go-manage {
  color: #2563EB;
  font-size: 28rpx;
}
.med-drawer-body {
  flex: 1;
  padding: 16rpx 32rpx;
}
.med-state {
  text-align: center;
  color: #9CA3AF;
  padding: 40rpx;
}
.med-state-error {
  color: #EF4444;
}
.med-state-retry {
  color: #9CA3AF;
}
.med-empty {
  text-align: center;
  padding: 60rpx;
}
.med-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.med-empty-text {
  color: #2563EB;
  font-size: 28rpx;
}
.med-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.med-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #111827;
}
.med-meta {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
}
